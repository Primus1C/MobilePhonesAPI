Функция ОставитьТолькоИМЕИ(ШК, Искать = "IMEI") Экспорт

	Если Найти(ШК, Искать) = 0 Тогда Возврат ШК КонецЕсли;

	Рез = "";
	Стр = СтрЗаменить(ШК, ",", гоРС());
	Кол = СтрЧислоСтрок(Стр);
	Для Н = 1 По Кол Цикл
		Лтр = СокрЛП(СтрПолучитьСтроку(Стр, Н));
		Если НЕ гоНачинаетсяС(Лтр, Искать) Тогда Продолжить КонецЕсли;
		гоРезСоо(Рез, СтрЗаменить(Лтр, Искать, ""));
	КонецЦикла;
	
	Возврат Рез; 
	
КонецФункции

Функция ПолучитьИМЕИИзБуфера_Стар() Экспорт

	Буф = "";  
	
	Попытка
		WSHShell = Новый COMОбъект("WScript.Shell");
		WSHShell.SendKeys("^V");
	Исключение
	    клОшибка(ОписаниеОшибки()); 
		Возврат Буф;
	КонецПопытки; 
	
	Если ВвестиСтроку(Буф, НСтр("ru = 'Вставьте (если пусто) серии (CTRL+V) и нажмите <ОК>'; en = 'Paste (if empty) series (CTRL+V) and click <OK>'"), , Истина) Тогда 
		Буф = РаботаСоСканеромШК.ОставитьТолькоИМЕИ(Буф);
	КонецЕсли;
	
	Возврат Буф;

КонецФункции // ПолучитьИМЕИИзБуфера()


Процедура ПолучитьИМЕИИзБуфера(ОписаниеОповещенияОЗавершении) Экспорт

	Буф = "";  
	
	Попытка
		WSHShell = Новый COMОбъект("WScript.Shell");
		WSHShell.SendKeys("^V");
	Исключение
	    клОшибка(ОписаниеОшибки()); 
		ВыполнитьОбработкуОповещения(ОписаниеОповещенияОЗавершении, Буф);
		Возврат;
	КонецПопытки; 
	
	ПоказатьВводСтроки(Новый ОписаниеОповещения("ПолучитьИМЕИИзБуфераПослеВвода", РаботаСоСканеромШК, ОписаниеОповещенияОЗавершении), 
		Буф, НСтр("ru = 'Вставьте (если пусто) серии (CTRL+V) и нажмите <ОК>'; en = 'Paste (if empty) series (CTRL+V) and click <OK>'"), , Истина);

КонецПроцедуры // ПолучитьИМЕИИзБуфера()

Процедура ПолучитьИМЕИИзБуфераПослеВвода(Буф, ОписаниеОповещенияОЗавершении) Экспорт
	
	Если Буф = Неопределено Тогда
		ВыполнитьОбработкуОповещения(ОписаниеОповещенияОЗавершении, "");
		Возврат;
	КонецЕсли;
	
	Буф = РаботаСоСканеромШК.ОставитьТолькоИМЕИ(Буф);
	ВыполнитьОбработкуОповещения(ОписаниеОповещенияОЗавершении, Буф); 
	
КонецПроцедуры

