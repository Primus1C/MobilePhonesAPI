Функция ЕстьДвиженияПартии(Пар, ТекДок, ВернутьВсе = Ложь) Экспорт
	//ПЕРЕДЕЛАТЬ НА ЗАПРОС ВАЖНО
	Спи = Новый СписокЗначений;
	
	//2016.04.14
	//для вернуть все возможна передача списка партий
	Если (ТипЗнч(Пар) = Тип("СписокЗначений")) И ВернутьВсе Тогда
		Для Каждого Эле Из Пар Цикл
			Выборка = РегистрыНакопления.ОстаткиТовара.Выбрать( , , Новый Структура("Партия", Эле.Значение), "Убыв");
			Пока Выборка.Следующий() Цикл
				Если Выборка.Регистратор = ТекДок Тогда Продолжить КонецЕсли; 
				Если Спи.НайтиПоЗначению(Выборка.Регистратор) = Неопределено Тогда Спи.Добавить(Выборка.Регистратор) КонецЕсли;
			КонецЦикла; 
		КонецЦикла; 
	Иначе 
		Выборка = РегистрыНакопления.ОстаткиТовара.Выбрать( , , Новый Структура("Партия", Пар), "Убыв");
		Пока Выборка.Следующий() Цикл
			Если Выборка.Регистратор = ТекДок Тогда Продолжить КонецЕсли; 
			
			Если ВернутьВсе Тогда
				Если Спи.НайтиПоЗначению(Выборка.Регистратор) = Неопределено Тогда Спи.Добавить(Выборка.Регистратор) КонецЕсли; 
			Иначе
				Возврат Истина;
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	Если ВернутьВсе Тогда
		Возврат Спи; 
	Иначе
		Возврат Ложь;
	КонецЕсли; 
КонецФункции

