Функция ЕстьЕщеСеансы() Экспорт
	
	Если гоАдминистратор() Тогда Возврат "" КонецЕсли; 
	ТекПол = гоПользователь();
	Если ТекПол.НеПроверятьСеансы Тогда Возврат "" КонецЕсли; 
	
	ТекИмя = СокрЛП(ТекПол.Код);
	
	Сче = 0;
	
	Соединения = ПолучитьСоединенияИнформационнойБазы();  
	
	Для Каждого Соединение Из Соединения Цикл
	    Если (Соединение.НомерСоединения = НомерСоединенияИнформационнойБазы()) ИЛИ (Соединение.ИмяПриложения = "Designer") Тогда Продолжить КонецЕсли;
	    Если ТекИмя = Соединение.Пользователь.Имя Тогда гоПлюс(Сче) КонецЕсли;
	КонецЦикла;
	
	Если Сче = 0 Тогда 
		Возврат "";
	Иначе
		Можно = ТекПол.МожноСеансов;
		Если Можно = 0 Тогда Можно = 1 КонецЕсли; 
		Если Сче < Можно Тогда
			Возврат "";
		Иначе
		    Возврат СтрШаблон(НСтр("ru = 'Доступ запрещен, т.к. пользователь: %1 превысил разрешенное число сеансов: %2'; en = 'Access is denied because user: %1 has exceeded the allowed number of sessions: %2'"), ТекИмя, Можно);
		КонецЕсли; 
	КонецЕсли; 
	
КонецФункции

