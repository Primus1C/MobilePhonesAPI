Функция ПолучитьЦветИзHEX(Знач HEXСтрока) Экспорт
    
    // Очищаем от решетки, если она есть, и переводим в верхний регистр
    HEXСтрока = СтрЗаменить(ВРег(HEXСтрока), "#", "");
    
    // Обработка короткого формата (например, #FFF -> FFFFFF)
    Если СтрДлина(HEXСтрока) = 3 Тогда
        HEXСтрока = Лев(HEXСтрока, 1) + Лев(HEXСтрока, 1) + 
                    Сред(HEXСтрока, 2, 1) + Сред(HEXСтрока, 2, 1) + 
                    Прав(HEXСтрока, 1) + Прав(HEXСтрока, 1);
    КонецЕсли;
    
    Если СтрДлина(HEXСтрока) <> 6 Тогда
        Возврат Новый Цвет(); // Возвращаем пустой/черный цвет при ошибке
    КонецЕсли;
    
    // Разбиваем на RGB и переводим в десятичное число
    Красный = HEXВДесятичное(Сред(HEXСтрока, 1, 2));
    Зеленый = HEXВДесятичное(Сред(HEXСтрока, 3, 2));
    Синий   = HEXВДесятичное(Сред(HEXСтрока, 5, 2));
    
    Возврат Новый Цвет(Красный, Зеленый, Синий);
    
КонецФункции

// Вспомогательная функция перевода 16-ричного числа в 10-ичное
Функция HEXВДесятичное(Знач HEXЗначение)
    
    Результат = 0;
    СимволыЦвета = "0123456789ABCDEF";
    
    Для Индекс = 1 По СтрДлина(HEXЗначение) Цикл
        Символ = Сред(HEXЗначение, Индекс, 1);
        ЗначениеСимвола = Найти(СимволыЦвета, Символ) - 1;
        Результат = Результат * 16 + ЗначениеСимвола;
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

