Процедура ПровестиДокументыСервер(СпиДок, РезСоо = "", Сче = 0) Экспорт
//2016.02.22	
	Сче = 0;
	РезСоо = "";
	
	Для Каждого Стр Из СпиДок Цикл
		Тек = Стр.Значение;
		Док = Тек.ПолучитьОбъект();
		
		Если гоЭто("РасходнаяНакладная, Перемещение, ВозвратПоставщику", гоДокИмя(Тек)) Тогда Док.ФлагНеПроверятьОстатки = 1 КонецЕсли; 
		
		Попытка
			Док.Записать(РежимЗаписиДокумента.Проведение);
			гоПлюс(Сче);
		Исключение
			гоРезСоо(РезСоо, "Ошибка при записи с проведением " + гоИмя(Тек) + "!");
		КонецПопытки; 
	КонецЦикла; 
КонецПроцедуры 


Функция ИскатьКонтрагента(Знач Стр) Экспорт
//2016.06.09

	Рез = Новый СписокЗначений;
	
	//убираем линшние пробелы
	Пока Найти(Стр, "  ") <> 0 Цикл Стр = СтрЗаменить(Стр, "  ", " ") КонецЦикла; 
	
	//делаем много строк из слов	
	Стр = СтрЗаменить(Стр, " ", гоРС());
	Слв = СтрЧислоСтрок(Стр);
	
	Слово1 = "";
	Слово2 = "";
	Слово3 = "";
	
	Если Слв > 0 Тогда Слово1 = СокрЛП(СтрПолучитьСтроку(Стр, 1)) КонецЕсли; 
	Если Слв > 1 Тогда Слово2 = СокрЛП(СтрПолучитьСтроку(Стр, 2)) КонецЕсли; 
	Если Слв > 2 Тогда Слово3 = СокрЛП(СтрПолучитьСтроку(Стр, 3)) КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	Спр.Ссылка,
		|	Спр.Наименование КАК Имя, 
		|	Спр.Родитель.Наименование КАК ГруИмя
		|ИЗ
		|	Справочник.Контрагенты КАК Спр
		|ГДЕ
		|	(Спр.Наименование ПОДОБНО &Слово1)" + ?(Слово2 <> "", " И (Спр.Наименование ПОДОБНО &Слово2)", "") + ?(Слово3 <> "", " И (Спр.Наименование ПОДОБНО &Слово3)", "") + "
		|УПОРЯДОЧИТЬ ПО
		|	Спр.Наименование
		|";          
	// © Primus1C  16.10.2023  НАЧАЛО ►
	Если НЕ РольДоступна("ЧтениеИзменениеНаименованийКонтрагентов") И НЕ РольДоступна("Администратор") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Спр.Наименование", "Спр.Псевдоним");	
	КонецЕсли;	
	// © Primus1C  ОКОНЧАНИЕ ◄  
	
	Запрос.УстановитьПараметр("Слово1", "%" + Слово1 + "%");
	Запрос.УстановитьПараметр("Слово2", "%" + Слово2 + "%");
	Запрос.УстановитьПараметр("Слово3", "%" + Слово3 + "%");
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Рез.Добавить(Выборка.Ссылка, Выборка.Имя + " / " + Выборка.ГруИмя);
	КонецЦикла;
	
	Возврат Рез;
КонецФункции

