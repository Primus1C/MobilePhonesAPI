// Возвращает список партий, имеющихся на складе (складах), БЕЗ УЧЕТА ДАТЫ
//
Функция ПартииПоСерииОстатки(ШК, Фирма = Неопределено, Склад = Неопределено) Экспорт
	
	Рез = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Рег.Партия КАК Партия,
	               |	Рег.Партия.Наименование КАК ИмяПартии,
	               |	Рег.ОстатокОстаток КАК Ост,
	               |	Рег.Номенклатура.Наименование КАК ИмяНоменклатуры
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара.Остатки(
	               |			,
	               |			Фирма = &Фирма
	               |				И Партия.Серия = &Серия) КАК Рег
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА &Склад = НЕОПРЕДЕЛЕНО
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ Рег.Склад = &Склад
	               |		КОНЕЦ
	               |	И Рег.ОстатокОстаток >= 1";
	Запрос.УстановитьПараметр("Серия", ШК);
	Запрос.УстановитьПараметр("Фирма", ?(Фирма=Неопределено, ПараметрыСеанса.Фирма, Фирма));
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Рез.Добавить(Выборка.Партия, Строка(Выборка.Ост) + ": " + СокрЛП(Выборка.ИмяПартии) + " / " + СокрЛП(Выборка.ИмяНоменклатуры));
	КонецЦикла;

	Возврат Рез;
	
КонецФункции

Функция ЕстьРазныеЦены(СпиДок, Имя = "РасходнаяНакладная") Экспорт
	Усл = ?(Имя = "Счет", "И НТЧ.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	НТЧ.Номенклатура,
		|	НТЧ.Ссылка.Валюта,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ НТЧ.ЦенаПродажи) КАК ЧислоРазныхЦен
		|ИЗ
		|	Документ." + Имя + ".Товары КАК НТЧ
		|ГДЕ
		|	НТЧ.Ссылка В(&СпиДок)" + Усл + "  
		|СГРУППИРОВАТЬ ПО
		|	НТЧ.Номенклатура,
		|	НТЧ.Ссылка.Валюта
		|УПОРЯДОЧИТЬ ПО
		|	ЧислоРазныхЦен УБЫВ";

	Запрос.УстановитьПараметр("СпиДок", СпиДок);

	Рабл = Запрос.Выполнить().Выгрузить();
	
	Для Каждого _Рабл Из Рабл Цикл
		Если _Рабл.ЧислоРазныхЦен > 1 Тогда Возврат Истина КонецЕсли; 
		Прервать;
	КонецЦикла; 
	
	Возврат Ложь;
КонецФункции

Процедура ПечатьДокумента(Имя, Тек, Поз, ТабДок, Параметры = 0, Картинка = 0) Экспорт
	
	//Если Имя = "Спецификация" Тогда 
