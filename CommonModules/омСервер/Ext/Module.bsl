Функция ПолучитьПользователя() Экспорт
	Имя = ИмяПользователя();
	
	Тек = Справочники.Пользователи.НайтиПоКоду(Имя);
	Если Тек.Пустая() И (Имя <> "Регистрация") Тогда
		Тек = Справочники.Пользователи.СоздатьЭлемент();
		Тек.Код = Имя;
		Тек.Наименование = Имя;
		Тек.Записать();
		Тек = Тек.Ссылка;
	КонецЕсли; 
	
	Возврат Тек;
КонецФункции
 
Функция ПолучитьВалюту(Код) Экспорт
	Тек = Справочники.Валюты.НайтиПоКоду(Код);
	Если Тек.Пустая() Тогда
		Тек = Справочники.Валюты.СоздатьЭлемент();
		Тек.Код = Код;
		Тек.Наименование = Код;
		Тек.Обозначение = Код;
		Тек.Записать();
		Тек = Тек.Ссылка;
	КонецЕсли; 
	
	Возврат Тек;
КонецФункции

Функция ПолучитьФирму() Экспорт
	Фирма = Справочники.Фирмы.ПустаяСсылка();
	
	омСервер.ВЗН("Старт", "Фирма", Фирма);
	
	Если ТипЗнч(Фирма) = Тип("СправочникСсылка.Фирмы") Тогда
		Если ЗначениеЗаполнено(Фирма) Тогда Возврат Фирма КонецЕсли; КонецЕсли;
		
	Фирма = Справочники.Фирмы.НайтиПоКоду(1);
	Если Фирма.Пустая() Тогда
		Нов = Справочники.Фирмы.СоздатьЭлемент();
		Нов.Код = 1;
		Нов.Наименование = "НАША ФИРМА";
		Нов.ПолнНаименование = "Полное наименование нашей фирмы";
		Нов.Валюта = ПараметрыСеанса.Валюта;
		Нов.Записать();
		Фирма = Нов.Ссылка;
	КонецЕсли; 
	
	Возврат Фирма;
КонецФункции
 
