// © Primus1C  30.11.2023  НАЧАЛО ►

// Возвращает СписокЗначений, заполненный всеми элементами указанного перечисления.
//
// Параметры:
//  ИмяПеречисления - Строка - Имя перечисления в дереве метаданных (например, "ВидыЦен").
//
// Возвращаемое значение:
//  СписокЗначений  - Готовый список. Значение = ссылка на элемент, Представление = синоним.
//
Функция ПолучитьСписокЗначенийПеречисления(Знач ИмяПеречисления) Экспорт
	
	Список = Новый СписокЗначений;
	
	// 1. Защита от ошибок: проверяем, существует ли такое перечисление в конфигурации
	МетаданныеПеречисления = Метаданные.Перечисления.Найти(ИмяПеречисления);
	Если МетаданныеПеречисления = Неопределено Тогда
		// Можно вернуть пустой список, но лучше просигнализировать об ошибке разработчика
		ВызватьИсключение СтрШаблон("Перечисление с именем ""%1"" не найдено в метаданных!", ИмяПеречисления);
	КонецЕсли;
	
	// 2. Получаем доступ к менеджеру конкретного перечисления
	Менеджер = Перечисления[ИмяПеречисления];
	
	// 3. Обходим все значения перечисления 
	// (Платформа обходит только реальные значения, пустая ссылка сюда не попадает)
	Для Каждого ЗначениеПеречисления Из Менеджер Цикл
		
		// Функция Строка() для перечисления автоматически возвращает его синоним, 
		// понятный пользователю, поэтому используем её для представления.
		Список.Добавить(ЗначениеПеречисления, Строка(ЗначениеПеречисления));
		
	КонецЦикла;
	
	Возврат Список;
	
КонецФункции

Процедура ЗаписатьОбщиеРеквизиты(Объект, ЕстьФирма = Истина) Экспорт
	
	Если ЕстьФирма Тогда
		Если НЕ ЗначениеЗаполнено(Объект.Фирма) Тогда Объект.Фирма = гоФирма() КонецЕсли; 
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.КемСоздан) Тогда Объект.КемСоздан = гоПользователь() КонецЕсли; 
	Если Объект.Создан = Дата(1,1,1) Тогда Объект.Создан = ТекущаяДатаСеанса() КонецЕсли; 
	Объект.КемСохранен = гоПользователь();
	Объект.Сохранен = ТекущаяДатаСеанса();

КонецПроцедуры

Функция Фрмт(ФорматируемаяСтрока, Знач Вариант) Экспорт
	
	Размер 	= 6;        
	
	Стр = СтрЗаменить(Строка(ФорматируемаяСтрока), Символы.ПС, "<br/>");
	
	Вариант	= ВРег(Вариант);
	Если Найти(Вариант, "_ЦВ1") > 0 Тогда
		Цв 		= Метаданные.ЭлементыСтиля.ЦветНадписиИнфоСиний.Значение;
		Цвет 	= СтрШаблон("color:rgb(%1,%2,%3)", Цв.Красный, Цв.Зеленый, Цв.Синий);
	ИначеЕсли Найти(Вариант, "_ЦВ2") > 0 Тогда
		Цв 		= Метаданные.ЭлементыСтиля.ЦветНадписиИнфоМорской.Значение;
		Цвет 	= СтрШаблон("color:rgb(%1,%2,%3)", Цв.Красный, Цв.Зеленый, Цв.Синий);
	ИначеЕсли Найти(Вариант, "_ЦВ3") > 0 Тогда // серый неактивный
		Цв 		= Метаданные.ЭлементыСтиля.НедоступныеДанныеЦвет.Значение;
		Цвет 	= СтрШаблон("color:rgb(%1,%2,%3)", Цв.Красный, Цв.Зеленый, Цв.Синий);
	ИначеЕсли Найти(Вариант, "КРАСНЫЙ_ТЕКСТ") > 0 Тогда
		Цвет	= "color:rgb(255,0,0)";	
	Иначе
		Цвет 	= "";
	КонецЕсли;
	
	СтильСписка = Найти(Вариант, "_СПИСОК") > 0;
	Вариант = СтрЗаменить(Вариант, "_СПИСОК", "");
	
	Если Вариант = "НАДПИСЬ_Ж" Тогда
		Строка = "<b>" + Стр + "</b>";
	ИначеЕсли Найти(Вариант, "НАДПИСЬ_ЦВ") > 0 Тогда	
		Строка = СтрШаблон("<span style='%1'>%2</span>", Цвет, Стр);
	ИначеЕсли Найти(Вариант, "ЧИСЛОЦЕЛ_ЦВ") > 0 Тогда
		Руб = Формат(Окр(Стр), "ЧРГ=");
		Строка = СтрШаблон("<span style='font-size:%1; %2'>%3</span>", Размер, Цвет, Руб);
	ИначеЕсли Найти(Вариант, "ЧИСЛО_ЦВ") > 0 Тогда
		Руб = Формат(Цел(Стр), "ЧРГ=; ЧН=");
		Коп = Формат((Стр-Цел(Стр))*100,"ЧЦ=2; ЧДЦ=0; ЧН=00; ЧВН=");
		Строка = СтрШаблон("<span style='font-size:%1; %2'>%3.</span><span style='%2'>%4</span>", Размер, Цвет, Руб, Коп);
	ИначеЕсли Вариант = "КРАСНЫЙ_ТЕКСТ" Тогда
	    Строка = СтрШаблон("<span style='%1'>%2</span>", Цвет, Стр);
	Иначе
		Строка = Строка(Стр);
	КонецЕсли;
	
	Если СтильСписка Тогда
		Строка = СтрШаблон("<li>%1</li>", Строка);
	КонецЕсли;      
	
	Возврат Строка;
	
КонецФункции 

Функция МоиИтогиФорматированные(Знач Объект, надоИтоги=Истина, надоОплата=Истина, надоЗатраты = Ложь) Экспорт
	
	СтруктураИтогов = Новый Структура;
	Если Объект.Свойство("Ссылка") Тогда
	    Ссылка 		= Объект.Ссылка;
		ТипОбъекта 	= ТипЗнч(Ссылка);
	Иначе
		Ссылка 		= Неопределено;
		ТипОбъекта  = "ПроизвольнаяФорма";
	КонецЕсли;

	Если надоИтоги Тогда 
			
		шСумма 				= НСтр("ru = 'Сумма:'; en = 'Sum:'");  
		шСкидка				= НСтр("ru = 'Скидка:'; en = 'Discount:'"); 
