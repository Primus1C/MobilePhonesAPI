Функция МассивСкладовКонтрагентов() Экспорт
	Если гоПользователь().СкладовОтправителя = 0 Тогда 
		Возврат Новый Массив 
	Иначе
		Возврат гоПользователь().СкладыКонтрагентов.ВыгрузитьКолонку("Склад");
	КонецЕсли; 
КонецФункции

Функция МассивКонтрагентов() Экспорт
	
	Пользователь = гоПользователь();
	Если Пользователь.Контрагентов = 0 Тогда 
		Результат = Новый Массив;
	Иначе	
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		             |	Контрагенты.Ссылка КАК Ссылка
		             |ИЗ
		             |	Справочник.Контрагенты КАК Контрагенты
		             |ГДЕ
		             |	Контрагенты.Ссылка В ИЕРАРХИИ
		             |			(ВЫБРАТЬ
		             |				ПользователиКонтрагенты.Группа КАК ГруппаКонтрагентов
		             |			ИЗ
		             |				Справочник.Пользователи.Контрагенты КАК ПользователиКонтрагенты
		             |			ГДЕ
		             |				ПользователиКонтрагенты.Ссылка = &Ссылка)";     
		Если Пользователь.ВариантДоступаККонтрагентам = Перечисления.ВариантДоступа.Запретить Тогда
		 	Запр.Текст = СтрЗаменить(Запр.Текст, "В ИЕРАРХИИ", "НЕ В ИЕРАРХИИ");
		КонецЕсли;
		Запр.УстановитьПараметр("Ссылка", Пользователь);
