Процедура СЗН(Вид, Имя, Зна) Экспорт
	ТекПол = гоПользователь();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиФорм.Ссылка
		|ИЗ
		|	Справочник.НастройкиФорм КАК НастройкиФорм
		|ГДЕ
		|	НастройкиФорм.Автор = &Автор
		|	И НастройкиФорм.Тип = &Тип";

	Запрос.УстановитьПараметр("Автор", ТекПол);
	Запрос.УстановитьПараметр("Тип", Вид);

	Табл = Запрос.Выполнить().Выгрузить();
	Если Табл.Количество() = 0 Тогда 
		Нов = Справочники.НастройкиФорм.СоздатьЭлемент();
		Нов.Наименование = Вид + "...";
		Нов.Автор = ТекПол;
		Нов.Тип = Вид;
		Нов.Хранилище = Новый ХранилищеЗначения(Новый Структура(Имя, Зна));
		Нов.Записать();
	Иначе 
		Тек = Табл[0].Ссылка;
		Спр = Тек.ПолучитьОбъект();
		
		С = Спр.Хранилище.Получить();
		Если НЕ (ТипЗнч(С) = Тип("Структура")) Тогда С = Новый Структура КонецЕсли; 
		
		Если С.Свойство(Имя) Тогда 
			С[Имя] = Зна;
		Иначе 
			С.Вставить(Имя, Зна);
		КонецЕсли; 
		
		Спр.Хранилище = Новый ХранилищеЗначения(С);
		Спр.Записать();
	КонецЕсли; 
КонецПроцедуры

