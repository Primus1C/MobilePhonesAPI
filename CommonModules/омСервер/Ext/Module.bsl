			стрИтоги = Стр;
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратПоставщику") Тогда
			Стр = "Сумма: " + гоСуммаЗнВал(Объект.Сумма, Объект.Валюта) + "   " + "Кол-во: " + Объект.Товары.Итог("Количество");
			
			Если Объект.Окончательно И НЕ Ссылка.Пустая() Тогда
				лДолг = Долг(Ссылка, "ПредоплатаПоставщику");
				лПривязать = Ссылка.Сумма;
				лИзвне = омСервер.ПривязаноИзвне(Ссылка);
				гоПлюс(Стр, гоРС() +
					   "Привязано: " + гоСуммаЗнВал(Ссылка.СуммаПривязано, Ссылка.Валюта) +
					   ?(лИзвне = 0, "", "   Извне: " + гоСуммаЗнВал(лИзвне, Ссылка.Валюта)) +
					   "   Не привязано: " + гоСуммаЗнВал(лПривязать - Ссылка.СуммаПривязано - лИзвне, Ссылка.Валюта));
			КонецЕсли;
			
			стрИтоги = Стр;
		КонецЕсли; 
	КонецЕсли; 
	
	Если надоОплата Тогда  
		Если НЕ Ссылка.Пустая() И 
			
			(ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПриходнаяНакладная")) 
			ИЛИ
			(ТипЗнч(Ссылка) = Тип("ДокументСсылка.РасходнаяНакладная"))
			ИЛИ
			(ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратПоставщику"))
			//ИЛИ
			//(ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратПокупателя"))
			Тогда
			
			стрОплата = "";
			ЕстьОплата = ЕстьОплатаДокумента(Ссылка);
			Если ЕстьОплата И (Ссылка.СуммаПривязано <> 0) Тогда стрОплата = НСтр("ru = 'ЕСТЬ ОПЛАТА+ПРИВЯЗКА'; en = 'PAYMENT+BINDING IS AVAILABLE'")
			ИначеЕсли ЕстьОплата Тогда стрОплата = НСтр("ru = 'Е С Т Ь   О П Л А Т А'; en = 'P A Y M E N T   I S   A V A I L A B L E'")
			ИначеЕсли Ссылка.СуммаПривязано <> 0 Тогда стрОплата = НСтр("ru = 'Е С Т Ь   П Р И В Я З К А'; en = 'B I N D I N G   I S   A V A I L A B L E'")
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры

Функция Долг(Тек, Имя, НаДату = 0) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ДОС." + Имя + "Остаток КАК Долг
		|ИЗ
		|	РегистрНакопления.Долги.Остатки(" + ?(НаДату = 0, "", "&НаДату") + ", Док = &Док) КАК ДОС
		|";
	Запрос.УстановитьПараметр("Док", Тек);
	Запрос.УстановитьПараметр("НаДату", НаДату);

	Табл = Запрос.Выполнить().Выгрузить();
	Возврат Табл.Итог("Долг");
КонецФункции

Функция ПривязаноИзвне(Тек) Экспорт
	Если НЕ ЗначениеЗаполнено(Тек) Тогда Возврат 0 КонецЕсли; 
	
	Сум = 0;
	
	ВидДок = гоДокИмя(Тек);
	ЭтоПН = (ВидДок = "ПриходнаяНакладная");
	ЭтоРН = (ВидДок = "РасходнаяНакладная");
	
	ЭтоОК = (ВидДок = "ДвижениеДенег") И (Тек.ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Покупатели);
	ЭтоОП = (ВидДок = "ДвижениеДенег") И (Тек.ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Поставщики);
	ЭтоУС = (ВидДок = "АктУслуг");
	ЭтоПУ = (ВидДок = "ПриходУслуг");
	ЭтоВК = (ВидДок = "ВозвратПокупателя");
	ЭтоВП = (ВидДок = "ВозвратПоставщику");
	
	ТипДД = Тип("ДокументСсылка.ДвижениеДенег");
	
	ТипВК = 0;	//Тип("ДокументСсылка.ВозвратПокупателя");
	ТипВП = Тип("ДокументСсылка.ВозвратПоставщику");
	
	перПокупатели = Перечисления.ВидДвиженияДенег.Покупатели;
	перПоставщики = Перечисления.ВидДвиженияДенег.Поставщики;
	
	Выборка = РегистрыНакопления.Долги.Выбрать( , , Новый Структура("Док", Тек), "Убыв");
	Пока Выборка.Следующий() Цикл
		Если Выборка.Регистратор = Тек Тогда Продолжить КонецЕсли; 
		
		ТипРег = ТипЗнч(Выборка.Регистратор);
		
		регОК = Ложь;
		Если ТипРег = ТипДД Тогда регОК = (Выборка.Регистратор.ВидДвиженияДенег = перПокупатели) КонецЕсли; 
		
		регОП = Ложь;
		Если ТипРег = ТипДД Тогда регОП = (Выборка.Регистратор.ВидДвиженияДенег = перПоставщики) КонецЕсли; 
		
	//	Если ТипРег = ТипДО Тогда Продолжить КонецЕсли;
	//	Если ТипРег = ТипКД Тогда Продолжить КонецЕсли;
		
		Если ЭтоОК ИЛИ ЭтоВК Тогда
			Если регОК ИЛИ (ТипРег = ТипВК) Тогда 
				Сум = Сум + (- Выборка.ПредоплатаПокупателя);
			Иначе 
				Сум = Сум + Выборка.ПредоплатаПокупателя;
				Если ТипРег = Тип("ДокументСсылка._СписаниеЗадолженности") Тогда
					Сум = ?(Сум>0, Сум, -Сум);
				КонецЕсли;
			КонецЕсли; 
			
		ИначеЕсли ЭтоРН ИЛИ ЭтоУС Тогда
			
			Сум = Сум + Выборка.ДолгПокупателя;
			
		ИначеЕсли ЭтоОП ИЛИ ЭтоВП Тогда
			
			Если регОП ИЛИ (ТипРег = ТипВП) Тогда 
				Сум = Сум + (- Выборка.ПредоплатаПоставщику);
			Иначе 
				Сум = Сум + Выборка.ПредоплатаПоставщику;
			КонецЕсли; 
			
		ИначеЕсли ЭтоПН ИЛИ ЭтоПУ Тогда
			
			Сум = Сум + Выборка.ДолгПоставщику;
			
		КонецЕсли; 
	КонецЦикла;
	
	Возврат Сум;
КонецФункции

// Если в ТекстОшибки передавать строку (пустую), то СообщениеПользователю не вызовется
//
Функция Курс(Валюта, Фирма, НаДату = 0, ВидКурса = Неопределено, ТекстОшибки = Неопределено) Экспорт
	Струк = Новый Структура("Фирма, Валюта", Фирма, Валюта);
	
	Если НаДату = 0 Тогда 
		РезСтрук = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(, Струк);
	Иначе
		РезСтрук = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(НаДату, Струк);
	КонецЕсли; 
	
	Если ВидКурса = Неопределено Тогда
		Курс = РезСтрук.Курс;
	ИначеЕсли ВидКурса = "закупка" Тогда
		Курс = РезСтрук.КурсЗакупкиСредний;
		Стр = "закупки";
	ИначеЕсли ВидКурса = "продажа" Тогда
		Курс = РезСтрук.КурсПродажиСредний;
		Стр = "продажи";
	КонецЕсли;		
	
	Если Курс = 0 Тогда 
		Курс = 1;
		Стр = НСтр("ru = 'Обнаружен нулевой курс'; en = 'Zero rate detected'");
		Если ВидКурса <> Неопределено Тогда
			Стр = СтрШаблон("%1 (%2)!", Стр); 	
		КонецЕсли;
		ТекстОшибки = Стр;
		Если ТекстОшибки = Неопределено Тогда
			Сообщить(Стр);
		Иначе	
			ТекстОшибки = Стр;
		КонецЕсли;	
	КонецЕсли;
	Возврат Курс; 
	
КонецФункции

Функция КроссКурс(ВалОткуда, ВалКуда, Фирма, Знаков = 5, НаДату = 0, Обратный = Ложь, ТолькоПрямой = Ложь) Экспорт
	Обратный = Ложь;
	
	Если ВалОткуда.Пустая() Тогда Возврат 0 КонецЕсли; 
	Если ВалКуда.Пустая() Тогда Возврат 0 КонецЕсли; 
	
	Если ВалКуда = ВалОткуда Тогда Возврат 1 КонецЕсли; 
	
	// © Primus1C  12.07.2024  НАЧАЛО ►
	Если ВалОткуда.БазоваяВалюта = ВалКуда Тогда
		Возврат Курс(ВалОткуда, Фирма, НаДату);
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	КурсОткуда = Курс(ВалОткуда, Фирма, НаДату);
	КурсКуда = Курс(ВалКуда, Фирма, НаДату);
	
	Если КурсКуда = КурсОткуда Тогда Возврат 1 КонецЕсли; 
	
	Если (КурсОткуда >= КурсКуда) ИЛИ (ТолькоПрямой) Тогда
		Возврат Окр(КурсОткуда / КурсКуда, Знаков);
	Иначе
		Обратный = Истина;
		
		Возврат Окр(КурсКуда / КурсОткуда, Знаков);
	КонецЕсли; 
КонецФункции

