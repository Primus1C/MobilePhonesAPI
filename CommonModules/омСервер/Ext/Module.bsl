		шСуммаСЗатратами	= НСтр("ru = 'Сумма с затратами:'; en = 'Sum with costs:'");
		шКво 				= НСтр("ru = 'Кол-во:'; en = 'Quantity:'");  
		шПривязано			= НСтр("ru = 'Привязано:'; en = 'Binded:'");
		шНеПривязано		= НСтр("ru = 'Не привязано:'; en = 'Not binded:'");
		шПривязаноИзвне		= НСтр("ru = 'Привязано извне:'; en = 'Binded outside:'");
		шПривязаноИнвойсов	= НСтр("ru = 'Привязано инвойсов:'; en = 'Binded invoices:'");
		шДолг				= НСтр("ru = 'Долг:'; en = 'Debt:'");
		шНаценка            = НСтр("ru = 'Наценка:'; en = 'Markup:'");
		шУслуги             = НСтр("ru = 'Услуги:'; en = 'Services:'");
		шИзвне              = НСтр("ru = 'Извне:'; en = 'From outside:'");
		шПредоплата         = НСтр("ru = 'Предоплата:'; en = 'Prepay:'");
		
		Если ТипОбъекта = Тип("ДокументСсылка.Перемещение") Тогда 
			
			//Стр = СтрШаблон(НСтр("ru = 'Сумма: %1   Кол-во: %2'; en = 'Sum: %1   Amount: %2'"), 
			Стр = СтрШаблон("%1 %2 %3    %4 %5",
							Фрмт(шСумма, "НАДПИСЬ_Ж"), 
							Фрмт(Объект.Сумма, "ЧИСЛО_ЦВ1"), 
							Фрмт(Объект.Валюта, "НАДПИСЬ_ЦВ1"),  
							Фрмт(шКво, "НАДПИСЬ_Ж"), 
							Фрмт(Объект.Товары.Итог("Количество"), "ЧИСЛОЦЕЛ_ЦВ1")); 
			
		ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			//Стр = СтрШаблон(НСтр("ru = 'Сумма: %1   Кол-во: %2%3Сумма со скидкой: %4, Сумма с затратами: %5'; en = 'Sum: %1   Amount: %2%3Discount sum: %4, Sum with costs: %5'"),
            Стр = СтрШаблон("%1 %2 %3     %4 %5<br>
							|%6 %7 %10     %8 %9 %10",
			                Фрмт(шСумма, "НАДПИСЬ_Ж"),
							Фрмт(Объект.Товары.Итог("СуммаЗакупки"), "ЧИСЛО_ЦВ1"),
							Фрмт(Объект.Валюта, "НАДПИСЬ_ЦВ1"),
							Фрмт(шКво, "НАДПИСЬ_Ж"), 
							Фрмт(Объект.Товары.Итог("Количество"), "ЧИСЛОЦЕЛ_ЦВ1"),
							Фрмт(шСуммаСоСкидкой, "НАДПИСЬ_Ж"),
							Фрмт(Объект.Товары.Итог("ВКД_СуммаСоСкидкой"), "ЧИСЛО_ЦВ2"),
							Фрмт(шСуммаСЗатратами, "НАДПИСЬ_Ж"), 
