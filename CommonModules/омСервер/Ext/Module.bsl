Процедура ЗаписатьРеквизит(Ссылка, Имя, НовЗна, РезСоо = "", Провести = Ложь) Экспорт
	РезСоо = "";
	
	Попытка
		Объект = Ссылка.ПолучитьОбъект();
	Исключение
		гоРезСоо(РезСоо, ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Попытка
		Объект[Имя] = НовЗна;
	Исключение
		гоРезСоо(РезСоо, ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Попытка
		Если Провести Тогда 
			Объект.Записать(РежимЗаписиДокумента.Проведение);
		Иначе 
			Объект.Записать();
		КонецЕсли; 
	Исключение
		гоРезСоо(РезСоо, ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
КонецПроцедуры

