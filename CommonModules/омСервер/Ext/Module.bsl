				гоПлюс(Стр, СтрШаблон("<br>%1 %2 %3,   %4%5 %6 %3,   %7 %8 %3",
										Фрмт(шПривязано, "НАДПИСЬ_Ж"),
										Фрмт(Ссылка.СуммаПривязано, "ЧИСЛО_ЦВ2"),
