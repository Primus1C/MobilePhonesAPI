	ОстПар = "?";
	
	Если гоНПЗ(Ном) Тогда
		Если Общий Тогда
			ОстНом = ОстатокНоменклатуры(Тек.Фирма, , Ном);
		Иначе
			ОстНом = ОстатокНоменклатуры(Тек.Фирма, ?(ПоКуда, Тек.Куда, Тек.Склад), Ном);
		КонецЕсли; 
	КонецЕсли; 
	
	Если Пар = 0 Тогда  
		Возврат НСтр("ru = 'Ном = '; en = 'Good = '") + ОстНом;
	Иначе
		Если гоНПЗ(Пар) Тогда ОстПар = ОстатокПартии(Тек.Фирма, ?(ПоКуда, Тек.Куда, Тек.Склад), Пар) КонецЕсли; 
		//Возврат "Ном / Пар = " + ОстНом + " / " + ОстПар;
		Возврат СтрШаблон(НСтр("ru = 'Ном / Пар = %1 / %2'; en = 'Stock balance: Good / Batch = %1 / %2'"), ОстНом, ОстПар);
	КонецЕсли; 
