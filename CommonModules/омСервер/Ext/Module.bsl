Процедура ПоследняяЦенаЗакупки(Ном, Фир, Пос = 0, ВернутьЦену, ВернутьВалюту, ВернутьДату, ВВалюту = 0, НаДату = 0) Экспорт
//2015.12.18	
	
	ВернутьЦену = 0;
	ВернутьВалюту = Справочники.Валюты.ПустаяСсылка();
	ВернутьДату = гоПустаяДата();
	
	УС = ?(Пос = 0, "", " И ДТЧ.Ссылка.Контрагент = &Пос");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ДТЧ.Номенклатура КАК Ном,
		|	МАКСИМУМ(ДТЧ.Ссылка.Дата) КАК Дат,
		|	ДТЧ.Ссылка.Валюта КАК Вал,
		|	ДТЧ.ЦенаЗакупки КАК Цен
		|ИЗ
		|	Документ.ПриходнаяНакладная.Товары КАК ДТЧ
		|ГДЕ
		|	ДТЧ.Ссылка.Проведен
		|	И ДТЧ.Номенклатура = &Ном
		|	И ДТЧ.Ссылка.Фирма = &Фир" + УС + "
		|СГРУППИРОВАТЬ ПО
		|	ДТЧ.Номенклатура,
		|	ДТЧ.Ссылка.Валюта,
		|	ДТЧ.ЦенаЗакупки
		|";
	Запрос.УстановитьПараметр("Ном", Ном);
	Запрос.УстановитьПараметр("Фир", Фир);
	Запрос.УстановитьПараметр("Пос", Пос);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ВернутьЦену = Выборка.Цен;
		ВернутьВалюту = Выборка.Вал;
		ВернутьДату = Выборка.Дат;
		Прервать;
	КонецЦикла;
	
	Если ВернутьЦену = 0 Тогда Возврат КонецЕсли;
	Если ВВалюту = 0 Тогда Возврат КонецЕсли;
	
	ВернутьЦену = омСервер.ПересчетЗн(ВернутьЦену, ВернутьВалюту, ВВалюту, Фир, НаДату, Фир.ЧислоЗнаковЦенаЗакупки);
КонецПроцедуры

