							Объект.стрПроцент) +
				  // © Primus1C  ОКОНЧАНИЕ ◄
				  //2016.05.24 выводим услуги отдельно, если они есть
				  ?(Объект.СуммаУслуг = 0, "", "   Услуги: " + гоСуммаЗнВал(Объект.СуммаУслуг, Объект.Валюта)) + 
				  //2017.01.18 + - Объект.КоличествоВозвратов
				  "   " + "Кол-во: " + Строка(Объект.Товары.Итог("Количество") - Объект.КоличествоВозвратов);
         //ВКД--
			
			Если Объект.Окончательно И НЕ Ссылка.Пустая() Тогда
				лДолг = Долг(Ссылка, "ДолгПокупателя");
				лПривязать = Ссылка.Сумма;
				лИзвне = омСервер.ПривязаноИзвне(Ссылка);
				гоПлюс(Стр, гоРС() +
					   "Привязано: " + гоСуммаЗнВал(Ссылка.СуммаПривязано, Ссылка.Валюта) +
