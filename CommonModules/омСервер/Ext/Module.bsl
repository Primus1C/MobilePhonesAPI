										?(лИзвне = 0, "", НСтр("ru = '   Извне: '; en = '   From outside: '") + гоСуммаЗнВал(лИзвне, Ссылка.Валюта)),
										гоСуммаЗнВал(лПривязать - Ссылка.СуммаПривязано - лИзвне, Ссылка.Валюта),
