//
//
Функция СоздатьДокументУстановкиЦен(Запрос, ДанныеЗапроса, КонтекстАвторизации) Экспорт
	
	Результат = Новый Структура("success,error,documentNumber,items", Ложь, "", "", 0);
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	ВидЦены = ВидЦеныДляЗаписиAPI(ЗначениеПоляJSON(ДанныеЗапроса, "priceType"));
	Если НЕ ЗначениеЗаполнено(ВидЦены) Тогда
		Результат.error = "Не найден вид цены priceType.";
		Возврат Результат;
	КонецЕсли;
	
	Валюта = ВалютаДляЗаписиAPI(ЗначениеПоляJSON(ДанныеЗапроса, "currency"));
	Если НЕ ЗначениеЗаполнено(Валюта) Тогда
		Результат.error = "Не найдена валюта currency.";
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидЦены.Валюта) И ВидЦены.Валюта <> Валюта Тогда
		Результат.error = СтрШаблон("Валюта %1 не соответствует виду цены %2.", Строка(Валюта), Строка(ВидЦены));
		Возврат Результат;
	КонецЕсли;
	
	//Склад = СкладДляЗаписиЦенAPI(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись); 
	Склад = StockAPI_Справочники.НайтиСклад(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат.error); 
	Если Результат.error <> "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ПозицииЦенИзЗапроса(ДанныеЗапроса);
	Если Позиции = Неопределено Тогда
		Результат.error = "В запросе не найден массив строк items.";
		Возврат Результат;
	КонецЕсли;
	
	Документ = Документы.УстановкаЦен.СоздатьДокумент();
	Документ.Дата 		= ТекущаяДатаСеанса();
	Документ.Фирма 		= гоФирма();
	Документ.КемСоздан 	= гоПользователь();
	Документ.Создан 	= ТекущаяДатаСеанса();
	Документ.Склад 		= Склад;
	Документ.ПороговЦен = 0;
	Документ.Примечание = "Создано StockAPI";
	Документ.ВидыЦен.Добавить().ВидЦены = ВидЦены;
	
	НомСтроки = 0;
	Для Каждого Позиция Из Позиции Цикл
		
		Номенклатура = НоменклатураДляЗаписиЦенAPI(ЗначениеПоляJSON(Позиция, "itemCode"));
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.error = СтрШаблон("Не найдена номенклатура itemCode=%1.", Строка(ЗначениеПоляJSON(Позиция, "itemCode")));
			Возврат Результат;
		КонецЕсли;
		
		ЦеныПозиции = ЗначениеПоляJSON(Позиция, "price");
		Если ЦеныПозиции = Неопределено Тогда
			Результат.error = СтрШаблон("Для товара %1 не заполнен массив price.", Строка(ЗначениеПоляJSON(Позиция, "itemCode")));
			Возврат Результат;
		КонецЕсли;
		
		НомСтроки = НомСтроки + 1;
		СтрокаЦены = Документ.Товары.Добавить();
		СтрокаЦены.НомСтроки 		= НомСтроки;
		СтрокаЦены.Номенклатура 	= Номенклатура;
		СтрокаЦены.ВидЦены 			= ВидЦены;
		СтрокаЦены.РазрешитьПродажу = Истина;
		
		ПороговЦенСтроки = ЗаполнитьЦеныСтрокиДокументаAPI(СтрокаЦены, ЦеныПозиции);
		Если ПороговЦенСтроки > Документ.ПороговЦен Тогда
			Документ.ПороговЦен = ПороговЦенСтроки;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Документ.Товары.Количество() = 0 Тогда
		Результат.error = "В запросе нет строк цен.";
		Возврат Результат;
	КонецЕсли;
	
	Документ.Записать(РежимЗаписиДокумента.Проведение);
	
	Результат.success 			= Истина;
	Результат.documentNumber 	= Документ.Номер;
	Результат.items 			= Документ.Товары.Количество();
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеПоляJSON(Данные, ИмяПоля)
	
	Если Данные <> Неопределено И Данные.Свойство(ИмяПоля) Тогда
		Возврат Данные[ИмяПоля];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПозицииЦенИзЗапроса(ДанныеЗапроса)
	
	Позиции = ЗначениеПоляJSON(ДанныеЗапроса, "items");
	Если Позиции <> Неопределено Тогда
		Возврат Позиции;
	КонецЕсли;
	
	Позиции = ЗначениеПоляJSON(ДанныеЗапроса, "prices");
	Если Позиции <> Неопределено Тогда
		Возврат Позиции;
	КонецЕсли;
	
	Позиции = ЗначениеПоляJSON(ДанныеЗапроса, "data");
	Если Позиции <> Неопределено Тогда
		Возврат Позиции;
	КонецЕсли;
	
	Если ЗначениеПоляJSON(ДанныеЗапроса, "itemCode") <> Неопределено Тогда
		Позиции = Новый Массив;
		Позиции.Добавить(ДанныеЗапроса);
		Возврат Позиции;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ВидЦеныДляЗаписиAPI(ИмяВидаЦены)
	
	Если ИмяВидаЦены = Неопределено Тогда
		Возврат Справочники.ВидыЦен.ПустаяСсылка();
	КонецЕсли;
	
	Норм = ВРег(СтрЗаменить(СокрЛП(Строка(ИмяВидаЦены)), " ", ""));
	Если Норм = "КРУПНЫЙОПТ" Или Норм = "LARGE" Или Норм = "WHOLESALE" Тогда
		Возврат Справочники.ВидыЦен.КрупныйОпт;
	ИначеЕсли Норм = "МЕЛКИЙОПТ" Или Норм = "SMALL" Тогда
		Возврат Справочники.ВидыЦен.МелкийОпт;
	КонецЕсли;
	
	Возврат Справочники.ВидыЦен.НайтиПоНаименованию(СокрЛП(Строка(ИмяВидаЦены)), Истина);
	
КонецФункции

Функция ВалютаДляЗаписиAPI(ИмяВалюты)
	
	Если ИмяВалюты = Неопределено Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	Норм = ВРег(СокрЛП(Строка(ИмяВалюты)));
	Если Норм = "" Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИмяВалюты", Норм);
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Валюты.Ссылка КАК Валюта
	               |ИЗ
	               |	Справочник.Валюты КАК Валюты
	               |ГДЕ
	               |	НЕ Валюты.ПометкаУдаления
	               |	И ((ВЫРАЗИТЬ(Валюты.Код КАК СТРОКА(20))) = &ИмяВалюты
	               |			ИЛИ Валюты.Наименование = &ИмяВалюты
	               |			ИЛИ Валюты.КодISO = &ИмяВалюты)";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Валюта;
	КонецЕсли;
	
	Возврат Справочники.Валюты.ПустаяСсылка();
	
КонецФункции

