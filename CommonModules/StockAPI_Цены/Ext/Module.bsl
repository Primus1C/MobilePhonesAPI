// Добавляет prices (все виды).
Процедура ДобавитьЦеныВСтруктуру(СтруктураЭлемента, ЦеныПоВидам, Количество, ВидЦеныПоУмолчанию) Экспорт
	
	МассивЦен = Новый Массив;
	ВидыДляОтвета = Новый Массив;
	ВидыДляОтвета.Добавить(Справочники.ВидыЦен.МелкийОпт);
	ВидыДляОтвета.Добавить(Справочники.ВидыЦен.КрупныйОпт);
	
	Если ЦеныПоВидам <> Неопределено Тогда
		Для Каждого ВидЦены Из ВидыДляОтвета Цикл
			ДанныеЦены = ЦеныПоВидам.Получить(ВидЦены);
			Если ДанныеЦены = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗаписьЦены = Новый Структура;
			ЗаписьЦены.Вставить("priceType", Строка(ВидЦены));
			ЗаписьЦены.Вставить("salePrice", ЦенаПродажиПоКоличеству(ДанныеЦены, Количество));
			ЗаписьЦены.Вставить("currency", ДанныеЦены.Валюта.Наименование);
			МассивЦен.Добавить(ЗаписьЦены);
		КонецЦикла;
	КонецЕсли;
	
	СтруктураЭлемента.Вставить("prices", МассивЦен);
	
КонецПроцедуры


