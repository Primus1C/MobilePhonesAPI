	Если КодНоменклатуры = Неопределено Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.НайтиПоКоду(СокрЛП(Строка(КодНоменклатуры)));
	
КонецФункции

Функция ЗаполнитьЦеныСтрокиДокументаAPI(СтрокаЦены, ЦеныПозиции)
	
	ПороговЦен = 0;
	
	Для Каждого СтрокаПрайса Из ЦеныПозиции Цикл
		
		Количество = Число(ЗначениеПоляJSON(СтрокаПрайса, "qty"));
		Цена = Число(ЗначениеПоляJSON(СтрокаПрайса, "priceQty"));
		
		Если Количество = 0 Тогда
			СтрокаЦены.Цена0 = Цена;
		ИначеЕсли СтрокаЦены.Порог1 = 0 Тогда
			СтрокаЦены.Порог1 = Количество;
			СтрокаЦены.Цена1 = Цена;
			ПороговЦен = 1;
		ИначеЕсли СтрокаЦены.Порог2 = 0 Тогда
			СтрокаЦены.Порог2 = Количество;
			СтрокаЦены.Цена2 = Цена;
			ПороговЦен = 2;
		ИначеЕсли СтрокаЦены.Порог3 = 0 Тогда
			СтрокаЦены.Порог3 = Количество;
			СтрокаЦены.Цена3 = Цена;
			ПороговЦен = 3;
		Иначе
			ВызватьИсключение "Документ УстановкаЦен поддерживает не более трех порогов цен.";
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПороговЦен;
	
КонецФункции
