Процедура УдалитьЗапись(Отбор) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НаборЗаписей = РегистрыСведений.Сооб_Сообщения.СоздатьМенеджерЗаписи();
	НаборЗаписей.УникИдент 					= Отбор.УникИдент;
	НаборЗаписей.Получатель					= Отбор.Получатель;
	НаборЗаписей.Автор      				= Отбор.Автор;
	НаборЗаписей.ЗапланированнаяДатаДоставки= Отбор.ЗапланированнаяДатаДоставки;
	НаборЗаписей.ТипСообщения  				= Отбор.ТипСообщения;
	НаборЗаписей.Категория    				= Отбор.Категория;
	НаборЗаписей.Прочитать();
	НаборЗаписей.Удалить();

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

Функция Инициалы(Знач ИмяПользователя)
	
	ИмяПользователя = СокрЛП(СтрЗаменить(ИмяПользователя, "_", " "));
	поз = Найти(ИмяПользователя, " ");
    Если поз = 0 Тогда
		Возврат Врег(Лев(ИмяПользователя, 2));	
	Иначе   
		ИмяПользователя = Лев(ИмяПользователя,1) + Сред(ИмяПользователя,поз+1,1);
		Возврат Врег(ИмяПользователя);	
	КонецЕсли;

КонецФункции 

Функция СообщенияОбъекта(ОбъектСсылка) Экспорт

	СтрокаВложHTML = "";
	ФорматДаты = "Л=" + НСтр("ru = 'ru'; en = 'en'") + "; ДФ='d MMMM HH:mm'";
	
	Запр = Новый Запрос;  
	//Запр.УстановитьПараметр("Получатель", гоПользователь());
	Запр.УстановитьПараметр("СсылкаНаОбъект", ОбъектСсылка);
	Запр.Текст = "ВЫБРАТЬ Разрешенные
	             |	Сооб_Сообщения.Автор,
	             |	Сооб_Сообщения.Автор.Код КАК КодПользователя,
	             |	Сооб_Сообщения.Тема,
	             |	Сооб_Сообщения.Сообщение,
	             |	Сооб_Сообщения.ДатаСоздания,
	             |	Сооб_Сообщения.ТипСообщения,
	             |	Сооб_Сообщения.Категория,
	             |	Сооб_Сообщения.ДатаПервогоПросмотра,
	             |	Сооб_Сообщения.СсылкаНаОбъект,
	             |	Сооб_Сообщения.Выполнено,
	             |	Сооб_Сообщения.ДатаВыполнения,
	             |	Сооб_Сообщения.Получатель,
	             |	Сооб_Сообщения.УникИдент КАК ИД
	             |ИЗ
	             |	РегистрСведений.Сооб_Сообщения КАК Сооб_Сообщения
	             |ГДЕ
	             |	Сооб_Сообщения.СсылкаНаОбъект = &СсылкаНаОбъект
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ДатаСоздания";
    Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Количество() = 0 Тогда
		СтрокаВложHTML = ПолучитьОбщийМакет("component_li_empty").ПолучитьТекст(); 
		ОчиститьСтрокуHTML(СтрокаВложHTML);
	Иначе
		Пока Выборка.Следующий() Цикл
			ПодСтрокаHTML = ПолучитьОбщийМакет("component_li").ПолучитьТекст(); 
			ОчиститьСтрокуHTML(ПодСтрокаHTML);
			ПараметрыHTML = Новый Структура("Инициалы, Автор, Сообщение, Создано, Просмотрено, ИД_Ответа, ИД_Выполнить, ДатаВыполнения",
											Инициалы(Выборка.Автор), 
											Выборка.Автор, 
											Выборка.Сообщение, 
											Формат(Выборка.ДатаСоздания, ФорматДаты), 
											Формат(Выборка.ДатаПервогоПросмотра, ФорматДаты),
											"answer_"+СокрЛП(Выборка.КодПользователя),
											"doit_"+Выборка.ИД,
											Формат(Выборка.ДатаВыполнения, ФорматДаты),
			 								); 
			Если Выборка.ТипСообщения = Перечисления.Сооб_ТипСообщения.Поручение Тогда
				Если Выборка.Выполнено Тогда
					ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_completed></component_li_completed>", ПолучитьОбщийМакет("component_li_completed").ПолучитьТекст()); 
				ИначеЕсли Выборка.Получатель = гоПользователь() Тогда
					ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_doit></component_li_doit>", ПолучитьОбщийМакет("component_li_doit").ПолучитьТекст()); 
				Иначе
					ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_doit></component_li_doit>", ""); 
					ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_completed></component_li_completed>", ""); 
				КонецЕсли;
			Иначе
				ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_doit></component_li_doit>", ""); 
				ПодСтрокаHTML = СтрЗаменить(ПодСтрокаHTML, "<component_li_completed></component_li_completed>", ""); 
			КонецЕсли;								
		    ЗаполнитьПараметрыHTML(ПодСтрокаHTML, ПараметрыHTML);
			СтрокаВложHTML = СтрокаВложHTML + ПодСтрокаHTML;
		КонецЦикла; 
	КонецЕсли;
	
	СтрокаHTML = ПолучитьОбщийМакет("component_body").ПолучитьТекст(); 
	
	Стиль = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("СтильОформленияСообщений");
	Если Стиль = Перечисления.СтилиОформленияСообщений.Standart Тогда
 	  	СтрокаСтильHTML = ":root {
				 			|--background-color: #f4f0dc;
				 			|--text-color: #000000;
				 			|--person-color: #febc65;
				 			|--message-background-color: #fcfaeb;
				 			|--user-name-color: #162779; 
				 			|--details-text-color: #b3ac86; 
				 			|--details-icon-color: #b3ac86;
				 			|--details-hilight-color: #000000;
				 			|--info-color: #1c55ae;
							|}"; 
	ИначеЕсли Стиль = Перечисления.СтилиОформленияСообщений.Today Тогда
    	СтрокаСтильHTML = ":root {
				 			|--background-color: #181b34;
				 			|--text-color: #ffffff;
				 			|--person-color: #9dd421;
				 			|--message-background-color: #393b53;
				 			|--user-name-color: #0073ea; 
				 			|--details-text-color: #9699a6; 
				 			|--details-icon-color: #d5d8df;
				 			|--details-hilight-color: #0073ea;
				 			|--info-color: #0073ea;
							|}"; 
	Иначе // Light
    	СтрокаСтильHTML = ":root {
				 			|--background-color: #ffffff;
				 			|--text-color: #323338;
				 			|--person-color: #fdad3a;
				 			|--message-background-color: #eceff8;
				 			|--user-name-color: #323338; 
				 			|--details-text-color: #999999; 
				 			|--details-icon-color: #999999;
				 			|--details-hilight-color: #000000;
				 			|--info-color: #ff642a;
							|}"; 
	КонецЕсли;
	СтрокаHTML = СтрЗаменить(СтрокаHTML, ":root {}", СтрокаСтильHTML);
	
	СтрокаHTML = СтрЗаменить(СтрокаHTML, "<component_li></component_li>", СтрокаВложHTML);
	ЗаполнитьПараметрыHTML(СтрокаHTML, Новый Структура("Обновлено", Формат(ТекущаяДатаСеанса(),"ДЛФ=T")));
	
	Возврат Новый Структура("СтрокаHTML,КоличествоСообщений", СтрокаHTML, Выборка.Количество());

КонецФункции // СтрокаHTML()

Процедура ОчиститьСтрокуHTML(СтрокаHTML)
	
	СтрокаHTML = СтрЗаменить(СтрокаHTML, "<html>",  "");
	СтрокаHTML = СтрЗаменить(СтрокаHTML, "</html>", "");
	СтрокаHTML = СтрЗаменить(СтрокаHTML, "<body>",  "");
	СтрокаHTML = СтрЗаменить(СтрокаHTML, "</body>", "");
	
	поз1 = Найти(СтрокаHTML, "<head><base ");
	Если поз1 > 0 Тогда
		поз2 = Найти(СтрокаHTML, "></base></head>");	
		СтрокаЗамены = Сред(СтрокаHTML, поз1, поз2+15 - поз1);	
	    СтрокаHTML = СтрЗаменить(СтрокаHTML, СтрокаЗамены, "");
	КонецЕсли;

КонецПроцедуры

Функция ЗаполнитьПараметрыHTML(СтрокаHTML, ПараметрыHTML)

	Для каждого Пар Из ПараметрыHTML Цикл
		СтрокаHTML = СтрЗаменить(СтрокаHTML, "{{"+Пар.Ключ+"}}", пар.Значение);
	КонецЦикла;

КонецФункции // ЗаполнитьПараметрыHTML()

Функция ПериодОбновленияЧата() Экспорт

	Возврат ПараметрыСеанса.Сооб_ПериодОбновленияЧата;	

КонецФункции // ПериодОбновленияЧата()

