Функция ПроверитьНаличиеРоли(Польз) Экспорт
	
	УстановитьПривилегированныйРежим (ИСТИНА);
	
	Если НЕ ЗначениеЗаполнено(Польз.ИдентификаторПользователяИБ) Тогда
		Возврат Ложь;	
	КонецЕсли;

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Польз.ИдентификаторПользователяИБ);
	
	Если (ПользовательИБ.Роли.Содержит(Метаданные.Роли["Сооб_ПользовательСообщений"]))
		ИЛИ (ПользовательИБ.Роли.Содержит(Метаданные.Роли["Сооб_АдминистраторСообщений"])) Тогда
		
		УстановитьПривилегированныйРежим (ЛОЖЬ);
		
		Возврат Истина;
		
	Иначе
		
		УстановитьПривилегированныйРежим (ЛОЖЬ);
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

