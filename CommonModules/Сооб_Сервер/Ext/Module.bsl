Процедура ПодпискаНаСобытиеОбработкаПолученияФормы(Источник, ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка) Экспорт
	
	Если ВидФормы = "ФормаЗаписи" Тогда
		
		//Проверим что первое открытие получателем сообщения и установим Дату первого просмотра
		
		Если Параметры.Свойство("Ключ",) Тогда  //Это открытие существующего 
			
			ЭтоПервоеОткрытие = ПроверитьЧтоПервоеОткрытиеПолучателем(Параметры.Ключ);
			
			Если ЭтоПервоеОткрытие Тогда
				
				НужнаяЗапись = РегистрыСведений.Сооб_Сообщения.СоздатьМенеджерЗаписи();
				
				НужнаяЗапись.Получатель = Параметры.Ключ.Получатель;
				НужнаяЗапись.Автор = Параметры.Ключ.Автор;
				НужнаяЗапись.ЗапланированнаяДатаДоставки = Параметры.Ключ.ЗапланированнаяДатаДоставки;
				НужнаяЗапись.ТипСообщения = Параметры.Ключ.ТипСообщения;
				НужнаяЗапись.Категория = Параметры.Ключ.Категория;
				НужнаяЗапись.УникИдент = Параметры.Ключ.УникИдент;
				
				НужнаяЗапись.Прочитать();
				
				Если НужнаяЗапись.Выбран() Тогда
					
					УстановитьПривилегированныйРежим(Истина);
					
					Если НужнаяЗапись.ДатаПервогоПросмотра = Дата('00010101000000') Тогда
						
						НужнаяЗапись.ДатаПервогоПросмотра = ТекущаяДата();
						НужнаяЗапись.Записать();
						
					КонецЕсли;
					
					УстановитьПривилегированныйРежим(ЛОЖЬ);
					
				КонецЕсли;				 
				
				Отбор = Новый Структура;
				Отбор.Вставить("Получатель", Параметры.Ключ.Получатель);
				Отбор.Вставить("Автор", Параметры.Ключ.Автор);
				Отбор.Вставить("ЗапланированнаяДатаДоставки", Параметры.Ключ.ЗапланированнаяДатаДоставки);
				Отбор.Вставить("ТипСообщения", Параметры.Ключ.ТипСообщения);
				Отбор.Вставить("Категория", Параметры.Ключ.Категория);
				Отбор.Вставить("УникИдент", Параметры.Ключ.УникИдент);
				
				НужнаяЗапись = РегистрыСведений.Сооб_Сообщения.Получить(Отбор);
				
			КонецЕсли;
			
		ИНАЧЕ
			//Это копирование или создание нового
			
			
		КонецЕсли;
		
	ИначеЕсли  ВидФормы = "ФормаСписка" Тогда
		
		
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьЧтоПервоеОткрытиеПолучателем(КлючНужнойЗаписи) ЭКСПОРТ
	
	Запрос = НОВЫЙ Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сооб_Сообщения.УникИдент КАК УникИдент
	|ИЗ
	|	РегистрСведений.Сооб_Сообщения КАК Сооб_Сообщения
	|ГДЕ
	|	Сооб_Сообщения.Получатель = &Получатель
	|	И Сооб_Сообщения.Автор = &Автор
	|	И Сооб_Сообщения.ЗапланированнаяДатаДоставки = &ЗапланированнаяДатаДоставки
	|	И Сооб_Сообщения.ТипСообщения = &ТипСообщения
	|	И Сооб_Сообщения.Категория = &Категория
	|	И Сооб_Сообщения.УникИдент = &УникИдент
	|	И Сооб_Сообщения.ДатаПервогоПросмотра = &ПустаяДата";
	
	//Запрос.УстановитьПараметр("Получатель", Пользователи.ТекущийПользователь() ); 
	Запрос.УстановитьПараметр("Получатель", ПараметрыСеанса.Пользователь); 
	Запрос.УстановитьПараметр("Автор", КлючНужнойЗаписи.Автор ); 
	Запрос.УстановитьПараметр("ЗапланированнаяДатаДоставки", КлючНужнойЗаписи.ЗапланированнаяДатаДоставки ); 
	Запрос.УстановитьПараметр("ТипСообщения", КлючНужнойЗаписи.ТипСообщения ); 
	Запрос.УстановитьПараметр("Категория", КлючНужнойЗаписи.Категория ); 
	Запрос.УстановитьПараметр("УникИдент", КлючНужнойЗаписи.УникИдент ); 
	Запрос.УстановитьПараметр("ПустаяДата", Дата('00010101000000'));
	
	РЗ = Запрос.Выполнить().Выгрузить();
	
	Если РЗ.Количество() = 1 Тогда
		
		Возврат Истина;
		
	Иначе
		
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

