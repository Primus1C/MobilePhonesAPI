Процедура АдминистраторУдалениеОтмеченныхСообщений() Экспорт
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина);
		
		Если Константы.Сооб_АвтоматическиУдалять.Получить() Тогда
			
			РС_Сообщ = РегистрыСведений.Сооб_Сообщения;
			
			ВыборкаСообщ = РС_Сообщ.Выбрать();
			
			Пока ВыборкаСообщ.Следующий() Цикл
				
				Если ВыборкаСообщ.ВременноНеУдалять Тогда
					
					Продолжить;
					
				КонецЕсли;
				
				Если ВыборкаСообщ.ПометитьНаУдаление Тогда
					
					ВремяЗадержкиУдаления = Константы.Сооб_ДнейДоУдаления.Получить() * 86400;
					
					Если ВыборкаСообщ.ДатаПометкиНаУдаление <= (ТекущаяДата() + ВремяЗадержкиУдаления) Тогда  //Четверо суток на раскачку
							
							Если ВыборкаСообщ.ТипСообщения = Перечисления.Сооб_ТипСообщения.Поручение Тогда
								
								Если ВыборкаСообщ.МожноУдалять Тогда
									
									ВыборкаСообщ.ПолучитьМенеджерЗаписи().Удалить();
									
								КонецЕсли;
								
							Иначе
								
								ВыборкаСообщ.ПолучитьМенеджерЗаписи().Удалить();
								
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
			УстановитьПривилегированныйРежим(ЛОЖЬ);
			
		Исключение
			
			ВызватьИсключение(НСтр("ru = 'Ошибка удаления сообщений'; en = 'Error deleting messages'")); 
			
		КонецПопытки;
	
	КонецПроцедуры
	
	
