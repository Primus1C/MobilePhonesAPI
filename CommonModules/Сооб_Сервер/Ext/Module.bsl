Функция СформироватьСписокНовыхСообщений() Экспорт
	
	Массив = Новый Массив;
	
	Запрос = НОВЫЙ Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Сооб_Сообщения.Получатель КАК Получатель,
	|	Сооб_Сообщения.Тема КАК Тема,
	|	Сооб_Сообщения.Автор КАК Автор,
	|	Сооб_Сообщения.ТипСообщения КАК ТипСообщения,   
	|	Сооб_Сообщения.Категория КАК Категория,
	|	Сооб_Сообщения.ЗапланированнаяДатаДоставки КАК ЗапланированнаяДатаДоставки,
	|	Сооб_Сообщения.УникИдент КАК УникИдент
	|ИЗ
	|	РегистрСведений.Сооб_Сообщения КАК Сооб_Сообщения
	|ГДЕ
	|	Сооб_Сообщения.Получатель = &Получатель
	|	И (Сооб_Сообщения.ЗапланированнаяДатаДоставки <= &ТекущаяДата
	|				И Сооб_Сообщения.ДатаПервогоПросмотра = &ПустаяДата)   
	|
	|";
	
	//Запрос.УстановитьПараметр("Получатель", Пользователи.ТекущийПользователь());
    Запрос.УстановитьПараметр("Получатель", ПараметрыСеанса.Пользователь); 
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("ПустаяДата", Дата('00010101000000'));
	
	РЗ = Запрос.Выполнить().Выгрузить();
	
	Если РЗ.Количество() > 0 Тогда
		
		Для КАЖДОГО текЗап ИЗ РЗ Цикл
			
			СтруктураЗаписи = Новый Структура;
			СтруктураЗаписи.Вставить("Получатель",текЗап.Получатель);
			СтруктураЗаписи.Вставить("Тема",текЗап.Тема);
			СтруктураЗаписи.Вставить("Автор",текЗап.Автор);
			СтруктураЗаписи.Вставить("ТипСообщения",текЗап.ТипСообщения);
			СтруктураЗаписи.Вставить("Категория",текЗап.Категория);
			СтруктураЗаписи.Вставить("ЗапланированнаяДатаДоставки",текЗап.ЗапланированнаяДатаДоставки);
			СтруктураЗаписи.Вставить("УникИдент",текЗап.УникИдент);
			
			КлючЗаписи = РегистрыСведений.Сооб_Сообщения.СоздатьКлючЗаписи(СтруктураЗаписи);
			
			СтруктураКлюча = Новый Структура;
			СтруктураКлюча.Вставить("Ключ",КлючЗаписи);
			СтруктураКлюча.Вставить("Реквизиты",СтруктураЗаписи);
			
			Массив.Добавить(СтруктураКлюча);
			
		КонецЦикла;
		
		Возврат Массив;
		
	Иначе
		
		Возврат НЕОПРЕДЕЛЕНО;
		
	КонецЕсли;
	
КонецФункции

