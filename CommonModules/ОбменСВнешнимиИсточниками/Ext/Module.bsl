#Область DHL

Процедура ПроверкаТрековДХЛ()
	
	ТекстДХЛ = "";
	СтатусДоставлено = "delivered";
	//Токен = "7633822212:AAGpRpvXlxB1OvzbDRTNBt1tOT5RvARUZK4"; 
	Токен = Константы.ТокенЧатаТреков.Получить();
	//ИдЧата = "-1002280760609";
	ИдЧата = Константы.ИдЧатаТреков.Получить();
	
	// 1. запишем в РС актуальные треки   
	
	запр = Новый Запрос;    
	запр.УстановитьПараметр("Дата", ДобавитьМесяц(ТекущаяДатаСеанса(), -1)); 
	запр.УстановитьПараметр("Перевозчик", Перечисления.Перевозчики.DHL); 
	запр.Текст = "ВЫБРАТЬ различные
	             |	ИнвойсЗакупкиТреки.Трек КАК Трек,
	             |	ИнвойсЗакупкиТреки.Дата КАК Дата
	             |ПОМЕСТИТЬ тз
	             |ИЗ
	             |	Документ.ИнвойсЗакупки.Треки КАК ИнвойсЗакупкиТреки
	             |ГДЕ
	             |	НЕ ИнвойсЗакупкиТреки.Ссылка.ПометкаУдаления
	             |	И ИнвойсЗакупкиТреки.Ссылка.Дата > &Дата
	             |	И ИнвойсЗакупкиТреки.Ссылка.Перевозчик = &Перевозчик
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тз.Трек КАК Трек,
	             |	тз.Дата КАК Дата,
	             |	РСТреки.Трек КАК ТрекРС
	             |ИЗ
	             |	тз КАК тз
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			РСТреки.Трек КАК Трек
	             |		ИЗ
	             |			РегистрСведений.Треки КАК РСТреки
	             |		ГДЕ
	             |			РСТреки.Перевозчик = &Перевозчик) КАК РСТреки
	             |		ПО тз.Трек = РСТреки.Трек
	             |ГДЕ
	             |	РСТреки.Трек ЕСТЬ NULL";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.Треки.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Перевозчик.Установить(Перечисления.Перевозчики.DHL); 
		НаборЗаписей.Отбор.Трек.Установить(Выборка.Трек); 
		НоваяЗапись = НаборЗаписей.Добавить(); 
		НоваяЗапись.Перевозчик 				= Перечисления.Перевозчики.DHL;   
		НоваяЗапись.Трек 					= Выборка.Трек;  
		НоваяЗапись.Статус 					= "";  
		НоваяЗапись.ОтправленоУведомление 	= Ложь;     
		НоваяЗапись.Ответ					= "";
		НаборЗаписей.Записать(); 
		Сообщить("найдено в инвойсах " + Выборка.Трек);
	КонецЦикла;
	
	// 2. Запишем ответы сервера ДХЛ (по всем недоставленным трекам) в РС
	
	Запр = Новый Запрос;
	запр.УстановитьПараметр("Перевозчик", Перечисления.Перевозчики.DHL); 
	запр.УстановитьПараметр("Статус", СтатусДоставлено); 
	Запр.Текст = "ВЫБРАТЬ
	             |	Треки.Трек КАК Трек
	             |ИЗ
	             |	РегистрСведений.Треки КАК Треки
	             |ГДЕ
	             |	Треки.Перевозчик = &Перевозчик
	             |	И Треки.Статус <> &Статус";       
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	
		Ответ = ОтветДХЛ(Выборка.Трек);	
		Если Ответ.Отказ Тогда                                                                                  
			тлгДействия.ОтправитьТекстовоеСообщение(Токен, ИДЧата, стрШаблон("Ошибка %1: трек %2 (%3)", Ответ.Код, Выборка.Трек, Ответ.СообщениеПользователю));
			Продолжить;
		КонецЕсли;

		НаборЗаписей = РегистрыСведений.Треки.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Перевозчик.Установить(Перечисления.Перевозчики.DHL); 
		НаборЗаписей.Отбор.Трек.Установить(Выборка.Трек); 
		НоваяЗапись = НаборЗаписей.Добавить(); 
		НоваяЗапись.Перевозчик 				= Перечисления.Перевозчики.DHL;   
		НоваяЗапись.Трек 					= Выборка.Трек;  
		НоваяЗапись.Статус 					= Ответ.Статус;  
		НоваяЗапись.ОтправленоУведомление 	= Ложь;     
		НоваяЗапись.Ответ 					= Ответ.СообщениеПользователю;
		НаборЗаписей.Записать(); 
		Сообщить("записан ответ трека " + Выборка.Трек);
		
		Пауза(3);
		
	КонецЦикла;
	
	// 3.  отправим сообщениx в тлг
	
	Запр = Новый Запрос;
	запр.УстановитьПараметр("Перевозчик", Перечисления.Перевозчики.DHL); 
	запр.УстановитьПараметр("Статус", СтатусДоставлено); 
	Запр.Текст = "ВЫБРАТЬ
	             |	Треки.Трек КАК Трек,
	             |	Треки.Статус КАК Статус,
	             |	ВЫРАЗИТЬ(Треки.Ответ КАК СТРОКА(500)) КАК Ответ
	             |ИЗ
	             |	РегистрСведений.Треки КАК Треки
	             |ГДЕ
	             |	Треки.Перевозчик = &Перевозчик
	             |	И НЕ Треки.ОтправленоУведомление";  
	РезультатЗапроса = Запр.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		тлгДействия.ОтправитьТекстовоеСообщение(Токен, ИДЧата, "Проверка статусов *DHL*: в 1С нет отслеживаемых треков DHL"); 
		
	Иначе
		
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ТекстДХЛ = ТекстДХЛ + СтрШаблон("*Track* %1: status '%2' %3", Выборка.трек, ВРег(Выборка.Статус), Выборка.Ответ) + Символы.ПС + Символы.ПС;  
			
			НаборЗаписей = РегистрыСведений.Треки.СоздатьНаборЗаписей(); 
			НаборЗаписей.Отбор.Перевозчик.Установить(Перечисления.Перевозчики.DHL); 
			НаборЗаписей.Отбор.Трек.Установить(Выборка.Трек); 
			НоваяЗапись = НаборЗаписей.Добавить(); 
			НоваяЗапись.Перевозчик 				= Перечисления.Перевозчики.DHL;   
			НоваяЗапись.Трек 					= Выборка.Трек;  
			НоваяЗапись.Статус 					= Выборка.Статус;  
			НоваяЗапись.ОтправленоУведомление 	= Истина;     
			НоваяЗапись.Ответ 					= Выборка.Ответ;
			НаборЗаписей.Записать();
			
		КонецЦикла;
		
		тлгДействия.ОтправитьКартинку(Токен, ИдЧата, "Проверка статусов *DHL*", БиблиотекаКартинок.dhl_logo.ПолучитьДвоичныеДанные(), );
		тлгДействия.ОтправитьТекстовоеСообщение(Токен, ИДЧата, ТекстДХЛ); 
		
	КонецЕсли;

КонецПроцедуры

Функция ОтветДХЛ(НомерТрека)

	ИмяСервера 	= "api-eu.dhl.com";

	Заголовки = Новый Соответствие;    
    Заголовки.Вставить("Accept", 		"application/json");
    //Заголовки.Вставить("DHL-API-Key", 	"JaowVB7MmnZ8xCyLBTQAr6YnB5Aqi2rX");
    Заголовки.Вставить("DHL-API-Key", 	Константы.ТокенДХЛ.Получить());

	Запрос = Новый HTTPЗапрос();
	Запрос.АдресРесурса = "/track/shipments?trackingNumber=" + СокрЛП(НомерТрека);
	Запрос.Заголовки = Заголовки;
	
	Соединение = Новый HTTPСоединение(ИмяСервера,,,,,,Новый ЗащищенноеСоединениеOpenSSL()); 
	Ответ = Соединение.Получить(Запрос);
	КодСостояния = Ответ.КодСостояния;  
	Сообщить(НомерТрека + " КодСостояния: " + КодСостояния);
	Если КодСостояния = 200 Тогда
		
		СтрокаОтвета = Ответ.ПолучитьТелоКакСтроку();	
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(СтрокаОтвета);
		
		СтруктураОтвет = Неопределено;
		РазобратьJSONРекурсия(ЧтениеJSON, СтруктураОтвет);  
		СтруктураОтвет = СтруктураОтвет.shipments[0];
		СтруктураСтатус = СтруктураОтвет.status;
		КодСтатуса 		= СтруктураОтвет.status.status;
		//ОжидаемаяДата   = СтруктураОтвет.shipments[0].estimatedTimeOfDelivery;
		//ОжидаемоеВремя  = СтруктураОтвет.shipments[0].estimatedTimeOfDeliveryRemark;
		//
		//Статус 			= СтруктураСтатус.description;
		//ДатаВремя 		= СтруктураСтатус.timestamp;
		//АдресДоставки 	= СтруктураСтатус.location.addressLocality;
		
		Если КодСтатуса = "101" Тогда	
			Статус = "delivered";
			СообщениеПользователю = "";
		ИначеЕсли КодСтатуса = "102" Тогда	
			Статус = НРег(СтруктураСтатус.description);
			Если Статус = "delivered" Тогда
				СообщениеПользователю = "прибыл " + СтруктураСтатус.timestamp;
			Иначе
				Если СтруктураОтвет.Свойство("estimatedTimeOfDelivery") Тогда
					ОжидаемаяДата   = СтруктураОтвет.estimatedTimeOfDelivery;
					ОжидаемоеВремя  = СтруктураОтвет.estimatedTimeOfDeliveryRemark;
					СообщениеПользователю = СтрШаблон("ожидаемое прибытие %1 %2", ОжидаемаяДата, ОжидаемоеВремя);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли КодСтатуса = "103" Тогда	
			Статус = "failure";
			Опис = СтруктураСтатус.description; 
			Прим = СтруктураСтатус.remark;
			СледШаг = СтруктураСтатус.nextSteps;
			СообщениеПользователю = СтрШаблон("%1. %2", Опис, Прим);
		ИначеЕсли КодСтатуса = "104" Тогда	
			СообщениеПользователю = "";
			Статус = "pre-transit";
		Иначе     
			Статус = "<неизвестен>";
			СообщениеПользователю = "";
		КонецЕсли;
		
		Возврат Новый Структура("Статус,СообщениеПользователю,Код,Отказ", Статус, СообщениеПользователю, КодСостояния, Ложь);
		
	ИначеЕсли КодСостояния = 404 тогда
		
		Возврат Новый Структура("Статус,СообщениеПользователю,Код,Отказ", "unknown", "Сервер не отвечает", КодСостояния, Истина);
		
	ИначеЕсли КодСостояния = 429 тогда
		
		Возврат Новый Структура("Статус,СообщениеПользователю,Код,Отказ", "too much requests", "Слишком много запросов", КодСостояния, Истина);

	ИначеЕсли КодСостояния = 500 тогда
		
		Возврат Новый Структура("Статус,СообщениеПользователю,Код,Отказ", "unknown", "Сервер не отвечает", КодСостояния, Истина);

	Иначе
		
		Возврат Новый Структура("Статус,СообщениеПользователю,Код,Отказ", "error", "Ошибка сервера", КодСостояния, Истина);
		
	КонецЕсли;
	
КонецФункции 

#КонецОбласти


#Область Fedex

Процедура ПроверкаТрековФедекс() Экспорт
	
	Перем ТрекНомер;
	
	
    // 1. Параметры подключения
    ИмяСервера = "apis.fedex.com"; // Для теста используйте apis-sandbox.fedex.com
    APIKey     = "ВАШ_API_KEY";
    SecretKey  = "ВАШ_SECRET_KEY";
    AccountNum = "ВАШ_ACCOUNT_NUMBER";

    // 2. Получение Токена (OAuth2)
    Токен = ПолучитьТокенFedex(ИмяСервера, APIKey, SecretKey);
    Если Токен = Неопределено Тогда
        Возврат;
    КонецЕсли;

    // 3. Формирование тела запроса для отслеживания
    СтруктураЗапроса = Новый Структура;
    СтруктураЗапроса.Вставить("includeDetailedScans", Истина);
    
    МассивТреков = Новый Массив;
    МассивТреков.Добавить(Новый Структура("trackingNumber", ТрекНомер));
    
    ИнформацияОбОтслеживании = Новый Структура;
    ИнформацияОбОтслеживании.Вставить("trackingInfo", МассивТреков);
    
    СтруктураЗапроса.Вставить("trackingInfoList", ИнформацияОбОтслеживании);

    // Сериализация в JSON
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, СтруктураЗапроса);
    СтрокаJSON = ЗаписьJSON.Закрыть();

    // 4. Выполнение HTTP-запроса
    HTTPСоединение = Новый HTTPСоединение(ИмяСервера, 443, , , , , Новый ЗащищенноеСоединениеOpenSSL());
    
    Запрос = Новый HTTPЗапрос("/track/v1/trackingnumbers");
    Запрос.Заголовки.Вставить("Content-Type", "application/json");
    Запрос.Заголовки.Вставить("Authorization", "Bearer " + Токен);
    Запрос.УстановитьТелоИзСтроки(СтрокаJSON);

    Попытка
        Ответ = HTTPСоединение.ОтправитьДляОбработки(Запрос);
        Если Ответ.КодСостояния = 200 Тогда
            ЧтениеJSON = Новый ЧтениеJSON;
            ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
            Результат = ПрочитатьJSON(ЧтениеJSON);
            ЧтениеJSON.Закрыть();
            
            // Здесь обрабатываем результат (например, выводим статус)
            Сообщить("Статус посылки: " + Результат.output.completeTrackResults[0].trackResults[0].latestStatusDetail.description);
        Иначе
            Сообщить("Ошибка запроса: " + Ответ.КодСостояния + " " + Ответ.ПолучитьТелоКакСтроку());
        КонецЕсли;
    Исключение
        Сообщить("Ошибка связи: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

Функция ПолучитьТокенFedex(ИмяСервера, APIKey, SecretKey)
	
	HTTPСоединение = Новый HTTPСоединение(ИмяСервера, 443, , , , , Новый ЗащищенноеСоединениеOpenSSL());
    Запрос = Новый HTTPЗапрос("/oauth/token");
    Запрос.Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
    
    ТелоЗапроса = "grant_type=client_credentials&client_id=" + APIKey + "&client_secret=" + SecretKey;
    Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
    
    Ответ = HTTPСоединение.ОтправитьДляОбработки(Запрос);
    Если Ответ.КодСостояния = 200 Тогда
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
        Данные = ПрочитатьJSON(ЧтениеJSON);
        Возврат Данные.access_token;
    Иначе
        Сообщить("Ошибка авторизации!");
        Возврат Неопределено;
	КонецЕсли; 
	
КонецФункции

