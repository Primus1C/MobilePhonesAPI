// Безопасно удаляет свойства из СтруктурыЗначений по их именам
// 
// Параметры:
//  СтруктураДанных - Структура
//  ИменаПолей - Строка - имена, разделенные запятой
//
Процедура УдалитьСвойства(СтруктураДанных, ИменаПолей) Экспорт
	
	Если ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;  
	
	массивИмен = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИменаПолей, ",", Истина);	
    Для каждого Имя Из массивИмен Цикл
		Если СтруктураДанных.Свойство(Имя) Тогда
			СтруктураДанных.Удалить(Имя);
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры 

