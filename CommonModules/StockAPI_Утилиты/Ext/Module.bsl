// Возвращает криптографически стойкий хеш SHA-256 (строка 64 символа в нижнем регистре)   
//
Функция СгенерироватьТокенSHA256() Экспорт
	
	// 1. Формируем уникальную исходную строку (соль)
	// Комбинация GUID и времени до миллисекунд исключает совпадения даже теоретически
	УникальнаяСтрока = Строка(Новый УникальныйИдентификатор) 
	                 + Строка(ТекущаяУниверсальнаяДатаВМиллисекундах());
	
	// 2. Инициализируем объект хеширования алгоритмом SHA-256
	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	
	// 3. Вычисляем хеш для нашей строки
	Хеширование.Добавить(УникальнаяСтрока);
	
	// 4. Получаем результат в виде двоичных данных
	ДвоичныеДанныеХеша = Хеширование.ХешСумма;
	
	// 5. Конвертируем в шестнадцатеричную строку (Hex)
	СтрокаHex = НРег(ПолучитьHexСтрокуИзДвоичныхДанных(ДвоичныеДанныеХеша));
	
	Возврат СтрокаHex;
	
КонецФункции

Функция ПроверитьКлючAPI(ЗапросАПИ, КонтекстАвторизации) Экспорт
	
	// Ожидаем, что клиент присылает ключ в заголовке X-Api-Key
	КлючКлиента = ЗапросАПИ.Заголовки.Получить("X-Api-Key");

	Если Не ЗначениеЗаполнено(КлючКлиента) Тогда
		КонтекстАвторизации.Вставить("Ошибка", "Отсутствует заголовок ключа.");
		Возврат Ложь;
	КонецЕсли;
	
	ЗапросБД = Новый Запрос;
	ЗапросБД.Текст = "ВЫБРАТЬ
	                 |	УчЗаписи.Ссылка КАК УчетнаяЗапись,
	                 |	УчЗаписи.Активен КАК Активен,
	                 |	УчЗаписи.Администратор КАК Администратор
	                 |ИЗ
	                 |	Справочник.УчетныеЗаписиИнтеграции КАК УчЗаписи
	                 |ГДЕ
	                 |	УчЗаписи.ТокенАвторизации = &КлючAPI";
		
	ЗапросБД.УстановитьПараметр("КлючAPI", КлючКлиента);
	Выборка = ЗапросБД.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Если Выборка.Активен Тогда
			КонтекстАвторизации.Вставить("УчетнаяЗапись", Выборка.УчетнаяЗапись);
			КонтекстАвторизации.Вставить("Администратор", Выборка.Администратор = Истина);
			Возврат Истина; 
		Иначе
			КонтекстАвторизации.Вставить("Ошибка", "Учетная запись отключена.");
			Возврат Ложь;
		КонецЕсли;
	Иначе 
		КонтекстАвторизации.Вставить("Ошибка", "Ошибка авторизации: неверный логин или пароль.");
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Признак «Администратор» учётной записи API.
//
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиИнтеграции - учётная запись из авторизации.
//
// Возвращаемое значение:
//  Булево - Истина, если у записи включён реквизит Администратор.
//
Функция ЭтоАдминистраторAPI(УчетнаяЗапись) Экспорт
	
	Если НЕ ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат УчетнаяЗапись.Администратор = Истина;
	
КонецФункции

// Число активных (не помеченных на удаление) учётных записей интеграции.
//
Функция КоличествоАктивныхУчетныхЗаписейИнтеграции() Экспорт
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	КОЛИЧЕСТВО(УЗ.Ссылка) КАК Количество
	             |ИЗ
	             |	Справочник.УчетныеЗаписиИнтеграции КАК УЗ
	             |ГДЕ
	             |	УЗ.Активен
	             |	И НЕ УЗ.ПометкаУдаления";
	Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Количество;
	КонецЕсли;
	Возврат 0;
	
КонецФункции

// Склады, входящие в ТЧ «Склады» всех активных учётных записей (пересечение).
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.Склады.
//
Функция СкладыОбщиеДляВсехУчетныхЗаписейAPI() Экспорт
	
	КоличествоУЗ = КоличествоАктивныхУчетныхЗаписейИнтеграции();
	Если КоличествоУЗ = 0 Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("КоличествоУЗ", КоличествоУЗ);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	СкладыУЗ.Склад КАК Склад
	             |ИЗ
	             |	Справочник.УчетныеЗаписиИнтеграции.Склады КАК СкладыУЗ
	             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиИнтеграции КАК УЗ
	             |		ПО СкладыУЗ.Ссылка = УЗ.Ссылка
	             |ГДЕ
	             |	УЗ.Активен
	             |	И НЕ УЗ.ПометкаУдаления
	             |	И НЕ СкладыУЗ.Склад.ПометкаУдаления
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	СкладыУЗ.Склад
	             |
	             |ИМЕЮЩИЕ
	             |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СкладыУЗ.Ссылка) = &КоличествоУЗ";
	
	Возврат Запр.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	
КонецФункции

// Контрагенты, входящие в группу контрагентов каждой активной учётной записи (пересечение иерархий).
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.Контрагенты.
//
Функция КонтрагентыОбщиеДляВсехУчетныхЗаписейAPI() Экспорт
	
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		                   |	Контрагенты.Ссылка КАК Ссылка
		                   |ИЗ
		                   |	Справочник.Контрагенты КАК Контрагенты
		                   |ГДЕ
		                   |	НЕ Контрагенты.ЭтоГруппа
		                   |	И НЕ Контрагенты.ПометкаУдаления
		                   |	И Контрагенты.Ссылка В ИЕРАРХИИ
		                   |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		                   |				УЗ.ГруппаКонтрагентов КАК Группа
		                   |			ИЗ
		                   |				Справочник.УчетныеЗаписиИнтеграции КАК УЗ
		                   |			ГДЕ
		                   |				УЗ.Активен
		                   |				И НЕ УЗ.ПометкаУдаления
		                   |				И УЗ.ГруппаКонтрагентов <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка))";
	РезультатЗапроса = Запр.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Массив;	
	Иначе
	    Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0);
	КонецЕсли;
	
КонецФункции

// Сотрудники, доступные каждой активной учётной записи (есть общий склад с ТЧ каждой записи).
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.Сотрудники.
//
Функция СотрудникиОбщиеДляВсехУчетныхЗаписейAPI() Экспорт
	
	КоличествоУЗ = КоличествоАктивныхУчетныхЗаписейИнтеграции();
	Если КоличествоУЗ = 0 Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("КоличествоУЗ", КоличествоУЗ);
	Запр.УстановитьПараметр("ПустаяДата", Дата(1, 1, 1));
	Запр.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Запр.Текст = "ВЫБРАТЬ
	             |	СотрудникиСклады.Ссылка КАК Сотрудник
	             |ИЗ
	             |	Справочник.Сотрудники.Склады КАК СотрудникиСклады
	             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	             |		ПО СотрудникиСклады.Ссылка = Сотрудники.Ссылка
	             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиИнтеграции.Склады КАК СкладыУЗ
	             |		ПО СотрудникиСклады.Склад = СкладыУЗ.Склад
	             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиИнтеграции КАК УЗ
	             |		ПО (СкладыУЗ.Ссылка = УЗ.Ссылка)
	             |ГДЕ
	             |	УЗ.Активен
	             |	И НЕ УЗ.ПометкаУдаления
	             |	И НЕ Сотрудники.ЭтоГруппа
	             |	И НЕ Сотрудники.ПометкаУдаления
	             |	И (Сотрудники.ДатаУвольнения = &ПустаяДата
	             |			ИЛИ Сотрудники.ДатаУвольнения >= &ТекущаяДата)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	СотрудникиСклады.Ссылка
	             |
	             |ИМЕЮЩИЕ
	             |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СкладыУЗ.Ссылка) = &КоличествоУЗ";
	
	Возврат Запр.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");
	
КонецФункции

