// Общие утилиты StockAPI: разбор параметров запроса, пагинация, форматирование ошибок.

// Возвращает строковое значение параметра HTTP-запроса из URL (query string).
// Если передано несколько имён через запятую — перебирает их слева направо
// и возвращает значение первого найденного (алиасы для совместимости API).
//
// Параметры:
//  Запрос        - HTTPСервисЗапрос - входящий запрос StockAPI;
//  ИмяПараметра  - Строка - имя параметра URL или список имён через запятую,
//                   например "orderNumber" или "orderNumber,orderNo,order".
//
// Возвращаемое значение:
//  Строка - значение параметра без крайних пробелов;
//           пустая строка, если параметр отсутствует или не задан ни один из алиасов.
//
Функция СтрокаПараметраЗапроса(Запрос, ИмяПараметра) Экспорт
	
	Разделитель = ",";  
	
	Если СтрНайти(ИмяПараметра, Разделитель) = 0 Тогда
		
		Значение = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
		Если Значение = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		Возврат СокрЛП(Строка(Значение));
		
	Иначе  
		
		мас = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИмяПараметра, Разделитель, Истина);
		Для каждого Параметр Из мас Цикл
			Значение = Запрос.ПараметрыЗапроса.Получить(Параметр);
			Если Значение <> Неопределено Тогда
				Возврат СокрЛП(Строка(Значение));
			КонецЕсли;
		КонецЦикла;
		Возврат "";
		
	КонецЕсли;
	
КонецФункции

// Возвращает значение параметра из тела запроса (Structure/Соответствие) или Неопределено, если не передан.
//
// Параметры:
//  ДанныеЗапроса - Структура, Соответствие, Неопределено - данные HTTP-запроса;
//  ИмяПараметра  - Строка - имя параметра.
//
// Возвращаемое значение:
//  Произвольный, Неопределено - значение параметра; Неопределено, если параметр отсутствует.
//
Функция ЗначениеПараметраДанныхЗапроса(ДанныеЗапроса, ИмяПараметра) Экспорт
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипДанных = ТипЗнч(ДанныеЗапроса);
	Если ТипДанных = Тип("Структура") Или ТипДанных = Тип("ФиксированнаяСтруктура") Тогда
		Значение = Неопределено;
		Если ДанныеЗапроса.Свойство(ИмяПараметра, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	ИначеЕсли ТипДанных = Тип("Соответствие") Тогда
		Для Каждого КлючИЗначение Из ДанныеЗапроса Цикл
			Если КлючИЗначение.Ключ = ИмяПараметра Тогда
				Возврат КлючИЗначение.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Возвращает булево значение параметра запроса или Неопределено, если параметр не передан.
//
// Параметры:
//  ДанныеЗапроса - Структура, Соответствие, Неопределено - данные HTTP-запроса;
//  ИмяПараметра  - Строка - имя параметра (blocked, canceled, readyToShip и т.п.).
//
// Возвращаемое значение:
//  Булево, Неопределено - значение параметра; Неопределено, если параметр отсутствует.
//
Функция БулевоПараметраЗапроса(ДанныеЗапроса, ИмяПараметра) Экспорт
	
	Значение = ЗначениеПараметраДанныхЗапроса(ДанныеЗапроса, ИмяПараметра);
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Булево") Тогда
		Возврат Значение;
	КонецЕсли;
	
	СтрокаЗнач = НРег(СокрЛП(Строка(Значение)));
	Если СтрокаЗнач = "true"
		Или СтрокаЗнач = "1"
		Или СтрокаЗнач = "yes" Тогда
		Возврат Истина;
	ИначеЕсли СтрокаЗнач = "false"
		Или СтрокаЗнач = "0"
		Или СтрокаЗнач = "no" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Значение = Истина;
	
КонецФункции

// Дополняет структуру тела запроса параметрами URL (тело имеет приоритет).
//
Процедура ДополнитьДанныеЗапросаПараметрамиURL(ДанныеЗапроса, Запрос, ИменаПараметров) Экспорт
	
	Если ДанныеЗапроса = Неопределено Тогда
		ДанныеЗапроса = Новый Структура;
	КонецЕсли;
	
	Имена = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИменаПараметров, ",", Истина);
	Для Каждого ИмяПараметра Из Имена Цикл
		Если ЗначениеПараметраДанныхЗапроса(ДанныеЗапроса, ИмяПараметра) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗначениеПараметра = СтрокаПараметраЗапроса(Запрос, ИмяПараметра);
		Если ЗначениеПараметра <> "" Тогда
			ДанныеЗапроса.Вставить(ИмяПараметра, ЗначениеПараметра);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция СвойствоДанныхЗапроса(ДанныеЗапроса, ИмяСвойства, ЗначениеКогдаНеНайдено = "") Экспорт
	
	Разделитель = ",";  
	
	Если СтрНайти(ИмяСвойства, Разделитель) = 0 Тогда
		
		Если ДанныеЗапроса.Свойство(ИмяСвойства) Тогда
		    Возврат ДанныеЗапроса[ИмяСвойства]; 
		Иначе
			Возврат ЗначениеКогдаНеНайдено;
		КонецЕсли;
		
	Иначе  
		
		мас = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИмяСвойства, Разделитель, Истина);
		Для каждого Имя Из мас Цикл
			Если ДанныеЗапроса.Свойство(Имя) Тогда
				Возврат ДанныеЗапроса[Имя];
			КонецЕсли;
		КонецЦикла;
		Возврат ЗначениеКогдаНеНайдено;
		
	КонецЕсли;
	
КонецФункции

Функция ДатаПараметраЗапроса(Запрос, ИмяПараметра) Экспорт
	
	Разделитель = ",";  

	Если СтрНайти(ИмяПараметра, Разделитель) = 0 Тогда 
		
		СтрокаДаты = СтрокаПараметраЗапроса(Запрос, ИмяПараметра);
		Возврат СтрокаВДату(СтрокаДаты);
		
	Иначе
		
		мас = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИмяПараметра, Разделитель ,Истина);
		Для каждого Параметр Из мас Цикл
			СтрокаДаты = Запрос.ПараметрыЗапроса.Получить(Параметр);
			Если СтрокаДаты <> Неопределено Тогда
				Возврат СтрокаВДату(СтрокаДаты);
			КонецЕсли;
		КонецЦикла;
		Возврат "";

	КонецЕсли;
	
КонецФункции

Функция ЦелоеПараметраЗапроса(СтрокаЗначения, ЗначениеПоУмолчанию) Экспорт
	
	Если СтрокаЗначения = Неопределено Или СокрЛП(СтрокаЗначения) = "" Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Попытка
		ЧислоЗначения = Число(СтрокаЗначения);
	Исключение
		Возврат -1;
	КонецПопытки;
	
	Если ЧислоЗначения <> Цел(ЧислоЗначения) Тогда
		Возврат -1;
	КонецЕсли;
	
	Возврат Цел(ЧислоЗначения);
	
КонецФункции

Функция ВсегоСтраницПагинации(ВсегоЭлементов, РазмерСтраницы) Экспорт
	
	Если ВсегоЭлементов = 0 Или РазмерСтраницы <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Цел((ВсегоЭлементов - 1) / РазмерСтраницы) + 1;
	
КонецФункции

// Разбор параметров пагинации: page (с 1), pageSize/limit (макс. 500). 
//
Функция ПараметрыПагинацииОстатков(Запрос) Экспорт
	
	МаксРазмерСтраницы = 500;
	РазмерПоУмолчанию = 500;
	Результат = Новый Структура("page, pageSize, Ошибка", 1, РазмерПоУмолчанию, "");
	
	СтрокаСтраницы = Запрос.ПараметрыЗапроса.Получить("page");
	СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("pageSize");
	Если СтрокаРазмера = Неопределено Или СокрЛП(СтрокаРазмера) = "" Тогда
		СтрокаРазмера = Запрос.ПараметрыЗапроса.Получить("limit");
	КонецЕсли;
	
	НомерСтраницы = ЦелоеПараметраЗапроса(СтрокаСтраницы, 1);
	Если НомерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр page должен быть целым числом >= 1.";
		Возврат Результат;
	КонецЕсли;
	Если НомерСтраницы = 0 Тогда
		НомерСтраницы = 1;
	КонецЕсли;
	
	РазмерСтраницы = ЦелоеПараметраЗапроса(СтрокаРазмера, РазмерПоУмолчанию);
	Если РазмерСтраницы < 0 Тогда
		Результат.Ошибка = "Параметр pageSize (или limit) должен быть целым числом от 1 до 500.";
		Возврат Результат;
	КонецЕсли;
	Если РазмерСтраницы = 0 Тогда
		РазмерСтраницы = РазмерПоУмолчанию;
	КонецЕсли;
	Если РазмерСтраницы > МаксРазмерСтраницы Тогда
		Результат.Ошибка = СтрШаблон("pageSize не может превышать %1.", МаксРазмерСтраницы);
		Возврат Результат;
	КонецЕсли;
	
	Результат.page = НомерСтраницы;
	Результат.pageSize = РазмерСтраницы;
	Возврат Результат;
	
КонецФункции

// Собирает все строки из СписокЗначений или Массива в одну строку с переносами.
//
Функция ТекстОшибокСписка(Ошибки) Экспорт
	
	Текст = "";
	Для Каждого Ошибка Из Ошибки Цикл
		Если ТипЗнч(Ошибка) = тип("Строка") Тогда
			Текст = Текст + Ошибка + Символы.ПС;
		Иначе
			Текст = Текст + Ошибка.Значение + Символы.ПС;
		КонецЕсли;
	КонецЦикла;
	Возврат СокрЛП(Текст);
	
КонецФункции

// serials=with|without. ПоУмолчаниюССериями — если параметр не передан.       
//
Функция ПараметрSerialsЗапроса(Запрос, ПоУмолчаниюССериями = Истина) Экспорт
	
	Результат = Новый Структура("ССериями, Ошибка", ПоУмолчаниюССериями, "");
	СтрокаПараметра = НРег(СтрокаПараметраЗапроса(Запрос, "serials"));
	Если СтрокаПараметра = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокаПараметра = "with"
		Или СтрокаПараметра = "true"
		Или СтрокаПараметра = "1"
		Или СтрокаПараметра = "yes" Тогда
		Результат.ССериями = Истина;
	ИначеЕсли СтрокаПараметра = "without"
		Или СтрокаПараметра = "false"
		Или СтрокаПараметра = "0"
		Или СтрокаПараметра = "no" Тогда
		Результат.ССериями = Ложь;
	Иначе
		Результат.Ошибка = "Неподдерживаемый serials. Допустимые значения: with, without (или true, false).";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции


