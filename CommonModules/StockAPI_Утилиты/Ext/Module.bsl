// Преобразует строку формата yyyy-MM-dd (допускается суффикс времени yyyy-MM-ddTHH:mm:ss) в дату.
// Пустая или некорректная строка — Неопределено. 
//
Функция СтрокаВДату(СтрокаДаты) Экспорт
	
	СтрокаДаты = СокрЛП(СтрокаДаты);
	Если СтрокаДаты = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если СтрДлина(СтрокаДаты) >= 10 Тогда
		СтрокаДаты = Лев(СтрокаДаты, 10);
	КонецЕсли;
	
	Части = СтрРазделить(СтрокаДаты, "-", Ложь);
	Если Части.Количество() <> 3 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

//
//
Процедура ЗаписатьВПротокол(Запрос, Ответ, ПользовательИнтеграции, ДлительностьМс, ТекстОшибкиВнутр = "", ТелоЗапроса = Неопределено, ТелоОтвета = Неопределено) Экспорт
	
	Попытка
		МЗ = РегистрыСведений.ПротоколОбменов.СоздатьМенеджерЗаписи();
		
		// Измерения и базовые реквизиты
		МЗ.ИдентификаторЗапроса = Новый УникальныйИдентификатор;
		МЗ.Дата 			= ТекущаяДатаСеанса();
		МЗ.ИмяСервиса 		= "StockAPI";
		
		//МЗ.ШаблонURL = Запрос.ШаблонURL;  
		Попытка
			МЗ.ШаблонURL 	= Лев(Запрос.ОтносительныйURL, 50);
		Исключение
			МЗ.ШаблонURL 	= "";
		КонецПопытки;

		Попытка
			// Запись перечисления (GET, POST и т.д.)
			МЗ.HTTPМетод 	= Перечисления.HTTPМетод[Запрос.HTTPМетод];
		Исключение
		КонецПопытки;
		
		МЗ.КодСостояния 	= Ответ.КодСостояния;
		МЗ.Длительность 	= ДлительностьМс;
		МЗ.Пользователь 	= ПользовательИнтеграции;
		МЗ.ТекстОшибки 		= Лев(ТекстОшибкиВнутр, 200);
		
		// Определение IP адреса
		IP = Запрос.Заголовки.Получить("X-Forwarded-For");
		Если IP = Неопределено Тогда
			IP = Запрос.Заголовки.Получить("Remote-Addr");
		КонецЕсли;
		МЗ.IPАдрес 			= ?(IP = Неопределено, "", Лев(IP, 50));
		
		// Запись ресурсов (ХранилищеЗначения)
		МЗ.ЗаголовкиЗапроса = Новый ХранилищеЗначения(СтруктураВJSON(Запрос.Заголовки), Новый СжатиеДанных(9));
		МЗ.ТелоЗапроса 		= Новый ХранилищеЗначения(ТелоHTTPЗапросаДляПротокола(Запрос, ТелоЗапроса), Новый СжатиеДанных(9));
		МЗ.ТелоОтвета 		= Новый ХранилищеЗначения(ТелоHTTPОтветаДляПротокола(Ответ, ТелоОтвета), Новый СжатиеДанных(9));
		
		МЗ.Записать();
	Исключение
		// Ошибка записи лога не должна ронять сам API
		ЗаписьЖурналаРегистрации("StockAPI.Протоколирование", УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

//
//
Функция ТелоHTTPЗапросаДляПротокола(Запрос, ТелоЗапроса = Неопределено)
	
	Если ТипЗнч(ТелоЗапроса) = Тип("Строка") Тогда
		Возврат ТелоЗапроса;
	КонецЕсли;
	
	Попытка
		Возврат Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	Исключение
		Попытка
			Возврат Запрос.ПолучитьТелоКакСтроку();
		Исключение
			Возврат "";
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

//
//
Функция ТелоHTTPОтветаДляПротокола(Ответ, ТелоОтвета = Неопределено)
	
	Если ТипЗнч(ТелоОтвета) = Тип("Строка") Тогда
		Возврат ТелоОтвета;
	КонецЕсли;
	
	Попытка
		Возврат Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	Исключение
		Попытка
			Возврат Ответ.ПолучитьТелоКакСтроку();
		Исключение
		КонецПопытки;
	КонецПопытки;
	
	Попытка
		ДвоичныеДанные = Ответ.ПолучитьТелоКакДвоичныеДанные();
		Если ДвоичныеДанные = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		
		Размер = ДвоичныеДанные.Размер();
		Если Размер = 0 Тогда
			Возврат "";
		КонецЕсли;
		
		ContentType = Ответ.Заголовки.Получить("Content-Type");
		Если ContentType = Неопределено Тогда
			ContentType = "";
		КонецЕсли;
		
		Возврат СтрШаблон("<binary body, %1 bytes, Content-Type: %2>", Размер, ContentType);
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции


#Область ВебХуки  

Процедура ОтправкаWebHook() Экспорт
	
	Попытка
		ОтправитьОчередьWebHook();
	Исключение
		ЗаписьЖурналаРегистрации("StockAPI.WebHook", УровеньЖурналаРегистрации.Ошибка,,,
			"Ошибка регламентной отправки web hook: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтправитьОчередьWebHook(МаксимумЗаписей = 100) Экспорт
	
	Если МаксимумЗаписей <= 0 Тогда
		МаксимумЗаписей = 100;
	КонецЕсли;
	
	Расписание = РасписаниеПовторовWebHook();
	ТекущаяДата = ТекущаяДатаСеанса();
	ПустаяДата = Дата(1, 1, 1);
	ЛимитВыборки = МаксимумЗаписей * 500;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПустаяДата", ПустаяДата);
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(ЛимитВыборки, "ЧГ=0") + "
	               |	ОчередьWebHook.ИД КАК ИД,
	               |	ОчередьWebHook.УчетнаяЗапись КАК УчетнаяЗапись,
	               |	ОчередьWebHook.ТипСобытия КАК ТипСобытия,
	               |	ОчередьWebHook.Номенклатура КАК Номенклатура,
	               |	ОчередьWebHook.Склад КАК Склад,
	               |	ОчередьWebHook.ВидЦены КАК ВидЦены,
	               |	ОчередьWebHook.Заказ КАК Заказ,
	               |	ОчередьWebHook.Отправлен КАК Отправлен,
	               |	ОчередьWebHook.Создан КАК Создан,
	               |	ОчередьWebHook.Ошибка КАК Ошибка,
	               |	ОчередьWebHook.Инициатор КАК Инициатор,
	               |	ОчередьWebHook.КоличествоПопыток КАК КоличествоПопыток,
	               |	ОчередьWebHook.ПоследняяПопытка КАК ПоследняяПопытка,
	               |	ОчередьWebHook.УчетнаяЗапись.WebhookURL КАК WebhookURL,
	               |	ОчередьWebHook.УчетнаяЗапись.WebhookToken КАК WebhookToken
	               |ИЗ
	               |	РегистрСведений.ОчередьWebHook КАК ОчередьWebHook
	               |ГДЕ
	               |	ОчередьWebHook.Отправлен = &ПустаяДата
				   |	И ОчередьWebHook.УчетнаяЗапись.Активен
				   |	И ОчередьWebHook.УчетнаяЗапись.WebhookАктивен
				   |	И ОчередьWebHook.УчетнаяЗапись.WebhookURL <> """"
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ОчередьWebHook.Создан,
	               |	ОчередьWebHook.ИД";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пакеты = СформироватьПакетыWebHook(Выборка, Расписание, ТекущаяДата, ПустаяДата);
	ОтправленоПакетов = 0;
	
	Для Каждого Пакет Из Пакеты Цикл
		
		Если ОтправленоПакетов >= МаксимумЗаписей Тогда
			Прервать;
		КонецЕсли;
		
		ДатаПопытки = ТекущаяДатаСеанса();
		ТекстОшибки = "";
		Отправлено = Ложь;
		
		Попытка
			ТелоJSON = СтруктураВJSON(ТелоПакетаWebHook(Пакет));
			ОтветHTTP = ОтправитьPOSTWebHook(Пакет.WebhookURL, ТелоJSON, Пакет.WebhookToken);
			Отправлено = ОтветHTTP.КодСостояния >= 200 И ОтветHTTP.КодСостояния < 300;
			Если НЕ Отправлено Тогда
				ТекстОшибки = СтрШаблон("HTTP %1: %2", ОтветHTTP.КодСостояния, ОтветHTTP.ТелоОтвета);
			КонецЕсли;
		Исключение
			ТекстОшибки = ОписаниеОшибки();
		КонецПопытки;
		
		ЗаписатьРезультатОтправкиПакетаWebHook(Пакет.Строки, ДатаПопытки, Отправлено, ТекстОшибки);
		ОтправленоПакетов = ОтправленоПакетов + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Функция РасписаниеПовторовWebHook()
	
	СтрокаРасписания = Константы.ПериодичностьОповещенийИнтеграции.Получить();
	Результат = Новый Массив;
	
	Если Не ЗначениеЗаполнено(СтрокаРасписания) Тогда
		СтрокаРасписания = "30, 30, 30, 60, 60, 300, 600, 3600";
	КонецЕсли;
	
	Части = СтрРазделить(СтрокаРасписания, ",", Ложь);
	Для Каждого Часть Из Части Цикл
		
		Попытка
			Интервал = Цел(Число(СокрЛП(Часть)));
		Исключение
			Интервал = 0;
		КонецПопытки;
		
		Если Интервал > 0 Тогда
			Результат.Добавить(Интервал);
		КонецЕсли;
		
	КонецЦикла;
	
	Если Результат.Количество() = 0 Тогда
		Результат.Добавить(30);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтервалПовтораWebHook(КоличествоПопыток, Расписание)
	
	Если КоличествоПопыток <= 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Индекс = КоличествоПопыток;
	Если Индекс > Расписание.Количество() Тогда
		Индекс = Расписание.Количество();
	КонецЕсли;
	
	Возврат Расписание[Индекс - 1];
	
КонецФункции

Функция ЗаписьWebHookГотоваКОтправке(СтрокаОчереди, Расписание, ТекущаяДата, ПустаяДата)
	
	Если СтрокаОчереди.КоличествоПопыток = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтрокаОчереди.ПоследняяПопытка = ПустаяДата Тогда
		Возврат Истина;
	КонецЕсли;
	
	ИнтервалСекунд = ИнтервалПовтораWebHook(СтрокаОчереди.КоличествоПопыток, Расписание);
	СледующаяПопытка = СтрокаОчереди.ПоследняяПопытка + ИнтервалСекунд / 86400;
	
	Возврат СледующаяПопытка <= ТекущаяДата;
	
КонецФункции

Функция МаксимумЭлементовВПакетеWebHook()
	
	Возврат 200;
	
КонецФункции

Функция КлючПакетаWebHook(СтрокаОчереди)
	
	Возврат Строка(СтрокаОчереди.УчетнаяЗапись) + "|" + Строка(СтрокаОчереди.ТипСобытия);
	
КонецФункции

Функция СформироватьПакетыWebHook(Выборка, Расписание, ТекущаяДата, ПустаяДата)
	
	ПакетыПоКлючу = Новый Соответствие;
	Пакеты = Новый Массив;
	МаксимумЭлементов = МаксимумЭлементовВПакетеWebHook();
	
	Пока Выборка.Следующий() Цикл
		
		Если НЕ ЗаписьWebHookГотоваКОтправке(Выборка, Расписание, ТекущаяДата, ПустаяДата) Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ = КлючПакетаWebHook(Выборка);
		Пакет = ПакетыПоКлючу.Получить(Ключ);
		
		Если Пакет = Неопределено Или Пакет.Строки.Количество() >= МаксимумЭлементов Тогда
			Пакет = Новый Структура("УчетнаяЗапись,ТипСобытия,WebhookURL,WebhookToken,Строки,МинСоздан",
				Выборка.УчетнаяЗапись, Выборка.ТипСобытия, Выборка.WebhookURL, Выборка.WebhookToken, Новый Массив, Выборка.Создан);
			Пакеты.Добавить(Пакет);
			ПакетыПоКлючу.Вставить(Ключ, Пакет);
		КонецЕсли;
		
		Пакет.Строки.Добавить(СтрокаОчередиWebHookИзВыборки(Выборка));
		
		Если Выборка.Создан < Пакет.МинСоздан Тогда
			Пакет.МинСоздан = Выборка.Создан;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Пакеты;
	
КонецФункции

Функция СтрокаОчередиWebHookИзВыборки(Выборка)
	
	Возврат Новый Структура(
		"ИД,УчетнаяЗапись,ТипСобытия,Номенклатура,Склад,ВидЦены,Заказ,Отправлен,Создан,Ошибка,Инициатор,КоличествоПопыток,ПоследняяПопытка",
		Выборка.ИД, Выборка.УчетнаяЗапись, Выборка.ТипСобытия, Выборка.Номенклатура, Выборка.Склад, Выборка.ВидЦены, Выборка.Заказ,
		Выборка.Отправлен, Выборка.Создан, Выборка.Ошибка, Выборка.Инициатор, Выборка.КоличествоПопыток, Выборка.ПоследняяПопытка);
	
КонецФункции

Функция ТелоПакетаWebHook(Пакет)
	
	Тело = Новый Структура;
	Тело.Вставить("batchId", Строка(Новый УникальныйИдентификатор));
	Тело.Вставить("eventType", Строка(Пакет.ТипСобытия));
	Тело.Вставить("createdAt", ДатаВСтроку(Пакет.МинСоздан));
	
	ДанныеОбогащения = ДанныеОбогащенияWebHook(Пакет.ТипСобытия, Пакет.Строки);
	МассивЭлементов = Новый Массив;
	
	Для Каждого СтрокаОчереди Из Пакет.Строки Цикл
		МассивЭлементов.Добавить(ЭлементСообщенияWebHook(СтрокаОчереди, Пакет.ТипСобытия, ДанныеОбогащения));
	КонецЦикла;
	
	Тело.Вставить("items", МассивЭлементов);
	
	Возврат Тело;
	
КонецФункции

Функция ДанныеОбогащенияWebHook(ТипСобытия, СтрокиПакета)
	
	Если ТипСобытия = Перечисления.ТипыСобытийWebHooks.Остаток Тогда
		Возврат ЗагрузитьОстаткиДляWebHook(СтрокиПакета);
	ИначеЕсли ТипСобытия = Перечисления.ТипыСобытийWebHooks.Цена Тогда
		Возврат ЗагрузитьЦеныДляWebHook(СтрокиПакета);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция КлючТовараWebHook(Номенклатура, Склад, ВидЦены = Неопределено)
	
	Ключ = Строка(Номенклатура) + "|" + Строка(Склад);
	Если ЗначениеЗаполнено(ВидЦены) Тогда
		Ключ = Ключ + "|" + Строка(ВидЦены);
	КонецЕсли;
	
	Возврат Ключ;
	
КонецФункции

Функция ЗагрузитьОстаткиДляWebHook(СтрокиПакета)
	
	Результат = Новый Соответствие;
	ТаблицаКлючей = Новый ТаблицаЗначений;
	ТаблицаКлючей.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаКлючей.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ДобавленныеКлючи = Новый Соответствие;
	
	Для Каждого СтрокаОчереди Из СтрокиПакета Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаОчереди.Номенклатура) Или НЕ ЗначениеЗаполнено(СтрокаОчереди.Склад) Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ = КлючТовараWebHook(СтрокаОчереди.Номенклатура, СтрокаОчереди.Склад);
		Если ДобавленныеКлючи.Получить(Ключ) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавленныеКлючи.Вставить(Ключ, Истина);
		НоваяСтрока = ТаблицаКлючей.Добавить();
		НоваяСтрока.Номенклатура = СтрокаОчереди.Номенклатура;
		НоваяСтрока.Склад = СтрокаОчереди.Склад;
		
	КонецЦикла;
	
	Если ТаблицаКлючей.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ключи", ТаблицаКлючей);
	Запрос.Текст = "ВЫБРАТЬ
	               |	Ключи.Номенклатура КАК Номенклатура,
	               |	Ключи.Склад КАК Склад
	               |ПОМЕСТИТЬ Ключи
	               |ИЗ
	               |	&Ключи КАК Ключи
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Ключи.Номенклатура КАК Номенклатура,
	               |	Ключи.Склад КАК Склад,
	               |	ЕСТЬNULL(Ост.ОстатокОстаток, 0) КАК Остаток,
	               |	ЕСТЬNULL(Ост.РезервОстаток, 0) КАК Резерв
	               |ИЗ
	               |	Ключи КАК Ключи
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(, ) КАК Ост
	               |		ПО Ключи.Номенклатура = Ост.Номенклатура
	               |			И Ключи.Склад = Ост.Склад";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Данные = Новый Структура("balance,reserve", КодВСтроку(Выборка.Остаток), КодВСтроку(Выборка.Резерв));
		Результат.Вставить(КлючТовараWebHook(Выборка.Номенклатура, Выборка.Склад), Данные);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗагрузитьЦеныДляWebHook(СтрокиПакета)
	
	Результат = Новый Соответствие;
	Группы = Новый Соответствие;
	
	Для Каждого СтрокаОчереди Из СтрокиПакета Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаОчереди.Номенклатура)
			Или НЕ ЗначениеЗаполнено(СтрокаОчереди.Склад)
			Или НЕ ЗначениеЗаполнено(СтрокаОчереди.ВидЦены) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючГруппы = Строка(СтрокаОчереди.Склад) + "|" + Строка(СтрокаОчереди.ВидЦены);
		МассивНоменклатуры = Группы.Получить(КлючГруппы);
		
		Если МассивНоменклатуры = Неопределено Тогда
			МассивНоменклатуры = Новый Массив;
			Группы.Вставить(КлючГруппы, МассивНоменклатуры);
		КонецЕсли;
		
		Если МассивНоменклатуры.Найти(СтрокаОчереди.Номенклатура) = Неопределено Тогда
			МассивНоменклатуры.Добавить(СтрокаОчереди.Номенклатура);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из Группы Цикл
		
		Склад = Неопределено;
		ВидЦены = Неопределено;
		Для Каждого СтрокаОчереди Из СтрокиПакета Цикл
			Если КлючТовараWebHook(СтрокаОчереди.Номенклатура, СтрокаОчереди.Склад, СтрокаОчереди.ВидЦены) <> "" 
				И Строка(СтрокаОчереди.Склад) + "|" + Строка(СтрокаОчереди.ВидЦены) = КлючИЗначение.Ключ Тогда
				Склад = СтрокаОчереди.Склад;
				ВидЦены = СтрокаОчереди.ВидЦены;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЗначениеЗаполнено(Склад) Или НЕ ЗначениеЗаполнено(ВидЦены) Тогда
			Продолжить;
		КонецЕсли;
		
		Цены = StockAPI_Цены.ЗагрузитьЦеныПродажи(КлючИЗначение.Значение, ВидЦены, Склад);
		
		Для Каждого КлючЦены Из Цены Цикл
			Результат.Вставить(КлючТовараWebHook(КлючЦены.Ключ, Склад, ВидЦены), КлючЦены.Значение);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементСообщенияWebHook(СтрокаОчереди, ТипСобытия, ДанныеОбогащения)
	
	Если ТипСобытия = Перечисления.ТипыСобытийWebHooks.СтатусЗаказа Тогда
		Возврат ЭлементСтатусаWebHook(СтрокаОчереди);
	КонецЕсли;
	
	Элемент = Новый Структура;
	Элемент.Вставить("eventId", Строка(СтрокаОчереди.ИД));
	Элемент.Вставить("createdAt", ДатаВСтроку(СтрокаОчереди.Создан));
	
	Если ЗначениеЗаполнено(СтрокаОчереди.Номенклатура) Тогда
		Элемент.Вставить("itemCode", Формат(СтрокаОчереди.Номенклатура.Код, "ЧГ=0"));
		Элемент.Вставить("item", Строка(СтрокаОчереди.Номенклатура));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаОчереди.Склад) Тогда
		Элемент.Вставить("warehouse", Формат(СтрокаОчереди.Склад.Код, "ЧГ=0"));
		Элемент.Вставить("warehouseName", Строка(СтрокаОчереди.Склад));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаОчереди.ВидЦены) Тогда
		Элемент.Вставить("priceType", Строка(СтрокаОчереди.ВидЦены));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаОчереди.Инициатор) Тогда
		Элемент.Вставить("source", Строка(СтрокаОчереди.Инициатор));
	КонецЕсли;
	
	Если ТипСобытия = Перечисления.ТипыСобытийWebHooks.Остаток И ДанныеОбогащения <> Неопределено Тогда
		ДанныеОстатка = ДанныеОбогащения.Получить(КлючТовараWebHook(СтрокаОчереди.Номенклатура, СтрокаОчереди.Склад));
		Если ДанныеОстатка <> Неопределено Тогда
			Элемент.Вставить("balance", ДанныеОстатка.balance);
			Элемент.Вставить("reserve", ДанныеОстатка.reserve);
		КонецЕсли;
	ИначеЕсли ТипСобытия = Перечисления.ТипыСобытийWebHooks.Цена И ДанныеОбогащения <> Неопределено Тогда
		ДанныеЦены = ДанныеОбогащения.Получить(КлючТовараWebHook(СтрокаОчереди.Номенклатура, СтрокаОчереди.Склад, СтрокаОчереди.ВидЦены));
		Если ДанныеЦены <> Неопределено Тогда
			Элемент.Вставить("price", ЦеныWebHookИзДанныхРегистра(ДанныеЦены));
			Элемент.Вставить("currency", ДанныеЦены.Валюта);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Элемент;
	
КонецФункции

Функция ЦеныWebHookИзДанныхРегистра(ДанныеЦены)
	
	МассивЦен = Новый Массив;
	
	Если ДанныеЦены.Цена0 <> 0 Тогда
		Запись = Новый Структура("qty,price", 1, ДанныеЦены.Цена0);
		МассивЦен.Добавить(Запись);
	КонецЕсли;
	
	Если ДанныеЦены.Порог1 <> 0 И ДанныеЦены.Цена1 <> 0 Тогда
		Запись = Новый Структура("qty,price", ДанныеЦены.Порог1, ДанныеЦены.Цена1);
		МассивЦен.Добавить(Запись);
	КонецЕсли;
	
	Если ДанныеЦены.Порог2 <> 0 И ДанныеЦены.Цена2 <> 0 Тогда
		Запись = Новый Структура("qty,price", ДанныеЦены.Порог2, ДанныеЦены.Цена2);
		МассивЦен.Добавить(Запись);
	КонецЕсли;
	
	Если ДанныеЦены.Порог3 <> 0 И ДанныеЦены.Цена3 <> 0 Тогда
		Запись = Новый Структура("qty,price", ДанныеЦены.Порог3, ДанныеЦены.Цена3);
		МассивЦен.Добавить(Запись);
	КонецЕсли;
	
	Возврат МассивЦен;
	
КонецФункции

Функция ЭлементСтатусаWebHook(СтрокаОчереди)
	
	Элемент = Новый Структура;
	Элемент.Вставить("eventId", Строка(СтрокаОчереди.ИД));
	Элемент.Вставить("createdAt", ДатаВСтроку(СтрокаОчереди.Создан));
	
	Если ЗначениеЗаполнено(СтрокаОчереди.Инициатор) Тогда
		Элемент.Вставить("source", Строка(СтрокаОчереди.Инициатор));
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтрокаОчереди.Заказ) Тогда
		Возврат Элемент;
	КонецЕсли;
	
	РеквизитыЗаказа = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаОчереди.Заказ, "Номер,НомерВходящий");
	Элемент.Вставить("orderNumber", РеквизитыЗаказа.Номер);
	Элемент.Вставить("incomingNumber", РеквизитыЗаказа.НомерВходящий);
	
	Статус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СтрокаОчереди.Заказ);
	Элемент.Вставить("status", Строка(Статус.Состояние));
	Элемент.Вставить("statusSetBy", Строка(Статус.КемИзменено));
	Элемент.Вставить("statusDate", ДатаВСтроку(Статус.Зарегистрировано));
	
	Возврат Элемент;
	
КонецФункции

Функция ТелоСообщенияWebHook(СтрокаОчереди)
	
	// Совместимость: один элемент в формате пакета.
	Пакет = Новый Структура("ТипСобытия,Строки,МинСоздан", СтрокаОчереди.ТипСобытия, Новый Массив, СтрокаОчереди.Создан);
	Пакет.Строки.Добавить(СтрокаОчереди);
	Возврат ТелоПакетаWebHook(Пакет);
	
КонецФункции

Функция ОтправитьPOSTWebHook(URL, ТелоJSON, Токен)
	
	ДанныеURL = РазобратьURLWebHook(URL);
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Заголовки.Вставить("Accept", "application/json");
	Если ЗначениеЗаполнено(Токен) Тогда
		//Заголовки.Вставить("X-Webhook-Token", Строка(Токен));
		Заголовки.Вставить("Authorization", "Bearer " + Строка(Токен));
	КонецЕсли;
	
	Если ДанныеURL.HTTPS Тогда
		Соединение = Новый HTTPСоединение(ДанныеURL.Сервер, ДанныеURL.Порт, , , , , Новый ЗащищенноеСоединениеOpenSSL());
	Иначе
		Соединение = Новый HTTPСоединение(ДанныеURL.Сервер, ДанныеURL.Порт);
	КонецЕсли;
	
	ЗапросHTTP = Новый HTTPЗапрос(ДанныеURL.Адрес, Заголовки);
	ЗапросHTTP.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	Ответ = Соединение.ВызватьHTTPМетод("POST", ЗапросHTTP);
	
	Возврат Новый Структура("КодСостояния,ТелоОтвета", Ответ.КодСостояния, Ответ.ПолучитьТелоКакСтроку());
	
КонецФункции

Функция РазобратьURLWebHook(URL)
	
	СтрокаURL = СокрЛП(Строка(URL));
	НижнийURL = НРег(СтрокаURL);
	
	Если СтрНачинаетсяС(НижнийURL, "https://") Тогда
		HTTPS = Истина;
		БезСхемы = Сред(СтрокаURL, 9);
		Порт = 443;
	ИначеЕсли СтрНачинаетсяС(НижнийURL, "http://") Тогда
		HTTPS = Ложь;
		БезСхемы = Сред(СтрокаURL, 8);
		Порт = 80;
	Иначе
		ВызватьИсключение "WebhookURL должен начинаться с http:// или https://.";
	КонецЕсли;
	
	ПозицияПути = СтрНайти(БезСхемы, "/");
	Если ПозицияПути = 0 Тогда
		Хост = БезСхемы;
		Адрес = "/";
	Иначе
		Хост = Лев(БезСхемы, ПозицияПути - 1);
		Адрес = Сред(БезСхемы, ПозицияПути);
	КонецЕсли;
	
	ПозицияПорта = СтрНайти(Хост, ":");
	Если ПозицияПорта > 0 Тогда
		Порт = Число(Сред(Хост, ПозицияПорта + 1));
		Хост = Лев(Хост, ПозицияПорта - 1);
	КонецЕсли;
	
	Если Хост = "" Тогда
		ВызватьИсключение "В WebhookURL не указан сервер.";
	КонецЕсли;
	
	Возврат Новый Структура("HTTPS,Сервер,Порт,Адрес", HTTPS, Хост, Порт, Адрес);
	
КонецФункции

Процедура ЗаписатьРезультатОтправкиПакетаWebHook(СтрокиПакета, ДатаПопытки, Отправлено, ТекстОшибки)
	
	Для Каждого СтрокаОчереди Из СтрокиПакета Цикл
		ЗаписатьРезультатОтправкиWebHook(СтрокаОчереди, ДатаПопытки, Отправлено, ТекстОшибки);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьРезультатОтправкиWebHook(СтрокаОчереди, ДатаПопытки, Отправлено, ТекстОшибки)
	
	НаборЗаписей = РегистрыСведений.ОчередьWebHook.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИД.Установить(СтрокаОчереди.ИД);
	НаборЗаписей.Отбор.УчетнаяЗапись.Установить(СтрокаОчереди.УчетнаяЗапись);
	НаборЗаписей.Отбор.ТипСобытия.Установить(СтрокаОчереди.ТипСобытия);
	НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаОчереди.Номенклатура);
	НаборЗаписей.Отбор.Склад.Установить(СтрокаОчереди.Склад);
	НаборЗаписей.Отбор.ВидЦены.Установить(СтрокаОчереди.ВидЦены);
	НаборЗаписей.Отбор.Заказ.Установить(СтрокаОчереди.Заказ);
	
	Запись = НаборЗаписей.Добавить();
	Запись.ИД 				= СтрокаОчереди.ИД;
	Запись.УчетнаяЗапись 	= СтрокаОчереди.УчетнаяЗапись;
	Запись.ТипСобытия 		= СтрокаОчереди.ТипСобытия;
	Запись.Номенклатура 	= СтрокаОчереди.Номенклатура;
	Запись.Склад 			= СтрокаОчереди.Склад;
	Запись.ВидЦены 			= СтрокаОчереди.ВидЦены;
	Запись.Заказ 			= СтрокаОчереди.Заказ;
	Запись.Отправлен 		= ?(Отправлено, ДатаПопытки, СтрокаОчереди.Отправлен);
	Запись.Создан 			= СтрокаОчереди.Создан;
	Запись.Инициатор 		= СтрокаОчереди.Инициатор;
	Запись.КоличествоПопыток = СтрокаОчереди.КоличествоПопыток + 1;
	Запись.ПоследняяПопытка = ДатаПопытки;
	Запись.Ошибка 			= ?(Отправлено, "", Лев(ТекстОшибки, 500));
	
	НаборЗаписей.Записать(Истина);
	
КонецПроцедуры

