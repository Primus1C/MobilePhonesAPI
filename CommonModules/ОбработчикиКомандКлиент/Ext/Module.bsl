Процедура клПечатьДокументаЗавершениеРасходная(Поз, Тек) Экспорт
	Если Поз = 0 Тогда Возврат КонецЕсли; 
	
	Имя = "РасходнаяНакладная";
	Пар = Новый Структура;
	Таб = Новый ТабличныйДокумент;
	омСервер.ПечатьДокумента(Имя, Тек, Поз, Таб, Пар);
	
	Таб.ПолеСверху = 10;
	Таб.ПолеСлева = 10;
	Таб.ПолеСнизу = 10;
	Таб.ПолеСправа = 0;
	
	Таб.РазмерКолонтитулаСверху = 8;
	Таб.РазмерКолонтитулаСнизу = 8;	
	Таб.ОтображатьЗаголовки = Ложь;
	Таб.ОтображатьСетку = Ложь;
	Таб.ТолькоПросмотр = Истина;
	Таб.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	Таб.ВерхнийКолонтитул.Выводить = Истина;
	Таб.ВерхнийКолонтитул.НачальнаяСтраница = 1;
	Таб.ВерхнийКолонтитул.ТекстСправа = НСтр("ru = 'стр. [&НомерСтраницы] из [&СтраницВсего]'; en = 'page [&НомерСтраницы] of [&СтраницВсего]'");
	
	Таб.НижнийКолонтитул.Выводить = Истина;
	Таб.НижнийКолонтитул.НачальнаяСтраница = 1;
	Таб.НижнийКолонтитул.ТекстСлева = гоПользовательКод();
	Таб.НижнийКолонтитул.ТекстСправа = "[&Дата] [&Время]";
	
	Пар = Новый Структура("Таб", Таб);
	Пар.Вставить("Имя", гоИмя(Тек, Ложь));
	Пар.Вставить("НеДляПечати", Ложь);
	ОткрытьФорму("ОбщаяФорма.ПечатьБезЗащиты", Пар, , Истина); 	//не искать окно вообще, всегда открывать новое
КонецПроцедуры

