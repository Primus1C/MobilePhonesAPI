Процедура клЖурналНашИнтервалЗавершение(РезультатРедактирования, Параметры) Экспорт
	
	Если РезультатРедактирования = Неопределено Тогда 
		Возврат;
	КонецЕсли; 
	
	Форма = Параметры.Форма;
	Диалог = Параметры.Диалог;
	Форма.НачДата = Диалог.Период.ДатаНачала;
	Форма.КонДата = Диалог.Период.ДатаОкончания;
	
	гоЗаголовокИнтервал(Форма);
	Форма.ТекущийЭлемент = Форма.Элементы.Список; 
	
КонецПроцедуры

Процедура клНайтиНомерЗавершение(ИщемНомер, Параметры) Экспорт
	Форма = Параметры.Форма;
	
	Если ИщемНомер <> Неопределено Тогда
		ИщемПрефикс = Параметры.ИщемПрефикс;
		ИщемВсе = ?(ИщемПрефикс = "", ИщемНомер, ИщемПрефикс + гоЧислоНулиСлева(ИщемНомер, 7));
		
		Тек = омСервер.ДокументПоНомеру(ИщемВсе, Форма.ИмяДокумента);
		Если гоПЗ(Тек) Тогда
			клОшибка(СтрШаблон("%1 %2!", НСтр("ru = 'Не найден документ по номеру'; en = 'Document number not found'"), гоИмя(ИщемВсе))); 
		Иначе
			Форма.Элементы.Список.ТекущаяСтрока = Тек;
		КонецЕсли; 
	КонецЕсли; 
	
	Форма.ТекущийЭлемент = Форма.Элементы.Список;
КонецПроцедуры

