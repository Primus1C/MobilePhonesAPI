Процедура клВариантЗавершение(РезПар, Параметры) Экспорт
	Если РезПар = Неопределено Тогда 
		ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, 0); 
		Возврат;
	КонецЕсли;
	
	Старт = Параметры.Старт;
	Рез = РезПар.ВыбраннаяСтрока + 1;
	
	Если ТипЗнч(Старт) = Тип("Число") Тогда 
		//ничего не сохраняем
	Иначе 
		гоСЗН("Вариант", Старт, Рез);
	КонецЕсли; 
	
	ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, Рез);
КонецПроцедуры

