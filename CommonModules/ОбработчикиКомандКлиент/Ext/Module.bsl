Процедура клИскатьКонтрагентаПослеВводаСтроки(Стр, Параметры) Экспорт
	Если Стр = Неопределено Тогда 
		ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, Неопределено); 
		Возврат;
	КонецЕсли; 
	
	гоСЗН("Общие", "ПоискКонтрагента", Стр);
	Стр = СокрЛП(Стр);
	Если Стр = "" Тогда 
		ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, Неопределено); 
		Возврат;
	КонецЕсли; 
	
	Спи = омСервер.ИскатьКонтрагента(Стр);
	Если Спи.Количество() = 0 Тогда 
		клОшибка(НСтр("ru = 'Ничего найти не удалось!'; en = 'Couldn't find anything!'")); 
		ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, Неопределено); 
		Возврат;
	КонецЕсли;
	Если Спи.Количество() = 1 Тогда 
		ВыполнитьОбработкуОповещения(Параметры.ОписаниеОповещенияОЗавершении, Спи[0].Значение); 
		Возврат;
	КонецЕсли; 
	
	Эле = Спи.НайтиПоЗначению(Параметры.СтатьНа);
	Спи.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("клИскатьЭлементПослеВыбора", ОбработчикиКомандКлиент, Параметры.ОписаниеОповещенияОЗавершении), 
		НСтр("ru = 'Выберите из найденного:'; en = 'Select from what was found:'"), Эле);
КонецПроцедуры

