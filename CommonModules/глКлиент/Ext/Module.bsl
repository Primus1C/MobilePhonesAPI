				//ПараметрыВыполненияКоманды.НавигационнаяСсылка,    
				,,,,
				Неопределено,                                	 // <--- ОписаниеОповещенияОЗакрытии
				РежимОткрытияОкнаФормы.БлокироватьОкноВладельца  // <--- Режим открытия окна
			);
	
