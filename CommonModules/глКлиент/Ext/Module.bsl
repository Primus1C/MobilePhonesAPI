Процедура клФормаДокументаПередЗаписью(Объект, Отказ) Экспорт
	
	лДатаЗапрета = гоПараметрСеанса("ДатаЗапретаРедактирования");
	Если лДатаЗапрета <> Дата(1,1,1) И Объект.Дата <= КонецДня(лДатаЗапрета) Тогда
	    клОшибка(СтрШаблон(НСтр("ru = 'Запись документов до %1 запрещена! Период закрыт'; en = 'Writing documents up to %1 is prohibited! Period closed!'"), Формат(лДатаЗапрета,"ДФ=dd.MM.yyyy")));
		Отказ = Истина;	
	КонецЕсли;
	
КонецПроцедуры

