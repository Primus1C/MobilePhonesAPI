					НСтр("ru = 'В документе есть одинаковая номенклатура с разными ценами! Продолжать?'; en = 'The document contains the same nomenclature with different prices! Continue?'"));
			Иначе
				клПечатьДокументаВариантРасходная(Тек);
			КонецЕсли; 
			Возврат;
		КонецЕсли; 
	КонецЕсли; 	
	
	Имя = "ЗаказТовара";
	Если гоЭтоДок(Тек, Имя) Тогда
		Если ЭтоЖурнал Тогда
			//потом
		Иначе
			Если гоРеквизит(Тек, "Строк") = 0 Тогда Возврат КонецЕсли; 
			
			Спи = Новый СписокЗначений;
			Спи.Добавить(Тек);
			
			Поз = 1;
			Пар = Новый Структура;
			Таб = Новый ТабличныйДокумент;
			омСервер.ПечатьДокумента(Имя, Тек, Поз, Таб, Пар);
			
			Таб.ПолеСверху = 10;
