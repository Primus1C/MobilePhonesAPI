Процедура клЖурналСумма(Форма) Экспорт;
	Попытка
		Форма.ТекущийЭлемент = Форма.Элементы.Список;
		
		ВыдСтр = Форма.Элементы.Список.ВыделенныеСтроки;
		ИмяДок = Форма.ИмяДокумента;
		ИмяЖур = Форма.ИмяЖурнала;
		НачДат = Форма.НачДата;
		КонДат = Форма.КонДата;
	Исключение      
		
		клОшибка(НСтр("ru = 'Непонятная ошибка: %1! Сообщите разработчику!'; en = 'Strange error: %1! Notify the developer!'"), ОписаниеОшибки() );
	    Возврат;
	КонецПопытки; 
	
	Если ВыдСтр.Количество() < 2 Тогда клОшибка(НСтр("ru = 'Нет выделенных строк для суммирования!'; en = 'No dedicated lines for summing!'")); Возврат; КонецЕсли;
	Если гоПЗ(НачДат) Тогда клОшибка(НСтр("ru = 'Не задана начальная дата!'; en = 'Start date not set!'")); Возврат; КонецЕсли;
	Если гоПЗ(КонДат) Тогда клОшибка(НСтр("ru = 'Не задана конечная дата!'; en = 'The end date not set!'")); Возврат; КонецЕсли;
	
	//Р = "";
	//С = омСервер.СуммаДокументов(НачДат, КонДат, ИмяДок, ИмяЖур, ВыдСтр, Р);
	//Если клЕстьОшибка(Р) Тогда Возврат КонецЕсли;
	//
	//клВнимание(С);
КонецПроцедуры
 
Процедура клЖурналНашИнтервал(Форма, Вариант = 1) Экспорт
	Дат = НачалоДня(ТекущаяДата());
	
	Попытка
		Тек = Форма.Элементы.Список.ТекущаяСтрока;
	Исключение
	    //возможно, мы не в журнале
		Возврат;
	КонецПопытки; 
	
	// © Primus1C  25.10.2023  НАЧАЛО ►
	Если Форма.ИмяЖурнала = "ПоставкиИнвойсов" Тогда
		Если Форма.Элементы.Список.ТекущиеДанные = Неопределено Тогда
			Тек = Неопределено;
		Иначе
			Тек = Форма.Элементы.Список.ТекущиеДанные.Ссылка;
		КонецЕсли;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	Если НЕ (Тек = Неопределено) Тогда 
		Попытка
			Дат = НачалоДня(гоРеквизит(Тек, "Дата")); 
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Если Вариант = 1 Тогда
		//просто интервал
		
		Период = Новый СтандартныйПериод(Форма.НачДата, Форма.КонДата);
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();
		Диалог.Период = Период;
		//Диалог.ПоказатьРедактирование(Новый ОписаниеОповещения("клЖурналНашИнтервалЗавершение", ОбработчикиКомандКлиент, Новый Структура("Форма, Диалог", Форма, Диалог)));
		Диалог.Показать(Новый ОписаниеОповещения("клЖурналНашИнтервалЗавершение", ОбработчикиКомандКлиент, Новый Структура("Форма, Диалог", Форма, Диалог)));
		Возврат;
		
	ИначеЕсли Вариант = 2 Тогда
		//месяц
		
		Если (Форма.НачДата = НачалоМесяца(Дат)) И (Форма.КонДата = НачалоДня(КонецМесяца(Дат))) Тогда
			Форма.НачДата = Форма.СохНачДата;
			Форма.КонДата = Форма.СохКонДата;
		Иначе
			Форма.НачДата = НачалоМесяца(Дат);
			Форма.КонДата = КонецМесяца(Дат);
		КонецЕсли; 
		
	ИначеЕсли Вариант = 3 Тогда
		//день
		
		Если (Форма.НачДата = Дат) И (Форма.КонДата = Дат) Тогда
			Форма.НачДата = Форма.СохНачДата;
			Форма.КонДата = Форма.СохКонДата;
		Иначе
			Форма.НачДата = Дат;
			Форма.КонДата = Дат;
		КонецЕсли; 
	ИначеЕсли Вариант = 4 Тогда
		//неделя
		
		Если (Форма.НачДата = НачалоНедели(Форма.НачДата)) И (Форма.КонДата = НачалоДня(КонецНедели(Форма.НачДата))) Тогда
			Форма.НачДата = Форма.СохНачДата;
			Форма.КонДата = Форма.СохКонДата;
		Иначе
			Форма.НачДата = НачалоНедели(Дат);
			Форма.КонДата = КонецНедели(Дат);
		КонецЕсли; 
	ИначеЕсли Вариант = 5 Тогда
		//плюс неделя, только если стоит неделя
		
		Если (Форма.НачДата = НачалоНедели(Форма.НачДата)) И (Форма.КонДата = НачалоДня(КонецНедели(Форма.НачДата))) Тогда
			Дат = гоДобавитьДень(КонецНедели(Форма.НачДата), 1);
			
			Форма.НачДата = НачалоНедели(Дат);
			Форма.КонДата = КонецНедели(Дат);
		КонецЕсли; 
	ИначеЕсли Вариант = 6 Тогда
		//минус неделя, только если стоит неделя
		
		Если (Форма.НачДата = НачалоНедели(Форма.НачДата)) И (Форма.КонДата = НачалоДня(КонецНедели(Форма.НачДата))) Тогда
			Дат = гоДобавитьДень(НачалоНедели(Форма.НачДата), - 1);
			
			Форма.НачДата = НачалоНедели(Дат);
			Форма.КонДата = КонецНедели(Дат);
		КонецЕсли; 
	КонецЕсли; 
	
	гоЗаголовокИнтервал(Форма);
	Форма.ТекущийЭлемент = Форма.Элементы.Список; 

КонецПроцедуры

Процедура клНайтиНомер(Форма) Экспорт
	ИщемПрефикс = "";
	ИщемНомер = 0;
	
	Тек = Форма.Элементы.Список.ТекущаяСтрока;
	Если НЕ (Тек = Неопределено) Тогда 
		локНомер = СокрЛП(гоРеквизит(Тек, "Номер"));		
		
		Попытка
			ИщемНомер = Число(Прав(локНомер, 7));
			Если СтрДлина(локНомер) > 7 Тогда
				ИщемПрефикс = Лев(локНомер, СтрДлина(локНомер) - 7);
			КонецЕсли; 
		Исключение
		    Сообщить(ОписаниеОшибки());
		КонецПопытки; 
	КонецЕсли; 
	
	ПоказатьВводЧисла(Новый ОписаниеОповещения("клНайтиНомерЗавершение", ОбработчикиКомандКлиент, Новый Структура("Форма, ИщемПрефикс", Форма, ИщемПрефикс)),
		ИщемНомер, 
		?(ИщемПрефикс = "", НСтр("ru = 'Поиск без префикса'; en = 'Search without prefix'"), НСтр("ru = 'Поиск с префиксом '; en = 'Search with prefix '") + гоИмя(ИщемПрефикс)), 
		7, 0);
КонецПроцедуры


