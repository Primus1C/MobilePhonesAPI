Процедура клВариантСписка(ОписаниеОповещенияОЗавершении, Загол, СписВариантов, Старт = 0) Экспорт
	
	Пар = Новый Структура("Список", СписВариантов);
	Пар.Вставить("Заголовок", Загол);
	
	Если ТипЗнч(Старт) = Тип("Число") Тогда 
		Пар.Вставить("Старт", Старт);
	Иначе 
		СтартЧисло = 1;
		гоВЗН("Вариант", Старт, СтартЧисло, "Число");
		Если СтартЧисло = 0 Тогда СтартЧисло = 1 КонецЕсли; 
		Пар.Вставить("Старт", СтартЧисло);
	КонецЕсли; 
		
	ОткрытьФорму("ОбщаяФорма.ВыборПростогоВарианта", Пар, , , , , 
		Новый ОписаниеОповещения("клВариантСпискаЗавершение", ОбработчикиКомандКлиент, ОписаниеОповещенияОЗавершении));

КонецПроцедуры

