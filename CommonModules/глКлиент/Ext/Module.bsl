										);
		Иначе	
			Форма.ТолькоПросмотр = Истина;  
		//Попытка		
		//	Форма.КэшДанных.Вставить("ПериодЗакрыт", Истина);
		//Исключение	
		//	Сообщить(НСтр("ru = 'Период закрыт. Только просмотр'; en = 'Period is closed. Read only'"), СтатусСообщения.Внимание); 
		ПоказатьОповещениеПользователя(НСтр("ru = 'Только просмотр'; en = 'Read only'"),,
										НСтр("ru = 'Период закрыт'; en = 'Period is closed'"), 
										БиблиотекаКартинок.ДиалогИнформация, 
										СтатусОповещенияПользователя.Информация,
										);
		//КонецПопытки;
		КонецЕсли;
	КонецЕсли;	
	
