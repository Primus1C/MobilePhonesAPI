Функция клПросмотр(Форма, Избранный = Ложь, Объект = 0, ТолькоПривязки = 0) Экспорт
	стрТолькоПривязки = "";
	
	Если НЕ Объект = 0 Тогда
		Попытка
			стрТолькоПривязки = ?(ТолькоПривязки = 0, "", ?(ТолькоПривязки = 1, НСтр("ru = 'только привязки'; en = 'binds only'"), НСтр("ru = 'Без К'; en = 'No K'")));	//, К/К
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	// © Primus1C  01.02.2024  НАЧАЛО ►
	//Возврат ?(Форма.ТолькоПросмотр, ?(Избранный, НСтр("ru = 'только Избранный'; en = 'only favirite'"), НСтр("ru = 'П Р О С М О Т Р'; en = 'R E A D  O N L Y'")), стрТолькоПривязки);
	лПериодзакрыт = ""; 
	лДатаЗапрета = гоПараметрСеанса("ДатаЗапретаРедактирования");
	Если Форма.Объект.Дата <> Дата(1,1,1) И лДатаЗапрета <> Дата(1,1,1) Тогда
		Если Форма.Объект.Дата < лДатаЗапрета Тогда	 
			лпериодЗакрыт = НСтр("ru = ' (период закрыт)'; en = ' (closed period)'");
		КонецЕсли;
	КонецЕсли;	  
	Попытка
		Окончательно = Форма.Объект.Окончательно;
	Исключение
	    Окончательно = Ложь;
	КонецПопытки;
	
	Возврат ?(Форма.ТолькоПросмотр ИЛИ Окончательно, ?(Избранный, НСтр("ru = 'только Избранный'; en = 'only favirite'"), НСтр("ru = 'П Р О С М О Т Р'; en = 'R E A D  O N L Y'")) + лПериодзакрыт, стрТолькоПривязки);
