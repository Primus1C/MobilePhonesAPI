Процедура клДокументИзБуфера(Тек, ПараметрыВыполненияКоманды) Экспорт
//2016.02.02	

	БуфДок = Неопределено;
	БуфСтр = Новый Массив;
	РаботаСоСканеромШК.ВернутьБуфер(БуфДок, БуфСтр);
	
	Если гоПЗ(БуфДок) Тогда клОшибка(НСтр("ru = 'Буфер пустой!'; en = 'Clipboard is empty'")); Возврат; КонецЕсли; 

	Форма = 0;
	Попытка
		Форма = ПараметрыВыполненияКоманды.Источник;
	Исключение
	    Возврат;
	КонецПопытки; 
	
	ЭтоЖурнал = Ложь;
	ИмяДокумента = "";
	ИмяЖурнала = "";
	Если Форма = 0 Тогда Возврат КонецЕсли;
	
	Если ТипЗнч(Форма) = Тип("УправляемаяФорма") Тогда
		Попытка
			ИмяДокумента = Форма.ИмяДокумента;
			ИмяЖурнала = Форма.ИмяЖурнала;
			
			ЭтоЖурнал = Истина;
		Исключение
			Попытка
				ИмяДокумента = омСервер.МетаданныеОбъекта(Форма.Объект, "Имя");
			Исключение
			    Сообщить(ОписаниеОшибки());
			КонецПопытки; 
		КонецПопытки; 
	КонецЕсли; 
	
	Если ИмяДокумента = "" Тогда Возврат КонецЕсли; 
	//нам нужно быть именно внутри документа
	Если ЭтоЖурнал Тогда клОшибка(НСтр("ru = 'Нужно находиться внутри документа для вставки строк из буфера!'; en = 'You need to be inside the document to insert lines from the clipboard!'")); Возврат; КонецЕсли; 
	
	Попытка
		Форма.ВставитьСтрокиИзБуфера(БуфДок, БуфСтр)
	Исключение
	    клОшибка(ОписаниеОшибки());
	КонецПопытки; 
КонецПроцедуры
 
Процедура клДокументВБуфер(Тек, ПараметрыВыполненияКоманды) Экспорт
//2016.02.02	
	
	Форма = 0;
	Попытка
		Форма = ПараметрыВыполненияКоманды.Источник;
	Исключение
	    Возврат;
	КонецПопытки; 
	
	ЭтоЖурнал = Ложь;
	ИмяДокумента = "";
	ИмяЖурнала = "";
	Если Форма = 0 Тогда Возврат КонецЕсли;
	
	Если ТипЗнч(Форма) = Тип("УправляемаяФорма") Тогда
		Попытка
			ИмяДокумента = Форма.ИмяДокумента;
			ИмяЖурнала = Форма.ИмяЖурнала;
			
			ЭтоЖурнал = Истина;
		Исключение
			Попытка
				ИмяДокумента = омСервер.МетаданныеОбъекта(Форма.Объект, "Имя");
			Исключение
			    Сообщить(ОписаниеОшибки());
			КонецПопытки; 
		КонецПопытки; 
	КонецЕсли; 
	
	Если ИмяДокумента = "" Тогда Возврат КонецЕсли; 
	
	//пустые нам не нужны
	Если гоРеквизит(Тек, "Строк") = 0 Тогда клОшибка(НСтр("ru = 'Документ пустой!'; en = 'The document is empty!'")); Возврат; КонецЕсли; 
	
	//если мы не в журнале, то нужно попробовать получить массив строк выделенных
	ВыдСтр = 0;
	Если НЕ ЭтоЖурнал Тогда  
		Попытка
			ВыдСтр = Форма.Элементы.Товары.ВыделенныеСтроки;
			//если ничего не выделено, то весь документ "забираем"
			Если ВыдСтр.Количество() <= 0 Тогда ВыдСтр = 0 КонецЕсли; 
		Исключение
			ВыдСтр = 0;
		КонецПопытки; 
	КонецЕсли; 
	
	//Если клНетДа("Записать в буфер " + ?(ВыдСтр = 0, "все строки документа", " выделенные строки документа (" + ВыдСтр.Количество() + ")") + "?") Тогда Возврат КонецЕсли;
	Если ВыдСтр = 0 Тогда
	    лСтр = НСтр("ru = 'все строки документа'; en = 'all lines of the document'");
	Иначе
	    лСтр = НСтр("ru = 'выделенные строки документа ('; en = 'selected lines of the document ('") + + ВыдСтр.Количество() + ")";
	КонецЕсли;
	клНетДа(Новый ОписаниеОповещения("клДокументВБуферПослеПодтверждения", 
									ОбработчикиКомандКлиент, 
									Новый Структура("Тек, ВыдСтр, Форма", Тек, ВыдСтр, Форма)),
									СтрШаблон(НСтр("ru = 'Записать в буфер %1 ?'; en = 'Save to clipboard %1 ?'"), лСтр));
КонецПроцедуры

Процедура клПечатьДокумента(Тек, ПараметрыВыполненияКоманды) Экспорт
	
	Загол = НСтр("ru = 'Выберите вариант печати документа'; en = 'Select an option to print your document'");
	Старт = "СтартПечатьДокумента";
	
	//это не только печать документа, но и печать журнала
	//в каждом журнале у нас есть название его документа и название журнала
	//если они оба есть, это однозначно журнал
	
	Форма = 0;
	Попытка
		Форма = ПараметрыВыполненияКоманды.Источник;
	Исключение
	    //Сообщить(ОписаниеОшибки());
	КонецПопытки; 
	
	ЭтоЖурнал 		= Ложь; 
	// © Primus1C  21.10.2023  НАЧАЛО ►
	ЭтоФормаСписка = Ложь;
	// © Primus1C  ОКОНЧАНИЕ ◄
	ИмяДокумента 	= "";
	ИмяЖурнала 		= "";
	Если НЕ Форма = 0 Тогда
		Если ТипЗнч(Форма) = Тип("УправляемаяФорма") Тогда
			Попытка
				ИмяДокумента 	= Форма.ИмяДокумента;
				ИмяЖурнала 		= Форма.ИмяЖурнала;
				ЭтоЖурнал 		= Истина;
			Исключение
			КонецПопытки; 
		КонецЕсли; 
		// © Primus1C  21.10.2023  НАЧАЛО ► 
		Если Найти(Форма.ИмяФормы, "ФормаСписка") > 0 Тогда
			ЭтоФормаСписка 	= Истина;
		    ЭтоЖурнал 		= Ложь; 
		КонецЕсли;
		// © Primus1C  ОКОНЧАНИЕ ◄
	КонецЕсли; 	
	
	Имя = "РасходнаяНакладная";
	Если гоЭтоДок(Тек, Имя) Тогда
		Если ЭтоЖурнал Тогда
			//потом
		Иначе
