	КонецЕсли;
	Если Подробно Тогда 
		Лтр = Лтр + " " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Заголовок,Время,Стр", Заг, Время, Лтр);
	Если Таймаут > 0 Тогда
		ПараметрыФормы.Вставить("Таймаут", Таймаут);
	КонецЕсли;
	
	клПроизнестиГолосом(Сигнал);

	//ОткрытьФормуМодально("Обработка.Ошибка.Форма.Форма", ПараметрыФормы);  
