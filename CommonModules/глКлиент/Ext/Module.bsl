// 
Процедура клВариант(ОписаниеОповещенияОЗавершении, Загол, Старт = 0, Вар1 = "", Вар2 = "", Вар3 = "", Вар4 = "", Вар5 = "", Вар6 = "", Вар7 = "", Вар8 = "", Вар9 = "", Вар10 = "",
									Вар11 = "", Вар12 = "", Вар13 = "", Вар14 = "", Вар15 = "", Вар16 = "", Вар17 = "", Вар18 = "", Вар19 = "", Вар20 = "") Экспорт
//2016.04.07

	Если Вар1 = "" Тогда 
		ВыполнитьОбработкуОповещения(ОписаниеОповещенияОЗавершении, Старт); 
		Возврат;
	КонецЕсли; 
	
	Спи = Новый СписокЗначений;
	Если НЕ Вар1 = "" Тогда Спи.Добавить(Вар1) КонецЕсли; 
	Если НЕ Вар2 = "" Тогда Спи.Добавить(Вар2) КонецЕсли; 
	Если НЕ Вар3 = "" Тогда Спи.Добавить(Вар3) КонецЕсли; 
	Если НЕ Вар4 = "" Тогда Спи.Добавить(Вар4) КонецЕсли; 
	Если НЕ Вар5 = "" Тогда Спи.Добавить(Вар5) КонецЕсли; 
	Если НЕ Вар6 = "" Тогда Спи.Добавить(Вар6) КонецЕсли; 
	Если НЕ Вар7 = "" Тогда Спи.Добавить(Вар7) КонецЕсли; 
	Если НЕ Вар8 = "" Тогда Спи.Добавить(Вар8) КонецЕсли; 
	Если НЕ Вар9 = "" Тогда Спи.Добавить(Вар9) КонецЕсли; 
	Если НЕ Вар10 = "" Тогда Спи.Добавить(Вар10) КонецЕсли; 
	Если НЕ Вар11 = "" Тогда Спи.Добавить(Вар11) КонецЕсли; 
	Если НЕ Вар12 = "" Тогда Спи.Добавить(Вар12) КонецЕсли; 
	Если НЕ Вар13 = "" Тогда Спи.Добавить(Вар13) КонецЕсли; 
	Если НЕ Вар14 = "" Тогда Спи.Добавить(Вар14) КонецЕсли; 
	Если НЕ Вар15 = "" Тогда Спи.Добавить(Вар15) КонецЕсли; 
	Если НЕ Вар16 = "" Тогда Спи.Добавить(Вар16) КонецЕсли; 
	Если НЕ Вар17 = "" Тогда Спи.Добавить(Вар17) КонецЕсли; 
	Если НЕ Вар18 = "" Тогда Спи.Добавить(Вар18) КонецЕсли; 
	Если НЕ Вар19 = "" Тогда Спи.Добавить(Вар19) КонецЕсли; 
	Если НЕ Вар20 = "" Тогда Спи.Добавить(Вар20) КонецЕсли; 
	
	Пар = Новый Структура("Список", Спи);
	Пар.Вставить("Заголовок", Загол);
	
	Если ТипЗнч(Старт) = Тип("Число") Тогда 
		Пар.Вставить("Старт", Старт);
	Иначе 
		СтартЧисло = 1;
		гоВЗН("Вариант", Старт, СтартЧисло, "Число");
		Если СтартЧисло = 0 Тогда СтартЧисло = 1 КонецЕсли; 
		Пар.Вставить("Старт", СтартЧисло);
	КонецЕсли; 
		
	ОткрытьФорму("ОбщаяФорма.ВыборПростогоВарианта", Пар, , , , , 
		Новый ОписаниеОповещения("клВариантЗавершение", ОбработчикиКомандКлиент, Новый Структура("Старт, ОписаниеОповещенияОЗавершении", Старт, ОписаниеОповещенияОЗавершении)));
КонецПроцедуры

