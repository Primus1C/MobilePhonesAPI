// Возвращает структуру ИмяРеквизита+Номер
//
Функция НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	НомерВх = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "incomingNo,incomingNumber,incoming", Неопределено);
	Если НомерВх = Неопределено Тогда
		Номер = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "orderNo,orderNumber,order", Неопределено);
		Если Номер = Неопределено Тогда
			Возврат Неопределено;
		Иначе
			Возврат Новый Структура("ИмяРеквизита, Номер", "Номер", Номер);
		КонецЕсли;
	Иначе
		Возврат Новый Структура("ИмяРеквизита, Номер", "НомерВходящий", НомерВх);
	КонецЕсли;
	
КонецФункции

// Ищет Заказ (документ ИнвойсПродажи с видом «Заказ покупателя») по номеру
// и, при необходимости, по дате. Проверяет принадлежность учётной записи API-клиента
// и отсутствие пометки удаления.
//
// Параметры:
//  НомерЗаказа  - Структура - параметры поиска заказа:
//      * ИмяРеквизита - Строка - имя реквизита документа для поиска:
//          "Номер"           - внутренний номер 1С;
//          "НомерВходящий"   - входящий номер клиента (incomingNo / incomingNumber);
//      * Номер         - Строка - значение номера для поиска;
//  ДатаЗаказа   - Дата - дата заказа; если не задана (''), фильтр по дате не применяется;
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиИнтеграции - учётная запись интеграции,
//      от имени которой выполняется запрос; заказ должен принадлежать этой записи;
//  Ошибка       - Строка - текст ошибки, заполняется при неуспешном поиске
//      (пустой номер, заказ не найден, другая учётная запись, пометка удаления).
//
// Возвращаемое значение:
//  ДокументСсылка.ИнвойсПродажи - ссылка на найденный заказ;
//  пустая ссылка - если заказ не найден или поиск завершился с ошибкой.
//
Функция НайтиИнвойсПродажи(СтруктураНомера, ДатаЗаказа = "", УчетнаяЗапись, Результат)
	
	Если НЕ ЗначениеЗаполнено(СтруктураНомера.Номер) Тогда
		Результат.error = "Номер заказа пустой."; 
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	Запр = Новый Запрос; 
	Запр.УстановитьПараметр("Номер", СтруктураНомера.Номер);
	Запр.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	             |	ИнвойсПродажи.Ссылка КАК Ссылка,
	             |	ИнвойсПродажи.ПометкаУдаления КАК ПометкаУдаления,
	             |	ИнвойсПродажи.УчетнаяЗапись КАК УчетнаяЗапись
	             |ИЗ
	             |	Документ.ИнвойсПродажи КАК ИнвойсПродажи
	             |ГДЕ
	             |	ИнвойсПродажи.Номер = &Номер
	             |	И ИСТИНА = ИСТИНА";  
	Если СтруктураНомера.ИмяРеквизита = "НомерВходящий" Тогда
	 	Запр.Текст = СтрЗаменить(Запр.Текст, "ИнвойсПродажи.Номер = &Номер", "ИнвойсПродажи.НомерВходящий = &Номер");
	КонецЕсли;  
	Если ДатаЗаказа <> "" Тогда
	 	Запр.Текст = СтрЗаменить(Запр.Текст, "ИСТИНА = ИСТИНА", "ИнвойсПродажи.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)");
		Запр.УстановитьПараметр("Дата", ДатаЗаказа);
	КонецЕсли;
    РезультатЗапроса = Запр.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Результат.НеНайден = Истина;
		Результат.error = СтрШаблон("Заказ %1 не найден.", СтруктураНомера.Номер); 
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Если StockAPI_Утилиты.ЭтоАдминистраторAPI(УчетнаяЗапись) Тогда
			Если НЕ ЗначениеЗаполнено(Выборка.УчетнаяЗапись) Тогда
				Результат.error = СтрШаблон("Заказ %1 не связан с учётной записью интеграции.", СтруктураНомера.Номер);
				Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
			КонецЕсли;
		ИначеЕсли Выборка.УчетнаяЗапись <> УчетнаяЗапись Тогда
			Результат.error = СтрШаблон("Заказ %1 принадлежит другой учетной записи API-клиента.", СтруктураНомера.Номер); 
			Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
		КонецЕсли;
		Если Выборка.ПометкаУдаления Тогда
			Результат.error = СтрШаблон("Заказ %1 удален.", СтруктураНомера.Номер); 
			Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
		КонецЕсли;
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
КонецФункции

