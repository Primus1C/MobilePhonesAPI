	ДокОснование = СсылкаНакладной.ДокументОснование;
	Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.ИнвойсПродажи") И ЗначениеЗаполнено(ДокОснование) Тогда
		Накладная.Вставить("incomingNumber", ДокОснование.НомерВходящий);
	КонецЕсли;
	
	ДанныеВозврата = ВозвратПоРасходнойНакладной(СсылкаНакладной);
	Накладная.Вставить("returnNumber", ДанныеВозврата.Номер);
	Накладная.Вставить("returnDate", StockAPI_Утилиты.ДатаВСтроку(ДанныеВозврата.Дата));
	
	ЗапТовары = Новый Запрос;
	Если ССериями Тогда
		ЗапТовары.Текст = "ВЫБРАТЬ
		                  |	Товары.Номенклатура.Наименование КАК Номенклатура,
		                  |	Товары.Номенклатура.Код КАК Код,
		                  |	Товары.Номенклатура.SKU КАК SKU,
		                  |	Товары.Количество КАК Количество,
		                  |	Товары.ЦенаПродажи КАК ЦенаПродажи,
		                  |	Товары.СуммаПродажи КАК СуммаПродажи,
		                  |	Товары.Серия КАК Серия,
		                  |	Товары.НомерСтроки КАК НомерСтроки
		                  |ИЗ
		                  |	Документ.РасходнаяНакладная.Товары КАК Товары
		                  |ГДЕ
		                  |	Товары.Ссылка = &Ссылка
		                  |
		                  |УПОРЯДОЧИТЬ ПО
		                  |	Товары.НомерСтроки";
	Иначе
		ЗапТовары.Текст = "ВЫБРАТЬ
		                  |	Товары.Номенклатура.Наименование КАК Номенклатура,
		                  |	Товары.Номенклатура.Код КАК Код,
		                  |	Товары.Номенклатура.SKU КАК SKU,
		                  |	СУММА(Товары.Количество) КАК Количество,
		                  |	Товары.ЦенаПродажи КАК ЦенаПродажи,
		                  |	СУММА(Товары.СуммаПродажи) КАК СуммаПродажи,
		                  |	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтроки
		                  |ИЗ
		                  |	Документ.РасходнаяНакладная.Товары КАК Товары
		                  |ГДЕ
		                  |	Товары.Ссылка = &Ссылка
		                  |
		                  |СГРУППИРОВАТЬ ПО
		                  |	Товары.Номенклатура,
		                  |	Товары.Номенклатура.Наименование,
		                  |	Товары.Номенклатура.Код,
		                  |	Товары.ЦенаПродажи,
		                  |	Товары.Номенклатура.SKU
		                  |
		                  |УПОРЯДОЧИТЬ ПО
		                  |	НомерСтроки";
	КонецЕсли;
	ЗапТовары.УстановитьПараметр("Ссылка", СсылкаНакладной);
	
	МассивСтрок = Новый Массив;
	ВыборкаТовары = ЗапТовары.Выполнить().Выбрать();
	Пока ВыборкаТовары.Следующий() Цикл
		СтрокаJSON = Новый Структура("item, itemCode, sku, qty, price, amount",
			ВыборкаТовары.Номенклатура,
			StockAPI_Утилиты.КодВСтроку(ВыборкаТовары.Код),
			ВыборкаТовары.sku,
			ВыборкаТовары.Количество,
			ВыборкаТовары.ЦенаПродажи,
			ВыборкаТовары.СуммаПродажи);
		Если ССериями Тогда
			СтрокаJSON.Вставить("serial", СокрЛП(ВыборкаТовары.Серия));
		КонецЕсли;
		МассивСтрок.Добавить(СтрокаJSON);
	КонецЦикла;
	
	Накладная.Вставить("items", МассивСтрок);
	Возврат Накладная;
	
КонецФункции

Функция ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайла, Расширение)
	
	ИмяФайла = ПолучитьИмяВременногоФайла("." + Расширение);
	ТабДок.Записать(ИмяФайла, ТипФайла);
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайла);
	Попытка
		УдалитьФайлы(ИмяФайла);
	Исключение
	КонецПопытки;
	Возврат ДвоичныеДанные;
	
КонецФункции

Функция ИмяФайлаРасходнойНакладной(СсылкаНакладной, Расширение)
	
	БезопасныйНомер = СтрЗаменить(СокрЛП(СсылкаНакладной.Номер), "/", "-");
	БезопасныйНомер = СтрЗаменить(БезопасныйНомер, "\", "-");
	Возврат "delivery-note-" + БезопасныйНомер + "." + Расширение;
	
КонецФункции

#КонецОбласти


#Область POST_delivery
	
// ─── Расходные накладные (POST /delivery) ───────────────────────────────

Функция СоздатьРасходнуюНакладную(ДанныеЗапроса, КонтекстАвторизации) Экспорт
	
	Результат = Новый Структура("success, error, number", Ложь, "", "");
	
	НомерЗаказа = НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса);
	Если НомерЗаказа = Неопределено Тогда
		Результат.error = "Не указан номер заказа входящий (incomingNo или incomingNumber или incoming), или номер 1С (orderNo или orderNumber или order).";
		Возврат Результат;
	КонецЕсли;
	
	СерииРезультат = СерииИзЗапросаDelivery(ДанныеЗапроса);
	Если СерииРезультат.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СерииРезультат.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СерииРезультат.Серии.Количество() = 0 Тогда
		Результат.error = "Массив serials пуст.";
		Возврат Результат;
	КонецЕсли;
	
	УчетнаяЗапись = КонтекстАвторизации.УчетнаяЗапись;
	СсылкаИнвойса = НайтиИнвойсПродажи(НомерЗаказа, , УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Инвойс = СсылкаИнвойса.ПолучитьОбъект();
	Если НЕ Инвойс.Проведен Тогда
		Результат.error = СтрШаблон("Заказ %1 не проведён.", НомерЗаказа);
		Возврат Результат;
	КонецЕсли;
	
	Если Инвойс.Проформа = Перечисления.ВидыИнвойса.Инвойс Тогда
		Результат.error = "Расходную накладную можно создавать только на основании проформы или заказа.";
		Возврат Результат;
	КонецЕсли;
	
	РасходнаяНакладнаяПоИнвойсу = РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса);
	Если ЗначениеЗаполнено(РасходнаяНакладнаяПоИнвойсу.Ссылка) Тогда
		Результат.error = СтрШаблон("По заказу уже создана: %1 (%2).", 
									РасходнаяНакладнаяПоИнвойсу.Ссылка,
									?(РасходнаяНакладнаяПоИнвойсу.Проведен, "проведена", "не проведена"));
		Возврат Результат;
	КонецЕсли;
	
	СоставИнвойса = СоставИнвойсаДляОтгрузки(СсылкаИнвойса);
	Если СоставИнвойса.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СоставИнвойса.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СоставИнвойса.КоличествоВсего = 0 Тогда
		Результат.error = "В заказе нет товаров.";
		Возврат Результат;
	КонецЕсли;
	
	РазборСерий = РазобратьСерииДляОтгрузки(СерииРезультат.Серии, СоставИнвойса);
	Если РазборСерий.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(РазборСерий.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Док = Документы.РасходнаяНакладная.СоздатьДокумент();
	ОшибкиЗаполнения = ЗаполнитьРасходнуюПоИнвойсуИСериям(Док, Инвойс, РазборСерий.Строки);
	Если ОшибкиЗаполнения.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЗаполнения);
		Возврат Результат;
	КонецЕсли;
	
	ДанныеСотрудника = StockAPI_Справочники.СотрудникИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись);
    Если ДанныеСотрудника.Ошибка = "" Тогда
		Док.Сборщик = ДанныеСотрудника.Сотрудник; 
	Иначе
		// некритическая ошибка
		Результат.error = ДанныеСотрудника.Ошибка;
	КонецЕсли;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.error = "Не удалось провести расходную накладную: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success = Истина;
	Результат.number = Док.Номер;
	Возврат Результат;
	
КонецФункции

Функция СерииИзЗапросаDelivery(ДанныеЗапроса)
	
	Результат = Новый Структура("Серии, Ошибки", Новый Массив, Новый СписокЗначений);
	
	Если ДанныеЗапроса = Неопределено ИЛИ НЕ ДанныеЗапроса.Свойство("serials") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива serials.");
		Возврат Результат;
	КонецЕсли;
	
	СерииЗапроса = ДанныеЗапроса.serials;
	Если ТипЗнч(СерииЗапроса) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле serials должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	Уникальные = Новый Соответствие;
	Для Каждого Серия Из СерииЗапроса Цикл
		
		Если ТипЗнч(Серия) = Тип("Число") Тогда
		 	СерияСтрокой = Формат(Серия, "ЧГ=");
		Иначе
			СерияСтрокой = СокрЛП(Строка(Серия));
		КонецЕсли;
		Если СерияСтрокой = "" Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ = НРег(СерияСтрокой);
		Если Уникальные.Получить(Ключ) = Неопределено Тогда
			Уникальные.Вставить(Ключ, Истина);
			Результат.Серии.Добавить(СерияСтрокой);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция СоставИнвойсаДляОтгрузки(СсылкаИнвойса)
	
	Результат = Новый Структура("Количества, Цены, Наименования, Ошибки, КоличествоВсего", Новый Соответствие, Новый Соответствие, Новый Соответствие, Новый СписокЗначений, 0);
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Товары.Номенклатура КАК Номенклатура,
	            |	Товары.Номенклатура.Наименование КАК Наименование,
	            |	Товары.Номенклатура.УчетПоСериям КАК УчетПоСериям,
	            |	Товары.Количество КАК Количество,
	            |	Товары.Цена КАК Цена
	            |ИЗ
	            |	Документ.ИнвойсПродажи.Товары КАК Товары
	            |ГДЕ
	            |	Товары.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаИнвойса);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если НЕ Выборка.УчетПоСериям Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Позиция «%1» не ведёт серийный учёт.", СокрЛП(Выборка.Наименование)));
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = Результат.Количества.Получить(Выборка.Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		
		Результат.Количества.Вставить(Выборка.Номенклатура, ТекущееКоличество + Выборка.Количество);
		Результат.Цены.Вставить(Выборка.Номенклатура, Выборка.Цена);
		Результат.Наименования.Вставить(Выборка.Номенклатура, СокрЛП(Выборка.Наименование));
		Результат.КоличествоВсего = Результат.КоличествоВсего + Выборка.Количество;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция НоменклатурыСерийИзСправочника(МассивСерий)
	
	Соответствие = Новый Соответствие;
	Если МассивСерий.Количество() = 0 Тогда
		Возврат Соответствие;
	КонецЕсли;
	
	МассивВРег = Новый Массив;
	МассивНРег = Новый Массив;
	Для Каждого Серия Из МассивСерий Цикл
		МассивВРег.Добавить(ВРег(Серия));
		МассивНРег.Добавить(НРег(Серия));
	КонецЦикла;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Партии.Серия КАК Серия,
	            |	Партии.Владелец КАК Номенклатура
	            |ИЗ
	            |	Справочник.Партии КАК Партии
	            |ГДЕ
	            |	НЕ Партии.ПометкаУдаления
	            |	И Партии.Серия <> """"
	            |	И (Партии.Серия В (&Серии)
	            |			ИЛИ Партии.Серия В (&СерииВРег)
	            |			ИЛИ Партии.Серия В (&СерииНРег))";
	Зап.УстановитьПараметр("Серии", МассивСерий);
	Зап.УстановитьПараметр("СерииВРег", МассивВРег);
	Зап.УстановитьПараметр("СерииНРег", МассивНРег);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Серия = СокрЛП(Выборка.Серия);
		Сведения = Новый Структура("Серия, Номенклатура", Серия, Выборка.Номенклатура);
		Соответствие.Вставить(Серия, Сведения);
		Соответствие.Вставить(ВРег(Серия), Сведения);
		Соответствие.Вставить(НРег(Серия), Сведения);
		
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

Функция РазобратьСерииДляОтгрузки(МассивСерий, СоставИнвойса)
	
	Результат = Новый Структура("Строки, Ошибки", Новый Массив, Новый СписокЗначений);
	НоменклатурыСерий = НоменклатурыСерийИзСправочника(МассивСерий);
	КоличестваСерий = Новый Соответствие;
	
	Для Каждого Серия Из МассивСерий Цикл
		
		СведенияСерии = НоменклатурыСерий.Получить(Серия);
		Если СведенияСерии = Неопределено Тогда
			СведенияСерии = НоменклатурыСерий.Получить(ВРег(Серия));
		КонецЕсли;
		Если СведенияСерии = Неопределено Тогда
			СведенияСерии = НоменклатурыСерий.Получить(НРег(Серия));
		КонецЕсли;
		Если СведенияСерии = Неопределено Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Серия %1 не найдена.", Серия));
			Продолжить;
		КонецЕсли;
		
		Номенклатура = СведенияСерии.Номенклатура;
		Если СоставИнвойса.Количества.Получить(Номенклатура) = Неопределено Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Серия %1: товар не входит в состав заказа.", Серия));
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = КоличестваСерий.Получить(Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		КоличестваСерий.Вставить(Номенклатура, ТекущееКоличество + 1);
		
		СтрокаСерии = Новый Структура("Серия, Номенклатура, ЦенаПродажи",
			СведенияСерии.Серия,
			Номенклатура,
			СоставИнвойса.Цены.Получить(Номенклатура));
		Результат.Строки.Добавить(СтрокаСерии);
		
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() > 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Результат.Строки.Количество() <> СоставИнвойса.КоличествоВсего Тогда
		Результат.Ошибки.Добавить(СтрШаблон("Количество серий (%1) не совпадает с количеством товаров в заказе (%2).",
			Результат.Строки.Количество(),
			СоставИнвойса.КоличествоВсего));
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого КлючЗначение Из СоставИнвойса.Количества Цикл
		
		КоличествоСерий = КоличестваСерий.Получить(КлючЗначение.Ключ);
		Если КоличествоСерий = Неопределено Тогда
			КоличествоСерий = 0;
		КонецЕсли;
		
		Если КоличествоСерий <> КлючЗначение.Значение Тогда
			ИмяТовара = СоставИнвойса.Наименования.Получить(КлючЗначение.Ключ);
			Если ИмяТовара = Неопределено Тогда
				ИмяТовара = Строка(КлючЗначение.Ключ);
			КонецЕсли;
			Результат.Ошибки.Добавить(СтрШаблон("По товару «%1» передано серий %2, в заказе %3.",
				ИмяТовара,
				КоличествоСерий,
				КлючЗначение.Значение));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьРасходнуюПоИнвойсуИСериям(Док, Инвойс, СтрокиСерий)
	
	Ошибки = Новый СписокЗначений;
	
	Док.Дата 			= ТекущаяДатаСеанса();
	Док.Фирма 			= Инвойс.Фирма;
	Док.ДокументОснование = Инвойс.Ссылка;
	Док.Склад 			= Инвойс.Склад;
	Док.Контрагент 		= Инвойс.Контрагент;
	Док.Валюта 			= Инвойс.Валюта;
	Док.СуммаУслуг 		= Инвойс.Доставка; 
	Док.Окончательно	= Истина;
	Док.Товары.Очистить();
	
	Для Каждого СтрокаСерии Из СтрокиСерий Цикл
		
		СпиПар = омСервер.ПартииПоСерииОстатки(СтрокаСерии.Серия, Док.Фирма, Док.Склад);
		Если СпиПар.Количество() = 0 Тогда
			Ошибки.Добавить(СтрШаблон("Не найдена партия на складе для серии %1.", СтрокаСерии.Серия));
			Продолжить;
		ИначеЕсли СпиПар.Количество() > 1 Тогда
			Ошибки.Добавить(СтрШаблон("Для серии %1 найдено несколько партий на складе.", СтрокаСерии.Серия));
			Продолжить;
		КонецЕсли;
		
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрокаСерии.Номенклатура;
		НовСтр.Партия 		= СпиПар[0].Значение;
		НовСтр.Количество 	= 1;
		НовСтр.ЦенаПродажи 	= СтрокаСерии.ЦенаПродажи;
		НовСтр.СуммаПродажи = НовСтр.ЦенаПродажи;
		
	КонецЦикла;
	
	Возврат Ошибки;
	
КонецФункции

#КонецОбласти


#Область PATCH_delivery

Функция ЗаблокироватьРасходнуюНакладную(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура(
		"success, error, orderNumber, incomingNumber, deliveryNumber, status, statusSetBy, statusDate, НеНайден, КонфликтСтатуса",
		Ложь, "", "", "", "", "", "", "", Ложь, Ложь);
	
	НомерЗаказа = НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса);
	Если НомерЗаказа = Неопределено Тогда
		Результат.error = "Не указан номер заказа: incomingNumber (или incomingNo, incoming), либо orderNumber (или orderNo, order).";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаИнвойса = НайтиИнвойсПродажи(НомерЗаказа, , УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		//Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	ДанныеРасходной = РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса);
	Если НЕ ЗначениеЗаполнено(ДанныеРасходной.Ссылка) Тогда
		Результат.error = СтрШаблон("Расходная накладная по заказу %1 не найдена.", НомерЗаказа.Номер);
		Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Статусы = Перечисления.СтатусыИнвойсаПродажи;
	ТекущийСтатус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СсылкаИнвойса);
	Состояние = ТекущийСтатус.Состояние;
	
	Если Состояние = Статусы.Собирается Тогда
		Результат.error = "Заказ уже заблокирован (статус: Собирается).";
		Результат.КонфликтСтатуса = Истина;
		Возврат Результат;
	ИначеЕсли Состояние = Статусы.Отгружен Или ДанныеРасходной.Проведен Тогда
		Результат.error = "Заказ уже отгружен.";
		Результат.КонфликтСтатуса = Истина;
		Возврат Результат;
	ИначеЕсли Состояние = Статусы.Отменен Тогда
		Результат.error = "Заказ отменён.";
		Результат.КонфликтСтатуса = Истина;
		Возврат Результат;
	КонецЕсли;
	
	ДанныеСотрудника = StockAPI_Справочники.СотрудникИзДанныхЗапроса(ДанныеЗапроса);
	Если ДанныеСотрудника.Ошибка <> "" Тогда
		Результат.error = ДанныеСотрудника.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Отказ = Ложь;
	РаботаСИнвойсами.ЗаписатьСтатусИнвойсаПродажи(СсылкаИнвойса,
													,
													ДанныеРасходной.Ссылка, 
													ДанныеСотрудника.Сотрудник, 
													, , 
													ТекущаяДатаСеанса(),
													Отказ);
	Если Отказ Тогда
		Результат.error = "Не удалось установить статус «Собирается (заблокирован)».";
		Возврат Результат;
	КонецЕсли;
	
	НовыйСтатус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СсылкаИнвойса);
	Результат.success 			= Истина;
	Результат.orderNumber 		= СсылкаИнвойса.Номер;
	Результат.incomingNumber 	= СсылкаИнвойса.НомерВходящий;
	Результат.deliveryNumber 	= ДанныеРасходной.Номер;
	Результат.status 			= Строка(НовыйСтатус.Состояние); 
	Результат.statusSetBy 		= Строка(НовыйСтатус.КемИзменено);
	Результат.statusDate 		= StockAPI_Утилиты.ДатаВСтроку(НовыйСтатус.Зарегистрировано); 
	Результат.blocked           = НовыйСтатус.Заблокирован <> Дата(1,1,1);
	Возврат Результат;
	
КонецФункции

#КонецОбласти


#Область POST_status

// Устанавливает признаки blocked, canceled, readyToShip в регистре СостоянияИнвойсовПродажи.
//
// Параметры:
//  ДанныеЗапроса  - Структура - incomingNumber/orderNumber, blocked/canceled/readyToShip (хотя бы один),
//                   employeeCode/employeePin (необяз.);
//  УчетнаяЗапись  - СправочникСсылка.УчетныеЗаписиИнтеграции - учётная запись API.
//
// Возвращаемое значение:
//  Структура - success, error, orderNumber, incomingNumber, status, statusSetBy, statusDate,
//              deliveryNumber, returnNumber, shipmentDate, blocked, canceled, readyToShip,
//              НеНайден, КонфликтСтатуса.
//
Функция ИзменитьСтатусЗаказа(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура(
		"success, error, orderNumber, incomingNumber, status, statusSetBy, statusDate, deliveryNumber, returnNumber, shipmentDate, blocked, canceled, readyToShip, НеНайден, КонфликтСтатуса",
		Ложь, "", "", "", "", "", "", "", "", "", Ложь, Ложь, Ложь, Ложь, Ложь);
	
	Заблокирован 		= СтатусИзЗапроса(ДанныеЗапроса, "blocked");
	Отменен 			= СтатусИзЗапроса(ДанныеЗапроса, "canceled");
	ГотовКОтгрузке 		= СтатусИзЗапроса(ДанныеЗапроса, "readyToShip");
	
	Если Заблокирован = Неопределено И Отменен = Неопределено И ГотовКОтгрузке = Неопределено Тогда
		Результат.error = "Укажите хотя бы один параметр: blocked, canceled, readyToShip.";
		Возврат Результат;
	КонецЕсли;
	
	НомерЗаказа = НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса);
	Если НомерЗаказа = Неопределено Тогда
		Результат.error = "Не указан номер заказа: incomingNumber (или incomingNo, incoming), либо orderNumber (или orderNo, order).";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаИнвойса = НайтиИнвойсПродажи(НомерЗаказа, , УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ДанныеСотрудника = StockAPI_Справочники.СотрудникИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись);
	Если ДанныеСотрудника.Ошибка <> "" Тогда
		Результат.error = ДанныеСотрудника.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	ЗаписьСтатуса = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СсылкаИнвойса);
	ПустаяДата = Дата(1, 1, 1);
	ТекущийЗаблокирован = ЗаписьСтатуса.Заблокирован <> ПустаяДата;
	ТекущийОтменен = ЗаписьСтатуса.ОтмененЗакачиком <> ПустаяДата;
	ТекущийГотовКОтгрузке = ЗаписьСтатуса.ГотовКОтгрузке <> ПустаяДата;
	
	ВсеСовпадают = Истина;
	Если Заблокирован <> Неопределено И ТекущийЗаблокирован <> Заблокирован Тогда
		ВсеСовпадают = Ложь;
	КонецЕсли;
	Если Отменен <> Неопределено И ТекущийОтменен <> Отменен Тогда
		ВсеСовпадают = Ложь;
	КонецЕсли;
	Если ГотовКОтгрузке <> Неопределено И ТекущийГотовКОтгрузке <> ГотовКОтгрузке Тогда
		ВсеСовпадают = Ложь;
	КонецЕсли;
	Если ВсеСовпадают Тогда
		Результат.error = "Запрошенные значения статуса уже установлены.";
		Результат.КонфликтСтатуса = Истина;
		Возврат Результат;
	КонецЕсли;
	
	ДанныеРасходной = РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса);
	Если ЗначениеЗаполнено(ДанныеРасходной.Ссылка) Тогда
		Результат.deliveryNumber = ДанныеРасходной.Номер;
	КонецЕсли;
	
	Отказ = Ложь;
	РаботаСИнвойсами.ЗаписатьСтатусИнвойсаПродажи(
		СсылкаИнвойса,
		Перечисления.СтатусыИнвойсаПродажи.ПустаяСсылка(),
		СсылкаИнвойса,
		ДанныеСотрудника.Сотрудник,
		Отменен,
		ГотовКОтгрузке,
		Заблокирован,
		Отказ);
	Если Отказ Тогда
		Результат.error = "Не удалось записать статус заказа.";
		Возврат Результат;
	КонецЕсли;
	
	ЗаписьСтатуса = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СсылкаИнвойса);
	Результат.success 			= Истина;
	Результат.orderNumber 		= СсылкаИнвойса.Номер;
	Результат.incomingNumber 	= СсылкаИнвойса.НомерВходящий;
	Результат.shipmentDate      = StockAPI_Утилиты.ДатаВСтроку(СсылкаИнвойса.ДатаОтгрузки);
	Результат.status 			= Строка(ЗаписьСтатуса.Состояние);
	Результат.statusSetBy 		= Строка(ЗаписьСтатуса.КемИзменено);
	Результат.statusDate 		= StockAPI_Утилиты.ДатаВСтроку(ЗаписьСтатуса.Зарегистрировано);
	Результат.blocked           = ЗаписьСтатуса.Заблокирован <> ПустаяДата;
	Результат.canceled          = ЗаписьСтатуса.ОтмененЗакачиком <> ПустаяДата;
	Результат.readyToShip       = ЗаписьСтатуса.ГотовКОтгрузке <> ПустаяДата;
	Возврат Результат;
	
КонецФункции

// Отмена заказа: возврат по окончательной РН или отмена проведения РН, пометка проформы на удаление.
//
Функция ОбработатьОтменуЗаказа(СсылкаИнвойса, ДанныеРасходной, Сотрудник, Результат)
	
	Если ЗначениеЗаполнено(ДанныеРасходной.Ссылка) И ДанныеРасходной.Проведен Тогда
		
		Если ДанныеРасходной.Окончательно Тогда
			
			СуществующийВозврат = ВозвратПоРасходнойНакладной(ДанныеРасходной.Ссылка);
			Если ЗначениеЗаполнено(СуществующийВозврат.Ссылка) Тогда
				Результат.returnNumber = СуществующийВозврат.Номер;
			Иначе
				ДанныеВозврата = СоздатьВозвратОтПокупателяПоРасходнойНакладной(ДанныеРасходной.Ссылка);
				Если ДанныеВозврата.Ошибка <> "" Тогда
					Результат.error = ДанныеВозврата.Ошибка;
					Возврат Ложь;
				КонецЕсли;
				Результат.returnNumber = ДанныеВозврата.Номер;
			КонецЕсли;
			
		Иначе
			
			Если НЕ ОтменитьПроведениеРасходнойНакладной(ДанныеРасходной.Ссылка, Результат.error) Тогда
				Возврат Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Попытка
		Док = СсылкаИнвойса.ПолучитьОбъект();
		Если ЗначениеЗаполнено(Сотрудник) Тогда
			Док.ДополнительныеСвойства.Вставить("КемИзменено", Сотрудник);
		КонецЕсли;
		Если НЕ Док.ПометкаУдаления Тогда
			Док.УстановитьПометкуУдаления(Истина);
		КонецЕсли;
	Исключение
		Результат.error = "Не удалось отменить заказ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Создаёт и проводит документ _ВозвратОтПокупателя по проведённой окончательной расходной накладной.
//
// Параметры:
//  СсылкаРасходной - ДокументСсылка.РасходнаяНакладная - расходная накладная-основание.
//
// Возвращаемое значение:
//  Структура - Номер (Строка), Ошибка (Строка).
//
Функция СоздатьВозвратОтПокупателяПоРасходнойНакладной(СсылкаРасходной)
	
	Результат = Новый Структура("Номер, Ошибка", "", "");
	Расходная = СсылкаРасходной.ПолучитьОбъект();
	
	Если НЕ Расходная.Проведен Тогда
		Результат.Ошибка = "Расходная накладная не проведена.";
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ Расходная.Окончательно Тогда
		Результат.Ошибка = "Возврат оформляется только по окончательной расходной накладной.";
		Возврат Результат;
	КонецЕсли;
	
	Док = Документы._ВозвратОтПокупателя.СоздатьДокумент();
	Док.Дата = ТекущаяДатаСеанса();
	Док.Фирма = Расходная.Фирма;
	Док.Склад = Расходная.Склад;
	
	Для Каждого СтрокаРН Из Расходная.Товары Цикл
		
		Если СтрокаРН.Количество = 0 Или НЕ ЗначениеЗаполнено(СтрокаРН.Партия) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрокаРН.Номенклатура;
		НовСтр.Партия = СтрокаРН.Партия;
		НовСтр.Серия = ?(ЗначениеЗаполнено(СтрокаРН.Серия), СтрокаРН.Серия, СтрокаРН.Партия.Серия);
		НовСтр.Количество = СтрокаРН.Количество;
		НовСтр.ЦенаПродажи = СтрокаРН.ЦенаПродажи;
		НовСтр.СуммаПродажи = СтрокаРН.СуммаПродажи;
		НовСтр.Валюта = Расходная.Валюта;
		НовСтр.Контрагент = Расходная.Контрагент;
		НовСтр.РасходняНакладная = СсылкаРасходной;
		
	КонецЦикла;
	
	Если Док.Товары.Количество() = 0 Тогда
		Результат.Ошибка = "В расходной накладной нет строк для оформления возврата.";
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.Ошибка = "Не удалось провести возврат от покупателя: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.Номер = Док.Номер;
	Возврат Результат;
	
КонецФункции

// Отменяет проведение неокончательной расходной накладной (предварительно очищает табличную часть).
//
Функция ОтменитьПроведениеРасходнойНакладной(СсылкаРасходной, Ошибка)
	
	Ошибка = "";
	ДокРН = СсылкаРасходной.ПолучитьОбъект();
	
	Если НЕ ДокРН.Проведен Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДокРН.Окончательно Тогда
		Ошибка = "Невозможно отменить проведение окончательной расходной накладной.";
		Возврат Ложь;
	КонецЕсли;
	
	ДокРН.Товары.Очистить();
	
	Попытка
		ДокРН.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Исключение
		Ошибка = "Не удалось отменить проведение расходной накладной: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

// Ищет проведённый возврат от покупателя по расходной накладной.
//
// Параметры:
//  СсылкаРасходной - ДокументСсылка.РасходнаяНакладная - расходная накладная.
//
// Возвращаемое значение:
//  Структура - Ссылка, Номер, Дата; пустые значения, если возврат не найден.
//
Функция ВозвратПоРасходнойНакладной(СсылкаРасходной)
	
	Результат = Новый Структура("Ссылка, Номер, Дата",
		Документы._ВозвратОтПокупателя.ПустаяСсылка(), "", '00010101');
	
	Если НЕ ЗначениеЗаполнено(СсылкаРасходной) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	            |	Возврат.Ссылка КАК Ссылка,
	            |	Возврат.Номер КАК Номер,
	            |	Возврат.Дата КАК Дата
	            |ИЗ
	            |	Документ._ВозвратОтПокупателя.Товары КАК ВозвратТовары
	            |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ._ВозвратОтПокупателя КАК Возврат
	            |		ПО ВозвратТовары.Ссылка = Возврат.Ссылка
	            |ГДЕ
	            |	ВозвратТовары.РасходняНакладная = &Расходная
	            |	И Возврат.Проведен
	            |	И НЕ Возврат.ПометкаУдаления
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	Возврат.Дата УБЫВ";
	Зап.УстановитьПараметр("Расходная", СсылкаРасходной);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


 #Область GET_return

// GET /return — данные документа «Возврат от покупателя».
// Параметры: number (или returnNumber, returnNo), date (опционально).
//
// Возвращаемое значение:
//  Структура - Ошибка, НеНайден, Тело.
//
Функция ПолучитьВозвратОтПокупателя(Запрос, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура("Ошибка, НеНайден, Тело", "", Ложь, Неопределено);
	
	НомерВозврата = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "number,returnNumber,returnNo");
	//Если НомерВозврата = "" Тогда
	//	НомерВозврата = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "returnNumber");
	//КонецЕсли;
	//Если НомерВозврата = "" Тогда
	//	НомерВозврата = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "returnNo");
	//КонецЕсли;
	Если НомерВозврата = "" Тогда
		Результат.Ошибка = "Укажите number (или returnNumber, returnNo) — номер документа возврата от покупателя.";
		Возврат Результат;
	КонецЕсли;
	
	ДатаВозврата = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "date");
	Если ДатаВозврата = "" Тогда
		ДатаВозврата = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "returnDate");
	КонецЕсли;
	
	СсылкаВозврата = НайтиВозвратОтПокупателя(НомерВозврата, ?(ДатаВозврата = Неопределено, '00010101', ДатаВозврата));
	Если НЕ ЗначениеЗаполнено(СсылкаВозврата) Тогда
		Результат.Ошибка = СтрШаблон("Документ возврата от покупателя %1 не найден.", НомерВозврата);
		Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Результат.Тело = СформироватьJSONВозвратаОтПокупателя(СсылкаВозврата);
	Исключение
		Результат.Ошибка = "Не удалось сформировать ответ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция НайтиВозвратОтПокупателя(НомерВозврата, ДатаВозврата = '00010101')
	
	Если СокрЛП(НомерВозврата) = "" Тогда
		Возврат Документы._ВозвратОтПокупателя.ПустаяСсылка();
	КонецЕсли;
	
	Если ДатаВозврата <> '00010101' Тогда
		Ссылка = Документы._ВозвратОтПокупателя.НайтиПоНомеру(НомерВозврата, ДатаВозврата);
		Если ЗначениеЗаполнено(Ссылка) И НЕ Ссылка.ПометкаУдаления Тогда
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	            |	Возврат.Ссылка КАК Ссылка
	            |ИЗ
	            |	Документ._ВозвратОтПокупателя КАК Возврат
	            |ГДЕ
	            |	Возврат.Номер = &Номер
	            |	И НЕ Возврат.ПометкаУдаления
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	Возврат.Дата УБЫВ";
	Зап.УстановитьПараметр("Номер", СокрЛП(НомерВозврата));
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Документы._ВозвратОтПокупателя.ПустаяСсылка();
	
КонецФункции

Функция СформироватьJSONВозвратаОтПокупателя(СсылкаВозврата)
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Возврат.Номер КАК Номер,
	            |	Возврат.Дата КАК Дата,
	            |	Возврат.Проведен КАК Проведен,
	            |	Возврат.Склад.Наименование КАК Склад,
	            |	Возврат.Склад.Код КАК КодСклада,
	            |	Возврат.СуммаДокумента КАК Сумма,
	            |	isnull(Возврат.Сборщик.Наименование, """") КАК Сборщик,
	            |	isnull(Возврат.Сборщик.Код,0) КАК СборщикКод
	            |ИЗ
	            |	Документ._ВозвратОтПокупателя КАК Возврат
	            |ГДЕ
	            |	Возврат.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаВозврата);
	
	ВыборкаШапки = Зап.Выполнить().Выбрать();
	Если НЕ ВыборкаШапки.Следующий() Тогда
		ВызватьИсключение "Не удалось прочитать документ возврата от покупателя.";
	КонецЕсли;
	
	ВозвратJSON = Новый Структура;
	ВозвратJSON.Вставить("returnNumber", 	ВыборкаШапки.Номер);
	ВозвратJSON.Вставить("date", 			StockAPI_Утилиты.ДатаВСтроку(ВыборкаШапки.Дата));
	ВозвратJSON.Вставить("posted", 			ВыборкаШапки.Проведен);
	ВозвратJSON.Вставить("warehouse", 		ВыборкаШапки.Склад);
	ВозвратJSON.Вставить("warehouseCode", 	StockAPI_Утилиты.КодВСтроку(ВыборкаШапки.КодСклада));
	ВозвратJSON.Вставить("amount", 			ВыборкаШапки.Сумма);
	ВозвратJSON.Вставить("employee", 		ВыборкаШапки.Сборщик);
	ВозвратJSON.Вставить("employeeCode", 	StockAPI_Утилиты.КодВСтроку(ВыборкаШапки.СборщикКод));
	
	ЗапСвязи = Новый Запрос;
	ЗапСвязи.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	                 |	ВозвратТовары.Контрагент.Наименование КАК Контрагент,
	                 |	ВозвратТовары.Контрагент.Код КАК КодКонтрагента,
	                 |	ВозвратТовары.Валюта.Наименование КАК Валюта,
	                 |	ВозвратТовары.РасходняНакладная.Номер КАК НомерНакладной,
	                 |	РН.ДокументОснование.Номер КАК НомерЗаказа,
	                 |	Инвойс.НомерВходящий КАК НомерВходящий
	                 |ИЗ
	                 |	Документ._ВозвратОтПокупателя КАК Возврат
	                 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ._ВозвратОтПокупателя.Товары КАК ВозвратТовары
	                 |		ПО Возврат.Ссылка = ВозвратТовары.Ссылка
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РН
	                 |		ПО (ВозвратТовары.РасходняНакладная = РН.Ссылка)
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИнвойсПродажи КАК Инвойс
	                 |		ПО (РН.ДокументОснование = Инвойс.Ссылка)
	                 |ГДЕ
	                 |	Возврат.Ссылка = &Ссылка
	                 |
	                 |УПОРЯДОЧИТЬ ПО
	                 |	ВозвратТовары.НомерСтроки";
	ЗапСвязи.УстановитьПараметр("Ссылка", СсылкаВозврата);
	
	ВыборкаСвязи = ЗапСвязи.Выполнить().Выбрать();
	Если ВыборкаСвязи.Следующий() Тогда
		ВозвратJSON.Вставить("customer", ВыборкаСвязи.Контрагент);
		ВозвратJSON.Вставить("customerCode", StockAPI_Утилиты.КодВСтроку(ВыборкаСвязи.КодКонтрагента));
		Если ЗначениеЗаполнено(ВыборкаСвязи.Валюта) Тогда
			ВозвратJSON.Вставить("currency", ВыборкаСвязи.Валюта);
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаСвязи.НомерНакладной) Тогда
			ВозвратJSON.Вставить("deliveryNumber", ВыборкаСвязи.НомерНакладной);
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаСвязи.НомерЗаказа) Тогда
			ВозвратJSON.Вставить("orderNumber", ВыборкаСвязи.НомерЗаказа);
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаСвязи.НомерВходящий) Тогда
			ВозвратJSON.Вставить("incomingNumber", ВыборкаСвязи.НомерВходящий);
		КонецЕсли;
	КонецЕсли;
	
	ЗапТовары = Новый Запрос;
	ЗапТовары.Текст = "ВЫБРАТЬ
	                  |	Товары.Номенклатура.Наименование КАК Номенклатура,
	                  |	Товары.Номенклатура.Код КАК Код,
	                  |	Товары.Номенклатура.SKU КАК SKU,
	                  |	Товары.Количество КАК Количество,
	                  |	Товары.ЦенаПродажи КАК ЦенаПродажи,
	                  |	Товары.СуммаПродажи КАК СуммаПродажи,
	                  |	Товары.Серия КАК Серия,
	                  |	Товары.РасходняНакладная.Номер КАК НомерНакладной,
	                  |	Товары.ПричинаВозврата КАК ПричинаВозврата,
	                  |	Товары.НомерСтроки КАК НомерСтроки
	                  |ИЗ
	                  |	Документ._ВозвратОтПокупателя.Товары КАК Товары
	                  |ГДЕ
	                  |	Товары.Ссылка = &Ссылка
	                  |
	                  |УПОРЯДОЧИТЬ ПО
	                  |	Товары.НомерСтроки";
	ЗапТовары.УстановитьПараметр("Ссылка", СсылкаВозврата);
	
	МассивСтрок = Новый Массив;
	//МассивСерий = Новый Массив;
	ВыборкаТовары = ЗапТовары.Выполнить().Выбрать();
	Пока ВыборкаТовары.Следующий() Цикл
		
		СтрокаJSON = Новый Структура("item, itemCode, sku, qty, price, amount",
			ВыборкаТовары.Номенклатура,
			StockAPI_Утилиты.КодВСтроку(ВыборкаТовары.Код), 
			ВыборкаТовары.SKU,
			ВыборкаТовары.Количество,
			ВыборкаТовары.ЦенаПродажи,
			ВыборкаТовары.СуммаПродажи);
		
		СерияСтрокой = СокрЛП(ВыборкаТовары.Серия);
		Если СерияСтрокой <> "" Тогда
			СтрокаJSON.Вставить("serial", СерияСтрокой);
			//МассивСерий.Добавить(СерияСтрокой);
		КонецЕсли;
		//Если ЗначениеЗаполнено(ВыборкаТовары.НомерНакладной) Тогда
		//	СтрокаJSON.Вставить("deliveryNumber", ВыборкаТовары.НомерНакладной);
		//КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаТовары.ПричинаВозврата) Тогда
			СтрокаJSON.Вставить("reason", Строка(ВыборкаТовары.ПричинаВозврата));
		КонецЕсли;
		
		МассивСтрок.Добавить(СтрокаJSON);
		
	КонецЦикла;
	
	ВозвратJSON.Вставить("items", МассивСтрок);
	//ВозвратJSON.Вставить("serials", МассивСерий);
	Возврат ВозвратJSON;
	
КонецФункции

#КонецОбласти


#Область POST_return

// Создаёт документ ВозвратОтПокупателя по сериям из расходной накладной.
//
// Параметры:
//  ДанныеЗапроса  - Структура - orderNo/orderNumber/incomingNumber или delivery/deliveryNumber,
//      serials (массив), employeeCode или employeePin (обяз.);
//  УчетнаяЗапись  - СправочникСсылка.УчетныеЗаписиИнтеграции - учётная запись API.
//
// Возвращаемое значение:
//  Структура - success, error, returnNumber, deliveryNumber, orderNumber, incomingNumber,
//      serials, НеНайден, Конфликт.
//
Функция СоздатьВозвратОтПокупателя(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура(
		"success, error, returnNumber, deliveryNumber, orderNumber, incomingNumber, serials, НеНайден, Конфликт",
		Ложь, "", "", "", "", "", Новый Массив, Ложь, Ложь);
	
	СерииРезультат = СерииИзЗапросаDelivery(ДанныеЗапроса);
	Если СерииРезультат.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СерииРезультат.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СерииРезультат.Серии.Количество() = 0 Тогда
		Результат.error = "Массив serials пуст.";
		Возврат Результат;
	КонецЕсли;
	
	КодСотрудника = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "employeeCode", "");
	ПинСотрудника = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "employeePin", "");
	Если СокрЛП(Строка(КодСотрудника)) = "" И СокрЛП(Строка(ПинСотрудника)) = "" Тогда
		Результат.error = "Укажите employeeCode или employeePin.";
		Возврат Результат;
	КонецЕсли;
	
	ДанныеСотрудника = StockAPI_Справочники.СотрудникИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись);
	Если ДанныеСотрудника.Ошибка <> "" Тогда
		Результат.error = ДанныеСотрудника.Ошибка;
		Возврат Результат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДанныеСотрудника.Сотрудник) Тогда
		Результат.error = "Сотрудник не найден.";
		Возврат Результат;
	КонецЕсли;
	
	ДанныеРасходной = РасходнаяНакладнаяИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(ДанныеРасходной.Ссылка) Тогда
		Если Результат.error = "" Тогда
			Результат.error = "Расходная накладная не найдена.";
			Результат.НеНайден = Истина;
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	Расходная = ДанныеРасходной.Ссылка.ПолучитьОбъект();
	Если НЕ Расходная.Проведен Тогда
		Результат.error = "Расходная накладная не проведена.";
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ Расходная.Окончательно Тогда
		Результат.error = "Возврат оформляется только по окончательной расходной накладной.";
		Возврат Результат;
	КонецЕсли;
	
	СерииРасходной = СерииСтрокРасходнойНакладной(Расходная);
	ОшибкиСерий = Новый СписокЗначений;
	СтрокиВозврата = Новый Массив;
	
	Для Каждого Серия Из СерииРезультат.Серии Цикл
		
		СтрокаРН = НайтиСтрокуРасходнойПоСерии(СерииРасходной, Серия);
		Если СтрокаРН = Неопределено Тогда
			ОшибкиСерий.Добавить(СтрШаблон("Серия %1 не входит в расходную накладную %2.", Серия, Расходная.Номер));
			Продолжить;
		КонецЕсли;
		
		СтрокиВозврата.Добавить(СтрокаРН);
		
	КонецЦикла;
	
	Если ОшибкиСерий.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиСерий);
		Возврат Результат;
	КонецЕсли;
	
	УжеВозвращенные = СерииУжеВозвращенныеПоРасходной(ДанныеРасходной.Ссылка, СерииРезультат.Серии);
	Если УжеВозвращенные.Количество() > 0 Тогда
		Результат.error = "Серии уже возвращены: " + СтрСоединить(УжеВозвращенные, ", ");
		Результат.Конфликт = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Док = Документы._ВозвратОтПокупателя.СоздатьДокумент();
	Док.Дата = ТекущаяДатаСеанса();
	Док.Фирма = Расходная.Фирма;
	Док.Склад = Расходная.Склад;
	Док.Сборщик = ДанныеСотрудника.Сотрудник;
	Док.ДополнительныеСвойства.Вставить("КемИзменено", ДанныеСотрудника.Сотрудник);
	
	Для Каждого СтрокаРН Из СтрокиВозврата Цикл
		
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрокаРН.Номенклатура;
		НовСтр.Партия 		= СтрокаРН.Партия;
		НовСтр.Серия 		= СтрокаРН.Серия;
		НовСтр.Количество 	= СтрокаРН.Количество;
		НовСтр.ЦенаПродажи 	= СтрокаРН.ЦенаПродажи;
		НовСтр.СуммаПродажи = СтрокаРН.СуммаПродажи;
		НовСтр.Валюта 		= Расходная.Валюта;
		НовСтр.Контрагент 	= Расходная.Контрагент;
		НовСтр.РасходняНакладная = ДанныеРасходной.Ссылка;
		
	КонецЦикла;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.error = "Не удалось провести возврат от покупателя: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success 			= Истина;
	Результат.returnNumber 		= Док.Номер;
	Результат.deliveryNumber 	= Расходная.Номер;
	Результат.orderNumber 		= ДанныеРасходной.НомерЗаказа;
	Результат.incomingNumber 	= ДанныеРасходной.НомерВходящий;
	Результат.serials 			= СерииРезультат.Серии;
	Возврат Результат;
	
КонецФункции

// Определяет расходную накладную по номеру заказа или номеру накладной с проверкой учётной записи.
//
Функция РасходнаяНакладнаяИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись, Результат)
	
	Данные = Новый Структура("Ссылка, НомерЗаказа, НомерВходящий",
		Документы.РасходнаяНакладная.ПустаяСсылка(), "", "");
	
	НомерНакладной = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "delivery,deliveryNumber,deliveryNo", "");
	Если ЗначениеЗаполнено(НомерНакладной) Тогда
		Возврат НайтиРасходнуюНакладнуюДляAPI(СокрЛП(Строка(НомерНакладной)), УчетнаяЗапись, Результат);
	КонецЕсли;
	
	НомерЗаказа = НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса);
	Если НомерЗаказа = Неопределено Тогда
		Результат.error = "Не указан номер заказа (orderNo, orderNumber, incomingNumber) или расходной накладной (delivery, deliveryNumber).";
		Возврат Данные;
	КонецЕсли;
	
	СсылкаИнвойса = НайтиИнвойсПродажи(НомерЗаказа, , УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		//Результат.НеНайден = Истина;
		Возврат Данные;
	КонецЕсли;
	
	ДанныеРасходной = РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса);
	Если НЕ ЗначениеЗаполнено(ДанныеРасходной.Ссылка) Тогда
		Результат.error = СтрШаблон("Расходная накладная по заказу %1 не найдена.", НомерЗаказа.Номер);
		Результат.НеНайден = Истина;
		Возврат Данные;
	КонецЕсли;
	
	Данные.Ссылка = ДанныеРасходной.Ссылка;
	Данные.НомерЗаказа = СсылкаИнвойса.Номер;
	Данные.НомерВходящий = СсылкаИнвойса.НомерВходящий;
	Возврат Данные;
	
КонецФункции

// Ищет расходную накладную по номеру и проверяет принадлежность учётной записи API.
//
Функция НайтиРасходнуюНакладнуюДляAPI(НомерНакладной, УчетнаяЗапись, Результат)
	
	Данные = Новый Структура("Ссылка, НомерЗаказа, НомерВходящий",
		Документы.РасходнаяНакладная.ПустаяСсылка(), "", "");
	
	Если СокрЛП(НомерНакладной) = "" Тогда
		Результат.error = "Номер расходной накладной не указан.";
		Возврат Данные;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	            |	РН.Ссылка КАК Ссылка,
	            |	Инвойс.УчетнаяЗапись КАК УчетнаяЗапись,
	            |	Инвойс.Номер КАК НомерЗаказа,
	            |	Инвойс.НомерВходящий КАК НомерВходящий
	            |ИЗ
	            |	Документ.РасходнаяНакладная КАК РН
	            |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИнвойсПродажи КАК Инвойс
	            |		ПО РН.ДокументОснование = Инвойс.Ссылка
	            |ГДЕ
	            |	РН.Номер = &Номер
	            |	И НЕ РН.ПометкаУдаления
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	РН.Дата УБЫВ";
	Зап.УстановитьПараметр("Номер", НомерНакладной);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если НЕ Выборка.Следующий() Тогда
		Результат.error = СтрШаблон("Расходная накладная %1 не найдена.", НомерНакладной);
		Результат.НеНайден = Истина;
		Возврат Данные;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Выборка.УчетнаяЗапись) Тогда
		Результат.error = СтрШаблон("Расходная накладная %1 не связана с заказом интеграции.", НомерНакладной);
		Возврат Данные;
	КонецЕсли;
	
	Если Выборка.УчетнаяЗапись <> УчетнаяЗапись
		И НЕ StockAPI_Утилиты.ЭтоАдминистраторAPI(УчетнаяЗапись) Тогда
		Результат.error = СтрШаблон("Расходная накладная %1 принадлежит другой учётной записи API-клиента.", НомерНакладной);
		Возврат Данные;
	КонецЕсли;
	
	Данные.Ссылка = Выборка.Ссылка;
	Данные.НомерЗаказа = Выборка.НомерЗаказа;
	Данные.НомерВходящий = Выборка.НомерВходящий;
	Возврат Данные;
	
КонецФункции

// Строит соответствие серий строк расходной накладной (ключ — серия в разных регистрах).
//
Функция СерииСтрокРасходнойНакладной(Расходная)
	
	Соответствие = Новый Соответствие;
	
	Для Каждого СтрокаРН Из Расходная.Товары Цикл
		
		Если СтрокаРН.Количество = 0 Или НЕ ЗначениеЗаполнено(СтрокаРН.Партия) Тогда
			Продолжить;
		КонецЕсли;
		
		СерияСтрокой = СерияСтрокиРасходной(СтрокаРН);
		Если СерияСтрокой = "" Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаДанных = Новый Структура(
			"Номенклатура, Партия, Серия, Количество, ЦенаПродажи, СуммаПродажи",
			СтрокаРН.Номенклатура,
			СтрокаРН.Партия,
			СерияСтрокой,
			СтрокаРН.Количество,
			СтрокаРН.ЦенаПродажи,
			СтрокаРН.СуммаПродажи);
		
		Соответствие.Вставить(НРег(СерияСтрокой), СтрокаДанных);
		Соответствие.Вставить(ВРег(СерияСтрокой), СтрокаДанных);
		Соответствие.Вставить(СерияСтрокой, СтрокаДанных);
		
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

Функция СерияСтрокиРасходной(СтрокаРН)
	
	Если ЗначениеЗаполнено(СтрокаРН.Серия) Тогда
		Возврат СокрЛП(Строка(СтрокаРН.Серия));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаРН.Партия) И ЗначениеЗаполнено(СтрокаРН.Партия.Серия) Тогда
		Возврат СокрЛП(Строка(СтрокаРН.Партия.Серия));
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция НайтиСтрокуРасходнойПоСерии(СерииРасходной, Серия)
	
	СтрокаДанных = СерииРасходной.Получить(Серия);
	Если СтрокаДанных = Неопределено Тогда
		СтрокаДанных = СерииРасходной.Получить(ВРег(Серия));
	КонецЕсли;
	Если СтрокаДанных = Неопределено Тогда
		СтрокаДанных = СерииРасходной.Получить(НРег(Серия));
	КонецЕсли;
	
	Возврат СтрокаДанных;
	
КонецФункции

// Возвращает серии из запроса, которые уже оформлены проведённым возвратом по этой накладной.
//
Функция СерииУжеВозвращенныеПоРасходной(СсылкаРасходной, МассивСерий)
	
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаРасходной) Или МассивСерий.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивВРег = Новый Массив;
	МассивНРег = Новый Массив;
	Для Каждого Серия Из МассивСерий Цикл
		МассивВРег.Добавить(ВРег(Серия));
		МассивНРег.Добавить(НРег(Серия));
	КонецЦикла;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	            |	ВозвратТовары.Серия КАК Серия
	            |ИЗ
	            |	Документ._ВозвратОтПокупателя.Товары КАК ВозвратТовары
	            |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ._ВозвратОтПокупателя КАК Возврат
	            |		ПО ВозвратТовары.Ссылка = Возврат.Ссылка
	            |ГДЕ
	            |	ВозвратТовары.РасходняНакладная = &Расходная
	            |	И Возврат.Проведен
	            |	И НЕ Возврат.ПометкаУдаления
	            |	И (ВозвратТовары.Серия В (&Серии)
	            |			ИЛИ ВозвратТовары.Серия В (&СерииВРег)
	            |			ИЛИ ВозвратТовары.Серия В (&СерииНРег))";
	Зап.УстановитьПараметр("Расходная", СсылкаРасходной);
	Зап.УстановитьПараметр("Серии", МассивСерий);
	Зап.УстановитьПараметр("СерииВРег", МассивВРег);
	Зап.УстановитьПараметр("СерииНРег", МассивНРег);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(СокрЛП(Выборка.Серия));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
