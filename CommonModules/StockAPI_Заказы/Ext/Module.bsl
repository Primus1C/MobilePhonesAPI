// Возвращает структуру ответа с реквизитами Заказа.
// Вызывается из PATCH, PUT, DELETE
//
Функция РезультатИзмененияЗаказа()
	
	Возврат Новый Структура("success, error, orderNumber, incomingNumber, orderDate, reserved, posted, НеНайден, shipmentDate, status, statusDate, readyToShip, cancelled, blocked", 
							Ложь, "", "", "", "", Ложь, Ложь, Ложь, Ложь, "", "", "", Ложь, Ложь, Ложь);
	
КонецФункции

Функция УстановитьСотрудникаВДокумент(Док, ДанныеЗапроса, УчетнаяЗапись, Результат)
	
	ДанныеСотрудника = StockAPI_Справочники.СотрудникИзДанныхЗапроса(ДанныеЗапроса, УчетнаяЗапись);
	Если ДанныеСотрудника.Ошибка <> "" Тогда
		Результат.error = ДанныеСотрудника.Ошибка;
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеСотрудника.Сотрудник) Тогда
		Док.ДополнительныеСвойства.Вставить("КемИзменено", ДанныеСотрудника.Сотрудник);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция НайтиИнвойсДляРедактирования(ДанныеЗапроса, УчетнаяЗапись, Результат)
	
	НомерЗаказа = НомерЗаказаИзДанныхЗапроса(ДанныеЗапроса);
	Если НомерЗаказа = "" Тогда
		Результат.error = "Не указан номер заказа входящий (incomingNo или incomingNumber или incoming), или номер 1С (orderNo или orderNumber или order).";
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	//ДатаЗаказа = ДатаЗаказаИзДанных(ДанныеЗапроса);
	СсылкаЗаказ = НайтиИнвойсПродажи(НомерЗаказа, , УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказ) Тогда
	//	Результат.error = СтрШаблон("Заказ %1 не найден.", НомерЗаказа);
	//	Результат.НеНайден = Истина;
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	Результат.orderNumber	= СсылкаЗаказ.Номер;
	Результат.incomingNumber= СсылкаЗаказ.НомерВходящий;
	Результат.orderDate     = StockAPI_Утилиты.ДатаВСтроку(СсылкаЗаказ.Дата);
	Результат.reserved      = СсылкаЗаказ.РезервироватьТовар;
	Результат.posted        = СсылкаЗаказ.Проведен;
	
	РасходнаяНакладнаяПоИнвойсу = РасходнаяНакладнаяПоИнвойсу(СсылкаЗаказ);
	Если ЗначениеЗаполнено(РасходнаяНакладнаяПоИнвойсу.Ссылка) Тогда
		Результат.error = СтрШаблон("Невозможно изменить отгруженный заказ: по заказу уже создана %1 (%2).", 
									РасходнаяНакладнаяПоИнвойсу.Ссылка,
									?(РасходнаяНакладнаяПоИнвойсу.Проведен, "проведена", "не проведена"));
		Результат.Отгружен = РасходнаяНакладнаяПоИнвойсу.Проведен;
		Возврат Документы.ИнвойсПродажи.ПустаяСсылка();
	КонецЕсли;
	
	Возврат СсылкаЗаказ;
	
КонецФункции

Функция РасходнаяНакладнаяПоИнвойсу(СсылкаИнвойса)
	
	Результат = Новый Структура("Ссылка,Номер,Дата,Проведен", 
								Документы.РасходнаяНакладная.ПустаяСсылка(), "", "", Ложь);
	Если НЕ ЗначениеЗаполнено(СсылкаИнвойса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	            |	РН.Ссылка КАК Ссылка,
	            |	РН.Номер КАК Номер,
	            |	РН.Проведен КАК Проведен
	            |ИЗ
	            |	Документ.РасходнаяНакладная КАК РН
	            |ГДЕ
	            |	РН.ДокументОснование = &Инвойс
	            |	И НЕ РН.ПометкаУдаления
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	РН.Дата УБЫВ";
	Зап.УстановитьПараметр("Инвойс", СсылкаИнвойса);
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	КонецЕсли;

	Возврат Результат;

КонецФункции

Функция ПрименитьЗаголовокИнвойсаИзЗапроса(Док, ДанныеЗапроса, УчетнаяЗапись, Результат)
	
	Если ДанныеЗапроса.Свойство("counterpartyCode")
		Или ДанныеЗапроса.Свойство("customerCode")
		Или ДанныеЗапроса.Свойство("code")
		Или ДанныеЗапроса.Свойство("counterparty") 
		Или ДанныеЗапроса.Свойство("customer") 
		Или ДанныеЗапроса.Свойство("name") Тогда
		
		Контрагент = StockAPI_Контрагенты.НайтиКонтрагента(ДанныеЗапроса, УчетнаяЗапись, Результат.error);  
		Если ЗначениеЗаполнено(Результат.error) Тогда
			Возврат Ложь;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
			Результат.error = "Не найден покупатель. Укажите customer (наименование) или customerCode (код).";
			Возврат Ложь;
		КонецЕсли;
		Док.Контрагент = Контрагент;
		Док.Получатель = Контрагент; 
		
	КонецЕсли;
	
	//Фирма = Док.Фирма;
	//Если ДанныеЗапроса.Свойство("firm") И СокрЛП(ДанныеЗапроса.firm) <> "" Тогда
	//	//Фирма = StockAPI_Справочники.НайтиФирму(ДанныеЗапроса);  
	//	Фирма = ПараметрыСеанса.Фирма;
	//	Если НЕ ЗначениеЗаполнено(Фирма) Тогда
	//		Результат.error = "Не найдена фирма. Укажите firm (наименование).";
	//		Возврат Ложь;
	//	КонецЕсли;
	//	Док.Фирма = Фирма;
	//КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("warehouse") 
		ИЛИ ДанныеЗапроса.Свойство("warehouseCode")
		ИЛИ ДанныеЗапроса.Свойство("warehouseId") Тогда

		Склад = StockAPI_Справочники.НайтиСклад(ДанныеЗапроса, УчетнаяЗапись, Результат.error);
		Если Результат.error <> "" Тогда
			Возврат Ложь;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Склад) Тогда
			Результат.error = "Не найден склад. Укажите warehouse (наименование склада).";
			Возврат Ложь;
		КонецЕсли;
		Док.Склад = Склад;
		
	КонецЕсли;
	
	//Если ДанныеЗапроса.Свойство("currency") И СокрЛП(Строка(ДанныеЗапроса.currency)) <> "" Тогда
	//	Валюта = Справочники.Валюты.НайтиПоНаименованию(СокрЛП(ДанныеЗапроса.currency), Истина);
	//	Если ЗначениеЗаполнено(Валюта) Тогда
	//		Док.Валюта = Валюта;
	//	КонецЕсли;
	//КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserve") Или ДанныеЗапроса.Свойство("reserved") Тогда
		Док.РезервироватьТовар = РезервированиеИзЗапроса(ДанныеЗапроса);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("shipmentDate") Тогда
		Док.ДатаОтгрузки = ДатаОтгрузкиИзЗапроса(ДанныеЗапроса);
	КонецЕсли;

	Возврат Истина;
	
КонецФункции

Функция СнятьПроведениеИнвойса(Док, БылПроведен, Результат)
	
	Если НЕ БылПроведен Тогда
		Возврат Истина;
	КонецЕсли;
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	Исключение
		Результат.error = "Не удалось снять проведение инвойса: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

Функция ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен)
	
	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ВосстановитьИнвойсПослеОшибки(Док, СтарыеТовары, БылПроведен);
		Результат.error = "Не удалось провести инвойс: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	ЗаписьСтатуса = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(Док.Ссылка);

	StockAPI_Утилиты.УдалитьСвойства(Результат, "НеНайден,Отгружен");
	Результат.success 		= Истина;
	Результат.orderNumber 	= Док.Номер;
	Результат.incomingNumber= Док.НомерВходящий;
	Результат.orderDate 	= StockAPI_Утилиты.ДатаВСтроку(Док.Дата);
	Результат.shipmentDate  = StockAPI_Утилиты.ДатаВСтроку(Док.ДатаОтгрузки);
	Результат.reserved 		= Док.РезервироватьТовар И Док.Проведен;  
	Результат.posted 		= Док.Проведен;  
	Если Док.ПометкаУдаления Тогда
		Результат.deleted 	= Истина;  
	КонецЕсли;
	Результат.status 		= Строка(ЗаписьСтатуса.Состояние);
	Результат.statusDate 	= StockAPI_Утилиты.ДатаВСтроку(ЗаписьСтатуса.Зарегистрировано);
	Результат.readyToShip 	= ЗаписьСтатуса.ГотовКОтгрузке <> Дата(1,1,1);
	Результат.cancelled 	= ЗаписьСтатуса.ОтмененЗакачиком <> Дата(1,1,1); 
	Результат.blocked       = ЗаписьСтатуса.Заблокирован <> Дата(1,1,1); 
	Возврат Результат;
	
КонецФункции

Функция ПометитьИнвойсНаУдаление(СсылкаЗаказа, НомерЗаказа, ДанныеЗапроса, Результат)
	
	// Только пометка на удаление (как вручную). Резерв снимается платформой автоматически.
	Попытка
		Док = СсылкаЗаказа.ПолучитьОбъект();
		Если НЕ Док.ПометкаУдаления Тогда
			Док.УстановитьПометкуУдаления(Истина);
		КонецЕсли;
	Исключение
		Результат.error = "Не удалось пометить инвойс на удаление: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.success 		= Истина;
	Результат.deleted 		= Истина;
	Результат.orderNumber 	= НомерЗаказа;
	Результат.orderDate		= "";
	Результат.reserved 		= Ложь;
	Возврат Результат;
	
КонецФункции

Функция ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиЗаказа, ДанныеЗапроса, Склад = Неопределено)
	
	//ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	//ИмяВидаЦены = Строка(ВидЦены);
	//ЦеныПродажи = StockAPI_Цены.ЗагрузитьЦеныПродажи(НоменклатураИзСтрокЗаказа(СтрокиЗаказа.Строки), ВидЦены, Склад);
	//Возврат StockAPI_Цены.ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа, ЦеныПродажи, ИмяВидаЦены);

	Если ТипЗнч(СтрокиЗаказа) = Тип("Структура") Тогда
		Строки = СтрокиЗаказа.Строки;
	Иначе
		Строки = СтрокиЗаказа;
	КонецЕсли;
	
	ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	ИмяВидаЦены = Строка(ВидЦены);
	ЦеныПродажи = StockAPI_Цены.ЗагрузитьЦеныПродажи(НоменклатураИзСтрокЗаказа(Строки), ВидЦены, Склад);
	Возврат StockAPI_Цены.ПроверитьЦеныСтрокЗаказа(Строки, ЦеныПродажи, ИмяВидаЦены);
	
КонецФункции

Функция ТребуемыеКоличестваИзТабличнойЧасти(ТабличнаяЧасть)
	
	ТребуемыеКоличества = Новый Соответствие;
	
	Для Каждого СтрокаТЧ Из ТабличнаяЧасть Цикл
		
		Если СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(СтрокаТЧ.Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(СтрокаТЧ.Номенклатура, ТекущееКоличество + СтрокаТЧ.Количество);
		
	КонецЦикла;
	
	Возврат ТребуемыеКоличества;
	
КонецФункции

Процедура ДобавитьТребуемыеКоличества(ТребуемыеКоличества, СтрокиЗаказа)
	
	Для Каждого Стр Из СтрокиЗаказа Цикл
		
		Если Стр.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(Стр.Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(Стр.Номенклатура, ТекущееКоличество + Стр.Количество);
		
	КонецЦикла;
	
КонецПроцедуры

// Истина, если в запросе перечислены все номенклатуры инвойса — документ помечается на удаление.
//
Функция ВсеПозицииИнвойсаВЗапросе(СсылкаЗаказа, НоменклатурыУдаления)
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Товары.Номенклатура КАК Номенклатура
	            |ИЗ
	            |	Документ.ИнвойсПродажи.Товары КАК Товары
	            |ГДЕ
	            |	Товары.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаЗаказа);
	РезультатЗапроса = Зап.Выполнить(); 
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НоменклатурыИнвойса = Новый Соответствие;
	Выборка = РезультатЗапроса.Выбрать(); 
	Пока Выборка.Следующий() Цикл
		НоменклатурыИнвойса.Вставить(Выборка.Номенклатура, Истина);
	КонецЦикла;
	
	НоменклатурыЗапроса = Новый Соответствие;
	Для Каждого Номенклатура Из НоменклатурыУдаления Цикл
		НоменклатурыЗапроса.Вставить(Номенклатура, Истина);
	КонецЦикла;
	
	Для Каждого КлючЗначение Из НоменклатурыИнвойса Цикл
		Если НоменклатурыЗапроса.Получить(КлючЗначение.Ключ) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючЗначение Из НоменклатурыЗапроса Цикл
		Если НоменклатурыИнвойса.Получить(КлючЗначение.Ключ) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция НоменклатурыДляУдаленияИзЗапроса(ДанныеЗапроса)
	
	Результат = Новый Структура("Номенклатуры, Ошибки", Новый Массив, Новый СписокЗначений);
	Уникальные = Новый Соответствие;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива items.");
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ДанныеЗапроса.items;
	Если ТипЗнч(Позиции) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле items должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	НомерПозиции = 0;
	Для Каждого Позиция Из Позиции Цикл
		
		НомерПозиции = НомерПозиции + 1;
		
		Если ТипЗнч(Позиция) <> Тип("Структура") Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: неверный формат позиции.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоПозиции(Позиция);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите itemCode или item (наименование).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Если Уникальные.Получить(Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Номенклатура, Истина);
			Результат.Номенклатуры.Добавить(Номенклатура);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции


// ─── Заполнение ИнвойсаПродажи из запроса ───────────────────────────────────────────────

// Возвращает из ДанныхЗапроса значение параметра reserve|reserved
//
Функция РезервированиеИзЗапроса(ДанныеЗапроса)
	
	Если ДанныеЗапроса = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserve") Тогда
		Возврат ДанныеЗапроса.reserve = Истина;
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("reserved") Тогда
		Возврат ДанныеЗапроса.reserved = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Возвращает из ДанныхЗапроса значение параметра shipmentDate
//
Функция ДатаОтгрузкиИзЗапроса(ДанныеЗапроса)

	Если ДанныеЗапроса = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("shipmentDate") Тогда
		Возврат StockAPI_Утилиты.СтрокаВДату(ДанныеЗапроса.shipmentDate);    
	КонецЕсли;

	Возврат "";

КонецФункции 

// Возвращает значение по ИмениПараметра из тела запроса или Неопределено, если параметр не передан.
//
// Параметры:
//  ДанныеЗапроса - Структура - тело HTTP-запроса.
//
// Возвращаемое значение:
//  Булево, Неопределено - признак готовности к отгрузке.
//
Функция СтатусИзЗапроса(ДанныеЗапроса, ИмяПараметра)
	
	Возврат StockAPI_Утилиты.БулевоПараметраЗапроса(ДанныеЗапроса, ИмяПараметра);
	
КонецФункции

// Записывает readyToShip в регистр СостоянияИнвойсовПродажи, если параметр передан в запросе.
//
// Параметры:
//  СсылкаИнвойс   - ДокументСсылка.ИнвойсПродажи - заказ;
//  ДанныеЗапроса  - Структура - тело HTTP-запроса;
//  Инициатор      - ДокументСсылка - инициатор изменения;
//  КемИзменено    - СправочникСсылка.Сотрудники - сотрудник;
//  Результат      - Структура - структура ответа API для заполнения readyToShip и error.
//
Процедура ЗаписатьReadyToShipИзЗапроса(СсылкаИнвойс, ДанныеЗапроса, Инициатор, КемИзменено, Результат)
	
	//ГотовКОтгрузке = ReadyToShipИзЗапроса(ДанныеЗапроса); 
	ГотовКОтгрузке = СтатусИзЗапроса(ДанныеЗапроса, "readyToShip"); 
	Если ГотовКОтгрузке = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;
	РаботаСИнвойсами.ЗаписатьСтатусИнвойсаПродажи(
		СсылкаИнвойс,
		Перечисления.СтатусыИнвойсаПродажи.ПустаяСсылка(),
		Инициатор,
		КемИзменено,
		,
		ГотовКОтгрузке,
		,  
		Отказ);
	
	Если Отказ Тогда
		Если Результат.Свойство("success") Тогда
			Результат.success = Ложь;
		КонецЕсли;
		Результат.error = "Не удалось записать признак readyToShip.";
		Возврат;
	КонецЕсли;
	
	Если Результат.Свойство("readyToShip") Тогда
		Результат.readyToShip = ГотовКОтгрузке;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьТоварыИнвойса(Док, Строки)
	
	Док.Товары.Очистить();
	Для Каждого СтрЗаказа Из Строки Цикл
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = СтрЗаказа.Номенклатура;
		НовСтр.Количество = СтрЗаказа.Количество;
		НовСтр.Цена = СтрЗаказа.Цена;
		НовСтр.Сумма = СтрЗаказа.Цена * НовСтр.Количество;
	КонецЦикла;
	
КонецПроцедуры

// Разбирает массив items: только номенклатура + qty + price, без серий и партий. 
//
// Параметры:
//  ДанныеЗапроса - Структура - тело HTTP-запроса;
//  Склад - СправочникСсылка.Склад
//  ПроверятьОстатки - Булево - Ложь — для PUT, когда остатки проверяются отдельно по сумме строк.   
//
Функция СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Склад, ПроверятьОстатки = Истина)
	
	Результат = Новый Структура("Строки, Ошибки", Новый Массив, Новый СписокЗначений);
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.Ошибки.Добавить("В теле запроса нет массива items.");
		Возврат Результат;
	КонецЕсли;
	
	Позиции = ДанныеЗапроса.items;
	Если ТипЗнч(Позиции) <> Тип("Массив") Тогда
		Результат.Ошибки.Добавить("Поле items должно быть массивом.");
		Возврат Результат;
	КонецЕсли;
	
	ТребуемыеКоличества = Новый Соответствие;
	НомерПозиции = 0;
	
	Для Каждого Позиция Из Позиции Цикл
		
		НомерПозиции = НомерПозиции + 1;
		
		Если ТипЗнч(Позиция) <> Тип("Структура") Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: неверный формат позиции.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		//Если ПозицияСодержитПартиюИлиСерию(Позиция) Тогда
		//	Результат.Ошибки.Добавить(СтрШаблон("Строка %1: serial, batch и batchCode не поддерживаются. Укажите itemCode или item.", НомерПозиции));
		//	Продолжить;
		//КонецЕсли;
		
		Количество = 1;
		Если Позиция.Свойство("qty") Тогда
			Количество = Число(Позиция.qty);
		КонецЕсли;
		Если Количество <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: qty должно быть больше 0.", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Цена = StockAPI_Цены.ЦенаИзПозицииЗапроса(Позиция);
		Если Цена <= 0 Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите price (должна совпадать с salePrice из /balances).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоПозиции(Позиция);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Ошибки.Добавить(СтрШаблон("Строка %1: укажите itemCode или item (наименование).", НомерПозиции));
			Продолжить;
		КонецЕсли;
		
		СтрЗаказа = Новый Структура("НомерПозиции, Номенклатура, Количество, Цена",
									НомерПозиции, Номенклатура, Количество, Цена);
		Результат.Строки.Добавить(СтрЗаказа);
		
		Если Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущееКоличество = ТребуемыеКоличества.Получить(Номенклатура);
		Если ТекущееКоличество = Неопределено Тогда
			ТекущееКоличество = 0;
		КонецЕсли;
		ТребуемыеКоличества.Вставить(Номенклатура, ТекущееКоличество + Количество);
		
	КонецЦикла;
	
	Если Результат.Ошибки.Количество() = 0 И ПроверятьОстатки Тогда
		ОшибкиОстатков = ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Склад);
		Для Каждого Ошибка Из ОшибкиОстатков Цикл
			Результат.Ошибки.Добавить(Ошибка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

//Функция ПозицияСодержитПартиюИлиСерию(Позиция)
//	
//	Если Позиция.Свойство("serial") И СокрЛП(Позиция.serial) <> "" Тогда
//		Возврат Истина;
