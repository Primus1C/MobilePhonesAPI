// Заказы StockAPI: создание/изменение/получение исходящих инвойсов (проформ) с резервом.
// Расходные накладные создаются вручную в 1С на основании проформы.
// Зависимости: StockAPI_Утилиты, StockAPI_Справочники, StockAPI_Контрагенты, StockAPI_Цены

 #Область orders

// ─── Точки входа (POST/PATCH/PUT/DELETE/GET /orders) ─────────────────────────

// POST /orders — создание ИнвойсаПродажи с резервированием остатков. 
//
Функция СоздатьЗаказПокупателя(ДанныеЗапроса, КонтекстАвторизации) Экспорт
	
	Результат = Новый Структура("success, error, customer, incomingNumber, orderNumber, orderDate, status, statusSetBy, statusDate, posted, reserved, shipmentDate, readyToShip", 
								Ложь, "", "", "", "", "", "", "", "", Ложь, "", Ложь);
	
	НомерВходящий = StockAPI_Утилиты.СвойствоДанныхЗапроса(ДанныеЗапроса, "incomingNumber,incomingNo,incoming");	
	//Если НЕ ДанныеЗапроса.Свойство("incomingNo,incomingNumber,incoming") Тогда  
	Если НомерВходящий = "" Тогда
		Результат.error = "В запросе нет входящего номера заказа incomingNo (или incomingNumber или incoming).";
		Возврат Результат;
	КонецЕсли;
	НайденныйДок = Документы.ИнвойсПродажи.НайтиПоРеквизиту("НомерВходящий", НомерВходящий);
	Если НайденныйДок <> Документы.ИнвойсПродажи.ПустаяСсылка() Тогда    
		Статус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(НайденныйДок);
		Результат.error = СтрШаблон("В 1С уже зарегистрирован заказ %1 (%2) под номером %3.", НомерВходящий, НайденныйДок.Дата, НайденныйДок.Номер);  
		Результат.incomingNumber 	= НайденныйДок.НомерВходящий;
		Результат.orderNumber		= НайденныйДок.Номер;
		Результат.status 			= Строка(Статус.Состояние);
		Результат.statusSetBy		= Строка(Статус.КемИзменено);
		Результат.statusDate 		= StockAPI_Утилиты.ДатаВСтроку(Статус.Зарегистрировано);
		Результат.orderDate 		= StockAPI_Утилиты.ДатаВСтроку(НайденныйДок.Дата); 
		Результат.posted            = НайденныйДок.Проведен; 
		Если НайденныйДок.ПометкаУдаления Тогда
			Результат.deleted		= Истина; 
		КонецЕсли;
		Результат.reserved 			= НайденныйДок.РезервироватьТовар И НайденныйДок.Проведен;  
		Результат.shipmentDate		= StockAPI_Утилиты.ДатаВСтроку(НайденныйДок.ДатаОтгрузки);
		Результат.readyToShip		= Статус.ГотовКОтгрузке <> Дата(1,1,1);
		Возврат Результат;
	КонецЕсли;
	
	Контрагент = StockAPI_Контрагенты.НайтиКонтрагента(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат.error);
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Результат.error = "Не найден покупатель. Укажите customer (наименование) или customerCode (код).";
		Возврат Результат;
	КонецЕсли;
	
	Склад = StockAPI_Справочники.НайтиСклад(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат.error);
	Если Результат.error <> "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	// +++
	//ПроверятьОстатки = ЛОЖЬ;
	ПроверятьОстатки = ИСТИНА;
	// ---
	СтрокиЗаказа = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Склад, ПроверятьОстатки);
	Если СтрокиЗаказа.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиЗаказа.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиЗаказа.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст.";
		Возврат Результат;
	КонецЕсли;
	
	//ВидЦены = StockAPI_Цены.ВидЦеныИзПараметра(?(ДанныеЗапроса.Свойство("priceType"), ДанныеЗапроса.priceType, ""));
	ВидЦены = Контрагент.ВидЦены;
	Если НЕ ЗначениеЗаполнено(ВидЦены) Тогда
		Результат.error = "В 1С у контрагента не указан вид цен.";
		Возврат Результат;
	КонецЕсли;
	
	ИмяВидаЦены = Строка(ВидЦены);   
	Валюта = ВидЦены.Валюта;
	ЦеныПродажи = StockAPI_Цены.ЗагрузитьЦеныПродажи(НоменклатураИзСтрокЗаказа(СтрокиЗаказа.Строки), ВидЦены, Склад);
	
	ОшибкиЦен = StockAPI_Цены.ПроверитьЦеныСтрокЗаказа(СтрокиЗаказа.Строки, ЦеныПродажи, ИмяВидаЦены);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Док = Документы.ИнвойсПродажи.СоздатьДокумент();
	Док.Дата 				= ТекущаяДатаСеанса(); 
	Док.НомерВходящий		= НомерВходящий; 
	Док.УчетнаяЗапись		= КонтекстАвторизации.УчетнаяЗапись;
	Док.Фирма 				= ПараметрыСеанса.Фирма;
	Док.Контрагент 			= Контрагент;
	//Док.Получатель 			= Контрагент;
	Док.Валюта 				= Валюта;
	Док.Склад 				= Склад;
	Док.Проформа 			= Перечисления.ВидыИнвойса.ЗаказПокупателя;
	Док.РезервироватьТовар 	= РезервированиеИзЗапроса(ДанныеЗапроса); 
	Док.ДатаОтгрузки		= ДатаОтгрузкиИзЗапроса(ДанныеЗапроса);
	ЗаполнитьТоварыИнвойса(Док, СтрокиЗаказа.Строки);
	
	Если НЕ УстановитьСотрудникаВДокумент(Док, ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись, Результат) Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		Док.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		Результат.error = "Не удалось провести инвойс: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	КемИзменено = Неопределено;
	Если Док.ДополнительныеСвойства.Свойство("КемИзменено") Тогда
		КемИзменено = Док.ДополнительныеСвойства.КемИзменено;
	КонецЕсли;
	ЗаписатьReadyToShipИзЗапроса(Док.Ссылка, ДанныеЗапроса, Док.Ссылка, КемИзменено, Результат);
	Если Результат.error <> "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	Статус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(Док.Ссылка);
	Результат.success 			= Истина; 
	Результат.customer 			= Контрагент.Наименование;
	Результат.incomingNumber	= Док.НомерВходящий;
	Результат.orderNumber 		= Док.Номер;
	Результат.posted            = Док.Проведен;
	Если Док.ПометкаУдаления Тогда
		Результат.deleted		= Истина; 
	КонецЕсли;
	Результат.reserved 			= Док.РезервироватьТовар И Док.Проведен; 
	Результат.status 			= Строка(Статус.Состояние);
	Результат.statusSetBy		= Строка(Статус.КемИзменено);
	Результат.statusDate 		= StockAPI_Утилиты.ДатаВСтроку(Статус.Зарегистрировано);
	Результат.orderDate 		= StockAPI_Утилиты.ДатаВСтроку(Док.Дата);
	Результат.shipmentDate		= StockAPI_Утилиты.ДатаВСтроку(Док.ДатаОтгрузки);
	Результат.readyToShip		= Статус.ГотовКОтгрузке <> Дата(1,1,1);
	Возврат Результат;

КонецФункции

// PATCH /orders — полное редактирование проформы (заголовок + полная замена items). 
//
Функция ИзменитьЗаказПокупателя(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.error = "В теле запроса нет массива items.";
		Возврат Результат;
	КонецЕсли;
	
	Док = СсылкаЗаказа.ПолучитьОбъект();
	БылПроведен = Док.Проведен;
	СтарыеТовары = Док.Товары.Выгрузить();
	
	Если НЕ УстановитьСотрудникаВДокумент(Док, ДанныеЗапроса, УчетнаяЗапись, Результат) Тогда
		Возврат Результат;
	КонецЕсли;

	Если НЕ ПрименитьЗаголовокИнвойсаИзЗапроса(Док, ДанныеЗапроса, УчетнаяЗапись, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Склад = Док.Склад;
	
	СтрокиЗаказа = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Склад);
	Если СтрокиЗаказа.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиЗаказа.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиЗаказа.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	//ОшибкиЦен = ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиЗаказа.Строки, ДанныеЗапроса, Склад);
	ОшибкиЦен = ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиЗаказа, ДанныеЗапроса, Склад);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Док.ДополнительныеСвойства.Вставить("ИзмененВызовомAPI", Истина);
	ЗаполнитьТоварыИнвойса(Док, СтрокиЗаказа.Строки);
	
	Результат = ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	Если НЕ Результат.success Тогда
		Возврат Результат;
	КонецЕсли;
	
	КемИзменено = Неопределено;
	Если Док.ДополнительныеСвойства.Свойство("КемИзменено") Тогда
		КемИзменено = Док.ДополнительныеСвойства.КемИзменено;
	КонецЕсли;
	ЗаписатьReadyToShipИзЗапроса(Док.Ссылка, ДанныеЗапроса, Док.Ссылка, КемИзменено, Результат);
	Возврат Результат;
	
КонецФункции

// PUT /orders — добавление позиций в существующую проформу.
//
Функция ДобавитьПозицииВЗаказ(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ДанныеЗапроса.Свойство("items") Тогда
		Результат.error = "В теле запроса нет массива items.";
		Возврат Результат;
	КонецЕсли;
	
	Док = СсылкаЗаказа.ПолучитьОбъект();
	Фирма = Док.Фирма;
	Склад = Док.Склад;
	БылПроведен = Док.Проведен;
	СтарыеТовары = Док.Товары.Выгрузить();
	
	СтрокиНовые = СтрокиИнвойсаИзЗапроса(ДанныеЗапроса, Склад, Ложь);
	Если СтрокиНовые.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(СтрокиНовые.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрокиНовые.Строки.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	ТребуемыеКоличества = ТребуемыеКоличестваИзТабличнойЧасти(Док.Товары);
	ДобавитьТребуемыеКоличества(ТребуемыеКоличества, СтрокиНовые.Строки);
	ОшибкиОстатков = ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Склад);
	Если ОшибкиОстатков.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиОстатков);
		Возврат Результат;
	КонецЕсли;
	
	ОшибкиЦен = ПроверитьЦеныСтрокЗаказаИзЗапроса(СтрокиНовые.Строки, ДанныеЗапроса, Склад);
	Если ОшибкиЦен.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(ОшибкиЦен);
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Док.ДополнительныеСвойства.Вставить("ИзмененВызовомAPI", Истина);
	Для Каждого СтрЗаказа Из СтрокиНовые.Строки Цикл
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура 	= СтрЗаказа.Номенклатура;
		НовСтр.Количество 		= СтрЗаказа.Количество;
		НовСтр.Цена 			= СтрЗаказа.Цена;
		НовСтр.Сумма 			= СтрЗаказа.Цена * НовСтр.Количество;
	КонецЦикла;
	
	Возврат ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	
КонецФункции

// DELETE /orders — удаление позиций; если позиций не осталось — удаление инвойса целиком.  
//
Функция УдалитьПозицииИзЗаказа(ДанныеЗапроса, УчетнаяЗапись) Экспорт
	
	Результат = РезультатИзмененияЗаказа();
	Результат.Вставить("deleted", Ложь);
	
	Если ДанныеЗапроса = Неопределено Тогда
		Результат.error = "Тело запроса пустое.";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсДляРедактирования(ДанныеЗапроса, УчетнаяЗапись, Результат);
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	НоменклатурыУдаления = НоменклатурыДляУдаленияИзЗапроса(ДанныеЗапроса);
	Если НоменклатурыУдаления.Ошибки.Количество() > 0 Тогда
		Результат.error = StockAPI_Утилиты.ТекстОшибокСписка(НоменклатурыУдаления.Ошибки);
		Возврат Результат;
	КонецЕсли;
	
	Если НоменклатурыУдаления.Номенклатуры.Количество() = 0 Тогда
		Результат.error = "Список items пуст или все позиции отклонены.";
		Возврат Результат;
	КонецЕсли;
	
	НомерЗаказа = СсылкаЗаказа.Номер;
	УдалениеВсегоИнвойса = ВсеПозицииИнвойсаВЗапросе(СсылкаЗаказа, НоменклатурыУдаления.Номенклатуры);
	
	// Все позиции инвойса — только пометка на удаление, табличную часть не меняем.
	Если УдалениеВсегоИнвойса Тогда
		Возврат ПометитьИнвойсНаУдаление(СсылкаЗаказа, НомерЗаказа, ДанныеЗапроса, Результат);
	КонецЕсли;
	
	Док 			= СсылкаЗаказа.ПолучитьОбъект();
	БылПроведен 	= Док.Проведен;
	СтарыеТовары 	= Док.Товары.Выгрузить();
	
	Если НЕ УстановитьСотрудникаВДокумент(Док, ДанныеЗапроса, УчетнаяЗапись, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ СнятьПроведениеИнвойса(Док, БылПроведен, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Номенклатура Из НоменклатурыУдаления.Номенклатуры Цикл
		СтрокиДляУдаления = Док.Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
		Для Каждого СтрокаТЧ Из СтрокиДляУдаления Цикл
			Док.Товары.Удалить(СтрокаТЧ);
		КонецЦикла;
	КонецЦикла;
	
	Если Док.Товары.Количество() = 0 Тогда
		Результат.error = "Нельзя оставить инвойс без позиций. Для удаления заказа укажите все позиции в items.";
		Возврат Результат;
	КонецЕсли;
	
	РезультатПроведения = ПровестиИнвойсИЗаполнитьРезультат(Док, Результат, СтарыеТовары, БылПроведен);
	РезультатПроведения.deleted = Ложь;
	Возврат РезультатПроведения;
	
КонецФункции

// GET /orders — список проформ по номеру (один) или по покупателю + дате (с пагинацией). 
//
Функция ПолучитьЗаказы(Запрос, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура("Тело, Ошибка, НеНайден", Неопределено, "", Ложь);
	Фильтр = ПараметрыПоискаЗаказов(Запрос, УчетнаяЗапись);
	Если Фильтр.Ошибка <> "" Тогда
		Результат.Ошибка = Фильтр.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Пагинация = StockAPI_Утилиты.ПараметрыПагинацииОстатков(Запрос);
	Если Пагинация.Ошибка <> "" Тогда
		Результат.Ошибка = Пагинация.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Если Фильтр.Режим = "single" Тогда
		
		Если Фильтр.incomingNumber = "" Тогда
			СтруктураНомера = Новый Структура("ИмяРеквизита,Номер", "Номер", Фильтр.orderNumber);
		Иначе
			СтруктураНомера = Новый Структура("ИмяРеквизита,Номер", "НомерВходящий", Фильтр.incomingNumber);
		КонецЕсли;
		СсылкаЗаказа = НайтиИнвойсПродажи(СтруктураНомера, Фильтр.orderDate, УчетнаяЗапись, Результат);
		Если Результат.Ошибка <> "" Тогда
			Возврат Результат;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СсылкаЗаказа) Тогда
			Результат.Ошибка = СтрШаблон("Заказ %1 не найден.", Фильтр.orderNumber);
			Результат.НеНайден = Истина;
			Возврат Результат;
		КонецЕсли;
		
		МассивЗаказов = Новый Массив;
		МассивЗаказов.Добавить(СтруктураЗаказаJSON(СсылкаЗаказа, СтрокиЗаказовПоДокументам(СсылкаЗаказа)));
		
		ТелоОтвета = Новый Структура;
		ТелоОтвета.Вставить("page", 1);
		ТелоОтвета.Вставить("pageSize", Пагинация.pageSize);
		ТелоОтвета.Вставить("totalItems", 1);
		ТелоОтвета.Вставить("totalPages", 1);
		ТелоОтвета.Вставить("items", МассивЗаказов);
		Результат.Тело = ТелоОтвета;
		
	Иначе
		
		// Режим = "multi"
		
		МассивЗаказовПокупателя = МассивЗаказовПокупателя(
			Фильтр.Контрагент, Фильтр.dateFrom, Фильтр.dateTo, Фильтр.shipmentDateFrom, Фильтр.shipmentDateTo,
			StockAPI_Утилиты.ЭтоАдминистраторAPI(УчетнаяЗапись));
		ВсегоЗаказов = МассивЗаказовПокупателя.Количество();
		ВсегоСтраниц = StockAPI_Утилиты.ВсегоСтраницПагинации(ВсегоЗаказов, Пагинация.pageSize);
		Пропустить = (Пагинация.page - 1) * Пагинация.pageSize;
		СтрокиПоЗаказам = СтрокиЗаказовПоДокументам(МассивЗаказовПокупателя);
		
		МассивЗаказов = Новый Массив;
		Для Каждого СсылкаЗаказа Из МассивЗаказовПокупателя Цикл 
			МассивЗаказов.Добавить(СтруктураЗаказаJSON(СсылкаЗаказа, СтрокиПоЗаказам));
		КонецЦикла;
		
		ТелоОтвета = Новый Структура;
		ТелоОтвета.Вставить("page", 		Пагинация.page);
		ТелоОтвета.Вставить("pageSize", 	Пагинация.pageSize);
		ТелоОтвета.Вставить("totalItems", 	ВсегоЗаказов);
		ТелоОтвета.Вставить("totalPages", 	ВсегоСтраниц);
		ТелоОтвета.Вставить("items", 		МассивЗаказов);
		Результат.Тело = ТелоОтвета;
		
	КонецЕсли;

	Возврат Результат;

КонецФункции

#КонецОбласти


// ─── Параметры поиска и чтение заказов ───────────────────────────────────────

Функция МассивЗаказовПокупателя(Контрагент, ДатаНачала, ДатаОкончания,
	ДатаОтгрузкиС = '00010101', ДатаОтгрузкиПо = '00010101', ТолькоСУчетнойЗаписью = Ложь);
	
	МассивЗаказов = Новый Массив;
	ПустаяДата = Дата(1, 1, 1);

	Зап = Новый Запрос;
	Условия = Новый Массив;
	Условия.Добавить("Заказ.Проформа = ЗНАЧЕНИЕ(Перечисление.ВидыИнвойса.ЗаказПокупателя)");
	Условия.Добавить("НЕ Заказ.ПометкаУдаления");
	
	Если ТолькоСУчетнойЗаписью Тогда
		Условия.Добавить("Заказ.УчетнаяЗапись <> ЗНАЧЕНИЕ(Справочник.УчетныеЗаписиИнтеграции.ПустаяСсылка)");
	КонецЕсли;
	
	Если Контрагент <> Неопределено Тогда
		Условия.Добавить("Заказ.Контрагент В (&Контрагент)");
		Зап.УстановитьПараметр("Контрагент", Контрагент);
	КонецЕсли;
	
	Если ДатаНачала <> ПустаяДата Или ДатаОкончания <> ПустаяДата Тогда
		Условия.Добавить("(Заказ.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания)");
		Зап.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаНачала));
		Зап.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
	КонецЕсли;
	
	Если ДатаОтгрузкиС <> ПустаяДата И ДатаОтгрузкиПо <> ПустаяДата Тогда
		Условия.Добавить("(Заказ.ДатаОтгрузки МЕЖДУ &ДатаОтгрузкиС И &ДатаОтгрузкиПо)");
		Зап.УстановитьПараметр("ДатаОтгрузкиС", НачалоДня(ДатаОтгрузкиС));
		Зап.УстановитьПараметр("ДатаОтгрузкиПо", КонецДня(ДатаОтгрузкиПо));
	ИначеЕсли ДатаОтгрузкиС <> ПустаяДата Тогда
		Условия.Добавить("Заказ.ДатаОтгрузки >= &ДатаОтгрузкиС");
		Зап.УстановитьПараметр("ДатаОтгрузкиС", НачалоДня(ДатаОтгрузкиС));
	ИначеЕсли ДатаОтгрузкиПо <> ПустаяДата Тогда
		Условия.Добавить("Заказ.ДатаОтгрузки <> ДАТАВРЕМЯ(1, 1, 1)");
		Условия.Добавить("Заказ.ДатаОтгрузки <= &ДатаОтгрузкиПо");
		Зап.УстановитьПараметр("ДатаОтгрузкиПо", КонецДня(ДатаОтгрузкиПо));
	КонецЕсли;
	
	ТекстУсловий = "";
	Для Каждого Условие Из Условия Цикл
		Если ТекстУсловий = "" Тогда
			ТекстУсловий = Условие;
		Иначе
			ТекстУсловий = ТекстУсловий + "
				|	И " + Условие;
		КонецЕсли;
	КонецЦикла;
	
	Зап.Текст =
	"ВЫБРАТЬ
	|	Заказ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИнвойсПродажи КАК Заказ
	|ГДЕ
	|	" + ТекстУсловий + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заказ.Дата УБЫВ,
	|	Заказ.Номер УБЫВ";
	
	РезультатЗапроса = Зап.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		МассивЗаказов = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0);
	КонецЕсли;
	Возврат МассивЗаказов;
	
КонецФункции // МассивЗаказовПокупателя()

Функция ПараметрыПоискаЗаказов(Запрос, УчетнаяЗапись)
	
	Результат = Новый Структура(
		"Режим, orderNumber, incomingNumber, orderDate, Контрагент, dateFrom, dateTo, shipmentDateFrom, shipmentDateTo, Ошибка",
		"unknown", "", "", '00010101', Справочники.Контрагенты.ПустаяСсылка(),
		'00010101', '00010101', '00010101', '00010101', "");
	
	//НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNumber");
	//Если НомерЗаказа = "" Тогда
	//	НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNo");
	//КонецЕсли;
	//Если НомерЗаказа = "" Тогда
	//	НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "order");
	//КонецЕсли;
	НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNumber,orderNo,order");
	НомерЗаказаВх = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "incomingNumber,incomingNo,incoming");	
	
	ПустаяДата = Дата(1,1,1);
	
	Если НомерЗаказа = "" И НомерЗаказаВх = "" Тогда     
		
		Результат.Режим = "multiple";
		
		Контрагент = КонтрагентИзПараметровЗапроса(Запрос); 
		Если Контрагент = Неопределено Тогда
			Если StockAPI_Утилиты.ЭтоАдминистраторAPI(УчетнаяЗапись) Тогда
				Контрагент = StockAPI_Утилиты.КонтрагентыОбщиеДляВсехУчетныхЗаписейAPI();
			Иначе
				Контрагент = РазрешенныеКонтрагенты(УчетнаяЗапись, Результат.Ошибка);
				Если Результат.Ошибка <> "" Тогда
					Возврат Результат;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли Контрагент = Справочники.Контрагенты.ПустаяСсылка() Тогда	
			Результат.Ошибка = "Контрагент не найден.";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Контрагент = Контрагент;
		ДатаНачала = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "dateFrom,from");
		ДатаОкончания = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "dateTo,to");
		
		Если ДатаНачала = "" И ДатаОкончания = "" Тогда
			// ничего
		Иначе	
			
			Если ДатаНачала = "" ИЛИ ДатаОкончания = "" Тогда
				Результат.Ошибка = "Для поиска по контрагенту укажите dateFrom и dateTo (формат yyyy-MM-dd).";
				Возврат Результат;
			КонецЕсли;
			
			Если ДатаНачала > ДатаОкончания Тогда
				Результат.Ошибка = "dateFrom не может быть позже dateTo.";
				Возврат Результат;
			КонецЕсли;
			
			Результат.dateFrom = НачалоДня(ДатаНачала);
			Результат.dateTo = КонецДня(ДатаОкончания); 
			
		КонецЕсли;
		
		СтрокаОтгрузкиС = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "shipmentDateFrom");
		СтрокаОтгрузкиПо = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "shipmentDateTo");
		ДатаОтгрузкиС = ПустаяДата;
		ДатаОтгрузкиПо = ПустаяДата;
		
		Если СтрокаОтгрузкиС <> "" Тогда
			ДатаОтгрузкиС = StockAPI_Утилиты.СтрокаВДату(СтрокаОтгрузкиС);
			Если ДатаОтгрузкиС = Неопределено Тогда
				Результат.Ошибка = "Некорректный shipmentDateFrom (формат yyyy-MM-dd).";
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаОтгрузкиПо <> "" Тогда
			ДатаОтгрузкиПо = StockAPI_Утилиты.СтрокаВДату(СтрокаОтгрузкиПо);
			Если ДатаОтгрузкиПо = Неопределено Тогда
				Результат.Ошибка = "Некорректный shipmentDateTo (формат yyyy-MM-dd).";
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
		
		Если ДатаОтгрузкиС <> ПустаяДата И ДатаОтгрузкиПо <> ПустаяДата
			И ДатаОтгрузкиС > ДатаОтгрузкиПо Тогда
			Результат.Ошибка = "shipmentDateFrom не может быть позже shipmentDateTo.";
			Возврат Результат;
		КонецЕсли;
		
		Если ДатаОтгрузкиС <> ПустаяДата Тогда
			Результат.shipmentDateFrom = НачалоДня(ДатаОтгрузкиС);
		КонецЕсли;
		Если ДатаОтгрузкиПо <> ПустаяДата Тогда
			Результат.shipmentDateTo = КонецДня(ДатаОтгрузкиПо);
		КонецЕсли;
		
		Возврат Результат;
		
	Иначе
				
		Результат.Режим = "single";
		
		Результат.orderNumber 		= НомерЗаказа; 
		Результат.incomingNumber 	= НомерЗаказаВх;
		Результат.orderDate 		= StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "orderDate,date");
		
		Возврат Результат;

	КонецЕсли;

КонецФункции

// Ищет контрагента по коду или наименованию
//
Функция КонтрагентИзПараметровЗапроса(Запрос)
	
	ПараметрыЗапроса = Запрос.ПараметрыЗапроса;
	Если ПараметрыЗапроса.Получить("customerCode") = Неопределено И
		ПараметрыЗапроса.Получить("counterpartyCode") = Неопределено И
		ПараметрыЗапроса.Получить("code") = Неопределено И
		ПараметрыЗапроса.Получить("customer") = Неопределено И
		ПараметрыЗапроса.Получить("counterparty") = Неопределено И
		ПараметрыЗапроса.Получить("name") = Неопределено Тогда
	    	Возврат Неопределено;
	КонецЕсли;  
	
	КодСтрока = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "customerCode,counterpartyCode,code");
	
	Если КодСтрока <> "" Тогда
		Попытка
			Контрагент = Справочники.Контрагенты.НайтиПоКоду(Число(КодСтрока));
			Если ЗначениеЗаполнено(Контрагент) И НЕ Контрагент.ЭтоГруппа Тогда
				Возврат Контрагент;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	ИмяПокупателя = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "customer,counterparty,name");
	
	Если ИмяПокупателя <> "" Тогда
		Контрагент = Справочники.Контрагенты.НайтиПоНаименованию(ИмяПокупателя, Истина);
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция РазрешенныеКонтрагенты(УчетнаяЗапись, Ошибка)
	
	ГруппаКонтрагентов = УчетнаяЗапись.ГруппаКонтрагентов;
	Если Не ЗначениеЗаполнено(ГруппаКонтрагентов) Тогда
		Ошибка = "В 1С не заполнена группа контрагентов в учетной записи";
		Возврат Новый Массив;
	КонецЕсли;               
	
	запр = Новый Запрос;
	запр.УстановитьПараметр("Группа", УчетнаяЗапись.ГруппаКонтрагентов);
	запр.Текст = "ВЫБРАТЬ
	             |	Контрагенты.Ссылка КАК Ссылка
	             |ИЗ
	             |	Справочник.Контрагенты КАК Контрагенты
	             |ГДЕ
	             |	Контрагенты.Ссылка В ИЕРАРХИИ(&Группа)
	             |	И НЕ Контрагенты.ПометкаУдаления
	             |	И НЕ Контрагенты.ЭтоГруппа";
    Возврат запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
	
КонецФункции // РазрешенныеКонтрагенты()

