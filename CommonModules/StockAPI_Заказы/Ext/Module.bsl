// Возвращает соответствие ИнвойсПродажи - МассивСтрок
//
Функция СтрокиЗаказовПоДокументам(СсылкиЗаказов)
	
	Результат = Новый Соответствие;
	
	МассивСсылок = Новый Массив;
	Если ТипЗнч(СсылкиЗаказов) = Тип("Массив") Тогда
		МассивСсылок = СсылкиЗаказов;
	ИначеЕсли ЗначениеЗаполнено(СсылкиЗаказов) Тогда
		МассивСсылок.Добавить(СсылкиЗаказов);
	КонецЕсли;
	
	Если МассивСсылок.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Товары.Ссылка КАК Ссылка,
	            |	Товары.Номенклатура.Код КАК КодНоменклатуры,
	            |	Товары.Номенклатура.Наименование КАК НаименованиеНоменклатуры,
	            |	Товары.Количество КАК Количество,
	            |	Товары.Цена КАК Цена
	            |ИЗ
	            |	Документ.ИнвойсПродажи.Товары КАК Товары
	            |ГДЕ
	            |	Товары.Ссылка В(&Ссылки)
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	Товары.Ссылка,
	            |	Товары.НомерСтроки";
	Зап.УстановитьПараметр("Ссылки", МассивСсылок);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		МассивСтрок = Результат.Получить(Выборка.Ссылка);
		Если МассивСтрок = Неопределено Тогда
			МассивСтрок = Новый Массив;
			Результат.Вставить(Выборка.Ссылка, МассивСтрок);
		КонецЕсли;
		
		СтрокаJSON = Новый Структура;
		СтрокаJSON.Вставить("item", 	Строка(Выборка.НаименованиеНоменклатуры));
		СтрокаJSON.Вставить("itemCode", Формат(Выборка.КодНоменклатуры, "ЧГ=0"));
		СтрокаJSON.Вставить("qty", 		Выборка.Количество);
		СтрокаJSON.Вставить("price", 	Выборка.Цена);
		МассивСтрок.Добавить(СтрокаJSON);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру ответа с реквизитами Заказа
//
Функция СтруктураЗаказаJSON(СсылкаЗаказа, СтрокиПоЗаказам)
	
	Заказ = Новый Структура;
	Заказ.Вставить("orderNumber", 	СсылкаЗаказа.Номер);
	Заказ.Вставить("orderDate", 	StockAPI_Утилиты.ДатаВСтроку(СсылкаЗаказа.Дата));   
	Заказ.Вставить("incomingNumber", СсылкаЗаказа.НомерВходящий);
	Заказ.Вставить("customer", 		Строка(СсылкаЗаказа.Контрагент.Наименование));
	Заказ.Вставить("customerCode", 	StockAPI_Утилиты.КодВСтроку(СсылкаЗаказа.Контрагент.Код));
	Заказ.Вставить("warehouse", 	Строка(СсылкаЗаказа.Склад));
	Заказ.Вставить("warehouseCode", StockAPI_Утилиты.КодВСтроку(СсылкаЗаказа.Склад.Код));
	Заказ.Вставить("currency", 		Строка(СсылкаЗаказа.Валюта));
	Заказ.Вставить("posted", 		СсылкаЗаказа.Проведен); 
	Если СсылкаЗаказа.ПометкаУдаления Тогда
		Заказ.Вставить("deleted", 	Истина); 
	КонецЕсли;
	Заказ.Вставить("reserved", 		СсылкаЗаказа.РезервироватьТовар И СсылкаЗаказа.Проведен);
	Заказ.Вставить("shipmentDate", 	StockAPI_Утилиты.ДатаВСтроку(СсылкаЗаказа.ДатаОтгрузки));
	
	Статус = РаботаСИнвойсами.ПолучитьСтатусИнвойсаПродажи(СсылкаЗаказа);
	ДанныеРасходной = РасходнаяНакладнаяПоИнвойсу(СсылкаЗаказа);
	Заказ.Вставить("deliveryNumber", ДанныеРасходной.Номер);
	Заказ.Вставить("deliveryDate", 	StockAPI_Утилиты.ДатаВСтроку(ДанныеРасходной.Дата));
	
	ДанныеВозврата = ВозвратПоРасходнойНакладной(ДанныеРасходной.Ссылка);
	Заказ.Вставить("returnNumber", 	ДанныеВозврата.Номер);
	Заказ.Вставить("returnDate", 	StockAPI_Утилиты.ДатаВСтроку(ДанныеВозврата.Дата));
	
	Заказ.Вставить("status", 		Строка(Статус.Состояние)); 
	Заказ.Вставить("statusSetBy",	Строка(Статус.КемИзменено));
	Заказ.Вставить("statusDate", 	StockAPI_Утилиты.ДатаВСтроку(Статус.Зарегистрировано));
	
	Заказ.Вставить("canceled", 		Статус.ОтмененЗакачиком <> Дата(1,1,1)); 
	Заказ.Вставить("readyToShip", 	Статус.ГотовКОтгрузке <> Дата(1,1,1));
	Заказ.Вставить("blocked", 		Статус.Заблокирован <> Дата(1,1,1));
	
	МассивСтрок = СтрокиПоЗаказам.Получить(СсылкаЗаказа);
	Если МассивСтрок = Неопределено Тогда
		МассивСтрок = Новый Массив;
	КонецЕсли;
	Заказ.Вставить("items", МассивСтрок);
	
	Возврат Заказ;
	
КонецФункции

Процедура ВосстановитьИнвойсПослеОшибки(Док, СтарыеТовары, БылПроведен)
	
	Док.Товары.Загрузить(СтарыеТовары);
	Если БылПроведен Тогда
		Попытка
			Док.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		КонецПопытки;
	Иначе
		Попытка
			Док.Записать(РежимЗаписиДокумента.Запись);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры


