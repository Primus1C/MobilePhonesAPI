Функция ПроверитьОстаткиНоменклатуры(ТребуемыеКоличества, Склад)
	
	Ошибки = Новый Массив;
	
	Для Каждого Пара Из ТребуемыеКоличества Цикл
		
		Доступно = ДоступныйОстатокНоменклатуры(Склад, Пара.Ключ);
		Если Пара.Значение > Доступно Тогда
			Ошибки.Добавить(СтрШаблон("Недостаточно %1 (код %2, SKU %3): доступно %4, требуется %5.",
							Строка(Пара.Ключ), 
							StockAPI_Утилиты.КодВСтроку(Пара.Ключ.Код), 
							Пара.Ключ.SKU,
							Доступно, 
							Пара.Значение));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ошибки;
	
КонецФункции

Функция ДоступныйОстатокНоменклатуры(Склад, Номенклатура)
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	ЕСТЬNULL(СУММА(Ост.ОстатокОстаток - Ост.РезервОстаток), 0) КАК Доступно
	            |ИЗ
	            |	РегистрНакопления.ОстаткиТовара.Остатки(
	            |			,
	            |			Склад = &Склад
	            |				И Номенклатура = &Номенклатура) КАК Ост";
	Зап.УстановитьПараметр("Склад", Склад);
	Зап.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Доступно = 0;
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Доступно = Выборка.Доступно;
	КонецЕсли;
	
	// Резерв Заказа — регистр ТоварыВДороге (без привязки к партиям).
	//Доступно = Доступно - РезервНоменклатурыВТоварахВДороге(Склад, Номенклатура);
	
	Возврат Макс(0, Доступно);
	
КонецФункции

