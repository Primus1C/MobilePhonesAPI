Функция НайтиНоменклатуруПоПозиции(Позиция)
	
	Если Позиция.Свойство("itemCode") И СокрЛП(Строка(Позиция.itemCode)) <> "" Тогда
		Номенклатура = Справочники.Номенклатура.НайтиПоКоду(СокрЛП(Строка(Позиция.itemCode)));
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если Позиция.Свойство("item") И СокрЛП(Позиция.item) <> "" Тогда
		Наименование = СокрЛП(Позиция.item);
		Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Ложь);
		КонецЕсли;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция НоменклатураИзСтрокЗаказа(СтрокиЗаказа)
	
	Уникальные = Новый Соответствие;
	МассивНоменклатуры = Новый Массив;
	Для Каждого Стр Из СтрокиЗаказа Цикл
		Если Уникальные.Получить(Стр.Номенклатура) = Неопределено Тогда
			Уникальные.Вставить(Стр.Номенклатура, Истина);
			МассивНоменклатуры.Добавить(Стр.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивНоменклатуры;
	
КонецФункции


#Область series

// GET /series — серии товаров заказа, имеющиеся на складе инвойса.
//
// Параметры:
//  Запрос        - HTTPСервисЗапрос - параметры orderNumber/orderNo/order
//      или incomingNumber/incomingNo/incoming;
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиИнтеграции - учётная запись API-клиента.
//
// Возвращаемое значение:
//  Структура - результат обработки:
//      * Тело      - Структура - orderNumber, incomingNumber, items (itemCode + serials);
//      * Ошибка    - Строка;
//      * НеНайден  - Булево.
//
Функция ПолучитьСерииЗаказа(Запрос, УчетнаяЗапись) Экспорт
	
	Результат = Новый Структура("Тело, Ошибка, НеНайден", Неопределено, "", Ложь);
	
	СтруктураНомера = СтруктураНомераЗаказаИзЗапроса(Запрос);
	Если СтруктураНомера = Неопределено Тогда
		Результат.Ошибка = "Укажите orderNumber (или orderNo, order) либо incomingNumber (или incomingNo, incoming).";
		Возврат Результат;
	КонецЕсли;
	
	СсылкаЗаказа = НайтиИнвойсПродажи(СтруктураНомера, , УчетнаяЗапись, Результат);
	Если Результат.Ошибка <> "" Тогда
		//Если СтрНайти(Результат.Ошибка, "не найден") > 0 Тогда
		//	Результат.НеНайден = Истина;
		//КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СсылкаЗаказа.Склад) Тогда
		Результат.Ошибка = "В заказе не указан склад.";
		Возврат Результат;
	КонецЕсли;
	
	НоменклатурыСерийногоУчета = НоменклатурыСерийногоУчетаИнвойса(СсылкаЗаказа);
	СерииПоНоменклатуре = СерииНоменклатурыНаСкладе(СсылкаЗаказа.Фирма, СсылкаЗаказа.Склад, НоменклатурыСерийногоУчета);
	
	МассивПозиций = Новый Массив;
	Для Каждого Номенклатура Из НоменклатурыСерийногоУчета Цикл
		
		МассивСерий = СерииПоНоменклатуре.Получить(Номенклатура);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
		КонецЕсли;
		
		Позиция = Новый Структура;
		Позиция.Вставить("itemCode", StockAPI_Утилиты.КодВСтроку(Номенклатура.Код));
		Позиция.Вставить("serials", МассивСерий);
		МассивПозиций.Добавить(Позиция);
		
	КонецЦикла;
	
	ТелоОтвета = Новый Структура;
	ТелоОтвета.Вставить("orderNumber", 		СсылкаЗаказа.Номер);
	ТелоОтвета.Вставить("incomingNumber", 	СсылкаЗаказа.НомерВходящий);
	ТелоОтвета.Вставить("items", 			МассивПозиций);
	Результат.Тело = ТелоОтвета;
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру ИмяРеквизита + Номер из параметров GET-запроса.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос - параметры orderNumber/incomingNumber и их синонимы.
//
// Возвращаемое значение:
//  Структура, Неопределено - параметры поиска заказа или Неопределено, если номер не указан.
//
Функция СтруктураНомераЗаказаИзЗапроса(Запрос)
	
	НомерЗаказа = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "orderNumber,orderNo,order");
	НомерЗаказаВх = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "incomingNumber,incomingNo,incoming");
	
	Если НомерЗаказа = "" И НомерЗаказаВх = "" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если НомерЗаказаВх <> "" Тогда
		Возврат Новый Структура("ИмяРеквизита, Номер", "НомерВходящий", НомерЗаказаВх);
	КонецЕсли;
	
	Возврат Новый Структура("ИмяРеквизита, Номер", "Номер", НомерЗаказа);
	
КонецФункции   

// Уникальная номенклатура с серийным учётом из табличной части инвойса.
//
// Параметры:
//  СсылкаИнвойса - ДокументСсылка.ИнвойсПродажи - заказ покупателя.
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.Номенклатура - позиции с УчетПоСериям = Истина.
//
Функция НоменклатурыСерийногоУчетаИнвойса(СсылкаИнвойса)
	
	Зап = Новый Запрос;
	Зап.Текст =	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	           	|	Товары.Номенклатура КАК Номенклатура
	           	|ИЗ
	           	|	Документ.ИнвойсПродажи.Товары КАК Товары
	           	|ГДЕ
	           	|	Товары.Ссылка = &Ссылка
	           	|	И Товары.Номенклатура.УчетПоСериям";
	Зап.УстановитьПараметр("Ссылка", СсылкаИнвойса);
	РезультатЗапроса = Зап.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Массив;
	Иначе
	    Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку(0);
	КонецЕсли;
	
КонецФункции     

// Серии номенклатуры на складе с ненулевым остатком.
//
// Параметры:
//  Фирма              - СправочникСсылка.Фирмы - фирма инвойса;
//  Склад              - СправочникСсылка.Склады - склад инвойса;
//  МассивНоменклатуры - Массив из СправочникСсылка.Номенклатура - номенклатура заказа.
//
// Возвращаемое значение:
//  Соответствие - ключ: Номенклатура, значение: Массив серий (Строка).
//
Функция СерииНоменклатурыНаСкладе(Фирма, Склад, МассивНоменклатуры)
	
	Результат = Новый Соответствие;
	Если МассивНоменклатуры.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	Ост.Номенклатура КАК Номенклатура,
	            |	Ост.Партия.Серия КАК Серия
	            |ИЗ
	            |	РегистрНакопления.ОстаткиТовара.Остатки(
	            |			,
	            |			Фирма = &Фирма
	            |				И Склад = &Склад
	            |				И Номенклатура В (&Номенклатура)) КАК Ост
	            |ГДЕ
	            |	Ост.ОстатокОстаток >= 1
	            |	И Ост.Партия.Серия <> """"
	            |
	            |УПОРЯДОЧИТЬ ПО
	            |	Номенклатура,
	            |	Серия";
	Зап.УстановитьПараметр("Фирма", Фирма);
	Зап.УстановитьПараметр("Склад", Склад);
	Зап.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
	
	Выборка = Зап.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Серия = СокрЛП(Выборка.Серия);
		Если Серия = "" Тогда
			Продолжить;
		КонецЕсли;
		
		МассивСерий = Результат.Получить(Выборка.Номенклатура);
		Если МассивСерий = Неопределено Тогда
			МассивСерий = Новый Массив;
			Результат.Вставить(Выборка.Номенклатура, МассивСерий);
		КонецЕсли;
		
		ДобавитьСериюВМассив(МассивСерий, Серия);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции   

// Добавляет серию в массив без дубликатов.
//
// Параметры:
//  МассивСерий   - Массив - массив серий;
//  ЗначениеСерии - Строка - серия для добавления.
//
Процедура ДобавитьСериюВМассив(МассивСерий, ЗначениеСерии)
	
	Серия = СокрЛП(ЗначениеСерии);
	Если Серия = "" Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Существующая Из МассивСерий Цикл
		Если Существующая = Серия Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	МассивСерий.Добавить(Серия);
	
КонецПроцедуры

