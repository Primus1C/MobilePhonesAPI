#Область delivery_notes
	
// ─── Расходные накладные (GET /delivery-notes) ───────────────────────────────

// GET /delivery-notes — выгрузка расходной накладной в PDF, Excel или JSON.
// Параметры: number (или deliveryNoteNumber), date (опционально), format=pdf|excel|json, serials=with|without (по умолчанию with).  
//
Функция ПолучитьРасходнуюНакладнуюФайл(Запрос) Экспорт
	
	Результат = Новый Структура("ДвоичныеДанные, ИмяФайла, ТипСодержимого, Тело, ЭтоJSON, Ошибка, НеНайден", Неопределено, "", "", Неопределено, Ложь, "", Ложь);
	
	НомерНакладной = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "number");
	Если НомерНакладной = "" Тогда
		НомерНакладной = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "deliveryNumber");
	КонецЕсли;
	Если НомерНакладной = "" Тогда
		НомерНакладной = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "deliveryNoteNumber");
	КонецЕсли;
	Если НомерНакладной = "" Тогда
		Результат.Ошибка = "Укажите number (или deliveryNumber или deliveryNoteNumber) — номер расходной накладной.";
		Возврат Результат;
	КонецЕсли;
	
	ДатаНакладной = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "date");
	Если ДатаНакладной = "" Тогда
		ДатаНакладной = StockAPI_Утилиты.ДатаПараметраЗапроса(Запрос, "deliveryNoteDate");
	КонецЕсли;
	
	СсылкаНакладной = НайтиРасходнуюНакладную(НомерНакладной, ?(ДатаНакладной = Неопределено, '00010101', ДатаНакладной));
	Если НЕ ЗначениеЗаполнено(СсылкаНакладной) Тогда
		Результат.Ошибка = СтрШаблон("Расходная накладная %1 не найдена.", НомерНакладной);
		Результат.НеНайден = Истина;
		Возврат Результат;
	КонецЕсли;
	
	Формат = НРег(StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "format"));
	Если Формат = "" Тогда
		Формат = "pdf";
	КонецЕсли;
	
	ПараметрСерий = StockAPI_Утилиты.ПараметрSerialsЗапроса(Запрос, Истина);
	Если ПараметрСерий.Ошибка <> "" Тогда
		Результат.Ошибка = ПараметрСерий.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Если Формат = "pdf" Тогда
			Результат.ДвоичныеДанные = СформироватьPDFРасходнойНакладной(СсылкаНакладной, ПараметрСерий.ССериями);
			Результат.ИмяФайла = ИмяФайлаРасходнойНакладной(СсылкаНакладной, "pdf");
			Результат.ТипСодержимого = "application/pdf";
		ИначеЕсли Формат = "excel" Или Формат = "xlsx" Или Формат = "xls" Тогда
			Результат.ДвоичныеДанные = СформироватьExcelРасходнойНакладной(СсылкаНакладной, ПараметрСерий.ССериями);
			Результат.ИмяФайла = ИмяФайлаРасходнойНакладной(СсылкаНакладной, "xlsx");
			Результат.ТипСодержимого = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
		ИначеЕсли Формат = "json" Тогда
			Результат.Тело = СформироватьJSONРасходнойНакладной(СсылкаНакладной, ПараметрСерий.ССериями);
			Результат.ЭтоJSON = Истина;
		Иначе
			Результат.Ошибка = "Неподдерживаемый format. Допустимые значения: pdf, excel, json.";
			Возврат Результат;
		КонецЕсли;
	Исключение
		Результат.Ошибка = "Не удалось сформировать ответ накладной: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Возврат Результат;

КонецФункции

Функция НайтиРасходнуюНакладную(НомерНакладной, ДатаНакладной = '00010101')
	
	Если СокрЛП(НомерНакладной) = "" Тогда
		Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	КонецЕсли;
	
	Если ДатаНакладной <> '00010101' Тогда
		Ссылка = Документы.РасходнаяНакладная.НайтиПоНомеру(НомерНакладной, ДатаНакладной);
		Если ЗначениеЗаполнено(Ссылка) И НЕ Ссылка.ПометкаУдаления Тогда
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Зап = Новый Запрос;
	Зап.Текст =	"ВЫБРАТЬ ПЕРВЫЕ 1
	           	|	РН.Ссылка КАК Ссылка
	           	|ИЗ
	           	|	Документ.РасходнаяНакладная КАК РН
	           	|ГДЕ
	           	|	РН.Номер = &Номер
	           	|	И НЕ РН.ПометкаУдаления
	           	|
	           	|УПОРЯДОЧИТЬ ПО
	           	|	РН.Дата УБЫВ";
	Зап.УстановитьПараметр("Номер", СокрЛП(НомерНакладной));
	
	Выборка = Зап.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Документы.РасходнаяНакладная.ПустаяСсылка();
	
КонецФункции

Функция СформироватьPDFРасходнойНакладной(СсылкаНакладной, ССериями = Истина)
	
	ТабДок = Новый ТабличныйДокумент;
	ВариантПечати = ?(ССериями, "ПоСериям", "БезСерий");
	Документы.РасходнаяНакладная.ПечатьДокумента(СсылкаНакладной, ВариантПечати, ТабДок);
	Возврат ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайлаТабличногоДокумента.PDF, "pdf");
	
КонецФункции

Функция СформироватьExcelРасходнойНакладной(СсылкаНакладной, ССериями = Истина)
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Ложь;
	ТабДок.ОтображатьСетку = Ложь;
	
	КолонокВсего = ?(ССериями, 6, 5);
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	РН.Номер КАК Номер,
	            |	РН.Дата КАК Дата,
	            |	РН.Контрагент.Наименование КАК Контрагент,
	            |	РН.Склад.Наименование КАК Склад,
	            |	РН.Валюта.Наименование КАК Валюта,
	            |	РН.Сумма КАК Сумма,
	            |	РН.ДокументОснование.Номер КАК НомерЗаказа
	            |ИЗ
	            |	Документ.РасходнаяНакладная КАК РН
	            |ГДЕ
	            |	РН.Ссылка = &Ссылка";
	Зап.УстановитьПараметр("Ссылка", СсылкаНакладной);
	
	ВыборкаШапки = Зап.Выполнить().Выбрать();
	Если НЕ ВыборкаШапки.Следующий() Тогда
		ВызватьИсключение "Не удалось прочитать расходную накладную.";
	КонецЕсли;
	
	ТабДок.Область(1, 1, 1, КолонокВсего).Текст = СтрШаблон("Расходная накладная № %1 от %2",
		ВыборкаШапки.Номер, Формат(ВыборкаШапки.Дата, "ДЛФ=D"));
	ТабДок.Область(2, 1, 2, КолонокВсего).Текст = СтрШаблон("Покупатель: %1 | Склад: %2 | Валюта: %3",
		ВыборкаШапки.Контрагент, ВыборкаШапки.Склад, ВыборкаШапки.Валюта);
	Если ЗначениеЗаполнено(ВыборкаШапки.НомерЗаказа) Тогда
		ТабДок.Область(3, 1, 3, КолонокВсего).Текст = "Заказ: " + ВыборкаШапки.НомерЗаказа;
	КонецЕсли;
	
	СтрокаЗаголовков = 5;
	ТабДок.Область(СтрокаЗаголовков, 1).Текст = "Номенклатура";
	ТабДок.Область(СтрокаЗаголовков, 2).Текст = "Код";
	ТабДок.Область(СтрокаЗаголовков, 3).Текст = "Количество";
	ТабДок.Область(СтрокаЗаголовков, 4).Текст = "Цена продажи";
	ТабДок.Область(СтрокаЗаголовков, 5).Текст = "Сумма";
	Если ССериями Тогда
		ТабДок.Область(СтрокаЗаголовков, 6).Текст = "Серийный номер";
	КонецЕсли;
	
	ЗапТовары = Новый Запрос;
	Если ССериями Тогда
		ЗапТовары.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура.Наименование КАК Номенклатура,
		|	Товары.Номенклатура.Код КАК Код,
		|	Товары.Количество КАК Количество,
		|	Товары.ЦенаПродажи КАК ЦенаПродажи,
		|	Товары.СуммаПродажи КАК СуммаПродажи,
		|	Товары.Серия КАК Серия,
		|	Товары.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	Товары.НомерСтроки";
	Иначе
		ЗапТовары.Текст =
		"ВЫБРАТЬ
		|	Товары.Номенклатура.Наименование КАК Номенклатура,
		|	Товары.Номенклатура.Код КАК Код,
		|	СУММА(Товары.Количество) КАК Количество,
		|	Товары.ЦенаПродажи КАК ЦенаПродажи,
		|	СУММА(Товары.СуммаПродажи) КАК СуммаПродажи,
		|	МИНИМУМ(Товары.НомерСтроки) КАК НомерСтроки
		|ИЗ
		|	Документ.РасходнаяНакладная.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура,
		|	Товары.Номенклатура.Наименование,
		|	Товары.Номенклатура.Код,
		|	Товары.ЦенаПродажи
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
	КонецЕсли;
	ЗапТовары.УстановитьПараметр("Ссылка", СсылкаНакладной);
	
	НомерСтроки = СтрокаЗаголовков + 1;
	ВыборкаТовары = ЗапТовары.Выполнить().Выбрать();
	Пока ВыборкаТовары.Следующий() Цикл
		ТабДок.Область(НомерСтроки, 1).Текст = ВыборкаТовары.Номенклатура;
		ТабДок.Область(НомерСтроки, 2).Текст = Формат(ВыборкаТовары.Код, "ЧГ=0");
		ТабДок.Область(НомерСтроки, 3).Текст = ВыборкаТовары.Количество;
		ТабДок.Область(НомерСтроки, 4).Текст = ВыборкаТовары.ЦенаПродажи;
		ТабДок.Область(НомерСтроки, 5).Текст = ВыборкаТовары.СуммаПродажи;
		Если ССериями Тогда
			ТабДок.Область(НомерСтроки, 6).Текст = СокрЛП(ВыборкаТовары.Серия);
		КонецЕсли;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	ТабДок.Область(НомерСтроки, 4).Текст = "Итого:";
	ТабДок.Область(НомерСтроки, 5).Текст = ВыборкаШапки.Сумма;
	
	Возврат ТабличныйДокументВДвоичныеДанные(ТабДок, ТипФайлаТабличногоДокумента.XLSX, "xlsx");
	
КонецФункции

Функция СформироватьJSONРасходнойНакладной(СсылкаНакладной, ССериями = Истина)
	
	Зап = Новый Запрос;
	Зап.Текст = "ВЫБРАТЬ
	            |	РН.Номер КАК Номер,
	            |	РН.Дата КАК Дата,
	            |	РН.Проведен КАК Проведен,
	            |	РН.Контрагент.Наименование КАК Контрагент,
	            |	РН.Контрагент.Код КАК КодКонтрагента,
	            |	РН.Склад.Наименование КАК Склад,
	            |	РН.Склад.Код КАК КодСклада,
	            |	РН.Валюта.Наименование КАК Валюта,
	            |	РН.Сумма КАК Сумма,
	            |	РН.ДокументОснование.Номер КАК НомерЗаказа
	            |ИЗ
	            |	Документ.РасходнаяНакладная КАК РН
