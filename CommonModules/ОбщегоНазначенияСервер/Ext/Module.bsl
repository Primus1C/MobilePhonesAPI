Функция ОстаткиПриходнойНакладной(ДокументСсылка) Экспорт

	Запр = Новый Запрос; 
		Запр.УстановитьПараметр("ПрихНакладная", ДокументСсылка);
		Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		             |	Свод.Номенклатура КАК Номенклатура,
		             |	Свод.Серия КАК Серия,
		             |	Свод.Партия КАК Партия,
		             |	Свод.ЦенаЗакупки КАК ЦенаЗакупки,
		             |	СУММА(Свод.Количество) КАК Количество,
		             |	СУММА(Свод.СуммаЗакупки) КАК СуммаЗакупки
		             |ИЗ
		             |	(ВЫБРАТЬ
		             |		ПрихНакл.Номенклатура КАК Номенклатура,
		             |		ПрихНакл.Серия КАК Серия,
		             |		ПрихНакл.Партия КАК Партия,
		             |		ПрихНакл.ЦенаЗакупки КАК ЦенаЗакупки,
		             |		ПрихНакл.Количество КАК Количество,
		             |		ПрихНакл.СуммаЗакупки КАК СуммаЗакупки
		             |	ИЗ
		             |		Документ.ПриходнаяНакладная.Товары КАК ПрихНакл
		             |	ГДЕ
		             |		ПрихНакл.Ссылка = &ПрихНакладная
		             |		И НЕ ПрихНакл.Ссылка.ПометкаУдаления
		             |	
		             |	ОБЪЕДИНИТЬ
		             |	
		             |	ВЫБРАТЬ
		             |		Перем.Номенклатура,
		             |		Перем.Серия,
		             |		Перем.Партия,
		             |		Перем.ЦенаЗакупки,
		             |		-Перем.Количество,
		             |		-Перем.СуммаЗакупки
		             |	ИЗ
		             |		Документ.Перемещение.Товары КАК Перем
		             |	ГДЕ
		             |		Перем.Ссылка.ДокументОснование = &ПрихНакладная
		             |		И НЕ Перем.Ссылка.ПометкаУдаления
		             |	
		             |	ОБЪЕДИНИТЬ
		             |	
		             |	ВЫБРАТЬ
		             |		РасхНакл.Номенклатура,
		             |		РасхНакл.Серия,
		             |		РасхНакл.Партия,
		             |		РасхНакл.ЦенаЗакупки,
		             |		-РасхНакл.Количество,
		             |		-РасхНакл.СуммаЗакупки
		             |	ИЗ
		             |		Документ.РасходнаяНакладная.Товары КАК РасхНакл
		             |	ГДЕ
		             |		РасхНакл.Ссылка.ДокументОснование = &ПрихНакладная
		             |		И НЕ РасхНакл.Ссылка.ПометкаУдаления) КАК Свод
		             |
		             |СГРУППИРОВАТЬ ПО
		             |	Свод.Номенклатура,
		             |	Свод.Серия,
		             |	Свод.Партия,
		             |	Свод.ЦенаЗакупки
		             |
		             |ИМЕЮЩИЕ
		             |	СУММА(Свод.Количество) > 0"; 
		Возврат Запр.Выполнить().Выгрузить();

