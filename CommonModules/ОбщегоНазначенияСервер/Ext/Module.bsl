	л_Дата = ТекущаяДата();	
	//л_НастройкаХраненияФайлов = РегистрыСведений.НастройкаХраненияФайлов.ПолучитьПоследнее(л_Дата); 
	л_НастройкаХраненияФайлов = ОбщегоНазначенияПовтИсп.НастройкаХраненияФайлов();
	Если НЕ ЗначениеЗаполнено(п_Файл.Расширение) Тогда
	    ТекстСообщения = НСтр("ru = 'Нельзя прикреплять файл, не имеющий расширения!'; en = 'You cannot attach a file that does not have an extension!'");
		п_Отказ = Истина;  	
	КонецЕсли;

	НачатьТранзакцию();
	Если л_НастройкаХраненияФайлов.МестоХраненияФайлов = Перечисления.МестоХраненияПрикрепленныхФайлов.ОбщийДисковыйРесурс Тогда 
		Если п_Файл.Размер > л_НастройкаХраненияФайлов.МаксРазмерФайлаДляИБ Тогда 
			ТекстСообщения = ?(ТекстСообщения="", "", ТекстСообщения + Символы.ПС) + СтрШаблон(
							НСтр("ru = 'Размер файла: %1 Мбайт превышает максимальный размер, установленный в настройках (%2 Мбайт)'; en = 'File size: %1 Mb exceeds the maximum size in the settings (%2 Mb)'"), 
							Формат(п_Файл.Размер/(1024*1024), "ЧДЦ=1; ЧРГ="), 
							Формат(л_НастройкаХраненияФайлов.МаксРазмерФайлаДляИБ/(1024*1024), "ЧДЦ=1; ЧРГ="));
			п_Отказ = Истина;                
			УдалитьИзВременногоХранилища(п_АдресВременногоХранилища);
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
		РегистрыСведений.ХранилищеФайлов.СохранитьФайлНаДиск(п_АдресВременногоХранилища, л_НастройкаХраненияФайлов, п_Объект, п_Файл, п_Отказ, ТекстСообщения);
		Если п_Отказ Тогда 
			УдалитьИзВременногоХранилища(п_АдресВременногоХранилища);
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
	КонецЕсли;	
	
	Если НЕ п_Отказ Тогда
		л_Запись = РегистрыСведений.ХранилищеФайлов.СоздатьМенеджерЗаписи();
		Если ТипЗнч(п_КлючЗаписи) = Тип("Структура") И п_КлючЗаписи.Свойство("ОбъектСсылка") И ЗначениеЗаполнено(п_КлючЗаписи.ОбъектСсылка) Тогда
			ЗаполнитьЗначенияСвойств(л_Запись, п_КлючЗаписи);
			л_Запись.Прочитать();
		КонецЕсли;
		РегистрыСведений.ХранилищеФайлов.ДобавитьЗаписьВРегистр(л_Дата, п_Объект, п_Файл, л_НастройкаХраненияФайлов, п_Отказ, п_ИзменитьСуществующуюЗапись, л_Запись, ТекстСообщения);
		Если п_Отказ Тогда 
			ОтменитьТранзакцию();
			Возврат;
		КонецЕсли;
		п_КлючЗаписи = РегистрыСведений.ХранилищеФайлов.ПолучитьКлючЗаписи(п_Объект, п_Файл, л_НастройкаХраненияФайлов);
	КонецЕсли;
	УдалитьИзВременногоХранилища(п_АдресВременногоХранилища);
	ЗафиксироватьТранзакцию();  
	
КонецПроцедуры

Процедура СформироватьГиперссылкиФайловНаФорме(ОбъектСсылка, Форма, ГруппаЭлементовФормы, Назначение, ИмяПроцедурыПриНажатии, ИмяПроцедурыУдаления = "") Экспорт 
	
	Префикс = ?(Назначение=Перечисления.НазначениеФайлов.Прочее,"_П","_О");

	// удаление реквизитов и элементов   
	УдаляемыеЭлементы  = Новый Массив;
	УдаляемыеРевизиты = Новый Массив;
	Для каждого Эл Из ГруппаЭлементовФормы.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(Эл);
		Если Найти(Эл.Имя, "ГруппаФайл") > 0 Тогда
			УдаляемыеРевизиты.Добавить(СтрЗаменить(Эл.Имя, "ГруппаФайл", "КартинкаФайл"));
		КонецЕсли;   
	КонецЦикла;
	Для каждого Эл Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(Эл);
	КонецЦикла;
	Форма.ИзменитьРеквизиты( , УдаляемыеРевизиты);
	
	// добавление
	
	масФайлов = РегистрыСведений.ХранилищеФайлов.ПолучитьМассивФайлов(ОбъектСсылка, Назначение);
	
	ДобавляемыеРеквизиты = Новый Массив; //Определяем массив добавляемых реквизитов
	Для каждого Эл Из масФайлов Цикл
		//Создание реквизитов
		НовыйРеквизит = Новый РеквизитФормы("КартинкаФайл" + Префикс + масФайлов.Найти(Эл), Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(3,0))); 
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит); 
	КонецЦикла;
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты); //Применяем реквизиты 
	
	Для каждого Эл Из масФайлов Цикл
     	Форма["КартинкаФайл" + Префикс + масФайлов.Найти(Эл)] = ОбщегоНазначения.ПолучитьИндексПиктограммыФайла(ОбщегоНазначения.ПолучитьРасширение(Эл));
	КонецЦикла;
	
	Если ИмяПроцедурыУдаления <> "" И масФайлов.ВГраница() > -1 Тогда
		Если Форма.Команды.Найти("УдалениеФайлаВложения") = Неопределено Тогда
			НоваяКомандаУдаления = Форма.Команды.Добавить("УдалениеФайлаВложения");
			НоваяКомандаУдаления.Действие = ИмяПроцедурыУдаления;		
		КонецЕсли;
	КонецЕсли;    
	
	Если масФайлов.ВГраница() = -1 Тогда
		НовыйЭлементБ = Форма.Элементы.Добавить("БезФайлов" + Префикс, Тип("ДекорацияФормы"), ГруппаЭлементовФормы);
		НовыйЭлементБ.Вид 					= ВидДекорацииФормы.Надпись; 
		НовыйЭлементБ.Заголовок 			= НСтр("ru = '(нет файлов)'; en = '(no files)'");
		НовыйЭлементБ.ЦветТекста			= ЦветаСтиля.ЦветТекстаФормы;
	КонецЕсли;

	Для каждого Эл Из масФайлов Цикл
		
		ИмяЭлемента = Префикс + масФайлов.Найти(Эл);
		
		НовГруппа = Форма.Элементы.Добавить("ГруппаФайл" + ИмяЭлемента, Тип("ГруппаФормы"), ГруппаЭлементовФормы); 
		НовГруппа.Вид 						= ВидГруппыФормы.ОбычнаяГруппа; 
		НовГруппа.Группировка 				= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда; 
		НовГруппа.Отображение 				= ОтображениеОбычнойГруппы.Нет;
		НовГруппа.ОтображатьЗаголовок 		= Ложь;
		
		НовыйЗначок = Форма.Элементы.Добавить("Картинка" + ИмяЭлемента, Тип("ПолеФормы"), НовГруппа);
		НовыйЗначок.Вид 					= ВидПоляФормы.ПолеКартинки; 
		НовыйЗначок.ПутьКДанным 			= "КартинкаФайл" + ИмяЭлемента;
		НовыйЗначок.КартинкаЗначений 		= БиблиотекаКартинок.КоллекцияПиктограммФайлов;
		НовыйЗначок.ПоложениеЗаголовка 		= ПоложениеЗаголовкаЭлементаФормы.нет;
		НовыйЗначок.Ширина 					= 2;
		НовыйЗначок.Высота 					= 1;  
		НовыйЗначок.ВертикальноеПоложение 	= ВертикальноеПоложениеЭлемента.Верх;  
		НовыйЗначок.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Верх; 
        НовыйЗначок.РастягиватьПоГоризонтали = Ложь;    
		НовыйЗначок.РастягиватьПоВертикали 	= Ложь;
		НовыйЗначок.Рамка 					= Новый Рамка(ТипРамкиЭлементаУправления.БезРамки, ); 
		//НовыйЗначок.КонтекстноеМеню.Доступность = Ложь;
		//НовыйЗначок.КонтекстноеМеню.Видимость = Ложь;
		Если ИмяПроцедурыУдаления <> "" Тогда
			НовыйЗначок.Гиперссылка 		= Истина;
			НовыйЗначок.УстановитьДействие("Нажатие", ИмяПроцедурыУдаления);
		КонецЕсли;
		
		НовыйЭлемент = Форма.Элементы.Добавить("Файл" + ИмяЭлемента, Тип("ДекорацияФормы"), НовГруппа);
		НовыйЭлемент.Вид 					= ВидДекорацииФормы.Надпись; 
		НовыйЭлемент.Гиперссылка 			= Истина;
		НовыйЭлемент.Заголовок 				= Эл;	
		НовыйЭлемент.УстановитьДействие("Нажатие", ИмяПроцедурыПриНажатии);
		
		Если ИмяПроцедурыУдаления <> "" Тогда
			НовыйЭлементП = Форма.Элементы.Добавить("Пробел" + ИмяЭлемента, Тип("ДекорацияФормы"), НовГруппа);
			НовыйЭлементП.Вид 				= ВидДекорацииФормы.Картинка; 
			НовыйЭлементП.Ширина 			= 1;
			НовыйЭлементП.Высота 			= 1;  
		КонецЕсли;
		
	КонецЦикла; 
	
КонецПроцедуры

