// Выводит сообщение об ошибке заполнения поля.
//
Процедура СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения, ИмяТабличнойЧасти = Неопределено, НомерСтроки = Неопределено, Поле = Неопределено, Отказ = Ложь) Экспорт
	
	Сообщение = Новый СообщениеПользователю();
	Сообщение.Текст = ТекстСообщения;
	
	Если ИмяТабличнойЧасти <> Неопределено Тогда
		Сообщение.Поле = ИмяТабличнойЧасти + "[" + (НомерСтроки - 1) + "]." + Поле;
	ИначеЕсли ЗначениеЗаполнено(Поле) Тогда
		Сообщение.Поле = Поле;
	КонецЕсли;
	
	Сообщение.УстановитьДанные(ЭтотОбъект);
	
	Сообщение.Сообщить();
	
	Отказ = Истина;
	
КонецПроцедуры // СообщитьОбОшибке()

Процедура УстановитьДоступностьРеквизитов(Форма, МассивДоступныхРеквизитов) Экспорт

	Для каждого Элемент Из Форма.Элементы Цикл
		Если МассивДоступныхРеквизитов.Найти(Элемент.Имя) = Неопределено Тогда
			Тип = ТипЗнч(Элемент);
			Если Тип = Тип("ПолеФормы") Тогда
				Элемент.Доступность = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	

КонецПроцедуры

Функция ТекстHTMLВФорматированнуюСтроку(ТекстHTML) Экспорт
	
    ФорматированныйДокумент = Новый ФорматированныйДокумент;
    ФорматированныйДокумент.УстановитьHTML(ТекстHTML, Новый Структура);
    Возврат ФорматированныйДокумент.ПолучитьФорматированнуюСтроку(); 
	
КонецФункции

#Область Затраты

&НаСервере                 
// 	Расчет скопирован из проц.ПередЗаписью() док-та ПриходнаяНакладная
//   Параметры:
//    Партия - СправочникСсылка.Партии - партия товара
//    ДокВызова - ДокументСсылка.РасходнаяНакладная 
//    ТолькоИтог - Булево         
//
Функция СоставЗатрат(Партия, ДокВызова, ТолькоИтог = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	мас = Новый Массив; 
	Итог = 0; 
	ИтогВал = 0;
	
	// 1. Док-ты ДопЗатраты
	
	ДокПН = Партия.Док;
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Приходная", 	ДокПН);	
	Запрос.УстановитьПараметр("Партия", 	Партия);	
	//Запрос.УстановитьПараметр("ДопЗатраты", Затраты.Выгрузить(,"ДокументЗатрат").ВыгрузитьКолонку(0));
    Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
                   |	СУММА(ВКД_ДополнительныеЗатратыДокументы.СуммаНаценки) КАК СуммаНаценки,
                   |	СУММА(ВКД_ДополнительныеЗатратыДокументы.Количество) КАК Количество,
                   |	ВКД_ДополнительныеЗатратыДокументы.Ссылка КАК Ссылка
                   |ИЗ
                   |	Документ.ВКД_ДополнительныеЗатраты.Документы КАК ВКД_ДополнительныеЗатратыДокументы
                   |ГДЕ
                   |	ВКД_ДополнительныеЗатратыДокументы.Документ = &Приходная
                   |	И ВКД_ДополнительныеЗатратыДокументы.Ссылка.Проведен
                   |
                   |СГРУППИРОВАТЬ ПО
                   |	ВКД_ДополнительныеЗатратыДокументы.Ссылка
                   |
                   |УПОРЯДОЧИТЬ ПО
                   |	ВКД_ДополнительныеЗатратыДокументы.Ссылка.Дата
                   |;
                   |
                   |////////////////////////////////////////////////////////////////////////////////
                   |ВЫБРАТЬ
                   |	ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
                   |	ПриходнаяНакладнаяТовары.Партия КАК Партия,
                   |	ПриходнаяНакладнаяТовары.СуммаЗакупки КАК СуммаЗакупки,
                   |	ПриходнаяНакладнаяТовары.Количество КАК Количество,
                   |	ПриходнаяНакладнаяТовары.Номенклатура.Вес КАК НоменклатураВес
                   |ИЗ
                   |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
                   |ГДЕ
                   |	ПриходнаяНакладнаяТовары.Ссылка = &Приходная
                   |	И ПриходнаяНакладнаяТовары.Партия = &Партия";
	Пакет = Запрос.ВыполнитьПакет();
    Выборка 	= Пакет[0].Выбрать(); 
	СтрокиПН 	= Пакет[1].Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		ВариантРаспределения = Выборка.Ссылка.ВариантРаспределения;
		ОбщаяСуммаКРаспределению = омСервер.ПересчетЗн(Выборка.СуммаНаценки, Выборка.Ссылка.Валюта, ПараметрыСеанса.БазоваяВалюта, ДокПН.Фирма, Выборка.Ссылка.Дата, 5);
		СтрокиПН.Сбросить();
		Пока СтрокиПН.Следующий() Цикл
			Если ОбщаяСуммаКРаспределению = 0 Тогда 
				ДельтаЦены = 0;
				лЕдИзм = "";
			Иначе
				Если ВариантРаспределения = 1 Тогда
					лВесоваяЧасть = СтрокиПН.СуммаЗакупки / ДокПН.Сумма * 100  ;
					лСуммаКРаспределению = ОбщаяСуммаКРаспределению * лВесоваяЧасть / 100;
					ДельтаЦены = лСуммаКРаспределению / СтрокиПН.Количество; 
					лЕдИзм = Выборка.Ссылка.Валюта;	
				ИначеЕсли ВариантРаспределения = 2 Тогда
					ДельтаЦены = ОбщаяСуммаКРаспределению / ДокПН.ВКД_Количество; 
					лЕдИзм = "шт.";
				Иначе
					ДельтаЦены = 0;
					лЕдИзм = "";
				КонецЕсли;         
			КонецЕсли; 		
			стр = стрШаблон("%1: %2 %3 / %4 %5 * %6 = %7 %3", 
									ОбщегоНазначения.ПредставлениеДокументаДляПечати(Выборка.Ссылка) + Символы.ПС, 
									Выборка.СуммаНаценки, 
									ПараметрыСеанса.БазоваяВалюта.Символ,
									Выборка.Количество, 
		                            лЕдИзм,    
									СтрокиПН.Количество,	
									Формат(ДельтаЦены, "ЧДЦ=5")
								);
			Итог = Итог + ДельтаЦены;
			Если ДокВызова <> Неопределено Тогда
				//Если ДокВызова.Валюта <> ПараметрыСеанса.БазоваяВалюта Тогда 
					ДельтаЦеныВал = омСервер.ПересчетЗн(ДельтаЦены, ПараметрыСеанса.БазоваяВалюта, ДокВызова.Валюта, ДокПН.Фирма, ДокВызова.Дата, 5);
					стр = СтрШаблон("%1 = %2 %3", 
									стр,
					                Формат(ДельтаЦеныВал, "ЧДЦ=5"),
									ДокВызова.Валюта.Символ
									);
					ИтогВал = ИтогВал + ДельтаЦеныВал;	
				//КонецЕсли;
			КонецЕсли;
			мас.Добавить(стр);		
		КонецЦикла;     
	КонецЦикла;
	
	// 2. Док-ты Отправки
	
	//ЗатратыОтправки = Документы.ПриходнаяНакладная.ЗатратыОтправки(ПрихНакладная.Инвойс, ПрихНакладная.Поставка);
     Если ЗначениеЗаполнено(ДокПН.ВКД_Инвойс) Тогда
	 
		 Запр = Новый Запрос; 
		 Запр.УстановитьПараметр("Инвойс", 		ДокПН.ВКД_Инвойс);
		 Запр.УстановитьПараметр("Поставка", 	ДокПН.Поставка);
		 Запр.УстановитьПараметр("Номенклатура",Партия.Владелец);
		 Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		              |	ОтправкаРаспределениеЗатрат.Ссылка КАК Ссылка,
		              |	ОтправкаРаспределениеЗатрат.Номенклатура КАК Номенклатура,
		              |	ОтправкаРаспределениеЗатрат.Номенклатура.Вес/1000 КАК ВесЕдиницы,
		              |	ОтправкаРаспределениеЗатрат.Цена КАК Цена,
		              |	ОтправкаРаспределениеЗатрат.Количество КАК Количество,
		              |	ОтправкаРаспределениеЗатрат.Вес КАК Вес,
		              |	ОтправкаРаспределениеЗатрат.Сумма КАК Сумма
		              |ИЗ
		              |	Документ.Отправка.РаспределениеЗатрат КАК ОтправкаРаспределениеЗатрат
		              |ГДЕ
		              |	ОтправкаРаспределениеЗатрат.Ссылка В
		              |			(ВЫБРАТЬ
		              |				ОтправкаИнвойсы.Ссылка
		              |			ИЗ
		              |				Документ.Отправка.Инвойсы КАК ОтправкаИнвойсы
		              |			ГДЕ
		              |				ОтправкаИнвойсы.Инвойс = &Инвойс
		              |				И ОтправкаИнвойсы.Поставка = &Поставка
		              |				И ОтправкаИнвойсы.Ссылка.Проведен)
		              |	И ОтправкаРаспределениеЗатрат.Номенклатура = &Номенклатура"; 
		 Выборка = Запр.Выполнить().Выбрать();
		 Пока Выборка.Следующий() Цикл
			стр = стрШаблон("%1: %2 %3 / %4 %5 * %6 %5 = %7 %3",
		            				ОбщегоНазначения.ПредставлениеДокументаДляПечати(Выборка.Ссылка) + Символы.ПС, 
									Выборка.Сумма,
									ПараметрыСеанса.БазоваяВалюта.Символ,
									Выборка.Вес,
									"кг", 
									Выборка.ВесЕдиницы,
									//Выборка.Количество,
									Выборка.Цена
						);
			Итог = Итог + Выборка.Цена;			
			Если ДокВызова <> Неопределено Тогда
				//Если ДокВызова.Валюта <> ПараметрыСеанса.БазоваяВалюта Тогда 
					ЦенаВал = омСервер.ПересчетЗн(Выборка.Цена, ПараметрыСеанса.БазоваяВалюта, ДокВызова.Валюта, ДокПН.Фирма, ДокВызова.Дата, 5);
					стр = СтрШаблон("%1 = %2 %3", 
									стр,
					                Формат(ЦенаВал, "ЧДЦ=5"),
									ДокВызова.Валюта.Символ
									);
					ИтогВал = ИтогВал + ЦенаВал;	
				//КонецЕсли;
			КонецЕсли;					
			мас.Добавить(стр);		
			 
		 КонецЦикла;
	 
	 КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	 
	 Если ТолькоИтог Тогда
	 	Возврат Новый Структура("Сумма,СуммаВал", Итог, ИтогВал);
	 Иначе
    	Возврат мас;
	 КонецЕсли;
	
КонецФункции // СоставЗатрат()

#КонецОбласти


