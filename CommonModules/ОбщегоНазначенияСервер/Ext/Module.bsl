Функция ДолгиПокупателя(Контрагент, Дата) Экспорт

	Если Контрагент.ОтсрочкаДней = 0 Тогда
		Возврат 0;
	Иначе	
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		             |	ДолгиОстатки.ДолгПокупателяОстаток КАК Сумма,
		             |	ДолгиОстатки.Док КАК Док,
		             |	РАЗНОСТЬДАТ(ДОБАВИТЬКДАТЕ(ДолгиОстатки.Док.Дата, ДЕНЬ, &Отсрочка), &Дата, ДЕНЬ) КАК Срок,
		             |	ДолгиОстатки.Валюта КАК Валюта
		             |ИЗ
		             |	РегистрНакопления.Долги.Остатки(&Дата, Контрагент = &Контрагент) КАК ДолгиОстатки
		             |
		             |УПОРЯДОЧИТЬ ПО
		             |	ДолгиОстатки.Док.Дата";
		Запр.УстановитьПараметр("Дата", Дата);
		Запр.УстановитьПараметр("Контрагент", Контрагент);
		Запр.УстановитьПараметр("Отсрочка", Контрагент.ОтсрочкаДней);
	    РезультатЗапроса = Запр.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			Возврат 0;
		Иначе
			мас = Новый Массив;
		    Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				мас.Добавить(Новый Структура("Сумма,Документ,Валюта,Срок", Выборка.Сумма, Выборка.Док, Выборка.Валюта, Выборка.Срок));	
			КонецЦикла;	
			Возврат Новый Структура("Срок, Долги", Мас[0].Срок, Мас);
		КонецЕсли;
	КонецЕсли;	

КонецФункции // ДолгПокупателя()

Функция ДолгиПоставщику(Контрагент, Дата = Неопределено) Экспорт
	
	Долги = Новый Массив;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Дата", Дата);
	Запр.УстановитьПараметр("Контрагент", Контрагент);
	Запр.Текст = "ВЫБРАТЬ
	             |	ВзаиморасчетыОстатки.Валюта КАК Валюта,
	             |	ВзаиморасчетыОстатки.СуммаОплатыОстаток КАК Сумма
	             |ИЗ
	             |	РегистрНакопления._ВзаиморасчетыСПоставщиками.Остатки({(&Дата)}, Контрагент = &Контрагент) КАК ВзаиморасчетыОстатки";	
    Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Долги.Добавить(Новый Структура("Валюта,Сумма", Выборка.Валюта, Выборка.Сумма));	
	Конеццикла;
	Возврат Долги;
	
КонецФункции // ДолгПоставщику()

Функция ДолгиПоставщикуПоИнвойсам(Контрагент, Дата = Неопределено) Экспорт

	ПоИнвойсам = Новый Массив;
	ПоВалютам = Новый Массив;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Дата", Дата);
	Запр.УстановитьПараметр("Контрагент", Контрагент);
	Запр.Текст = "ВЫБРАТЬ
	             |	РасчетыПоИнвойсамОстатки.Инвойс КАК Инвойс,
	             |	РасчетыПоИнвойсамОстатки.Валюта КАК Валюта,
	             |	СУММА(РасчетыПоИнвойсамОстатки.СуммаОстаток) КАК Сумма,
	             |	СостоянияИнвойсов.СтатусОплатыАвто КАК СтатусОплатыАвто
	             |ПОМЕСТИТЬ тз
	             |ИЗ
	             |	РегистрНакопления.РасчетыПоИнвойсам.Остатки({(&Дата)}, Контрагент = &Контрагент) КАК РасчетыПоИнвойсамОстатки
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
	             |		ПО РасчетыПоИнвойсамОстатки.Инвойс = СостоянияИнвойсов.Инвойс
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	РасчетыПоИнвойсамОстатки.Инвойс,
	             |	РасчетыПоИнвойсамОстатки.Валюта,
	             |	СостоянияИнвойсов.СтатусОплатыАвто
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тз.Инвойс КАК Инвойс,
	             |	тз.Валюта КАК Валюта,
	             |	тз.Сумма КАК Сумма,
	             |	тз.СтатусОплатыАвто КАК СтатусОплатыАвто
	             |ИЗ
	             |	тз КАК тз
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тз.Валюта КАК Валюта,
	             |	СУММА(тз.Сумма) КАК Сумма
	             |ИЗ
	             |	тз КАК тз
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	тз.Валюта";	 
	Запр.Текст = "ВЫБРАТЬ
	             |	База.Инвойс КАК Инвойс,
	             |	База.Валюта КАК Валюта,
	             |	СУММА(База.Сумма) КАК Сумма,
	             |	МАКСИМУМ(База.СтатусОплатыАвто) КАК СтатусОплатыАвто
	             |ПОМЕСТИТЬ тз
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Остатки.Инвойс КАК Инвойс,
	             |		Остатки.Валюта КАК Валюта,
	             |		Остатки.СуммаОстаток КАК Сумма,
	             |		NULL КАК СтатусОплатыАвто
	             |	ИЗ
	             |		РегистрНакопления.РасчетыПоИнвойсам.Остатки({(&Дата)}, Контрагент = &Контрагент) КАК Остатки
	             |	
	             |	ОБЪЕДИНИТЬ ВСЕ
	             |	
	             |	ВЫБРАТЬ
	             |		Состояния.Инвойс,
	             |		Состояния.Инвойс.Валюта,
	             |		0,
	             |		Состояния.СтатусОплатыАвто
	             |	ИЗ
	             |		РегистрСведений.СостоянияИнвойсов КАК Состояния
	             |	ГДЕ
	             |		Состояния.Инвойс.Контрагент = &Контрагент) КАК База
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	База.Инвойс,
	             |	База.Валюта
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тз.Инвойс КАК Инвойс,
	             |	тз.Валюта КАК Валюта,
	             |	тз.Сумма КАК Сумма,
	             |	тз.СтатусОплатыАвто КАК СтатусОплатыАвто
	             |ИЗ
	             |	тз КАК тз
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	тз.Валюта КАК Валюта,
	             |	СУММА(тз.Сумма) КАК Сумма
	             |ИЗ
	             |	тз КАК тз
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	тз.Валюта";	 
	Пакет = Запр.ВыполнитьПакет();
	ВыборкаИнвойсы = Пакет[1].Выбрать();
	Пока ВыборкаИнвойсы.Следующий() Цикл
		ПоИнвойсам.Добавить(Новый Структура("Инвойс,Валюта,Сумма,СтатусОплатыАвто", ВыборкаИнвойсы.Инвойс, ВыборкаИнвойсы.Валюта, ВыборкаИнвойсы.Сумма, ВыборкаИнвойсы.СтатусОплатыАвто));	
	КонецЦикла; 
	ВыборкаВалюты = Пакет[2].Выбрать();
	Пока ВыборкаВалюты.Следующий() Цикл
		ПоВалютам.Добавить(Новый Структура("Валюта,Сумма", ВыборкаВалюты.Валюта, ВыборкаВалюты.Сумма));
	КонецЦикла;	
	Возврат Новый Структура("ПоИнвойсам,ПоВалютам", ПоИнвойсам, ПоВалютам);	

КонецФункции 

#Область ПодключаемыеКоманды

Процедура ПодключитьКомандыПечати(ПараметрыРазмещения, СтруктураПечатныхФорм) Экспорт

	Элементы = ПараметрыРазмещения.Форма.Элементы;
	КоманднаяПанель = ПараметрыРазмещения.КоманднаяПанель;
	Если КоманднаяПанель = Неопределено Тогда
		КоманднаяПанель = Элементы.Найти("ПодключаемыеКоманды");
		Если КоманднаяПанель = Неопределено Тогда
			КоманднаяПанель = Элементы.Найти("КоманднаяПанель");
			
			Если Не ПараметрыРазмещения.ЭтоФормаОбъекта
				И КоманднаяПанель = Неопределено  Тогда
				ТаблицаФормы = Элементы.Найти("Список");
				Если ТипЗнч(ТаблицаФормы) = Тип("ТаблицаФормы")
					И ТаблицаФормы.ПоложениеКоманднойПанели <> ПоложениеКоманднойПанелиЭлементаФормы.Нет Тогда
					КоманднаяПанель = ТаблицаФормы.КоманднаяПанель;
				КонецЕсли;
			КонецЕсли;
			Если КоманднаяПанель = Неопределено Тогда
				КоманднаяПанель = ПараметрыРазмещения.Форма.КоманднаяПанель;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	КоманднаяПанель.Подсказка = НСтр("ru = 'Печать'; en = 'Print'");
	
	Если СтруктураПечатныхФорм.Количество() > 1 Тогда
		Подменю = Элементы.Добавить("МенюПечать", Тип("ГруппаФормы"), КоманднаяПанель);
		Подменю.Вид         = ВидГруппыФормы.Подменю;
		Подменю.Заголовок   = НСтр("ru = 'Печать'; en = 'Print'");
		Подменю.Картинка    = БиблиотекаКартинок.Печать;
	Иначе
		Подменю = КоманднаяПанель;  
	КонецЕсли;
	
	Для каждого ОписаниеПечФормы Из СтруктураПечатныхФорм Цикл  
		ИмяКоманды = "ПодключеннаяПечать_" + ОписаниеПечФормы.Ключ;
		НоваяКоманда = ПараметрыРазмещения.Форма.Команды.Добавить(ИмяКоманды);
		НоваяКоманда.Действие = "ВыполнитьПодключеннуюПечать";   //Имя процедуры на клиенте
		НовыйЭлемент = Элементы.Добавить("Печать_"+ОписаниеПечФормы.Ключ, Тип("КнопкаФормы"), Подменю);
		НовыйЭлемент.Заголовок = ОписаниеПечФормы.Значение;
		НовыйЭлемент.ИмяКоманды = ИмяКоманды; 
		Если СтруктураПечатныхФорм.Количество() = 1 Тогда
			НовыйЭлемент.Картинка = БиблиотекаКартинок.Печать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
 
#КонецОбласти    

Функция СтатусПроведения(ДокументСсылка) Экспорт
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		Если ДокументСсылка.Проведен Тогда
			Возврат 0;
		ИначеЕсли ДокументСсылка.ПометкаУдаления Тогда
			Возврат 2;
		Иначе
			Возврат 1;
		КонецЕсли;
	Иначе	
		Возврат 3;
	КонецЕсли;
	
КонецФункции // СтатусПроведения()

