Функция СкладыКонтрагентов(Отправители = Истина, Получатели = Истина) Экспорт

	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	СкладыКонтрагентов.Ссылка
	             |ИЗ
	             |	Справочник.СкладыКонтрагентов КАК СкладыКонтрагентов
	             |ГДЕ
	             |	НЕ СкладыКонтрагентов.ПометкаУдаления
	             |	И НЕ СкладыКонтрагентов.Отправитель
	             |	И НЕ СкладыКонтрагентов.Получатель
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	СкладыКонтрагентов.Наименование";
	Если Отправители Тогда
		Запр.Текст = СтрЗаменить(Запр.Текст, "НЕ СкладыКонтрагентов.Отправитель", "СкладыКонтрагентов.Отправитель");
	КонецЕсли;				 
	Если Получатели Тогда
		Запр.Текст = СтрЗаменить(Запр.Текст, "НЕ СкладыКонтрагентов.Получатель", "СкладыКонтрагентов.Получатель");
	КонецЕсли;				 

	Возврат Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
	
КонецФункции // СкладыКонтрагентов()

Процедура ЗаполнитьРеквизитыДокументаПоУмолчанию(ДокументОбъект, ЕстьФирма = Истина) Экспорт
	
	Если ЕстьФирма Тогда
		ДокументОбъект.Фирма 	= гоФирма();
	КонецЕсли;
	ДокументОбъект.КемСоздан 	= гоПользователь(); 
	ДокументОбъект.Создан 		= ТекущаяДатаСеанса(); 
	
	Если ДокументОбъект.Метаданные().Реквизиты.Найти("Валюта") <> Неопределено Тогда
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.Валюта) Тогда 
			Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ПередачаНаКомиссию") Тогда
				ДокументОбъект.Валюта = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ВалютаРасчетовСКомиссионером");		
			ИначеЕсли ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ОтчетКомиссионера") Тогда
						
			Иначе	
				ДокументОбъект.Валюта = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("Валюта");		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ДокументОбъект.Метаданные().Реквизиты.Найти("Склад") <> Неопределено Тогда 
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.Склад) Тогда
			ДокументОбъект.Склад = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("Склад");
		КонецЕсли;	 
	КонецЕсли;
	Если  ДокументОбъект.Метаданные().Реквизиты.Найти("СкладОтправитель") <> Неопределено Тогда
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.СкладОтправитель) Тогда
			ДокументОбъект.СкладОтправитель = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("СкладОтправителя");
		КонецЕсли;	
	КонецЕсли;
	Если ДокументОбъект.Метаданные().Реквизиты.Найти("СкладПолучатель") <> Неопределено Тогда   
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.СкладПолучатель) Тогда
			ДокументОбъект.СкладПолучатель = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("СкладПолучателя");
		КонецЕсли;	 
	КонецЕсли;

	// комиссия
	Если ДокументОбъект.Метаданные().Реквизиты.Найти("СкладКомиссии") <> Неопределено Тогда   
		Если НЕ ЗначениеЗаполнено(ДокументОбъект.СкладКомиссии) Тогда
			ДокументОбъект.СкладКомиссии = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("СкладКомиссии");
		КонецЕсли;	 
	КонецЕсли;

КонецПроцедуры

