		Возврат Дата(2026, 4, 1);	
	ИначеЕсли Имя = "НачалоИспользованияПривязокИнвойсов" Тогда	
		Возврат Дата(2026, 6, 1);	
	Иначе
		ВызватьИсключение("Ошибка разработки: ОбщегоНазначенияПовтИсп.ПредустановленнаяДатаУчета()", КатегорияОшибки.ОшибкаКонфигурации);
		Возврат Дата(1,1,1);
	КонецЕсли;	

