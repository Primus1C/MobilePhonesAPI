Функция МассивДоступныхСкладов() Экспорт

	Рез = Новый Массив;
	Если гоПользователь().Складов = 0 Тогда Возврат Рез КонецЕсли; 
	Если гоПользователь().СкладыИсключать Тогда
		Запр = Новый Запрос; 
		Запр.УстановитьПараметр("Исключить", гоПользователь().Склады.ВыгрузитьКолонку(0));
		Запр.Текст = "ВЫБРАТЬ
		             |	Склады.Ссылка
		             |ИЗ
		             |	Справочник.Склады КАК Склады
		             |ГДЕ
		             |	НЕ Склады.Ссылка В (&Исключить)";
		Рез = Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
	Иначе	
		Рез = гоПользователь().Склады.ВыгрузитьКолонку(0); 
	КонецЕсли;
	Возврат Рез;
КонецФункции

Функция МассивДоступныхКасс() Экспорт

	Рез = Новый Массив;
	Если гоПользователь().ДенежныхСчетов = 0 Тогда Возврат Рез КонецЕсли;   
	Если гоПользователь().ДенежныеСчетаИсключать Тогда
		Запр = Новый Запрос; 
		Запр.УстановитьПараметр("Исключить", гоПользователь().ДенежныеСчета.ВыгрузитьКолонку(0));
		Запр.Текст = "ВЫБРАТЬ
		             |	ДенежныеСчета.Ссылка
		             |ИЗ
		             |	Справочник.ДенежныеСчета КАК ДенежныеСчета
		             |ГДЕ
		             |	НЕ ДенежныеСчета.Ссылка В (&Исключить)";
		Рез = Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0); 
	Иначе
		Для Каждого Стр Из гоПользователь().ДенежныеСчета Цикл
			Рез.Добавить(Стр.ДенежныйСчет);
		КонецЦикла;    
	КонецЕсли;		
	Возврат Рез;

КонецФункции

