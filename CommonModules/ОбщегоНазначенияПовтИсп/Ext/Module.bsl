Функция ДоступныеВалюты(Отбор = Неопределено) Экспорт
	
	Валюты 		= Новый СписокЗначений;
	ЦветаВалют 	= ЦветаВалют();
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Валюты.Ссылка,
	             |	Валюты.Код,
	             |	Валюты.ЦветРГБ,
	             |	Валюты.Символ
	             |ИЗ
	             |	Справочник.Валюты КАК Валюты
	             |ГДЕ
	             |	НЕ Валюты.ПометкаУдаления
	             |	И ИСТИНА = ИСТИНА
	             | АВТОУПОРЯДОЧИВАНИЕ";
	Если Отбор <> Неопределено Тогда                         
		Условие = "";
		Для каждого Отб Из Отбор Цикл 
			Если Отб.Значение = Истина Тогда
				ЗначениеОтбора = "ИСТИНА";
			ИначеЕсли Отб.Значение = Ложь Тогда	
				ЗначениеОтбора = "ЛОЖЬ";
			Иначе
				ЗначениеОтбора = Отб.Значение;
			КонецЕсли;
			Условие = СтрШаблон("%1 %2 = %3 И ", Условие, Отб.Ключ, ЗначениеОтбора);
		КонецЦикла;	
		Условие = Лев(Условие, СтрДлина(Условие) - 3);
		Если Условие <> "" Тогда
			Запр.Текст = СтрЗаменить(Запр.Текст, "ИСТИНА = ИСТИНА", Условие);
		КонецЕсли;
	КонецЕсли;
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Валюты.Добавить(Выборка.Ссылка, Новый ФорматированнаяСтрока(Выборка.Код + " (" + Выборка.Символ + ")",,, гоЦветРГБ(Выборка.ЦветРГБ),));
	КонецЦикла;
	Возврат Валюты;
	
КонецФункции	

// Функция возвращает значение по умолчанию для передаваемого пользователя и настройки.
//
// Параметры:
//  Пользователь - текущий пользователь программы
//  Настройка    - признак, для которого возвращается значение по умолчанию
//
// Возвращаемое значение:
//  Значение по умолчанию для настройки.
//
Функция ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, Настройка, ПустоеЗначение = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Настройка"   , ПланыВидовХарактеристик.НастройкиПользователей[Настройка]);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Значение
	|ИЗ
	|	РегистрСведений.НастройкиПользователей КАК РегистрЗначениеПрав
	|
	|ГДЕ
	|	Пользователь = &Пользователь
	| И Настройка    = &Настройка";

	Выборка = Запрос.Выполнить().Выбрать();

	Если ПустоеЗначение = Неопределено Тогда
		ПустоеЗначение = ПланыВидовХарактеристик.НастройкиПользователей[Настройка].ТипЗначения.ПривестиЗначение();
	КонецЕсли;

	Если Выборка.Количество() = 0 Тогда
		
		Возврат ПустоеЗначение;

	ИначеЕсли Выборка.Следующий() Тогда

		Если НЕ ЗначениеЗаполнено(Выборка.Значение) Тогда
			Возврат ПустоеЗначение;
		Иначе
			Возврат Выборка.Значение;
		КонецЕсли;

	Иначе
		Возврат ПустоеЗначение;

	КонецЕсли;

КонецФункции // ПолучитьЗначениеПоУмолчаниюПользователя()

// Функция возвращает значение по умолчанию для передаваемого пользователя и настройки.
//
// Параметры:
//  Настройка    - признак, для которого возвращается значение по умолчанию
//
// Возвращаемое значение:
//  Значение по умолчанию для настройки.
//
Функция ПолучитьЗначениеНастройки(Настройка, ПараметрыСеансаУстановлены = Истина) Экспорт
	
	Запрос = Новый Запрос;   
	Если ПараметрыСеансаУстановлены Тогда
		Запрос.УстановитьПараметр("Пользователь", гоПользователь());
	Иначе
		Запрос.УстановитьПараметр("Пользователь", омСервер.ПолучитьПользователя());
	КонецЕсли;
	Запрос.УстановитьПараметр("Настройка"   , ПланыВидовХарактеристик.НастройкиПользователей[Настройка]);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Значение
		|ИЗ
		|	РегистрСведений.НастройкиПользователей КАК РегистрЗначениеПрав
		|
		|ГДЕ
		|	Пользователь = &Пользователь
		| И Настройка    = &Настройка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПустоеЗначение = ПланыВидовХарактеристик.НастройкиПользователей[Настройка].ТипЗначения.ПривестиЗначение();
	
	Если Выборка.Количество() = 0 Тогда
		
		Возврат ПустоеЗначение;
		
	ИначеЕсли Выборка.Следующий() Тогда
		
		Если НЕ ЗначениеЗаполнено(Выборка.Значение) Тогда
			Возврат ПустоеЗначение;
		Иначе
			Возврат Выборка.Значение;
		КонецЕсли;
		
	Иначе
		Возврат ПустоеЗначение;
		
	КонецЕсли;  
	
КонецФункции // ПолучитьЗначениеНастройки()

Функция ЦветаВалют() Экспорт

	Соотв = Новый Соответствие;
	Выборка = Справочники.Валюты.Выбрать();
	Пока Выборка.Следующий() Цикл
		Соотв.Вставить(Выборка.Ссылка, гоЦветРГБ(выборка.ЦветРГБ));	
	КонецЦикла;
	Соотв.Вставить(Справочники.Валюты.ПустаяСсылка(), гоЦветРГБ("255,255,255"));	
	Возврат Соотв;

КонецФункции 

Функция ЦветаСтатусов() Экспорт
	
	Соотв = Новый Соответствие;
	Запр = Новый Запрос; 
	Запр.Текст = "ВЫБРАТЬ
	             |	ЦветаОформления.Значение КАК Цвет,
	             |	ЦветаОформления.Настройка.Наименование КАК Статус
	             |ИЗ
	             |	РегистрСведений.ЦветаОформления КАК ЦветаОформления
	             |ГДЕ
	             |	ЦветаОформления.Настройка.Родитель = ЗНАЧЕНИЕ(ПланВидовхарактеристик.ЦветаОформления.СтатусыИнвойсов)
	             |			ИЛИ ЦветаОформления.Настройка.Родитель = ЗНАЧЕНИЕ(ПланВидовхарактеристик.ЦветаОформления.СтатусыИнспекцииИнвойсов)
	             |			ИЛИ ЦветаОформления.Настройка.Родитель = ЗНАЧЕНИЕ(ПланВидовхарактеристик.ЦветаОформления.СтатусыОплатыИнвойсов)";
    Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Соотв.Вставить(Выборка.Статус, ?(ЗначениеЗаполнено(Выборка.Цвет), гоЦветРГБ(Выборка.Цвет), гоЦветРГБ("255,255,255")));
	КонецЦикла;
	Соотв.Вставить("", гоЦветРГБ("255,255,255"));	
	Возврат Соотв;

КонецФункции 
	
Функция ЦветЭлементаСписка(ИмяЭлемента) Экспорт

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Настройка", ИмяЭлемента);
	Запр.Текст = "ВЫБРАТЬ
	             |	ЦветаОформления.Значение КАК Цвет
	             |ИЗ
	             |	РегистрСведений.ЦветаОформления КАК ЦветаОформления
	             |ГДЕ
	             |	ЦветаОформления.Настройка.ИмяПредопределенныхДанных = &Настройка";
	Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.Цвет) Тогда
		    Возврат гоЦветРГБ(Выборка.Цвет);
		Иначе	
			Возврат гоЦветРГБ("255,255,255");
		КонецЕсли;	
	Иначе
		Возврат гоЦветРГБ("255,255,255");
	КонецЕсли;

КонецФункции // ЦветЭлементаСписка()

