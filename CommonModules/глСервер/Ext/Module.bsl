Процедура глНоваяКолонка(Табл, Имя, Стр = "", Дли = 0, Точ = 0, Неотр = Ложь) Экспорт
//2016.01.31	
	
	Если (Стр = "Число") И (Дли <> 0) Тогда
		
		Знак = ДопустимыйЗнак.Любой;
		Если Неотр Тогда Знак = ДопустимыйЗнак.Неотрицательный КонецЕсли; 
		
		Тип = Новый ОписаниеТипов(Стр, Новый КвалификаторыЧисла(Дли, Точ, Знак));
		
	ИначеЕсли (Стр = "Строка") И (Дли <> 0) Тогда
		
		//именно третьим параметром нужно писать
		Тип = Новый ОписаниеТипов(Стр, , Новый КвалификаторыСтроки(Дли));

	//2016.01.31	
	//добавляем без типа вообще, так тоже можно
	ИначеЕсли Стр = "" Тогда
	
		Табл.Колонки.Добавить(Имя);
		Возврат;
		
	Иначе
		
		Тип = Новый ОписаниеТипов(Стр);
		
	КонецЕсли; 
	
	Табл.Колонки.Добавить(Имя, Тип);
КонецПроцедуры

