Процедура глПокраситьПомеченныеНаУдаление(Форма, ИмяСписка = "Список") Экспорт

	ФормаСписок = Форма[ИмяСписка];	
	
	Эле = ФормаСписок.УсловноеОформление.Элементы.Добавить();
	Эле.ИдентификаторПользовательскойНастройки = "ПометкаУдаления";
	Эле.Представление = "ПометкаУдаления";
	Эле.Использование = Истина;
	Эле.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный;	//Недоступный
		
	Отб = Эле.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отб.Использование = Истина;
	Отб.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ПометкаУдаления");
	Отб.ВидСравнения  = ВидСравненияКомпоновкиДанных.Равно;
	Отб.ПравоеЗначение = Истина;

	Пол = Эле.Поля.Элементы.Добавить();
	Пол.Использование = Истина;
	//Пол.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
		
	Эле.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.ТемноГрифельноСерый);

КонецПроцедуры

Процедура глПокраситьУслуги(Форма, ИмяСписка = "Список") Экспорт
	
	Если НЕ ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ВыделятьЦветомУслуги") Тогда
		Возврат;	
	КонецЕсли;
	
	Попытка
		ФормаСписок = Форма[ИмяСписка];	
	Исключение
		ФормаСписок = Форма;	
	КонецПопытки;	
		
	Эле = ФормаСписок.УсловноеОформление.Элементы.Добавить();
	//Эле.ИдентификаторПользовательскойНастройки = "Услуги";
	//Эле.Представление = "Услуги";
	Эле.Использование = Истина;
	Эле.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный;	//Недоступный
		
	Отб = Эле.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отб.Использование = Истина;
	Отб.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТипНоменклатуры");
	Отб.ВидСравнения  = ВидСравненияКомпоновкиДанных.Равно;
	Отб.ПравоеЗначение = Перечисления.ТипыНоменклатуры.Услуга;

	Пол = Эле.Поля.Элементы.Добавить();
	Пол.Использование = Истина;
		
	Эле.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ОбщегоНазначенияПовтИсп.ЦветЭлементаСписка("ЦветУслуг"));

