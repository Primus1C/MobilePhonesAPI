Функция глПриСозданииНаСервереЭлемент(Форма, Объект) Экспорт

	МожноКод = гоЕстьРоль("РазрешитьКодыСправочников");
	
	Имя = Объект.Ссылка.Метаданные().Имя;
	
	//2016.05.15 + Аптеки
	//Если НЕ гоЭто("Пользователи, Валюты, Аптеки", Имя) Тогда
	Если НЕ гоЭто("Пользователи, Валюты", Имя) Тогда
		Попытка
			Форма.Элементы.Код.Видимость = МожноКод;
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Если гоЭто("Контрагенты, Номенклатура", Имя) Тогда
		Попытка
			Форма.Элементы.Родитель.Видимость = Ложь;
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Попытка
		Форма.Элементы.ФормаИзменитьФорму.Видимость = Ложь;
	Исключение
	КонецПопытки; 
	
	Если гоЭто("Фирмы", Имя) Тогда
		Попытка
			Форма.Элементы.Префикс.ТолькоПросмотр = НЕ гоАдминистратор();
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Если гоЭто("Партии", Имя) Тогда
		Попытка
			Форма.Элементы.Серия.Видимость = гоФирма().ВыводитьСерия;
			Форма.Элементы.СрокГодности.Видимость = гоФирма().ВыводитьСрокГодности;
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Если гоЭто("Номенклатура", Имя) Тогда
		Попытка
			Форма.Элементы.УчетПоСериям.Видимость = гоФирма().ВыводитьСерия;
			Форма.Элементы.Производитель.Видимость = гоФирма().ВыводитьПроизводитель;
		Исключение
		КонецПопытки; 
	
		//2016.05.24
		//флаг услуг нужно проверить на движения, если ссылка уже есть
		//если услуги были как товар, то найдет
		//но если услуги были как услуги, то движений не будет здесь
		//если когда-то мы сделаем обороты услуг, сможем там смотреть
		//2016.07.15 + И (НЕ Объект.ЭтоГруппа)
		Если ЗначениеЗаполнено(Объект.Ссылка) И (НЕ Объект.ЭтоГруппа) Тогда
			Форма.Элементы.ТипНоменклатуры.ТолькоПросмотр = омСервер.ЕстьДвиженияНоменклатуры(Объект.Ссылка) 
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат Истина;
КонецФункции

Функция глПриСозданииНаСервереСписок(Форма) Экспорт
	Можно = гоЕстьРоль("РазрешитьНастройкуСписка");
	МожноФорму = гоЕстьРоль("РазрешитьИзменятьФорму");
	МожноКод = гоЕстьРоль("РазрешитьКодыСправочников");
	
	Имя = "";
	Попытка
		Имя = СтрЗаменить(Форма.Список.ОсновнаяТаблица, "Справочник.", "");
	Исключение
	КонецПопытки; 
	
	//хочу везде код спрятать
	Попытка
		Форма.Элементы.Код.Видимость = МожноКод;
	Исключение
	КонецПопытки; 
	
	//и команду настройки формы
	Попытка
		Форма.Элементы.ФормаИзменитьФорму.Видимость = МожноФорму;
		Форма.Элементы.ФормаНастройкаСписка.Видимость = Можно;
		
		Форма.Элементы.ФормаОбновить.ТолькоВоВсехДействиях = Ложь;
		Форма.Элементы.ФормаОбновить.Отображение = ОтображениеКнопки.КартинкаИТекст;
	Исключение
	КонецПопытки; 
	
	Если гоЭто("Партии", Имя) Тогда
		Попытка
			Форма.Элементы.Серия.Видимость = гоФирма().ВыводитьСерия;
			Форма.Элементы.СрокГодности.Видимость = гоФирма().ВыводитьСрокГодности;
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	Если гоЭто("Номенклатура", Имя) Тогда
		Попытка
			Форма.Элементы.УчетПоСериям.Видимость = гоФирма().ВыводитьСерия;
			Форма.Элементы.Производитель.Видимость = гоФирма().ВыводитьПроизводитель;
		Исключение
		КонецПопытки; 
		
		Попытка
			Форма.Элементы.Остаток.Формат = "ЧДЦ=" + гоФирма().ЧислоЗнаковКоличество;
			Форма.Элементы.Резерв.Формат = "ЧДЦ=" + гоФирма().ЧислоЗнаковКоличество;
		Исключение
		КонецПопытки; 
	КонецЕсли; 
	
	//2016.01.30
	//это отключит окошко для поиска, которое не дает пользоваться старым вариантом поиска, когда при первой букве появляется окно
	Попытка
		Форма.Элементы.Список.ПоложениеСтрокиПоиска = ПоложениеСтрокиПоиска.Нет;
	Исключение
	КонецПопытки; 
	
	Возврат Истина;
КонецФункции

Функция глПрефикс(Фирма, ДСчет = 0) Экспорт
	Прф = "";
	Попытка
		Прф = СокрЛП(Фирма.Префикс);
	Исключение
	    Прф = "";
	КонецПопытки; 
	Если Прф = "" Тогда Прф = "ФР" КонецЕсли; 
	
	ПрфДоп = "";
	Если НЕ (ДСчет = 0) Тогда  
		Попытка
			ПрфДоп = СокрЛП(ДСчет.Префикс);
		Исключение
			ПрфДоп = "";
		КонецПопытки; 
		Если ПрфДоп = "" Тогда ПрфДоп = "ДС" КонецЕсли; 
	КонецЕсли; 
	
	Возврат Прф + ПрфДоп;
КонецФункции

Функция глПрефиксДефис(Фирма, ДСчет = 0) Экспорт
	Возврат глПрефикс(Фирма, ДСчет) + "-";
КонецФункции

