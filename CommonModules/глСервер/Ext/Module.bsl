Функция глЗапретЗаписиПоДате(ДокументСсылка) Экспорт
	
	Если ДокументСсылка.Дата = Дата(1,1,1) Тогда
		Возврат Ложь;
	КонецЕсли;
	лДатаЗапрета = гоПараметрСеанса("ДатаЗапретаРедактирования");
	Если лДатаЗапрета <> Дата(1,1,1) И ДокументСсылка.Дата <= КонецДня(лДатаЗапрета) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции     

