	Дли = СтрДлина(Стр);
	
	СейчасЧто = -1;
	Для Н = 1 По Дли Цикл
		Сим = Сред(Стр, Н, 1);
		//надо точки - это хорошо, но точка не должна быть первой, а я видел, где ".30" и "ч . "
		//и точно она не должна быть последней, точнее, после цифры она еще число, а вот после буквы
		Что = глЭтоСимЦифра(Сим, НадоТочки);
		
		//бывает, что пришла точка и она определилась как цифра, но до этого была буква
		//а после буквы нам точка совсем не цифра
		Если (Н <> 1) И (Сим = ".") И Что И (НЕ СейчасЧто) Тогда Что = Ложь КонецЕсли; 
		
		//первый раз инициализируем
		Если СейчасЧто = -1 Тогда СейчасЧто = Что КонецЕсли; 
		
		//когда идет смена, вставляем пробел
		Если СейчасЧто <> Что Тогда 
			Рез = Рез + " ";
			СейчасЧто = Что;
		КонецЕсли; 
		
		//символ добавляем всегда
		Рез = Рез + Сим;
	КонецЦикла; 
	
	Возврат Рез;
КонецФункции
 
Функция глСложныйАнализ(Имя) Экспорт
//2016.02.14
//мы хотим разделить цифры и буквы, нужна какая-то функция
//именно при загрузке нужно, чтобы изменения зафиксировались
//предлагается не просто так, а если слово начинается с цифры, точку внутри цифр тоже нужно считать цифрой, еще там может запятая
//можно сначала найти все запятые, если слева и справа цифры, то меняем на точку

	Стр = СокрЛП(Имя);
	Стр = СтрЗаменить(Стр, ";", ",");
	Стр = СтрЗаменить(Стр, """", "'");
	
	РС = Символы.ПС;
	//прежде всего нужно убрать РС, вдруг попали, можно и другие символы
	Стр = СтрЗаменить(Стр, РС, " ");
	Стр = СтрЗаменить(Стр, Символы.НПП, "");
	Стр = СтрЗаменить(Стр, Символы.Таб, "");
	
	//идея такая - можно легко получить список слов, потом каждое проанализируем
	//сначала нужно все двойные пробелы заменить на 1
	Пока Найти(Стр, "  ") Цикл Стр = СтрЗаменить(Стр, "  ", " ") КонецЦикла; 
	
	//теперь можно разделить на слова функцией по строкам, но сначала пробел меняем на РС
	Стр = СтрЗаменить(Стр, " ", РС);
	
	Рез = "";
	//обрабатываем все слова
	Ско = СтрЧислоСтрок(Стр);
	Для Н = 1 По Ско Цикл
		Сло = СтрПолучитьСтроку(Стр, Н);
		Если Сло = "" Тогда Продолжить КонецЕсли;
		
		//каждое слово мы хотим обработать
		//если оно начинается с цифры, то меняем запятые внутри на точки
		Пер = Лев(Сло, 1);
		НадоТочки = Ложь;
		Если глЭтоСимЦифра(Пер) Тогда 
			Сло = СтрЗаменить(Сло, ",", "."); 
			НадоТочки = Истина;
		КонецЕсли;
		
		//решили все слова разделять
		//задание посложнее, если внутри слова есть переход с цифр на буквы, то вставляем пробел
		Сло = глРазделитьЦифрыБуквы(Сло, НадоТочки);
		
		//после обработки складываем слова
		Рез = Рез + Сло + " ";
	КонецЦикла; 
	
	//чтобы ушел пробел в конце
	Возврат СокрЛП(Рез);
КонецФункции
