Процедура глПокраситьВалюты(Форма, ИмяПоля, ИмяСписка = "") Экспорт

	ФормаСписок = Форма[?(ИмяСписка = "", "Список", ИмяСписка)];
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Валюты.Ссылка КАК Ссылка,
	             |	Валюты.Код КАК Код,
	             |	Валюты.Обозначение КАК Обозначение
	             |ИЗ
	             |	Справочник.Валюты КАК Валюты";
	Выборка = Справочники.Валюты.Выбрать();  
	Пока Выборка.Следующий() Цикл  
		
		Эле = ФормаСписок.УсловноеОформление.Элементы.Добавить();
		//Эле.ИдентификаторПользовательскойНастройки = "Цвет" + Выборка.Код;
		//Эле.Представление = "Цвет " + Выборка.Код;
		Эле.Использование = Истина;
		//Эле.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный;	//Недоступный
		
		Отб = Эле.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		Отб.Использование = Истина;
		Отб.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля);
		Отб.ВидСравнения  = ВидСравненияКомпоновкиДанных.Равно;
		Отб.ПравоеЗначение = ?(ИмяПоля = "Обозначение", Выборка.Обозначение, Выборка.Ссылка);
		
		Пол = Эле.Поля.Элементы.Добавить();
		Пол.Использование = Истина;
		Пол.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
		
		Эле.Оформление.УстановитьЗначениеПараметра("ЦветФона", гоЦветРГБ(Выборка.ЦветРГБ)); 
		
	КонецЦикла;     
	
КонецПроцедуры

Процедура глПокраситьВалютыТЗ(Форма, ИмяПоля, ПутьКДанным) Экспорт
	
	Запр = Новый Запрос;
