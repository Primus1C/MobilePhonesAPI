Процедура глЗаписатьОбщиеРеквизиты(Объект) Экспорт

	Если НЕ ЗначениеЗаполнено(Объект.Фирма) Тогда Объект.Фирма = гоФирма() КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Объект.КемСоздан) Тогда Объект.КемСоздан = гоПользователь() КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Объект.Создан) Тогда Объект.Создан = ТекущаяДатаСеанса() КонецЕсли; 
	Объект.КемСохранен = гоПользователь();
	Объект.Сохранен = ТекущаяДатаСеанса();

КонецПроцедуры

Функция глОплатаЧем(Регистратор, СуммаПрихода, СуммаРасхода) Экспорт
	Попытка
		КолвоПривязок = Регистратор.Привязки.Количество();
	Исключение
		КолвоПривязок = 0;
	КонецПопытки; 
	
	Рез = Документы.РасходнаяНакладная.ПустаяСсылка();
	Сум = ?(СуммаПрихода = 0, СуммаРасхода, СуммаПрихода);
	
	Если НЕ (КолвоПривязок = 0) Тогда
		Для Каждого Строка Из Регистратор.Привязки Цикл
			Если Строка.Сумма1 = Сум Тогда  
				Рез = Строка.Док2;
				Прервать;
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	Возврат Рез;
КонецФункции

Процедура глВывестиСекцию(Таб, Макет, Область, Параметры, Уровень=Неопределено) Экспорт
	Ш = Макет.ПолучитьОбласть(Область); 
	Ш.Параметры.Заполнить(Параметры);  
	Если Уровень=Неопределено Тогда
		Таб.Вывести(Ш);
	Иначе
		Таб.Вывести(Ш, Уровень);
	КонецЕсли;
КонецПроцедуры

Процедура глПрисоединитьСекцию(Таб, Макет, Область, Параметры) Экспорт
	Ш = Макет.ПолучитьОбласть(Область); 
	Ш.Параметры.Заполнить(Параметры); 
	Таб.Присоединить(Ш);
КонецПроцедуры

Процедура глПовторятьПриПечатиСтроки(Таб, НумС, НумПо, ФиксСверху = 0) Экспорт
	Таб.ПовторятьПриПечатиСтроки = Таб.Область("R" + НумС + ":R" + НумПо);	//работает нормально
	
	Если ФиксСверху = 0 Тогда Возврат КонецЕсли; 
	
	Таб.ФиксацияСверху = ФиксСверху;
КонецПроцедуры

Процедура глПараметрыСтраницы(Таб, Ор = 1, Масштаб = -1, РежимПечатиКопий = -1, ПолеСлева = -1, ПолеСправа = -1, ПолеСверху = -1, ПолеСнизу = -1, КолонтитулСверху = -1, КолонтитулСнизу = -1, Автомасштаб = -1) Экспорт
	//еще там были <ФлагЧБПечати>,<ИмяПринтера>)

	Таб.ОриентацияСтраницы = ?(Ор = 1, ОриентацияСтраницы.Портрет, ОриентацияСтраницы.Ландшафт);
	
	Если НЕ (Масштаб = -1) Тогда Таб.МасштабПечати = Масштаб КонецЕсли;
	Если НЕ (РежимПечатиКопий = -1) Тогда Таб.РазборПоКопиям = (РежимПечатиКопий = 1) КонецЕсли;
	Если НЕ (ПолеСлева = -1) Тогда Таб.ПолеСлева = ПолеСлева КонецЕсли;
	Если НЕ (ПолеСправа = -1) Тогда Таб.ПолеСправа = ПолеСправа КонецЕсли;
	Если НЕ (ПолеСверху = -1) Тогда Таб.ПолеСверху = ПолеСверху КонецЕсли;
	Если НЕ (ПолеСнизу = -1) Тогда Таб.ПолеСнизу = ПолеСнизу КонецЕсли;
	Если НЕ (КолонтитулСверху = -1) Тогда Таб.РазмерКолонтитулаСверху = КолонтитулСверху КонецЕсли;
	Если НЕ (КолонтитулСнизу = -1) Тогда Таб.РазмерКолонтитулаСнизу = КолонтитулСнизу КонецЕсли;
	Если НЕ (Автомасштаб = -1) Тогда Таб.АвтоМасштаб = Автомасштаб КонецЕсли;
КонецПроцедуры

Процедура глОпции(Таб, ВыводСетки = -1, ВыводЗаголовков = -1, ФиксСтрок = -1, ФиксСтолбцов = -1, ИмяОпцийПечати = -1) Экспорт	//<ИмяСохрРазмОкна>,<ФлагЧБПросмотра>,<НаправлПерехода>)
	Если НЕ (ВыводСетки = -1) Тогда Таб.ОтображатьСетку = ВыводСетки КонецЕсли; 
	Если НЕ (ВыводЗаголовков = -1) Тогда Таб.ОтображатьЗаголовки = ВыводЗаголовков КонецЕсли; 
	Если НЕ (ФиксСтрок = -1) Тогда Таб.ФиксацияСверху = ФиксСтрок КонецЕсли; 
	Если НЕ (ФиксСтолбцов = -1) Тогда Таб.ФиксацияСлева = ФиксСтолбцов КонецЕсли; 
	Если НЕ (ИмяОпцийПечати = -1) Тогда Таб.КлючПараметровПечати = ИмяОпцийПечати КонецЕсли; 
КонецПроцедуры

