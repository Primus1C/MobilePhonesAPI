Процедура ПроверитьНаТолькоТовары(ТаблицаТовары, Ошибки) Экспорт

	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ТЗ", ТаблицаТовары);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.НомерСтроки КАК НомерСтрокиТЧ,
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.ТипНоменклатуры КАК ТипНоменклатуры
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
	               |	ВТ.Номенклатура КАК Номенклатура,
	               |	ВТ.ТипНоменклатуры КАК ТипНоменклатуры
	               |ИЗ
	               |	ВТ КАК ВТ";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Ошибки.Добавить(СтрШаблон(НСтр("ru = 'Строка %1: номенклатура %2 с видом %3!'; en = 'Line %1: good %2 has kind %3!'"), 
						Выборка.НомерСтрокиТЧ, Выборка.Номенклатура, Выборка.ТипНоменклатуры));
	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьНаОстаткиТоваров(ТаблицаТовары, Дата, Склад, Ошибки, Фирма = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТЗ", ТаблицаТовары);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Фирма", ?(Фирма = Неопределено, ПараметрыСеанса.Фирма, Фирма));
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.НомерСтроки КАК НомерСтрокиТЧ,
	               |	ТЗ.Номенклатура КАК Номенклатура,
	               |	ТЗ.Партия КАК Партия,
	               |	ТЗ.Серия КАК Серия,
	               |	ТЗ.Количество КАК Количество
	               |ПОМЕСТИТЬ ВТ
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ.НомерСтрокиТЧ КАК НомерСтрокиТЧ,
	               |	ВТ.Номенклатура КАК Номенклатура,
	               |	ВТ.Партия КАК Партия,
	               |	ВТ.Серия КАК Серия,
	               |	ВТ.Количество КАК Количество,
	               |	ЕСТЬNULL(ОстаткиПартий.ОстатокОстаток, 0) КАК Остаток
	               |ИЗ
	               |	ВТ КАК ВТ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(
	               |				&Дата,
	               |				Партия В
	               |						(ВЫБРАТЬ
	               |							Т.Партия
	               |						ИЗ
	               |							ВТ КАК Т)
	               |					И Склад = &Склад
	               |					И Фирма = &Фирма) КАК ОстаткиПартий
	               |		ПО ВТ.Партия = ОстаткиПартий.Партия
	               |ГДЕ
	               |	ВТ.Количество > ЕСТЬNULL(ОстаткиПартий.ОстатокОстаток, 0)";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Ошибки.Добавить(стршаблон("строка %1: требуется %2, в наличии %3",
						Выборка.НомерСтрокиТЧ,
						Выборка.Количество,
						Выборка.Остаток));
	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьДубли(ТЧ, Ошибки, ИмяПоля = "Серия") Экспорт

	СооствОшибки = Новый Соответствие;
	Для каждого СтрокаТЧ Из ТЧ Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ[ИмяПоля]) Тогда
			НайдСтроки = ТЧ.НайтиСтроки(Новый Структура(ИмяПоля, СтрокаТЧ[ИмяПоля]));
			Если НайдСтроки.ВГраница() > 0 Тогда  
				Стр = "";
				Для Инд = 0 По НайдСтроки.ВГраница() Цикл
					Стр = Стр + НайдСтроки[Инд].НомерСтроки + ", ";
				КонецЦикла;
				СооствОшибки.Вставить(СтрокаТЧ[ИмяПоля], Стр);
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;
	Если СооствОшибки.Количество() > 0 Тогда
		ТекстОшибки = + Символы.ПС;
		Для каждого Ош Из СооствОшибки Цикл 
			Ошибки.Добавить(СтрШаблон("%1 %2 %3: %4",
									  НСтр("ru = 'Найдены дубли серии'; en = 'Series'"),
									  Ош.Ключ,  
									  НСтр("ru = 'в строках'; en = 'duplicates found in the lines'"),
									  Лев(Ош.Значение, СтрДлина(Ош.Значение)-2)));
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры


// Возвращает структуру с суммами затрат одной партии, или массиваа партий
//
//  Параметры: 
//    МассивПартийИлиПартия - Массив|СправочникСсылка.Партии, партия
//
Функция ЗатратыПартий(МассивПартийИлиПартия) Экспорт
	
	ОднаПартия = ТипЗнч(МассивПартийИлиПартия) = Тип("СправочникСсылка.Партии");
	МассивПартий = Новый Массив;
	Если ОднаПартия Тогда
		МассивПартий.Добавить(МассивПартийИлиПартия);
	Иначе
	    МассивПартий = МассивПартийИлиПартия;
	КонецЕсли;
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Партии", МассивПартий);
	Запр.Текст = "ВЫБРАТЬ
	             |	Затраты.Партия КАК Партия,
	             |	СУММА(Затраты.Сумма) КАК Сумма
	             |ИЗ
	             |	РегистрСведений.Затраты КАК Затраты
	             |ГДЕ
	             |	Затраты.Партия В(&Партии)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	Затраты.Партия
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	Свод.Партия КАК Партия,
	             |	СУММА(Свод.Сумма) КАК Сумма
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Партии.Ссылка КАК Партия,
	             |		Партии.Владелец КАК Номенклатура,
	             |		Партии.Док.ВКД_Инвойс КАК Инвойс,
	             |		Партии.Док.Поставка КАК Поставка,
	             |		ЗатратыИнв.Сумма КАК Сумма
	             |	ИЗ
	             |		Справочник.Партии КАК Партии
	             |			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |				Затраты.Сумма КАК Сумма,
	             |				Затраты.Номенклатура КАК Номенклатура,
	             |				Затраты.Инвойс КАК Инвойс,
	             |				Затраты.Поставка КАК Поставка
	             |			ИЗ
	             |				РегистрСведений.Затраты КАК Затраты
	             |			ГДЕ
	             |				(Затраты.Номенклатура, Затраты.Инвойс, Затраты.Поставка, Затраты.Партия) В
	             |						(ВЫБРАТЬ
	             |							П.Владелец,
	             |							П.Док.ВКД_Инвойс,
	             |							П.Док.Поставка,
	             |							ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)
	             |						ИЗ
	             |							Справочник.Партии КАК П
	             |						ГДЕ
	             |							П.Ссылка В (&Партии))) КАК ЗатратыИнв
	             |			ПО Партии.Владелец = ЗатратыИнв.Номенклатура
	             |				И Партии.Док.ВКД_Инвойс = ЗатратыИнв.Инвойс
	             |				И Партии.Док.Поставка = ЗатратыИнв.Поставка
	             |	ГДЕ
	             |		Партии.Ссылка В(&Партии)) КАК Свод
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	Свод.Партия";
	Пакет = Запр.ВыполнитьПакет();
	ВыборкаПартии = Пакет[0].Выбрать();
	ВыборкаПартииИнв = Пакет[1].Выбрать(); 

	Если ОднаПартия Тогда
		
		Результат = Новый Структура("ЗатратыПартии, ЗатратыПартииИнвойсов", 0, 0);
		Пока ВыборкаПартии.Следующий() Цикл
			Результат.Вставить("ЗатратыПартии", ВыборкаПартии.Сумма);		
		КонецЦикла;
		Пока ВыборкаПартииИнв.Следующий() Цикл
			Результат.Вставить("ЗатратыПартииИнвойсов", ВыборкаПартииИнв.Сумма);		
		КонецЦикла;
		Возврат Результат;
		
	Иначе
		
		СоотвЗатратыПартии = Новый Соответствие;
		Пока ВыборкаПартии.Следующий() Цикл
			СоотвЗатратыПартии.Вставить(ВыборкаПартии.Партия, ВыборкаПартии.Сумма);		
		КонецЦикла;
		СоотвПартииИнв = Новый Соответствие;
		Пока ВыборкаПартииИнв.Следующий() Цикл
			СоотвПартииИнв.Вставить(ВыборкаПартииИнв.Партия, ВыборкаПартииИнв.Сумма);		
		КонецЦикла;
		Возврат Новый Структура("ЗатратыПартии, ЗатратыПартииИнвойсов", СоотвЗатратыПартии, СоотвПартииИнв);
		
	КонецЕсли;
	
КонецФункции 

// Выводит сообщение об ошибке с возможностью открыть документ кликом на сообщении
//
Процедура СообщитьОбОшибке(ТекстОшибки, ДокументСсылка, Ошибка) Экспорт
	
	Ошибка = Истина;
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстОшибки;
	Сообщение.КлючДанных = ДокументСсылка;
	Сообщение.Сообщить();

КонецПроцедуры
