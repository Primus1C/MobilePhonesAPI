Функция ТаблицаОстатков(Склады, ВидЦены, КодыНоменклатуры = Неопределено, Бренд = Неопределено)

	ФильтрПоКодам = КодыНоменклатуры <> Неопределено И КодыНоменклатуры.Количество() > 0;
	ФильтрПоБренду = ЗначениеЗаполнено(Бренд);

	запр = Новый Запрос;
	запр.УстановитьПараметр("Склады",			Склады);
	запр.УстановитьПараметр("ВидЦены",			ВидЦены);
	запр.УстановитьПараметр("ФильтрПоКодам", 	ФильтрПоКодам);
	запр.УстановитьПараметр("КодыНоменклатуры", ?(ФильтрПоКодам, КодыНоменклатуры, Новый Массив));
	запр.УстановитьПараметр("ФильтрПоБренду", 	ФильтрПоБренду);
	запр.УстановитьПараметр("Бренд", 			?(ФильтрПоБренду, Бренд, Справочники.Номенклатура.ПустаяСсылка()));
	//запр.Текст = "ВЫБРАТЬ
	//             |	ОстаткиТовара.Номенклатура КАК Номенклатура,
	//             |	ОстаткиТовара.Склад КАК Склад,
	//             |	ОстаткиТовара.ОстатокОстаток КАК Остаток,
	//             |	ОстаткиТовара.РезервОстаток КАК Резерв,
	//             |	ЦеныПродажи.Цена0 КАК Цена0,
	//             |	ЦеныПродажи.Цена1 КАК Цена1,
	//             |	ЦеныПродажи.Цена2 КАК Цена2,
	//             |	ЦеныПродажи.Цена3 КАК Цена3,
	//             |	ЦеныПродажи.Порог1 КАК Порог1,
	//             |	ЦеныПродажи.Порог2 КАК Порог2,
	//             |	ЦеныПродажи.Порог3 КАК Порог3,
	//             |	ЦеныПродажи.РазрешитьПродажу КАК РазрешитьПродажу
	//             |ИЗ
	//             |	РегистрНакопления.ОстаткиТовара.Остатки(, Склад В (&Склады)) КАК ОстаткиТовара
	//             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныПродажи.СрезПоследних(, ВидЦены = &ВидЦены) КАК ЦеныПродажи
	//             |		ПО ОстаткиТовара.Склад = ЦеныПродажи.Склад
	//             |			И ОстаткиТовара.Номенклатура = ЦеныПродажи.Номенклатура
	//             |ГДЕ
	//             |	ОстаткиТовара.ОстатокОстаток > 0
	//             |	И НЕ ОстаткиТовара.Номенклатура.ЗапретОтгрузки
	//             |	И ОстаткиТовара.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	//             |
	//             |УПОРЯДОЧИТЬ ПО
	//             |	Склад,
	//             |	Номенклатура";
	 запр.Текст = "ВЫБРАТЬ
	              |	Ост.Номенклатура КАК Номенклатура,
	              |	Ост.Склад КАК Склад,
	              |	Ост.ОстатокОстаток КАК Остаток,
	              |	Ост.РезервОстаток КАК Резерв
	              |ПОМЕСТИТЬ ВТОстатки
	              |ИЗ
	              |	РегистрНакопления.ОстаткиТовара.Остатки(
	              |			,
	              |			Склад В (&Склады)
	              |				И Номенклатура В
	              |					(ВЫБРАТЬ
	              |						Ном.Ссылка
	              |					ИЗ
	              |						Справочник.Номенклатура КАК Ном
	              |					ГДЕ
	              |						НЕ Ном.ЗапретОтгрузки
	              |						И Ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	              |						И (НЕ &ФильтрПоКодам
	              |							ИЛИ Ном.Код В (&КодыНоменклатуры))
	              |						И (НЕ &ФильтрПоБренду
	              |							ИЛИ Ном.Ссылка В ИЕРАРХИИ(&Бренд)))) КАК Ост
	              |ГДЕ
	              |	Ост.ОстатокОстаток > 0
	              |
	              |ИНДЕКСИРОВАТЬ ПО
	              |	Ост.Склад,
	              |	Ост.Номенклатура
	              |;  
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	Ост.Номенклатура КАК Номенклатура,
	              |	Ост.Склад КАК Склад,
	              |	Ост.Остаток КАК Остаток,
	              |	Ост.Резерв КАК Резерв,
	              |	Цены.Цена0 КАК Цена0,
	              |	Цены.Цена1 КАК Цена1,
	              |	Цены.Цена2 КАК Цена2,
	              |	Цены.Цена3 КАК Цена3,
	              |	Цены.Порог1 КАК Порог1,
	              |	Цены.Порог2 КАК Порог2,
	              |	Цены.Порог3 КАК Порог3,
	              |	Цены.РазрешитьПродажу КАК РазрешитьПродажу
	              |ИЗ
	              |	ВТОстатки КАК Ост
	              |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныПродажи.СрезПоследних(
	              |				,
	              |				ВидЦены = &ВидЦены
	              |					И Склад В (&Склады)
	              |					И Номенклатура В
	              |						(ВЫБРАТЬ
	              |							ВТОстатки.Номенклатура
	              |						ИЗ
	              |							ВТОстатки)) КАК Цены
	              |		ПО Ост.Склад = Цены.Склад
	              |			И Ост.Номенклатура = Цены.Номенклатура
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Склад,
	              |	Номенклатура";
 	Выгрузка = Запр.Выполнить().Выгрузить(); 
	
	Выгрузка.Колонки.Добавить("НомСтроки", Новый ОписаниеТипов("Число"));
	Номер = 0;
	Для Каждого Строка Из Выгрузка Цикл
		Номер = Номер + 1;
		Строка.НомСтроки = Номер;
	КонецЦикла;

	Возврат Выгрузка;
	
КонецФункции // ТаблицаОстатков()


