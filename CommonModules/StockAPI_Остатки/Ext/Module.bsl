Функция ВидЦеныИзЗапроса(Запрос)

	Результат = Новый Структура("ВидЦены, Ошибка", Неопределено, "");

	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("priceType");
	Если ПараметрКода = Неопределено Тогда
		Результат.Ошибка = "Параметр priceType не найден.";
		Возврат Результат;
	КонецЕсли;
	
	ВидЦены = Справочники.ВидыЦен.НайтиПоНаименованию(ПараметрКода, Истина);
	Если ВидЦены = Справочники.ВидыЦен.ПустаяСсылка() Тогда
		Результат.Ошибка = СтрШаблон("Не найден вид цены %1.", ПараметрКода);
	Иначе
	    Результат.ВидЦены = ВидЦены;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ВидЦеныизЗапроса()


// Опциональный фильтр по кодам номенклатуры: itemCode (один код) или itemCodes (через запятую).
//
Функция КодыНоменклатурыИзЗапроса(Запрос)
	
	Результат = Новый Структура("Коды, Ошибка", Новый Массив, "");
	
	СтрокаКодов = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "itemCodes");
	Если СтрокаКодов = "" Тогда
		СтрокаКодов = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "itemCode");
	КонецЕсли;
	
	Если СтрокаКодов = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	УникальныеКоды = Новый Соответствие;
	Части = СтрРазделить(СтрокаКодов, ",", Ложь);
	Для Каждого Часть Из Части Цикл
		
		КодСтрокой = СокрЛП(Часть);
		Если КодСтрокой = "" Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			КодЧисло = Число(КодСтрокой);
		Исключение
			Результат.Ошибка = СтрШаблон("Параметр itemCode/itemCodes: код ""%1"" должен быть числом.", КодСтрокой);
			Возврат Результат;
		КонецПопытки;
		
		УникальныеКоды.Вставить(КодЧисло, Истина);
		
	КонецЦикла;
	
	Если УникальныеКоды.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из УникальныеКоды Цикл
		Результат.Коды.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;
	
	ЗапросБД = Новый Запрос;
	ЗапросБД.УстановитьПараметр("Коды", Результат.Коды);
	ЗапросБД.Текст = "ВЫБРАТЬ
	                 |	Номенклатура.Код КАК Код
	                 |ИЗ
	                 |	Справочник.Номенклатура КАК Номенклатура
	                 |ГДЕ
	                 |	Номенклатура.Код В (&Коды)
	                 |	И НЕ Номенклатура.ПометкаУдаления";
	НайденныеКоды = Новый Соответствие;
	Выборка = ЗапросБД.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НайденныеКоды.Вставить(Выборка.Код, Истина);
	КонецЦикла;
	
	НеНайденные = Новый Массив;
	Для Каждого КодНоменклатуры Из Результат.Коды Цикл
		Если НайденныеКоды.Получить(КодНоменклатуры) = Неопределено Тогда
			НеНайденные.Добавить(StockAPI_Утилиты.КодВСтроку(КодНоменклатуры));
		КонецЕсли;
	КонецЦикла;
	
	Если НеНайденные.Количество() > 0 Тогда
		Результат.Ошибка = "Не найдена номенклатура с кодом: " + СтрСоединить(НеНайденные, ", ") + ".";
		Результат.Коды = Новый Массив;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Опциональный фильтр по бренду: brand (код или наименование группы первого уровня).
//
Функция БрендИзЗапроса(Запрос)
	
	Результат = Новый Структура("Бренд, Ошибка", Неопределено, "");
	
	СтрокаБренда = StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "brand");
	Если СтрокаБренда = "" Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОшибкаПоиска = "";
	Бренд = StockAPI_Справочники.НайтиБренд(СтрокаБренда, ОшибкаПоиска);
	Если ОшибкаПоиска <> "" Тогда
		Результат.Ошибка = ОшибкаПоиска;
		Возврат Результат;
	КонецЕсли;
	
	Результат.Бренд = Бренд;
	Возврат Результат;
	
КонецФункции


// Фильтр по складу: warehouseId, warehouseCode или code (числовой код из /warehouses). 
// Если код задан, возвращает склад по коду из перечня разрешенных
// Если код не задан, возвращает массив разрешенных складов
//
Функция РазрешенныйСкладИзЗапроса(Запрос, УчетаяЗапись) Экспорт
	
	Результат = Новый Структура("Склады, Ошибка", Неопределено, "");
	
	ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseId");
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("warehouseCode");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда
		ПараметрКода = Запрос.ПараметрыЗапроса.Получить("code");
	КонецЕсли;
	Если ПараметрКода = Неопределено Тогда  
		КодЧисло = Неопределено;
	Иначе	
		Попытка
			КодЧисло = Число(СокрЛП(Строка(ПараметрКода)));
			//Результат.warehouseId = Строка(ПараметрКода);
		Исключение
			Результат.Ошибка = "Параметр warehouseId (или warehouseCode) должен быть числовым кодом склада.";
			Возврат Результат;
		КонецПопытки;
	КонецЕсли;
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Код", КодЧисло);
	
	Если StockAPI_Утилиты.ЭтоАдминистраторAPI(УчетаяЗапись) Тогда
