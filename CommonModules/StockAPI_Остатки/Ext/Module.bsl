//	|	Ост.ОстатокОстаток > 0
//	|	И Ост.Номенклатура В(&Номенклатура)
//	|{ГДЕ
//	|		(Ост.Склад = &Склад)}";
//	Зап.УстановитьПараметр("Номенклатура", НоменклатураСтраницы);
//	Зап.УстановитьПараметр("Склад", Склад);
//	
//	Возврат Зап.Выполнить().Выгрузить();
//	
//КонецФункции

//Функция КлючГруппыОстатков(Склад, КодТовара, Партия)
//	Возврат Строка(Склад) + "|" + Строка(КодТовара) + "|" + Строка(Партия);
//КонецФункции

//Функция КлючГруппыОстатковСводно(Склад, КодТовара)
//	Возврат Строка(Склад) + "|" + Строка(КодТовара);
//КонецФункции

// ───  WebHook остатки товара ──────────────────────────────────────────────

// ПередЗаписью: при Замещение=Истина старые движения ещё доступны
// (нужно для отмены проведения, когда новый набор пустой).
//
Процедура WebHookОстаткиПередЗаписью(Источник, Отказ, Замещение) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ИзмененияОстатков = Новый ТаблицаЗначений;
	ИзмененияОстатков.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ИзмененияОстатков.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	
	Для Каждого ЗаписьНабора Из Источник Цикл
		ДобавитьИзменениеОстатковДляWebHook(ИзмененияОстатков, ЗаписьНабора.Номенклатура, ЗаписьНабора.Склад);
	КонецЦикла;
	
	Регистратор = РегистраторНабораОстатков(Источник);
	Если Замещение И ЗначениеЗаполнено(Регистратор) Тогда
		ДобавитьСтарыеИзмененияОстатковДляWebHook(ИзмененияОстатков, Регистратор);
	КонецЕсли;
	
	Если ИзмененияОстатков.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИзмененияОстатков", ИзмененияОстатков);
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ИзмененияОстатков.Номенклатура КАК Номенклатура,
	               |	ИзмененияОстатков.Склад КАК Склад
	               |ПОМЕСТИТЬ ИзмененияОстатков
	               |ИЗ
	               |	&ИзмененияОстатков КАК ИзмененияОстатков
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	УчетныеЗаписи.Ссылка КАК УчетнаяЗапись,
	               |	ИзмененияОстатков.Номенклатура КАК Номенклатура,
	               |	ИзмененияОстатков.Склад КАК Склад
	               |ИЗ
	               |	ИзмененияОстатков КАК ИзмененияОстатков
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиИнтеграции.Склады КАК СкладыУчетныхЗаписей
	               |		ПО ИзмененияОстатков.Склад = СкладыУчетныхЗаписей.Склад
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК СправочникСклады
	               |		ПО ИзмененияОстатков.Склад = СправочникСклады.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчетныеЗаписиИнтеграции КАК УчетныеЗаписи
	               |		ПО СкладыУчетныхЗаписей.Ссылка = УчетныеЗаписи.Ссылка
	               |ГДЕ
	               |	УчетныеЗаписи.Активен
	               |	И УчетныеЗаписи.WebhookАктивен
	               |	И УчетныеЗаписи.ОтправлятьОстатки
	               |	И УчетныеЗаписи.WebhookURL <> """"
	               |	И НЕ СправочникСклады.ПометкаУдаления";
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	Выборка = РезультатыЗапроса[1].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПерезаполнитьОчередьWebHookОстатки(Выборка.УчетнаяЗапись, Выборка.Номенклатура, Выборка.Склад, Регистратор);
	КонецЦикла;
		
КонецПроцедуры

Процедура ДобавитьИзменениеОстатковДляWebHook(ИзмененияОстатков, Номенклатура, Склад)
	
	Если НЕ ЗначениеЗаполнено(Номенклатура)
		Или НЕ ЗначениеЗаполнено(Склад) Тогда
		Возврат;
	КонецЕсли;
	
	НайдСтроки = ИзмененияОстатков.НайтиСтроки(Новый Структура("Номенклатура,Склад", Номенклатура, Склад));
	Если НайдСтроки.Количество() > 0 Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ИзмененияОстатков.Добавить();
	НоваяСтрока.Номенклатура = Номенклатура;
	НоваяСтрока.Склад = Склад;
	
КонецПроцедуры

Функция РегистраторНабораОстатков(Источник)
	
	Попытка
		Если Источник.Отбор.Регистратор.Использование Тогда
			Возврат Источник.Отбор.Регистратор.Значение;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ДобавитьСтарыеИзмененияОстатковДляWebHook(ИзмененияОстатков, Регистратор)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ОстаткиТовара.Номенклатура КАК Номенклатура,
	               |	ОстаткиТовара.Склад КАК Склад
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара КАК ОстаткиТовара
	               |ГДЕ
	               |	ОстаткиТовара.Регистратор = &Регистратор";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДобавитьИзменениеОстатковДляWebHook(ИзмененияОстатков, Выборка.Номенклатура, Выборка.Склад);
	КонецЦикла;
	
КонецПроцедуры

Процедура ПерезаполнитьОчередьWebHookОстатки(УчетнаяЗапись, Номенклатура, Склад, Регистратор)
	
	ТипСобытия = Перечисления.ТипыСобытийWebHooks.Остаток;
	ПустойВидЦены = Справочники.ВидыЦен.ПустаяСсылка();
	ПустаяДатаОтправки = Дата(1, 1, 1);
	
	УдалитьНеотправленныеЗаписиОчередиWebHookОстатки(УчетнаяЗапись, Номенклатура, Склад, ТипСобытия, ПустойВидЦены, ПустаяДатаОтправки);
	
	НоваяЗапись = РегистрыСведений.ОчередьWebHook.СоздатьМенеджерЗаписи();
	НоваяЗапись.ИД = Новый УникальныйИдентификатор;
	НоваяЗапись.УчетнаяЗапись = УчетнаяЗапись;
	НоваяЗапись.ТипСобытия = ТипСобытия;
	НоваяЗапись.Номенклатура = Номенклатура;
	НоваяЗапись.Склад = Склад;
	НоваяЗапись.ВидЦены = ПустойВидЦены;
	НоваяЗапись.Отправлен = ПустаяДатаОтправки;
	НоваяЗапись.Создан = ТекущаяДатаСеанса();
	НоваяЗапись.КоличествоПопыток = 0;
	НоваяЗапись.Ошибка = "";
	
	Если ЗначениеЗаполнено(Регистратор) Тогда
		Попытка
			НоваяЗапись.Инициатор = Регистратор;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	НоваяЗапись.Записать();
	
КонецПроцедуры

Процедура УдалитьНеотправленныеЗаписиОчередиWebHookОстатки(УчетнаяЗапись, Номенклатура, Склад, ТипСобытия, ПустойВидЦены, ПустаяДатаОтправки)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("УчетнаяЗапись", УчетнаяЗапись);
	Запрос.УстановитьПараметр("ТипСобытия", ТипСобытия);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ВидЦены", ПустойВидЦены);
	Запрос.УстановитьПараметр("Отправлен", ПустаяДатаОтправки);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОчередьWebHook.ИД КАК ИД,
	               |	ОчередьWebHook.УчетнаяЗапись КАК УчетнаяЗапись,
	               |	ОчередьWebHook.ТипСобытия КАК ТипСобытия,
	               |	ОчередьWebHook.Номенклатура КАК Номенклатура,
	               |	ОчередьWebHook.Склад КАК Склад,
	               |	ОчередьWebHook.ВидЦены КАК ВидЦены,
	               |	ОчередьWebHook.Отправлен КАК Отправлен
	               |ИЗ
	               |	РегистрСведений.ОчередьWebHook КАК ОчередьWebHook
	               |ГДЕ
	               |	ОчередьWebHook.УчетнаяЗапись = &УчетнаяЗапись
	               |	И ОчередьWebHook.ТипСобытия = &ТипСобытия
	               |	И ОчередьWebHook.Номенклатура = &Номенклатура
	               |	И ОчередьWebHook.Склад = &Склад
	               |	И ОчередьWebHook.ВидЦены = &ВидЦены
	               |	И ОчередьWebHook.Отправлен = &Отправлен";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаписьОчереди = РегистрыСведений.ОчередьWebHook.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(ЗаписьОчереди, Выборка);
		ЗаписьОчереди.Удалить();
	КонецЦикла;
	
КонецПроцедуры
