	лСтр = Лев(СокрЛП(Стр), Сим);
	лЛен = СтрДлина(лСтр);
	лЕще = Сим - лЛен;
	Если лЕще > 0 Тогда лСтр = гоСтрокаПробелов(лЕще) + лСтр КонецЕсли;
