КонецФункции

Функция гоСформироватьЕАН13(лШтрКод) Экспорт
	ШтрКод = гоДополнитьСтроку(Лев(СокрЛП(лШтрКод), 12), "0", 12, 1);
	
	Четн = 0;
	Нечетн = 0;
	
	Для Индекс = 1 По 6 Цикл
		Четн = Четн + Сред(ШтрКод, 2 * Индекс, 1);
	КонецЦикла;
	Четн = Четн * 3;

	Для Индекс = 1 По 6 Цикл
		Нечетн = Нечетн + Сред(ШтрКод, 2 * Индекс - 1, 1);
	КонецЦикла;

	КонтЦифра = (Четн + Нечетн) / 10 - Цел((Четн + Нечетн) / 10);
	КонтЦифра = 10 - Цел(КонтЦифра * 10);
	
	Если КонтЦифра = 10 Тогда КонтЦифра = 0 КонецЕсли;
	
	Возврат ШтрКод + Строка(КонтЦифра);
КонецФункции 

