Функция гоСледПолеТаб(Стр, Чис = 0) Экспорт
	Поз = Найти(Стр, гоТБ());
	
	Если Поз = 0 Тогда 
		Рез = СокрЛП(Стр);
		Стр = "";
	Иначе 
		Рез = СокрЛП(Лев(Стр, Поз - 1));
		Стр = Сред(Стр, Поз + 1);
	КонецЕсли;
	
	Если (Чис = 1) ИЛИ (Чис = "Число") Тогда
		Попытка
			Рез = Число(СтрЗаменить(Рез, " ", ""));
		Исключение
			Рез = 0;
		КонецПопытки;
	ИначеЕсли (Чис = 2) ИЛИ (Чис = "Дата") Тогда
		Попытка
			//Рез = Дата(Рез);
			Рез = гоСтрДата(Рез);
		Исключение
			Рез = гоПустаяДата();
		КонецПопытки;
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

Функция гоСтрДата(лСтр) Экспорт
	Стр = СокрЛП(лСтр);
	Если Стр = "" Тогда Возврат гоПустаяДата() КонецЕсли;
	Если Стр = ".  ." Тогда Возврат гоПустаяДата() КонецЕсли;
	
	лДен = Число(Сред(Стр, 1, 2));
	лМес = Число(Сред(Стр, 4, 2));
	лГод = Число(Сред(Стр, 7));	//сколько будет, пусть столько и берет
	
	Если лГод < 60 Тогда лГод = лГод + 2000 Иначе лГод = лГод + 1900 КонецЕсли; 
	
	Возврат Дата(лГод, лМес, лДен);
КонецФункции

Функция гоПроцентНаценки2(Знач Сум, Знач ЗакСум) Экспорт
	Если НЕ ТипЗнч(Сум) = Тип("Число") Тогда Сум = 0 КонецЕсли; 
	Если НЕ ТипЗнч(ЗакСум) = Тип("Число") Тогда ЗакСум = 0 КонецЕсли; 
	
	Попытка
		Если ЗакСум = 0 Тогда КонецЕсли; 
	Исключение
	    ЗакСум = 0
	КонецПопытки; 
	
	Попытка
		Если Сум = 0 Тогда КонецЕсли; 
	Исключение
	    Сум = 0;
	КонецПопытки; 
	
	Если (ЗакСум = 0) ИЛИ (Сум = 0) Тогда Возврат 0 КонецЕсли;
	
	Возврат Окр((Сум - ЗакСум) * 100.00 / ЗакСум, 2);
КонецФункции

Функция гоПроцентНаценкиСтрока(Знач Сум, Знач ЗакСум, Зн = 0) Экспорт
	Если НЕ ТипЗнч(Сум) = Тип("Число") Тогда Сум = 0 КонецЕсли;
	Если НЕ ТипЗнч(ЗакСум) = Тип("Число") Тогда ЗакСум = 0 КонецЕсли;
	
	Попытка
		Если ЗакСум = 0 Тогда КонецЕсли; 
	Исключение
	    ЗакСум = 0
	КонецПопытки; 
	
	Попытка
		Если Сум = 0 Тогда КонецЕсли; 
	Исключение
	    Сум = 0;
	КонецПопытки; 
	
	Если (ЗакСум = 0) И (Сум = 0) Тогда Возврат "?" КонецЕсли;
	Если (ЗакСум = 0) ИЛИ (Сум = 0) Тогда Возврат "" КонецЕсли;
	
	Про = Окр((Сум - ЗакСум) * 100.00 / ЗакСум, Зн);
	Если Про = 0 Тогда Возврат "" КонецЕсли; 
	
	Возврат Строка(Про);
КонецФункции
	
