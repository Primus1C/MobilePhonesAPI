Процедура гоУстановитьПараметр(Отчет, Имя, Зна, Снять = Ложь, ЭтоСписок = Ложь) Экспорт
//2016.09.16

	ПараметрыДанных = Отчет.КомпоновщикНастроек.Настройки.ПараметрыДанных;
	
	Параметр = ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных(Имя));
	Если Параметр <> Неопределено Тогда
		Параметр.Использование = НЕ Снять;
		Если ЭтоСписок Тогда 
			Параметр.Значение.Очистить();
			Параметр.Значение.Добавить(Зна);
		Иначе 
			Параметр.Значение = Зна;
		КонецЕсли; 
	Иначе
		Если гоАдминистратор() Тогда
			Сообщить("Не удалось установить параметр " + гоИмя(Имя) + "! Обратитесь к администратору!") КонецЕсли; 
		КонецЕсли;  
		
КонецПроцедуры
