Функция гоИмя(Знач Стр, Скобки = Истина) Экспорт
	Если ТипЗнч(Стр) = Тип("СправочникСсылка.Номенклатура") Тогда
		Возврат гоИмяНом(Стр, Скобки);
	КонецЕсли; 
	
	Если ТипЗнч(Стр) = Тип("СправочникСсылка.Партии") Тогда
		Ном = гоРеквизит(Стр, "Владелец");
		Возврат гоИмяПар(Ном, Стр, Скобки);
	КонецЕсли; 
	
	локВид = гоДокИмя(Стр);
	Если НЕ (локВид = "??") Тогда 
		Стр = гоДокВид(Стр, Ложь) + " " + СокрЛП(гоРеквизит(Стр, "Номер")) + " от " + гоДата(гоРеквизит(Стр, "Дата")) 
	КонецЕсли; 
	
	Возврат гоСкобки(СокрЛП(Стр), Скобки);
КонецФункции

Функция гоДополнитьСтроку(Стр, Чем, Длина, Режим = 1) Экспорт
	Добавить = Длина - СтрДлина(Стр);
	
	Если Добавить <= 0 Тогда Возврат Стр КонецЕсли;
	
	Добавок = "";
	Для Сч = 1 По Добавить Цикл
		Добавок = Добавок + Чем
	КонецЦикла;
	
	Возврат ?(Режим = 1, Добавок + Стр, Стр + Добавок);
КонецФункции

