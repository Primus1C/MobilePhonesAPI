Функция гоСуммаПрописьюВал(Знач Сумма, Знач Валюта) Экспорт
	СтрЦел = СокрЛП(гоРеквизит(Валюта, "Обозначение"));
	СтрКоп = СокрЛП(гоРеквизит(Валюта, "Копейки"));
	
	ФорматнаяСтрока = "Л=ru_RU;";
	ПараметрыПрописи = "" + СтрЦел + ", " + СтрЦел + ", " + СтрЦел + ", ж, " + СтрКоп + ", " + СтрКоп + ", " + СтрКоп + ", ж, 2";
    ПрефиксМинус = "Минус";
		
	Возврат ?(Сумма < 0, ПрефиксМинус, "") + ЧислоПрописью(Сумма, ФорматнаяСтрока, ПараметрыПрописи);
КонецФункции
 
Процедура гоВставитьКучу(С, Поля) Экспорт
	Строки = СтрЗаменить(Поля, ",", гоРС());
	
	Для Н = 1 По СтрЧислоСтрок(Строки) Цикл
		С.Вставить(СокрЛП(СтрПолучитьСтроку(Строки, Н)), "");
	КонецЦикла; 
