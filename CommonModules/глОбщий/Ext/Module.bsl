Процедура гоСтандартныйОтборПоПолю(ВариантОтбора, Список, ИмяПоля) Экспорт
	
	лПользователь = гоПользователь(); 
	Если НРег(ВариантОтбора) = "контрагенты" Тогда  
		Если НЕ омСервер.ПолучитьПараметрСеанса("ОграничитьДоступПоКонтрагентам") Тогда
			Возврат;	
		КонецЕсли;
		Если омСервер.ПолучитьПараметрСеанса("ВариантДоступаККонтрагентамРазрешить") Тогда
			лВидСравнения = ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии;
		Иначе
			лВидСравнения = ВидСравненияКомпоновкиДанных.НеВСпискеПоИерархии;
		КонецЕсли;
	ИначеЕсли НРег(ВариантОтбора) = "склады" Тогда
		Если лПользователь.СкладыИсключать Тогда
			лВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке;
		Иначе
			лВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		КонецЕсли;
	ИначеЕсли НРег(ВариантОтбора) = "денежныесчета" Тогда
		Если лПользователь.ДенежныеСчетаИсключать Тогда
			лВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке;
		Иначе
			лВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		КонецЕсли;
	Иначе
		лВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	КонецЕсли;
	
	тч = лПользователь[ВариантОтбора];
	Если тч.Количество() = 0 Тогда 
		Возврат; 
	КонецЕсли; 
	мас = тч.ВыгрузитьКолонку(0); 
	ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.Использование 	= Истина;
	ЭлементОтбора.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных(ИмяПоля);
	ЭлементОтбора.ВидСравнения 		= лВидСравнения;
	ЭлементОтбора.ПравоеЗначение 	= Мас;
	
КонецПроцедуры

Процедура гоЗаголовокИнтервалСписка(Форма, Обновить = Истина, ПриОткрытии = Ложь, ИмяЭлементаСписка = "Список", ПолеДаты = "Дата") Экспорт
	
	Отборы = Форма[ИмяЭлементаСписка].Отбор.Элементы;
	
	Если Отборы.Количество() = 0 Тогда
		Отбор = Отборы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПолеДаты);
		Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
		Отбор.ПравоеЗначение = Форма.НачДата;
		Отбор.Использование = Истина;
		
		Отбор = Отборы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПолеДаты);
		Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
		Отбор.ПравоеЗначение = Форма.КонДата;
		Отбор.Использование = Истина;
	Иначе
		Для каждого Отбор ИЗ Отборы Цикл
			Если Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ПолеДаты) Тогда
				Если Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно Тогда
					Отбор.ПравоеЗначение = Форма.НачДата;
				ИначеЕсли Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно Тогда
					Отбор.ПравоеЗначение = Форма.КонДата;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	

КонецПроцедуры

