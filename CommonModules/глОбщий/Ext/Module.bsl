Функция гоЦвет(Кра = 0, Зел = 0, Син = 0) Экспорт
	Возврат Макс(0, Син) * 65536 + Макс(0, Зел) * 256 + Макс(0, Кра);
КонецФункции
 
Процедура гоЦветОбратно(Цвет, Кра, Зел, Син) Экспорт
	Чис = Цвет;
	
	Син = Цел(Чис / 65536);
	Чис = Чис - (Син * 65536);
	
	Зел = Цел(Чис / 256);
	Чис = Чис - (Зел * 256);
	
	Кра = Чис;   

