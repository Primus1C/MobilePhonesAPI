Функция гоВидДолгов(ДолгПоставщику, ПредоплатаПоставщику, ДолгПокупателя, ПредоплатаПокупателя) Экспорт
	Если ДолгПоставщику > 0 Тогда Возврат гоПеречисление("ВидДолгов.ДолгПоставщику");
	ИначеЕсли ДолгПоставщику < 0 Тогда Возврат гоПеречисление("ВидДолгов.ПредоплатаПоставщику");
	ИначеЕсли ПредоплатаПоставщику > 0 Тогда Возврат гоПеречисление("ВидДолгов.ПредоплатаПоставщику");
	ИначеЕсли ПредоплатаПоставщику < 0 Тогда Возврат гоПеречисление("ВидДолгов.ДолгПоставщику");
	ИначеЕсли ДолгПокупателя > 0 Тогда Возврат гоПеречисление("ВидДолгов.ДолгПокупателя");
	ИначеЕсли ДолгПокупателя < 0 Тогда Возврат гоПеречисление("ВидДолгов.ПредоплатаПокупателя");
	ИначеЕсли ПредоплатаПокупателя > 0 Тогда Возврат гоПеречисление("ВидДолгов.ПредоплатаПокупателя");
	ИначеЕсли ПредоплатаПокупателя < 0 Тогда Возврат гоПеречисление("ВидДолгов.ДолгПокупателя");
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

Функция гоПересчитать(Сумма, ИзВалюты, ВВалюту, Фирма, НаДату = 0, умВалюта = 0, Зн = 2) Экспорт
	Если НЕ ЗначениеЗаполнено(ИзВалюты) Тогда Возврат 0 КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ВВалюту) Тогда
		Если умВалюта = 0 Тогда Возврат 0 КонецЕсли; 
		Если НЕ ЗначениеЗаполнено(умВалюта) Тогда Возврат 0 КонецЕсли; 
		ВалютаПересчета = умВалюта;
	Иначе
		ВалютаПересчета = ВВалюту;
	КонецЕсли; 
	
	Возврат омСервер.ПересчетЗн(Сумма, ИзВалюты, ВалютаПересчета, Фирма, НаДату, Зн);
КонецФункции

Функция гоПересчитатьНа(Сумма, ИзВалюты, ВВалюту, Фирма, Знач НаДату = 0, умВалюта = 0, Зн = 2) Экспорт
	Если НЕ ЗначениеЗаполнено(ИзВалюты) Тогда Возврат 0 КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ВВалюту) Тогда
		Если умВалюта = 0 Тогда Возврат 0 КонецЕсли; 
		Если НЕ ЗначениеЗаполнено(умВалюта) Тогда Возврат 0 КонецЕсли; 
		ВалютаПересчета = умВалюта;
	Иначе
		ВалютаПересчета = ВВалюту;
	КонецЕсли; 
	
	Если НЕ (НаДату = 0) Тогда
		Если НЕ ЗначениеЗаполнено(НаДату) Тогда 
			НаДату = КонецДня(гоТекущаяДата());
		Иначе
			НаДату = КонецДня(НаДату);
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат омСервер.ПересчетЗн(Сумма, ИзВалюты, ВалютаПересчета, Фирма, НаДату, Зн);
КонецФункции

