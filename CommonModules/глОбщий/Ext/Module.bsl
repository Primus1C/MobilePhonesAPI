			гоВидимостьДоступностьЭлементаФормы(Форма, "ФормаСкопировать", Ложь);
		КонецЕсли; 
	Исключение
	    //ОписаниеОшибки()
	КонецПопытки; 
	
	Попытка
		Форма.Элементы.ФормаОбновить.ТолькоВоВсехДействиях = Ложь;
		Форма.Элементы.ФормаОбновить.Отображение = ОтображениеКнопки.КартинкаИТекст;
	Исключение
	КонецПопытки; 
	
	//2016.01.30
	//это отключит окошко для поиска, которое не дает пользоваться старым вариантом поиска, когда при первой букве появляется окно
	Попытка
