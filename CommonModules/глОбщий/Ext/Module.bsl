Функция гоВремя(СохВремя = 0, Стр = "", Уро = 1, Обновить = Истина, ТолькоВернуть = Ложь) Экспорт
	Если СохВремя = 0 Тогда Возврат "" КонецЕсли; 
	Если НЕ ТипЗнч(СохВремя) = Тип("Дата") Тогда Возврат "" КонецЕсли; 
	
	Отступ = ?(Уро <= 1, "", гоДополнитьСправа("", 4 * (Уро - 1)));
	
	ТекВремя = ТекущаяДата();
	БылоВремя = СохВремя;
	Если Обновить Тогда СохВремя = ТекВремя КонецЕсли; 
	
	ОтлСек = ТекВремя - БылоВремя;
	Если ОтлСек > 60 Тогда
		ОтлМин = Окр(ОтлСек / 60, 2);
		Рез = Отступ + ОтлМин + НСтр("ru = ' мин  ->  '; en = ' min  ->  '") + Стр; 
	Иначе
		Рез = Отступ + ОтлСек + НСтр("ru = ' сек  ->  '; en = ' sec  ->  '") + Стр; 
	КонецЕсли;
	
	Если НЕ ТолькоВернуть Тогда Сообщить(Рез) КонецЕсли; 
	Возврат Рез;
КонецФункции     

