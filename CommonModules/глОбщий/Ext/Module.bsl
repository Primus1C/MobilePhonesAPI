Процедура гоСвернутьСписокЗначений(Список, Сорт = "") Экспорт
    Копия = Список.Скопировать();
	Список.Очистить();
	
	Для Каждого Стр Из Копия Цикл
		Тек = Стр.Значение;
		Если гоПЗ(Тек) Тогда Продолжить КонецЕсли; 
		
		Если НЕ (Список.НайтиПоЗначению(Тек) = Неопределено) Тогда Продолжить КонецЕсли; 
		
		Список.Добавить(Тек);
	КонецЦикла; 
	
	Если Список.Количество() = 0 Тогда Возврат КонецЕсли; 
	Если Сорт = "" Тогда Возврат КонецЕсли; 
	
	Список.СортироватьПоЗначению(?(Сорт = "Возр", НаправлениеСортировки.Возр, НаправлениеСортировки.Убыв));
