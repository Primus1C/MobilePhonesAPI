Функция гоДокВид(Тек, Кратко = Ложь) Экспорт
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда Возврат ?(Кратко, "ПН", "Прих.накл.") КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда Возврат ?(Кратко, "РН", "Расх.накл.") КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка._ВозвратОтПокупателя") Тогда Возврат ?(Кратко, "Возв", "Возв. от покуп.") КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ДвижениеДенег") Тогда
		Если гоРеквизит(Тек, "ВидДвиженияДенег") = гоПеречисление("ВидДвиженияДенег.Перемещение") Тогда
			Возврат ?(Кратко, "РД", "Перемещ.денег");   
		ИначеЕсли гоРеквизит(Тек, "ВидДвиженияДенег") = гоПеречисление("ВидДвиженияДенег.ОбменВалюты") Тогда
			Возврат ?(Кратко, "РД", "Обмен валют");   
		ИначеЕсли гоРеквизит(Тек, "ПриходРасход") = гоПеречисление("ПриходРасход.Приход") Тогда  
			Возврат ?(Кратко, "ПД", "Прих.денег"); 
		Иначе
			Возврат ?(Кратко, "РД", "Расх.денег"); 
		КонецЕсли; 
	КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ЗаказТовара") Тогда Возврат ?(Кратко, "ЗТ", "Заказ") КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.Перемещение") Тогда Возврат ?(Кратко, "ПМ", "Перемещение") КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВозвратПоставщику") Тогда Возврат ?(Кратко, "ВП", "Возв.пост.") КонецЕсли;

	Если ТипЗнч(Тек) = Тип("ДокументСсылка._Инвойс") Тогда Возврат ?(Кратко, "Инв", "Инвойс") КонецЕсли; 
	
	//ВКД++
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВКД_ПлатежноеПоручениеВходящее") Тогда Возврат ?(Кратко, "ППВх", "Вх. ПП") КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВКД_ПлатежноеПоручениеИсходящее") Тогда Возврат ?(Кратко, "ППИсх.", "Исх. ПП") КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.НачислениеЗарплаты") Тогда Возврат ?(Кратко,"Нач.ЗП","Нач. зарплаты") КонецЕсли;
	//ВКД--
	// © Primus1C  10.06.2026  НАЧАЛО ►
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ПередачаНаКомиссию") Тогда Возврат ?(Кратко, "ПКом", "Передача на ком.") КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ПереоценкаТовараНаКомиссии") Тогда Возврат ?(Кратко, "ЦенКом", "Переоценка ком.") КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВозвратСКомиссии") Тогда Возврат ?(Кратко, "ВоврКом", "Возв.с ком.") КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ОтчетКомиссионера") Тогда Возврат ?(Кратко, "ОтчКом", "Отч.ком.") КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	Возврат "??";
КонецФункции
 
Функция гоДокИмя(Тек) Экспорт
	
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда Возврат "ПриходнаяНакладная" КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда Возврат "РасходнаяНакладная" КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ДвижениеДенег") Тогда Возврат "ДвижениеДенег" КонецЕсли; 
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ЗаказТовара") Тогда Возврат "ЗаказТовара" КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.Перемещение") Тогда Возврат "Перемещение" КонецЕсли;
	Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВозвратПоставщику") Тогда Возврат "ВозвратПоставщику" КонецЕсли;
	//Если ТипЗнч(Тек) = Тип("ДокументСсылка.ВКД_НачислениеЗарплаты") Тогда Возврат "НачислениеЗарплаты" КонецЕсли;
	Возврат "??";
КонецФункции
 
