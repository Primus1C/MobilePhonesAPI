Процедура гоУстановитьПараметрСеанса(Имя, Зна) Экспорт
	Пар = Зна;
	Если (Имя = "Склад") И (Зна = 0) Тогда Пар = гоПустой("Склады") КонецЕсли; 
	Если (Имя = "Номенклатура") И (Зна = 0) Тогда Пар = гоПустой("Номенклатура") КонецЕсли; 
	//2015.12.20
	Если (Имя = "ВалютаВыбора") И (Зна = 0) Тогда Пар = гоПустой("Валюты") КонецЕсли; 
	//2015.12.24
	Если (Имя = "ПоставщикВыбора") И (Зна = 0) Тогда Пар = гоПустой("Контрагенты") КонецЕсли;
	
	омСервер.УстановитьПараметрСеанса(Имя, Пар);
КонецПроцедуры

