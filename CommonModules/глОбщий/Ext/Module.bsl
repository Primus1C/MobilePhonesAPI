Функция гоЭто(ллСтр, ллВид, ллСим = ",") Экспорт
	
	//2014.02.14
	//вот такое вот исправление позволит перечислять варианты через пробел после запятой, а то некрасиво получается
	//лСтр = СокрЛП(ллСтр);
	лСтр = СтрЗаменить(СокрЛП(ллСтр), ллСим + " ", ллСим);
	
	лВид = СокрЛП(ллВид);
	
	Если Лев(лСтр, 1) <> ллСим Тогда лСтр = ллСим + лСтр КонецЕсли;
	Если Лев(лВид, 1) <> ллСим Тогда лВид = ллСим + лВид КонецЕсли;
	Если Прав(лСтр, 1) <> ллСим Тогда лСтр = лСтр + ллСим КонецЕсли;
	Если Прав(лВид, 1) <> ллСим Тогда лВид = лВид + ллСим КонецЕсли;
	
	Возврат ?(Найти(лСтр, лВид) = 0, Ложь, Истина);
КонецФункции

