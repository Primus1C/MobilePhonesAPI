#Область Роутер

// ─── HTTP-утилиты (остаются в роутере — работают с объектами HTTPСервис*) ───────

Функция ПрочитатьТелоJSON(Запрос) Экспорт

	Тело = Запрос.ПолучитьТелоКакСтроку();
	Если СокрЛП(Тело) = "" Тогда
		Возврат Новый Структура;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Тело);

	Возврат ПрочитатьJSON(ЧтениеJSON);

КонецФункции

Функция ОтветJSON(КодСостояния, Данные)

	StockAPI_Утилиты.УдалитьСвойства(Данные, "Конфликт,КонфликтСтатуса,НеНайден");
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	Возврат Ответ;

КонецФункции

Функция ОтветФайла(КодСостояния, ДвоичныеДанные, ИмяФайла, ТипСодержимого)

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанные);
	Ответ.Заголовки.Вставить("Content-Type", ТипСодержимого);
	Ответ.Заголовки.Вставить("Content-Disposition", "attachment; filename=""" + ИмяФайла + """");
	Возврат Ответ;

КонецФункции

Функция ОтветИзмененияЗаказа(Результат)

	Если Результат.success Тогда
		Возврат ОтветJSON(200, Результат);
	КонецЕсли;

	КодСостояния = 400;
	Если Результат.НеНайден Тогда
		КодСостояния = 404;
	ИначеЕсли Результат.Отгружен Тогда
		КодСостояния = 409;
	КонецЕсли;

	StockAPI_Утилиты.УдалитьСвойства(Результат, "НеНайден,Отгружен");

	Возврат ОтветJSON(КодСостояния, Результат);

КонецФункции

Функция citiesGET(Запрос) 

	КонтекстАвторизации = Новый Структура;

	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда
		Возврат ОтветJSON(401, Новый Структура("error", КонтекстАвторизации.Ошибка));
	КонецЕсли;

	Попытка

		Результат = StockAPI_Контрагенты.ПолучитьСписокГородов(Запрос);
		Если Результат.Ошибка <> "" Тогда
			Возврат ОтветJSON(400, Новый Структура("error", Результат.Ошибка));
		КонецЕсли;
		Возврат ОтветJSON(200, Результат.Тело);

	Исключение

		Возврат ОтветJSON(500, Новый Структура("success, error", Ложь, ОписаниеОшибки()));

	КонецПопытки;

