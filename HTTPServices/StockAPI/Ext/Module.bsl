Функция УчетнаяЗаписьПротокола()

	Возврат Справочники.УчетныеЗаписиИнтеграции.ПустаяСсылка();

КонецФункции

Функция ВернутьСПротоколом(Запрос, УчетнаяЗапись, ВремяНачала, Ответ, ТекстОшибки = "") 

    Длительность = ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачала;
    StockAPI_Утилиты.ЗаписатьВПротокол(Запрос, Ответ, УчетнаяЗапись, Длительность, ТекстОшибки);
    Возврат Ответ;    

КонецФункции

