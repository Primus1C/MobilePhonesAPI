#Область РасходныеНакладные
	
// GET /delivery-notes — выгрузка расходной накладной в PDF, Excel или JSON. 
//
Функция deliveryNotesGET(Запрос)
	
	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	КонтекстАвторизации = Новый Структура;
	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда
		Возврат ВернутьСПротоколом(Запрос, УчетнаяЗаписьПротокола(), ВремяНачала,
			ОтветJSON(401, КонтекстАвторизации.Ошибка), "Ошибка авторизации");
	КонецЕсли;

	Попытка
		Формат = НРег(StockAPI_Утилиты.СтрокаПараметраЗапроса(Запрос, "format"));
		Результат = StockAPI_Заказы.ПолучитьРасходнуюНакладнуюФайл(Запрос);
		Если Результат.Ошибка <> "" Тогда
			КодСостояния = ?(Результат.НеНайден, 404, 400);
			Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
				ОтветJSON(КодСостояния, Новый Структура("error", Результат.Ошибка)));
		КонецЕсли;
		Если Формат = "json" Или (Результат.Свойство("ЭтоJSON") И Результат.ЭтоJSON) Тогда
			Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала, ОтветJSON(200, Результат.Тело));
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Результат.ДвоичныеДанные) Тогда
			Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
				ОтветJSON(500, Новый Структура("error", "Не удалось сформировать файл накладной.")));
		КонецЕсли;
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
			ОтветФайла(200, Результат.ДвоичныеДанные, Результат.ИмяФайла, Результат.ТипСодержимого));
	Исключение
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
			ОтветJSON(500, Новый Структура("error", ОписаниеОшибки())), КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
		
КонецФункции

