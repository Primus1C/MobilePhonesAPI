// GET /counterparties — список контрагентов (type=customer|supplier, пагинация).  
//
Функция counterpartiesGET(Запрос)

	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	КонтекстАвторизации = Новый Структура;

	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда

		Возврат ВернутьСПротоколом(Запрос, УчетнаяЗаписьПротокола(), ВремяНачала,
			ОтветJSON(401, КонтекстАвторизации.Ошибка), "Ошибка авторизации");

	КонецЕсли;

	Попытка

		Группа = КонтекстАвторизации.УчетнаяЗапись.ГруппаКонтрагентов; 
		Результат = StockAPI_Контрагенты.ПолучитьСписокКонтрагентов(Запрос, Группа);

		Если Результат.Ошибка <> "" Тогда

			Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
				ОтветJSON(400, Новый Структура("error", Результат.Ошибка)));

		КонецЕсли;

		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала, ОтветJSON(200, Результат.Тело));

	Исключение

		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
			ОтветJSON(500, Новый Структура("success, error", Ложь, ОписаниеОшибки())), КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));

	КонецПопытки;	

КонецФункции

