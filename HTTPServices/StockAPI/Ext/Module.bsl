#Область ОстаткиТоваров
	
// GET /balances — остатки товаров с ценами; serials=with для серийных номеров.
//
Функция balancesGET(Запрос)

	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	КонтекстАвторизации = Новый Структура;

	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда
		Возврат ВернутьСПротоколом(Запрос, УчетнаяЗаписьПротокола(), ВремяНачала,
			ОтветJSON(401, Новый Структура("error", КонтекстАвторизации.Ошибка)), "Ошибка авторизации");
	КонецЕсли;

	Попытка
		Рез = StockAPI_Остатки.ПолучитьОстатки(Запрос, КонтекстАвторизации);
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала, ОтветJSON(Рез.КодОтвета, Рез.Тело));
	Исключение
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
			ОтветJSON(500, Новый Структура("error", ОписаниеОшибки())), КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

КонецФункции

