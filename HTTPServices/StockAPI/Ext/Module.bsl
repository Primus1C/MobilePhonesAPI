// POST /status — блокировка/разблокировка/отмена/готовность к отгрузке заказа
//
Функция statusPOST(Запрос)

	ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
	КонтекстАвторизации = Новый Структура;
	Если Не StockAPI_Утилиты.ПроверитьКлючAPI(Запрос, КонтекстАвторизации) Тогда
		Возврат ВернутьСПротоколом(Запрос, УчетнаяЗаписьПротокола(), ВремяНачала,
			ОтветJSON(401, Новый Структура("error", КонтекстАвторизации.Ошибка)), "Ошибка авторизации");
	КонецЕсли;
	Попытка
		ДанныеЗапроса = ПрочитатьТелоJSON(Запрос);
		StockAPI_Утилиты.ДополнитьДанныеЗапросаПараметрамиURL(ДанныеЗапроса, Запрос,
			//"blocked,canceled,readyToShip,employeeCode,employeePin,orderNumber,orderNo,order,incomingNumber,incomingNo,incoming");
			"employeeCode,employeePin,orderNumber,orderNo,order,incomingNumber,incomingNo,incoming");
		Результат = StockAPI_Заказы.ИзменитьСтатусЗаказа(ДанныеЗапроса, КонтекстАвторизации.УчетнаяЗапись);
		Если Результат.error <> "" Тогда
			КодСостояния = 400;
			Если Результат.НеНайден Тогда
				КодСостояния = 404;
			ИначеЕсли Результат.КонфликтСтатуса Тогда
				КодСостояния = 409;
			КонецЕсли;
			Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
				ОтветJSON(КодСостояния, Новый Структура("success, error", Ложь, Результат.error)));
		КонецЕсли;
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала, ОтветJSON(200, Результат));
	Исключение
		Возврат ВернутьСПротоколом(Запрос, КонтекстАвторизации.УчетнаяЗапись, ВремяНачала,
			ОтветJSON(500, Новый Структура("success, error", Ложь, ОписаниеОшибки())), КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
		
КонецФункции

