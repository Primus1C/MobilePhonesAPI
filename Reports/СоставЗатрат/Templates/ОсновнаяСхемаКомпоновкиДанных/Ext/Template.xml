		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Затраты.Номенклатура КАК Номенклатура,
	Затраты.Поставка КАК Поставка,
	Затраты.Инвойс КАК Инвойс
ПОМЕСТИТЬ ПоставкиИнвойсы
ИЗ
	РегистрСведений.Затраты КАК Затраты
ГДЕ
	Затраты.Партия = ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)
	И Затраты.Регистратор.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Затраты.Регистратор КАК Регистратор,
	Затраты.Номенклатура КАК Номенклатура,
	Затраты.Инвойс КАК Инвойс,
	Затраты.Поставка КАК Поставка,
	Затраты.Валюта КАК Валюта,
	Затраты.Затрата КАК Затрата,
	Затраты.Сумма * ТоварыИнвойса.Количество КАК Сумма
ИЗ
	РегистрСведений.Затраты КАК Затраты
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			_ИнвойсВКД_Товары.Ссылка КАК Ссылка,
			_ИнвойсВКД_Товары.Номенклатура КАК Номенклатура,
			СУММА(_ИнвойсВКД_Товары.Количество) КАК Количество
		ИЗ
			Документ._Инвойс.ВКД_Товары КАК _ИнвойсВКД_Товары
		
		СГРУППИРОВАТЬ ПО
			_ИнвойсВКД_Товары.Ссылка,
			_ИнвойсВКД_Товары.Номенклатура) КАК ТоварыИнвойса
		ПО Затраты.Инвойс = ТоварыИнвойса.Ссылка
			И Затраты.Номенклатура = ТоварыИнвойса.Номенклатура
ГДЕ
	Затраты.Партия &lt;&gt; ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)
	И Затраты.Регистратор.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	Затраты.Регистратор,
	Затраты.Номенклатура,
	Затраты.Инвойс,
	Затраты.Поставка,
	Затраты.Валюта,
	Затраты.Затрата,
	Затраты.Сумма
ИЗ
	РегистрСведений.Затраты КАК Затраты
ГДЕ
	Затраты.Партия = ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)</query>
