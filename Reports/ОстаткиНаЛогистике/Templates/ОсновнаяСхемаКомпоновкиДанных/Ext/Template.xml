		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СкорректированныеИнвойсы.Инвойс,
	СкорректированныеИнвойсы.Номенклатура,
	СкорректированныеИнвойсы.НомерСтрокиИнвойса,
	СУММА(СкорректированныеИнвойсы.Количество) КАК Количество,
	СУММА(СкорректированныеИнвойсы.Сумма) КАК Сумма,
	ПоставкиИнвойса.Поставка,
	ИнвойсЗакупки.СкладОтправитель
ПОМЕСТИТЬ Инвойсы
ИЗ
	Документ.ИнвойсЗакупки КАК ИнвойсЗакупки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СкорректированныеИнвойсы КАК СкорректированныеИнвойсы
			ЛЕВОЕ СОЕДИНЕНИЕ Документ._Инвойс.Поставки КАК ПоставкиИнвойса
			ПО СкорректированныеИнвойсы.Инвойс = ПоставкиИнвойса.Ссылка
				И СкорректированныеИнвойсы.НомерСтрокиИнвойса = ПоставкиИнвойса.НомерСтрокиИнвойса
		ПО ИнвойсЗакупки.Ссылка = СкорректированныеИнвойсы.Инвойс.ДокументОснование
ГДЕ
	СкорректированныеИнвойсы.Номенклатура &lt;&gt; ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	И СкорректированныеИнвойсы.Номенклатура.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Товар)
	

СГРУППИРОВАТЬ ПО
	СкорректированныеИнвойсы.Инвойс,
	СкорректированныеИнвойсы.Номенклатура,
	СкорректированныеИнвойсы.НомерСтрокиИнвойса,
	ПоставкиИнвойса.Поставка,
	ИнвойсЗакупки.СкладОтправитель
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	НеОтправленные.Инвойс КАК Инвойс,
	НеОтправленные.Поставка КАК Поставка,
	Инвойсы.Номенклатура,
	СУММА(Инвойсы.Количество) КАК Количество,
	СУММА(Инвойсы.Сумма) КАК Сумма,
	Инвойсы.СкладОтправитель
ИЗ
	(ВЫБРАТЬ
		ОтправкаИнвойсовОбороты.Инвойс КАК Инвойс,
		ОтправкаИнвойсовОбороты.Поставка КАК Поставка,
		СУММА(ОтправкаИнвойсовОбороты.ОжидаемыеПоставкиОборот) КАК ОжидаемыеПоставкиОборот
	ИЗ
		РегистрНакопления.ОтправкаИнвойсов.Обороты(, , Регистратор, ) КАК ОтправкаИнвойсовОбороты
	
	СГРУППИРОВАТЬ ПО
		ОтправкаИнвойсовОбороты.Инвойс,
		ОтправкаИнвойсовОбороты.Поставка
	
	ИМЕЮЩИЕ
		СУММА(ОтправкаИнвойсовОбороты.ОжидаемыеПоставкиОборот) &lt;&gt; 0
	) КАК НеОтправленные
		ЛЕВОЕ СОЕДИНЕНИЕ Инвойсы КАК Инвойсы
		ПО НеОтправленные.Инвойс = Инвойсы.Инвойс
			И НеОтправленные.Поставка = Инвойсы.Поставка

СГРУППИРОВАТЬ ПО
	НеОтправленные.Инвойс,
	НеОтправленные.Поставка,
	Инвойсы.Номенклатура,
	Инвойсы.СкладОтправитель 
	
Имеющие СУММА(Инвойсы.Количество) &lt;&gt; 0	</query>
