		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДеньгиОстатки.Касса,
	ДеньгиОстатки.Валюта,
	ВЫБОР
		КОГДА НЕ ДеньгиОстатки.Касса.ТранзитнаяКасса
			ТОГДА ДеньгиОстатки.ОстатокОстаток
		ИНАЧЕ 0
	КОНЕЦ КАК ВНаличии,
	ВЫБОР
		КОГДА ДеньгиОстатки.Касса.ТранзитнаяКасса
			ТОГДА ДеньгиОстатки.ОстатокОстаток
		ИНАЧЕ 0
	КОНЕЦ КАК Ожидается
ИЗ
	РегистрНакопления.Деньги.Остатки(
			&amp;КонецПериода,
			Касса.ВключатьВПлатежныйКалендарь
				И Касса.Офис = &amp;Офис) КАК ДеньгиОстатки</query>
