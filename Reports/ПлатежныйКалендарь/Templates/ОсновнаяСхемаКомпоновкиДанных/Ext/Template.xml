		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ДолгиОстаткиИОбороты.Контрагент,
	ДолгиОстаткиИОбороты.Валюта,
	-ДолгиОстаткиИОбороты.ПоставщикОборот КАК ОплатыИВозвраты,
	ДолгиОстаткиИОбороты.Регистратор,
	ДолгиОстаткиИОбороты.ПериодСекунда,
	0 КАК СуммаИнвойсов,
	NULL КАК ДатаОплаты,
	//ДолгиОстаткиИОбороты.ДолгПоставщикуКонечныйОстаток 
	0 КАК КОплате
ИЗ
	РегистрНакопления.Долги.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, авто, движения, Контрагент.Родитель.Офис = &amp;Офис) КАК ДолгиОстаткиИОбороты
ГДЕ
	НЕ ДолгиОстаткиИОбороты.Регистратор ССЫЛКА Документ.ПриходнаяНакладная

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	Инвойс.Контрагент,
	Инвойс.Валюта,
	0,
	Инвойс.Ссылка,
	NULL,
	Инвойс.Сумма,
	Инвойс.ПланируемаяДатаОплаты,
	0
ИЗ
	Документ._Инвойс КАК Инвойс
ГДЕ
	Инвойс.Проведен
	И Инвойс.Дата МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	И Инвойс.Контрагент.Родитель.Офис = &amp;Офис</query>
