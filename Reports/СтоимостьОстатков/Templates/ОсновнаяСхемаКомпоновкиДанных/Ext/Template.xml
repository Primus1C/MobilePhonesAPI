		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ОстаткиТовараОстатки.Склад КАК Склад,
	ОстаткиТовараОстатки.Номенклатура КАК Номенклатура,
	ОстаткиТовараОстатки.Партия КАК Партия,
	ОстаткиТовараОстатки.Партия.ДатаПартии КАК ДатаПартии,  
	ВЫБОР
		КОГДА ОстаткиТовараОстатки.Партия.Валюта = &amp;ВалютаРуб
			ТОГДА &amp;ВалютаДол
		КОГДА ОстаткиТовараОстатки.Партия.Валюта = &amp;ВалютаДол
			ТОГДА &amp;ВалютаРуб
		ИНАЧЕ ОстаткиТовараОстатки.Партия.Валюта
	КОНЕЦ КАК  ВалютаПартии,
	ОстаткиТовараОстатки.Партия.ЦенаЗакупки КАК Цена,
	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток
ПОМЕСТИТЬ ОстаткиВТ
ИЗ
	РегистрНакопления.ОстаткиТовара.Остатки(, {(Склад В (&amp;Склад))}) КАК ОстаткиТовараОстатки
ГДЕ
	ОстаткиТовараОстатки.Номенклатура.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Товар)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ОстаткиВТ.ДатаПартии КАК Дата,
	ОстаткиВТ.ВалютаПартии КАК Валюта
ПОМЕСТИТЬ ДатаВалюта
ИЗ
	ОстаткиВТ КАК ОстаткиВТ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДатаВалюта.Дата КАК Дата,
	ДатаВалюта.Валюта КАК Валюта,
	МАКСИМУМ(КурсыВалют.Период) КАК Период
ПОМЕСТИТЬ ДатаКурса
ИЗ
	ДатаВалюта КАК ДатаВалюта
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ДатаВалюта.Валюта = КурсыВалют.Валюта
			И ДатаВалюта.Дата &gt;= КурсыВалют.Период

СГРУППИРОВАТЬ ПО
	ДатаВалюта.Дата,
	ДатаВалюта.Валюта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДатаКурса.Дата КАК Дата,
	ДатаКурса.Валюта КАК Валюта,
	ДатаКурса.Период КАК Период,
	КурсыВалют.Курс КАК Курс
ПОМЕСТИТЬ КурсыВалютСрез
ИЗ
	ДатаКурса КАК ДатаКурса
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют КАК КурсыВалют
		ПО ДатаКурса.Валюта = КурсыВалют.Валюта
			И ДатаКурса.Период = КурсыВалют.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ОстаткиВТ.Склад КАК Склад,
	ОстаткиВТ.Номенклатура КАК Номенклатура,
	ОстаткиВТ.Партия КАК Партия,
	ОстаткиВТ.ДатаПартии КАК ДатаПартии,
	ОстаткиВТ.ВалютаПартии КАК ВалютаПартии,
	ОстаткиВТ.Цена КАК Цена,
	ОстаткиВТ.Остаток КАК Остаток,
	КурсыВалютСрез.Курс КАК Курс
ИЗ
	ОстаткиВТ КАК ОстаткиВТ
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КурсыВалютСрез КАК КурсыВалютСрез
		ПО ОстаткиВТ.ВалютаПартии = КурсыВалютСрез.Валюта
			И ОстаткиВТ.ДатаПартии = КурсыВалютСрез.Дата</query>
