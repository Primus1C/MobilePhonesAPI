		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ разрешенные
	ОПО.Склад КАК Склад,
	ОПО.Номенклатура КАК Номенклатура,
	ОПО.Партия КАК Партия,
	ОПО.Партия.Серия КАК Серия,
	ВЫБОР
		КОГДА &amp;СкрытьЦены
			ТОГДА NULL
		ИНАЧЕ ОПО.Партия.ЦенаЗакупки
	КОНЕЦ КАК ЦенаЗакупки,
	ОПО.ОстатокНачальныйОстаток КАК ОстатокНачальныйОстаток,
	ОПО.ОстатокПриход КАК ОстатокПриход,
	ОПО.ОстатокРасход КАК ОстатокРасход,
	ОПО.ОстатокКонечныйОстаток КАК ОстатокКонечныйОстаток,
	ОПО.Регистратор КАК Регистратор,
	ОПО.ПериодСекунда КАК ПериодСекунда
{ВЫБРАТЬ
	Партия}
ИЗ
	РегистрНакопления.ОстаткиТовара.ОстаткиИОбороты(
			,
			,
			Авто,
			,
			Фирма = &amp;Фирма
				И Партия.Серия В (&amp;Серия)) КАК ОПО</query>
	</dataSet>
