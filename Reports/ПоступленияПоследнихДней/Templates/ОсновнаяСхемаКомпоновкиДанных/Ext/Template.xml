		<query>ВЫБРАТЬ
	ПриходнаяНакладная.Ссылка КАК Приходная,
	ПриходнаяНакладная.Поставка КАК Поставка,
	ПриходнаяНакладная.ВКД_Инвойс КАК Инвойс
ПОМЕСТИТЬ тз
ИЗ
	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
ГДЕ
	ПриходнаяНакладная.Проведен
	И ПриходнаяНакладная.Дата &gt; ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, -2)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	тз.Приходная КАК Приходная,
	ОтправкаИнвойсы.Ссылка КАК Отправка,
	ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	ПриходнаяНакладнаяТовары.Количество КАК Количество,
	ПриходнаяНакладнаяТовары.СуммаЗакупки КАК СуммаЗакупки,
	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток,
	НАЧАЛОПЕРИОДА(ПриходнаяНакладнаяТовары.Ссылка.Дата, ДЕНЬ) КАК День
ИЗ
	тз КАК тз
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Отправка.Инвойсы КАК ОтправкаИнвойсы
		ПО тз.Инвойс = ОтправкаИнвойсы.Инвойс
			И тз.Поставка = ОтправкаИнвойсы.Поставка
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(&amp;Дата, ) КАК ОстаткиТовараОстатки
			ПО ПриходнаяНакладнаяТовары.Номенклатура = ОстаткиТовараОстатки.Номенклатура
		ПО тз.Приходная = ПриходнаяНакладнаяТовары.Ссылка</query>
