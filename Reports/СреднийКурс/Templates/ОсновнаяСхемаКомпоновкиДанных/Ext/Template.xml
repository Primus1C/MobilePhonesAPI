	<totalField>
		<dataPath>КурсПокупки</dataPath>
		<expression>ВЫБОР
		КОГДА Операция="Покупка" ТОГДА ВЫБОР КОГДА Сумма(Сумма) = 0 ТОГДА 0 ИНАЧЕ Сумма(СубДСумма) / Сумма(Сумма) КОНЕЦ КОНЕЦ</expression>
		<group>Операция</group>
		<group>ОбщийИтог</group>
	</totalField>
	<totalField>
		<dataPath>КурсПродажи</dataPath>
		<expression>ВЫБОР
        КОГДА Операция="Продажа" ТОГДА ВЫБОР КОГДА Сумма(Сумма) = 0 ТОГДА 0 ИНАЧЕ Сумма(СубДСумма) / Сумма(Сумма) КОНЕЦ КОНЕЦ</expression>
		<group>Операция</group>
		<group>ОбщийИтог</group>
	</totalField>
	<totalField>
