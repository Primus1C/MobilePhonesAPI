		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ДвижениеДенег.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта = &amp;Валюта
			ТОГДА "Продажа"
		ИНАЧЕ "Покупка"
	КОНЕЦ КАК Операция,
	ДвижениеДенег.Валюта КАК Валюта,
	ДвижениеДенег.СубДВалюта КАК СубДВалюта,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта = &amp;Рубль
				И ДвижениеДенег.СубДВалюта = &amp;Доллар
			ТОГДА ДвижениеДенег.СубДСумма
		КОГДА ДвижениеДенег.Валюта = &amp;Доллар
				И ДвижениеДенег.СубДВалюта = &amp;Рубль
			ТОГДА ДвижениеДенег.Сумма
		КОГДА ДвижениеДенег.Валюта = &amp;Валюта
			ТОГДА ДвижениеДенег.СубДСумма
		ИНАЧЕ ДвижениеДенег.Сумма
	КОНЕЦ КАК Сумма,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта = &amp;Рубль
				И ДвижениеДенег.СубДВалюта = &amp;Доллар
			ТОГДА ДвижениеДенег.Сумма
		КОГДА ДвижениеДенег.Валюта = &amp;Доллар
				И ДвижениеДенег.СубДВалюта = &amp;Рубль
			ТОГДА ДвижениеДенег.СубДСумма
		КОГДА ДвижениеДенег.Валюта = &amp;Валюта
			ТОГДА ДвижениеДенег.Сумма
		ИНАЧЕ ДвижениеДенег.СубДСумма
	КОНЕЦ КАК СубДСумма,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта = &amp;Валюта
			ТОГДА ДвижениеДенег.Сумма / ДвижениеДенег.СубДСумма
		ИНАЧЕ ДвижениеДенег.СубДСумма / ДвижениеДенег.Сумма
	КОНЕЦ КАК Курс,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта = &amp;Валюта
			ТОГДА ДвижениеДенег.СубДКурс
	КОНЕЦ КАК КурсПродажи,
	ВЫБОР
		КОГДА ДвижениеДенег.Валюта &lt;&gt; &amp;Валюта
			ТОГДА ДвижениеДенег.СубДКурс
	КОНЕЦ КАК КурсПокупки
ИЗ
	Документ.ДвижениеДенег КАК ДвижениеДенег
ГДЕ
	ДвижениеДенег.Проведен
	И ДвижениеДенег.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.ОбменВалюты)
	И ДвижениеДенег.РассчитыватьСреднийКурс
	И ДвижениеДенег.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&amp;Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&amp;Дата, ДЕНЬ)
	И ВЫБОР
			КОГДА &amp;Валюта = &amp;Доллар
				ТОГДА ДвижениеДенег.Валюта = &amp;Рубль
						ИЛИ ДвижениеДенег.СубДВалюта = &amp;Рубль
			ИНАЧЕ ДвижениеДенег.Валюта = &amp;Валюта
					ИЛИ ДвижениеДенег.СубДВалюта = &amp;Валюта
		КОНЕЦ</query>
	</dataSet>
