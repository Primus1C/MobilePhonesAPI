	_ВзаиморасчетыСПоставщикамиОстаткиВсего.СуммаОплатыОстаток
ПОМЕСТИТЬ втОбщиеДолгиВсего
ИЗ
	РегистрНакопления._ВзаиморасчетыСПоставщиками.Остатки(&amp;Период, ) КАК _ВзаиморасчетыСПоставщикамиОстаткиВсего
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	_ВзаиморасчетыСПоставщикамиОстатки.Контрагент КАК КонтрагентКредитор,
	_ВзаиморасчетыСПоставщикамиОстатки.Инвойс.ПланируемаяДатаОплаты,
	_ВзаиморасчетыСПоставщикамиОстатки.Валюта КАК ВалютаКредитор,
	ЕСТЬNULL(втОбщиеДолгиКонтрагента.СуммаОплатыОстаток, 0) КАК СуммаОстатокВсегоКредитор,
	ЕСТЬNULL(втОбщиеДолгиВсего.СуммаОплатыОстаток, 0) КАК СуммаОстатокДолгаВсегоКредитор,
	_ВзаиморасчетыСПоставщикамиОстатки.СуммаОплатыОстаток КАК СуммаОстатокПоДокументуКредитор,
	ЕСТЬNULL(втОбщиеДолгиПросроченные.СуммаОплатыПросроченная, 0) КАК СуммаОстатокПросроченоКредитор,
	ЕСТЬNULL(втОбщиеДолгиПросроченныеВсего.СуммаОплатыПросроченнаяВсего, 0) КАК СуммаОплатыПросроченнаяВсегоКредитор
ИЗ
	РегистрНакопления._ВзаиморасчетыСПоставщиками.Остатки КАК _ВзаиморасчетыСПоставщикамиОстатки
		ЛЕВОЕ СОЕДИНЕНИЕ втОбщиеДолгиКонтрагента КАК втОбщиеДолгиКонтрагента
		ПО _ВзаиморасчетыСПоставщикамиОстатки.Контрагент = втОбщиеДолгиКонтрагента.Контрагент
			И _ВзаиморасчетыСПоставщикамиОстатки.Валюта = втОбщиеДолгиКонтрагента.Валюта
		ЛЕВОЕ СОЕДИНЕНИЕ втОбщиеДолгиВсего КАК втОбщиеДолгиВсего
		ПО _ВзаиморасчетыСПоставщикамиОстатки.Валюта = втОбщиеДолгиВсего.Валюта
		ЛЕВОЕ СОЕДИНЕНИЕ втОбщиеДолгиПросроченные КАК втОбщиеДолгиПросроченные
		ПО _ВзаиморасчетыСПоставщикамиОстатки.Контрагент = втОбщиеДолгиПросроченные.Контрагент
			И _ВзаиморасчетыСПоставщикамиОстатки.Валюта = втОбщиеДолгиПросроченные.Валюта
		ЛЕВОЕ СОЕДИНЕНИЕ втОбщиеДолгиПросроченныеВсего КАК втОбщиеДолгиПросроченныеВсего
		ПО _ВзаиморасчетыСПоставщикамиОстатки.Валюта = втОбщиеДолгиПросроченныеВсего.Валюта</query>
