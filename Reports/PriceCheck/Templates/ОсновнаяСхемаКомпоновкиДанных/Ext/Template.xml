		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ТекущиеОстатки.Номенклатура КАК Номенклатура,
	ТекущиеОстатки.Партия КАК Партия,
	ТекущиеОстатки.Партия.Серия КАК Серия,
	ТекущиеОстатки.Партия.ДатаПартии КАК ДатаПартии,
	ТекущиеОстатки.Партия.ЦенаЗакупкиВБазВалюте КАК ЦенаЗакупкиВДолларах,
	ТекущиеОстатки.Партия.ЦенаЗакупкиВБазВалюте - МинимальныеЦены.МинЦена КАК ПревышениеЦены,
	ТекущиеОстатки.ОстатокОстаток КАК Остаток
ИЗ
	РегистрНакопления.ОстаткиТовара.Остатки(, {(Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)), (Склад = &amp;Склад)}) КАК ТекущиеОстатки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВложенныйПартии.Номенклатура КАК Номенклатура,
			МИНИМУМ(ВложенныйПартии.Партия.ЦенаЗакупкиВБазВалюте) КАК МинЦена
		ИЗ
			РегистрНакопления.ОстаткиТовара.Остатки(, {(Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)), (Склад = &amp;Склад)}) КАК ВложенныйПартии
		
		СГРУППИРОВАТЬ ПО
			ВложенныйПартии.Номенклатура) КАК МинимальныеЦены
		ПО ТекущиеОстатки.Номенклатура = МинимальныеЦены.Номенклатура
ГДЕ
	ТекущиеОстатки.Партия.ЦенаЗакупкиВБазВалюте &gt; МинимальныеЦены.МинЦена + &amp;ПревышениеЦены
	И ТекущиеОстатки.ОстатокОстаток &gt; 0

//ВЫБРАТЬ
//	Партии.Владелец КАК Номенклатура,
//	Партии.Ссылка КАК Партия,
//	Партии.Ссылка.Серия КАК Серия,
//	Партии.ДатаПартии КАК ДатаПартии,
//	Партии.ЦенаЗакупкиВБазВалюте КАК ЦенаЗакупкиВДолларах,
//	Партии.ЦенаЗакупкиВБазВалюте - МинимальныеЦены.МинЦена КАК ПревышениеЦены
//ИЗ
//	Справочник.Партии КАК Партии
//		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
//			ВложенныйПартии.Номенклатура КАК Номенклатура,
//			МИНИМУМ(ВложенныйПартии.Партия.ЦенаЗакупкиВБазВалюте) КАК МинЦена
//		ИЗ
//			РегистрНакопления.ОстаткиТовара.Остатки(, {(Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)), (Склад = &amp;Склад)}) КАК ВложенныйПартии
//		
//		СГРУППИРОВАТЬ ПО
//			ВложенныйПартии.Номенклатура) КАК МинимальныеЦены
//		ПО Партии.Владелец = МинимальныеЦены.Номенклатура
//ГДЕ
//	Партии.ЦенаЗакупкиВБазВалюте &gt; МинимальныеЦены.МинЦена + &amp;ПревышениеЦены</query>
	</dataSet>
