		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Затраты.Сумма КАК Сумма,
	Затраты.Валюта КАК Валюта,
	Затраты.Источник КАК Источник,
	Затраты.Партия КАК Партия,
	Затраты.Зарегистрировано КАК Зарегистрировано,
	Затраты.Регистратор КАК Регистратор,
	Затраты.Затрата КАК Затрата
ИЗ
	РегистрСведений.Затраты КАК Затраты
ГДЕ
	(Затраты.Партия = &amp;Партия
			ИЛИ (Затраты.Номенклатура, Затраты.Инвойс, Затраты.Поставка, Затраты.Партия) В
				(ВЫБРАТЬ
					П.Владелец,
					П.Док.ВКД_Инвойс,
					П.Док.Поставка,
					ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)
				ИЗ
					Справочник.Партии КАК П
				ГДЕ
					П.Ссылка = &amp;Партия))</query>
	</dataSet>
