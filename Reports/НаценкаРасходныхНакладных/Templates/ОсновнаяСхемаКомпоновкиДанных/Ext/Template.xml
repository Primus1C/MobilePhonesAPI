		<field xsi:type="DataSetFieldField">
			<dataPath>НаценкаПроцентРуб</dataPath>
			<field>НаценкаПроцентРуб</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Наценка процент руб</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Товары.Ссылка КАК Документ,
	Товары.Ссылка.Валюта КАК Валюта,
	ВЫБОР
		КОГДА Товары.Ссылка.Валюта = &amp;Рубль
			ТОГДА Товары.СуммаПродажи - Товары.СуммаЗакупки
		ИНАЧЕ 0
	КОНЕЦ КАК НаценкаРуб,
	ВЫБОР
		КОГДА Товары.Ссылка.Валюта = &amp;Доллар
			ТОГДА Товары.СуммаПродажи - Товары.СуммаЗакупки
		ИНАЧЕ 0
	КОНЕЦ КАК НаценкаДоллар,
	ВЫБОР
		КОГДА Товары.Ссылка.Валюта = &amp;Доллар
			ТОГДА (Товары.СуммаПродажи - Товары.СуммаЗакупки) / Товары.СуммаПродажи * 100
		ИНАЧЕ 0
	КОНЕЦ КАК НаценкаПроцентДоллар,
	ВЫБОР
		КОГДА Товары.Ссылка.Валюта = &amp;Рубль
			ТОГДА (Товары.СуммаПродажи - Товары.СуммаЗакупки) / Товары.СуммаПродажи * 100
		ИНАЧЕ 0
	КОНЕЦ КАК НаценкаПроцентРуб
ИЗ
	(ВЫБРАТЬ
		РНТовары.Ссылка КАК Ссылка,
		СУММА(РНТовары.СуммаПродажи) КАК СуммаПродажи,
		СУММА(РНТовары.СуммаЗакупки) КАК СуммаЗакупки
	ИЗ
		Документ.РасходнаяНакладная.Товары КАК РНТовары
	ГДЕ
		НЕ РНТовары.Ссылка.ПометкаУдаления
		И РНТовары.Ссылка.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
	
	СГРУППИРОВАТЬ ПО
		РНТовары.Ссылка) КАК Товары</query>
