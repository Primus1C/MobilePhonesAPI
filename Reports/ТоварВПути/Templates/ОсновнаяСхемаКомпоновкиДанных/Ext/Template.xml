		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	РасчетыПоИнвойсам.Инвойс КАК Инвойс
ПОМЕСТИТЬ ТЗ_Инвойсы		
ИЗ
	РегистрНакопления.РасчетыПоИнвойсам.ОстаткиИОбороты(, &amp;КонецПериода, , , {Контрагент.*}) КАК РасчетыПоИнвойсам  
;
       
////////////////////////////////////////////////////////////////////////////////

ВЫБРАТЬ
	База.Контрагент КАК Контрагент,
	База.Инвойс КАК Инвойс,
	База.Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойса,
	База.Инвойс.ВКД_ДатаИнвойсаПоставщика КАК ДатаИнвойса,
	База.Инвойс.Сумма КАК СуммаИнвойса,
	База.Инвойс.ДокументОснование.Валюта КАК ВалютаИнвойса,
	База.Валюта КАК Валюта,
	
	// Выводим регистратор и период для правильной хронологии
	База.Регистратор КАК Регистратор,
	База.ПериодСекунда КАК ПериодСекунда,
	
	База.СуммаКонечныйОстаток * ЕСТЬNULL(Курсы.Курс, 1) КАК Долг,
	База.СуммаРасход КАК Оплачено,
	
	База.ПринятоКоличество КАК ПринятоКоличество,
	База.ПринятоСумма КАК ПринятоСумма,
	База.ОжидаемКоличество КАК ОжидаемКоличество,
	База.ОжидаемСумма КАК ОжидаемСумма
ИЗ
	(
		// --- ПОДЗАПРОС 1: Конечные остатки по инвойсу ---
		ВЫБРАТЬ
			Остатки.Контрагент КАК Контрагент,
			Остатки.Инвойс КАК Инвойс,
			Остатки.Валюта КАК Валюта,
			Остатки.Инвойс КАК Регистратор,        // Регистратор - сам Инвойс
			//Остатки.Инвойс.Дата КАК ПериодСекунда, // Дата инвойса для хронологии отчета
			&amp;КонецПериода КАК ПериодСекунда,  
			  
			Остатки.СуммаОстаток КАК СуммаКонечныйОстаток,
			0 КАК СуммаРасход,                     // Заглушка для расхода
			
			// Заглушки для показателей второго регистра
			0 КАК ПринятоКоличество,
			0 КАК ПринятоСумма,
			0 КАК ОжидаемКоличество,
			0 КАК ОжидаемСумма
		ИЗ
			РегистрНакопления.РасчетыПоИнвойсам.Остатки(&amp;КонецПериода, {Контрагент.*}) КАК Остатки
		
		ОБЪЕДИНИТЬ ВСЕ
		
		// --- ПОДЗАПРОС 2: Обороты (оплаты) только по документам ДвижениеДенег ---
		ВЫБРАТЬ
			Обороты.Контрагент КАК Контрагент,
			Обороты.Инвойс КАК Инвойс,
			Обороты.Валюта КАК Валюта,
			Обороты.Регистратор КАК Регистратор,   // Регистратор - ДвижениеДенег
			Обороты.ПериодСекунда КАК ПериодСекунда,
			
			0 КАК СуммаКонечныйОстаток,            // Заглушка для остатка
			Обороты.СуммаРасход КАК СуммаРасход,   
			
			// Заглушки для показателей второго регистра
			0 КАК ПринятоКоличество,
			0 КАК ПринятоСумма,
			0 КАК ОжидаемКоличество,
			0 КАК ОжидаемСумма
		ИЗ
			РегистрНакопления.РасчетыПоИнвойсам.Обороты(, &amp;КонецПериода, Авто, {Контрагент.*}) КАК Обороты
		ГДЕ
			Обороты.Регистратор ССЫЛКА Документ.ДвижениеДенег
		
		ОБЪЕДИНИТЬ ВСЕ
		
		// --- ПОДЗАПРОС 3.1: Оприходование (ТОЛЬКО ОСТАТКИ) ---
		ВЫБРАТЬ
			ОстаткиОприходования.Документ.Контрагент, 
			ОстаткиОприходования.Документ,
			ОстаткиОприходования.Документ.ДокументОснование.Валюта, 
			
			ОстаткиОприходования.Документ КАК Регистратор,
			//ОстаткиОприходования.Документ.Дата КАК ПериодСекунда,
			&amp;КонецПериода КАК ПериодСекунда,  
			  
			0, 
			0, 
			
			0 КАК КоличествоРасход, // Заглушка для оборотов
			0 КАК СуммаЗакупкиРасход,
			ОстаткиОприходования.КоличествоОстаток КАК КонечныйОстаток,
			ОстаткиОприходования.СуммаЗакупкиОстаток КАК СуммаЗакупкиКонечныйОстаток
		ИЗ
			РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Остатки(&amp;КонецПериода, 
				Документ В (ВЫБРАТЬ ТЗ_Инвойсы.Инвойс ИЗ ТЗ_Инвойсы КАК ТЗ_Инвойсы)) КАК ОстаткиОприходования
		
		ОБЪЕДИНИТЬ ВСЕ
		
		// --- ПОДЗАПРОС 3.2: Оприходование (ТОЛЬКО ОБОРОТЫ) ---
		ВЫБРАТЬ
			ОборотыОприходования.Документ.Контрагент, 
			ОборотыОприходования.Документ,
			ОборотыОприходования.Документ.ДокументОснование.Валюта, 
			
			ОборотыОприходования.Регистратор,
			ОборотыОприходования.ПериодСекунда,
			
			0, 
			0, 
			
			ОборотыОприходования.КоличествоРасход,
			ОборотыОприходования.СуммаЗакупкиРасход,
			0 КАК КонечныйОстаток, // Заглушка для остатков
			0 КАК СуммаЗакупкиКонечныйОстаток
		ИЗ
			РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Обороты(, &amp;КонецПериода, Авто, 
				Документ В (ВЫБРАТЬ ТЗ_Инвойсы.Инвойс ИЗ ТЗ_Инвойсы КАК ТЗ_Инвойсы)) КАК ОборотыОприходования	
	) КАК База
	
	// Подключаем курсы валют к уже объединенной базе
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&amp;КонецПериода, ) КАК Курсы
	ПО База.Валюта = Курсы.Валюта  
	
{ГДЕ
	База.Контрагент.*}	</query>
