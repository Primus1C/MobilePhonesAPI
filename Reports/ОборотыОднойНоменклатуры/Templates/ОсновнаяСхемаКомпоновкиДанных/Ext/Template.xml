		<query>ВЫБРАТЬ
	ОНО.Склад,
	ОНО.ОстатокНачальныйОстаток,
	ОНО.ОстатокПриход,
	ОНО.ОстатокРасход,
	ОНО.ОстатокКонечныйОстаток,
	ОНО.Регистратор,
	ОНО.ПериодСекунда
ИЗ
	РегистрНакопления.ОстаткиТовара.ОстаткиИОбороты(
			,
			,
			Авто,
			,
			Фирма = &amp;Фирма
				И Номенклатура = &amp;Номенклатура
				
				) КАК ОНО
				
{ГДЕ Склад В (&amp;Склад)}				</query>
	</dataSet>
