		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	База.Номенклатура КАК Номенклатура,
	База.Склад КАК Склад,
	СУММА(База.НачальныйОстаток) КАК НачальныйОстаток,
	СУММА(База.НачальныйОстатокСумма) КАК НачальныйОстатокСумма,
	СУММА(База.Приход) КАК Приход,
	СУММА(База.ПриходСумма) КАК ПриходСумма,
	СУММА(База.Расход) КАК Расход,
	СУММА(База.РасходСумма) КАК РасходСумма,
	СУММА(База.КонечныйОстаток) КАК КонечныйОстаток,
	СУММА(База.КонечныйОстатокСумма) КАК КонечныйОстатокСумма,
	СУММА(База.КоличествоПродаж) КАК КоличествоПродаж,
	СУММА(База.СуммаПродаж) КАК СуммаПродаж,
	СУММА(База.Наценка) КАК Наценка
ИЗ
	(ВЫБРАТЬ
		Остатки.Номенклатура КАК Номенклатура,
		Остатки.Склад КАК Склад,
		Остатки.Фирма КАК Фирма,
		Остатки.Партия КАК Партия,
		Остатки.ОстатокНачальныйОстаток КАК НачальныйОстаток,
		Остатки.ОстатокНачальныйОстаток * Остатки.Партия.ЦенаЗакупкиВБазВалюте КАК НачальныйОстатокСумма,
		Остатки.ОстатокПриход КАК Приход,
		Остатки.ОстатокПриход * Остатки.Партия.ЦенаЗакупкиВБазВалюте КАК ПриходСумма,
		Остатки.ОстатокРасход КАК Расход,
		Остатки.ОстатокРасход * Остатки.Партия.ЦенаЗакупкиВБазВалюте КАК РасходСумма,
		Остатки.ОстатокКонечныйОстаток КАК КонечныйОстаток,
		Остатки.ОстатокКонечныйОстаток * Остатки.Партия.ЦенаЗакупкиВБазВалюте КАК КонечныйОстатокСумма,
		0 КАК КоличествоПродаж,
		0 КАК СуммаПродаж,
		0 КАК Наценка
	ИЗ
		РегистрНакопления.ОстаткиТовара.ОстаткиИОбороты(&amp;НачалоПериода, &amp;КонецПериода, Авто, , {(Номенклатура).*, (Склад).*}) КАК Остатки
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		Продажи.Номенклатура,
		Продажи.Склад,
		Продажи.Фирма,
		Продажи.Партия,
		0,
		0,
		0,
		0,
		0,
		0,
		0,
		0,
		Продажи.КоличествоОборот,
		Продажи.СуммаВБазВалютеОборот,
		Продажи.НаценкаВБазВалютеОборот
	ИЗ
		РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Авто, {(Номенклатура).*, (Склад).*}) КАК Продажи) КАК База

СГРУППИРОВАТЬ ПО
	База.Номенклатура,
	База.Склад</query>
	</dataSet>
