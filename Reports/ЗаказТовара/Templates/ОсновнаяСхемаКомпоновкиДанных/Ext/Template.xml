		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	РегПро.Номенклатура КАК ПроНом,
	РегПро.Поставщик КАК Поставщик,
	РегПро.КоличествоОборот
ПОМЕСТИТЬ ВТПро
ИЗ
	РегистрНакопления.Продажи.Обороты(, , Авто, ) КАК РегПро
{ГДЕ 
	РегПро.Регистратор.Склад В (&amp;Склады)}
;
ВЫБРАТЬ
	РегОст.Номенклатура КАК ОстНом,
	РегОст.Партия.Контрагент КАК Поставщик,
	РегОст.ОстатокОстаток
ПОМЕСТИТЬ ВТОст
ИЗ
	РегистрНакопления.ОстаткиТовара.Остатки(, {Склад В (&amp;Склады)}) КАК РегОст
;
ВЫБРАТЬ
	ДТЧ.Номенклатура КАК ЗакНом,
	ДТЧ.Количество КАК Заказ
ПОМЕСТИТЬ ВТЗак
ИЗ
	Документ.ЗаказТовара.Товары КАК ДТЧ
ГДЕ
	ДТЧ.Ссылка = &amp;ЗаказТовара
;
ВЫБРАТЬ
	Спр.Ссылка КАК Товар,
	Спр.Родитель КАК Группа,
	ЕСТЬNULL(ВТПро.КоличествоОборот, 0) КАК Продажа,
	ЕСТЬNULL(ВТОст.ОстатокОстаток, 0) КАК Остаток,
	ЕСТЬNULL(ВТЗак.Заказ, 0) КАК Заказ
ИЗ
	Справочник.Номенклатура КАК Спр
		ЛЕВОЕ СОЕДИНЕНИЕ ВТПро КАК ВТПро
		ПО Спр.Ссылка = ВТПро.ПроНом
		ЛЕВОЕ СОЕДИНЕНИЕ ВТОст КАК ВТОст
		ПО Спр.Ссылка = ВТОст.ОстНом
		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗак КАК ВТЗак
		ПО Спр.Ссылка = ВТЗак.ЗакНом
ГДЕ
	НЕ Спр.ЭтоГруппа</query>
