&НаСервере
Процедура заполнитьДеревоРолиКонфигурации()
	
	Если не ЗначениеЗаполнено(кореньВнешниеДанные) Тогда
		кореньВнешниеДанные = добавитьСтрокуВДерево(Отчет.дрРоли, "кореньВнешниеДанные", "Внешние данные");
	Иначе
		кореньВнешниеДанные.Строки.Очистить();
	КонецЕсли;
	
	тРоли = Отчет.ВнешнийНабор.Выгрузить();
	тРоли.Свернуть("Роль","");
	
	Для каждого роль Из тРоли Цикл
		рольИмя = "внешняя" + роль.роль;
		найденнаяСтрока = кореньВнешниеДанные.строки.Найти(рольИмя, "Имя");
		Если найденнаяСтрока = Неопределено Тогда
	 		добавитьСтрокуВДерево(кореньВнешниеДанные, рольИмя, роль.роль, Ложь);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДействияФормыДействияОтличия(Кнопка)
	
	Результат = Элементы.Результат;
	
	Смещать = ТипСмещенияТабличногоДокумента.ПоВертикали;
	колонки = Результат.ШиринаТаблицы;
	
	массивВсехПравВозможных = получитьМассивВсехПрав();
	
	индСтрок = 4;
	Пока индСтрок < Результат.ВысотаТаблицы Цикл
		возможноеПраво = Результат.Область("R" + Формат(индСтрок, "ЧГ=") + "C1").Текст;
		
		перейтиНаСледующуюСтроку = Истина;
		
		Если не массивВсехПравВозможных.Найти(возможноеПраво) = Неопределено Тогда
			следующаяОбласть = Ложь;
			
			первоеЗначение = Результат.Область("R" + Формат(индСтрок, "ЧГ=") + "C2").Текст;
			Для инд = 3 По колонки Цикл
				текущееЗначение = Результат.Область("R" + Формат(индСтрок, "ЧГ=") + "C" + Формат(инд, "ЧГ=")).Текст;
				Если не первоеЗначение = текущееЗначение Тогда
					следующаяОбласть = Истина;
					Прервать;
				КонецЕсли;	
				первоеЗначение = текущееЗначение;
			КонецЦикла;
			
			Если не следующаяОбласть Тогда // удаляем область если в ней все значения равны
				строкаДокумента = Результат.Область("R" + Формат(индСтрок, "ЧГ="));
				Результат.УдалитьОбласть(строкаДокумента, Смещать);
				
				перейтиНаСледующуюСтроку = Ложь;
			КонецЕсли;	
		КонецЕсли;
		
		Если перейтиНаСледующуюСтроку Тогда 
			индСтрок = индСтрок + 1;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

