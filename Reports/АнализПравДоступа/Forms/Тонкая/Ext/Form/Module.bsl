	добавитьЭлементыМетаданных(узелРегистрыСведений, "РегистрыСведений");
	
	узелРегистрыНакопления = добавитьСтрокуВДерево(корень, "РегистрыНакопления", "Регистры накопления");
	добавитьЭлементыМетаданных(узелРегистрыНакопления, "РегистрыНакопления");
	
	узелРегистрыБухгалтерии = добавитьСтрокуВДерево(корень, "РегистрыБухгалтерии", "Регистры бухгалтерии");
	добавитьЭлементыМетаданных(узелРегистрыБухгалтерии, "РегистрыБухгалтерии");
	
	узелРегистрыРасчета = добавитьСтрокуВДерево(корень, "РегистрыРасчета", "Регистры расчета");
	добавитьЭлементыМетаданных(узелРегистрыРасчета, "РегистрыРасчета");
	
	узелПланыСчетов = добавитьСтрокуВДерево(корень, "ПланыОбмена", "Планы обмена", Истина);
	добавитьЭлементыМетаданных(узелПланыСчетов, "ПланыОбмена", Истина);
	
