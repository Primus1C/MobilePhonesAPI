&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	получитьОсновныеОбъекты();
	получитьРоли();
КонецПроцедуры

&НаСервере
Процедура дополнитьВнешнимиДанными(Данные, ВнешнийНабор) 
	
	Если не кореньВнешниеДанные = Неопределено Тогда
		мВнешниеРоли = Новый Массив;
		
		Отбор = Новый Структура("Пометка", 1);

		НайденныеСтроки = кореньВнешниеДанные.Строки.НайтиСтроки(Отбор, Истина);
		
		Для каждого стрДерева Из НайденныеСтроки Цикл
	 		мВнешниеРоли.Добавить(стрДерева.Представление);
	 	КонецЦикла;
		
	  //  Для каждого стрДерева Из кореньВнешниеДанные.Строки Цикл
	  //  	Если стрДерева.Пометка Тогда
	  //		мВнешниеРоли.Добавить(стрДерева.Представление);
	  //  	КонецЕсли;
	  //КонецЦикла;
		
		Для каждого стрДанных Из ВнешнийНабор Цикл
			роль = стрДанных.Роль;
			Если не мВнешниеРоли.Найти(роль) = Неопределено Тогда
		 		новаяСтрока = Данные.Добавить();
				ЗаполнитьЗначенияСвойств(новаяСтрока, стрДанных);
				новаяСтрока.Роль = Роль + " (внешняя)";
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура заполнитьВнешнийНаборДанных(древоРоли, древоОсновныеОбъекты, тДанные) Экспорт
	
	тДанные.Очистить();
	
	корень = древоРоли.Строки.Найти("корень", "имя");
	
	Если не корень = Неопределено Тогда
		получитьИсходныеДанные(корень, древоОсновныеОбъекты, тДанные);
	КонецЕсли;

КонецПроцедуры

Процедура получитьИсходныеДанные(узелРоли, древоОсновныеОбъекты, тДанные)
	
	Для каждого роль Из узелРоли.Строки Цикл
		Если роль.Пометка Тогда
			видОбъекта = роль.имя;
			типОбъекта = роль.Родитель.имя;
			
			Если не (типОбъекта = "Пользователи" или типОбъекта = "Роли") Тогда
				типОбъекта = "Роли";
			КонецЕсли;
			
			Попытка
				объектМетаданных = Метаданные[типОбъекта][видОбъекта];
			Исключение
				получитьИсходныеДанные(роль, древоОсновныеОбъекты, тДанные);
				Продолжить;
			КонецПопытки;
			
			получитьОбъектыИзДерева(древоОсновныеОбъекты, объектМетаданных, тДанные);
		КонецЕсли;
		
		получитьИсходныеДанные(роль, древоОсновныеОбъекты, тДанные);
	КонецЦикла;
	
КонецПроцедуры


Процедура получитьОбъектыИзДерева(узел, роль, тДанные)

	Отбор = Новый Структура("Пометка", 1);
	
	строки = узел.Строки.НайтиСтроки(Отбор, Истина);
	
	Для каждого текущийОбъект Из строки Цикл
		типОбъекта = текущийОбъект.Родитель.Имя;
		видОбъекта = текущийОбъект.Имя;
		представлениеОбъекта = текущийОбъект.представление;
		
		Попытка
			объектМетаданных = Метаданные[типОбъекта][видОбъекта];
		Исключение
			Продолжить;
		КонецПопытки;
		
		Для Каждого типПрава Из получитьМассивПрав(типОбъекта) Цикл
			Попытка
				запись = тДанные.Добавить();
				запись.ОбъектТип = типОбъекта;
				запись.ОбъектИмя = видОбъекта;
				запись.ОбъектПредставление = представлениеОбъекта;
				запись.Роль = роль.Синоним;
				запись.Права = типПрава;
				запись.НаличиеПрава = ПравоДоступа(типПрава, объектМетаданных, роль);
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура добавитьОбъектыИзДерева(узел, роль, тДанные)

	Для каждого текущийОбъект Из узел.Строки Цикл
		Если текущийОбъект.Пометка Тогда
			
			Если текущийОбъект.Родитель = Неопределено Тогда
				добавитьОбъектыИзДерева(текущийОбъект, роль, тДанные);
				Продолжить;
			КонецЕсли;
			
			типОбъекта = текущийОбъект.Родитель.Имя;
			видОбъекта = текущийОбъект.Имя;
			представлениеОбъекта = текущийОбъект.представление;
			
			Попытка
				объектМетаданных = Метаданные[типОбъекта][видОбъекта];
			Исключение
				добавитьОбъектыИзДерева(текущийОбъект, роль, тДанные);
				Продолжить;
			КонецПопытки;
			
			Для Каждого типПрава Из получитьМассивПрав(типОбъекта) Цикл
				Попытка
					запись = тДанные.Добавить();
					запись.ОбъектТип = типОбъекта;
					запись.ОбъектИмя = видОбъекта;
					запись.ОбъектПредставление = представлениеОбъекта;
					запись.Роль = роль.Синоним;
					запись.Права = типПрава;
					запись.НаличиеПрава = ПравоДоступа(типПрава, объектМетаданных, роль);
				Исключение
					Сообщить(ОписаниеОшибки());
				КонецПопытки;
			КонецЦикла;
			
		КонецЕсли;
		
		добавитьОбъектыИзДерева(текущийОбъект, роль, тДанные);
	КонецЦикла;

КонецПроцедуры

Функция получитьМассивПрав(типОбъекта) Экспорт
	
	массивПрав = Новый Массив;
	
	Если типОбъекта="Константы" или
		 типОбъекта="РегистрыСведений" или
		 типОбъекта="РегистрыРасчета"
	Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Изменение");
		массивПрав.Добавить("Просмотр");
		массивПрав.Добавить("Редактирование");
	ИначеЕсли типОбъекта="Справочники" или
		 	  типОбъекта="ПланыСчетов" или
		 	  типОбъекта="ПланыВидовРасчета"
	Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Добавление");
		массивПрав.Добавить("Изменение");
		массивПрав.Добавить("Удаление");
		массивПрав.Добавить("Просмотр");
		массивПрав.Добавить("ИнтерактивноеДобавление");
		массивПрав.Добавить("Редактирование");
		массивПрав.Добавить("ИнтерактивноеУдаление");
		массивПрав.Добавить("ИнтерактивнаяПометкаУдаления");
		массивПрав.Добавить("ИнтерактивноеСнятиеПометкиУдаления");
		массивПрав.Добавить("ИнтерактивноеУдалениеПомеченных");
		массивПрав.Добавить("ВводПоСтроке");
		
	ИначеЕсли типОбъекта="Документы" или типОбъекта="ПланыОбмена" Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Добавление");
		массивПрав.Добавить("Изменение");
		массивПрав.Добавить("Удаление");
		массивПрав.Добавить("Проведение");
		массивПрав.Добавить("ОтменаПроведения");
		массивПрав.Добавить("Просмотр");
		массивПрав.Добавить("ИнтерактивноеДобавление");
		массивПрав.Добавить("Редактирование");
		массивПрав.Добавить("ИнтерактивноеУдаление");
		массивПрав.Добавить("ИнтерактивнаяПометкаУдаления");
		массивПрав.Добавить("ИнтерактивноеСнятиеПометкиУдаления");
		массивПрав.Добавить("ИнтерактивноеУдалениеПомеченных");
		массивПрав.Добавить("ИнтерактивноеПроведение");
		массивПрав.Добавить("ИнтерактивноеПроведениеНеОперативное");
		массивПрав.Добавить("ИнтерактивнаяОтменаПроведения");
		массивПрав.Добавить("ИнтерактивноеИзменениеПроведенных");
		массивПрав.Добавить("ВводПоСтроке");
	ИначеЕсли типОбъекта="ЖурналыДокументов" Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Просмотр");
	ИначеЕсли типОбъекта="Отчеты" или
		 	  типОбъекта="Обработки"
	Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Использование");
		
	ИначеЕсли типОбъекта="Интерфейсы" Тогда
		массивПрав.Добавить("Использование");
		
	ИначеЕсли типОбъекта="ОбщиеФормы" Тогда
		массивПрав.Добавить("Просмотр");
	ИначеЕсли типОбъекта="РегистрыНакопления" или
		 	  типОбъекта="РегистрыБухгалтерии"
	Тогда
		массивПрав.Добавить("Чтение");
		массивПрав.Добавить("Изменение");
		массивПрав.Добавить("Просмотр");
		массивПрав.Добавить("Редактирование");
		массивПрав.Добавить("УправлениеИтогами");
	КонецЕсли;
	
	Возврат массивПрав;
			
КонецФункции // ПолучитьСписокПрав()

&НаКлиенте
Процедура ЭлементРолипометкаПриИзменении(Элемент)
	установитьСнятьПометкиПодчиненным(Элементы.ЭлементРоли.ТекущиеДанные, Элементы.ЭлементРоли.ТекущиеДанные.Пометка);
КонецПроцедуры

&НаСервере
Функция заполнитьДанные()
	
	Роли = РеквизитФормыВЗначение("ЭлементРоли");
 	ОсновныеОбъекты = РеквизитФормыВЗначение("ЭлементыОсновныеОбъекты");
	
	тДанные = Отчет.Данные.Выгрузить();
	
	заполнитьВнешнийНаборДанных(Роли, ОсновныеОбъекты, тДанные);
	дополнитьВнешнимиДанными(тДанные, Отчет.ВнешнийНабор.Выгрузить());
	
	Отчет.Данные.Загрузить(тДанные);
	
	Возврат тДанные;
	
КонецФункции // заполнитьДанные()


&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	вывестиОтчет();
	
	Отказ = Истина;
	
КонецПроцедуры

&НаСервере
Процедура вывестиОтчет()
	
	тДанные = заполнитьДанные();
	
	ОтчетОбъект = РеквизитФормыВЗначение("Отчет");
	ОтчетОбъект.вывестиОтчет(тДанные, Результат);
	
КонецПроцедуры


&НаКлиенте
Процедура ЭлементыОсновныеОбъектыпометкаПриИзменении(Элемент)
	установитьСнятьПометкиПодчиненным(Элементы.ЭлементыОсновныеОбъекты.ТекущиеДанные, Элементы.ЭлементыОсновныеОбъекты.ТекущиеДанные.Пометка);
КонецПроцедуры

