&НаСервере
Перем кореньВнешниеДанные;
Перем основнойМакет;

&НаСервере
Процедура получитьДоступныеРолиПользователей(узел)
	
	корень = узел.Строки.Добавить();
	корень.имя = "Пользователи";
	корень.представление = "Пользователи базы";
	
	Для каждого текПользователь Из ПользователиИнформационнойБазы.ПолучитьПользователей() Цикл
		пользователь = корень.Строки.Добавить();
		пользователь.имя = текПользователь.Имя;
		пользователь.представление = текПользователь.ПолноеИмя;
		
		Для каждого текРоль Из текПользователь.Роли Цикл
			добавитьСтрокуВДерево(пользователь, текРоль.Имя, текРоль.Синоним);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура получитьРоли()
	
 	Роли = РеквизитФормыВЗначение("ЭлементРоли");

	Роли.Строки.Очистить();
	
	корень = добавитьСтрокуВДерево(Роли, "корень", "Текущая информационная база");
	
	узелРоли = добавитьСтрокуВДерево(корень, "Роли", "Роли");
	добавитьЭлементыМетаданных(узелРоли, "Роли");
	
	получитьДоступныеРолиПользователей(корень);
	
	ЗначениеВРеквизитФормы(Роли, "ЭлементРоли");

КонецПроцедуры

&НаСервере
Процедура получитьОсновныеОбъекты()
	
 	ОсновныеОбъекты = РеквизитФормыВЗначение("ЭлементыОсновныеОбъекты");

	ОсновныеОбъекты.Строки.Очистить();
	
	корень = добавитьСтрокуВДерево(ОсновныеОбъекты, "корень", "Объекты конфигурации");
	
	узелКонстанты = добавитьСтрокуВДерево(корень, "Константы", "Константы");
	добавитьЭлементыМетаданных(узелКонстанты, "Константы");
	
	узелСправочники = добавитьСтрокуВДерево(корень, "ОбщиеФормы", "Общие формы");
	добавитьЭлементыМетаданных(узелСправочники, "ОбщиеФормы");
	
	узелСправочники = добавитьСтрокуВДерево(корень, "Интерфейсы", "Интерфейсы", Истина);
	добавитьЭлементыМетаданных(узелСправочники, "Интерфейсы", Истина);
	
	узелСправочники = добавитьСтрокуВДерево(корень, "Справочники", "Справочники", Истина);
	добавитьЭлементыМетаданных(узелСправочники, "Справочники", Истина);
	
	узелДокументы = добавитьСтрокуВДерево(корень, "Документы", "Документы");
	добавитьЭлементыМетаданных(узелДокументы, "Документы");
	
	узелЖурналыДокументов = добавитьСтрокуВДерево(корень, "ЖурналыДокументов", "Журналы документов", Истина);
	добавитьЭлементыМетаданных(узелЖурналыДокументов, "ЖурналыДокументов", Истина);
	
	узелОтчеты = добавитьСтрокуВДерево(корень, "Отчеты", "Отчеты", Истина);
	добавитьЭлементыМетаданных(узелОтчеты, "Отчеты", Истина);
	
	узелОбработки = добавитьСтрокуВДерево(корень, "Обработки", "Обработки", Истина);
	добавитьЭлементыМетаданных(узелОбработки, "Обработки", Истина);
	
	узелПланыСчетов = добавитьСтрокуВДерево(корень, "ПланыСчетов", "Планы счетов");
	добавитьЭлементыМетаданных(узелПланыСчетов, "ПланыСчетов");
	
	узелПланыВидовРасчета = добавитьСтрокуВДерево(корень, "ПланыВидовРасчета", "Планы видов расчета");
	добавитьЭлементыМетаданных(узелПланыВидовРасчета, "ПланыВидовРасчета");
	
