	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Докум.Ссылка,
	Докум.Дата,
	Докум.ПометкаУдаления,
	Докум.Номер,
	Докум.Проведен,
	Докум.Контрагент,
	Докум.Склад,
	Докум.Валюта,
	Докум.Сумма,
	Докум.Строк,
	Докум.СтрПроцент,
	Докум.Тип,
	Докум.Ссылка.КемСоздан КАК КемСоздан,
	Докум.Ссылка.Примечание КАК Примечание,
	Докум.Ссылка.Окончательно,
	ВЫБОР
		КОГДА Докум.Ссылка.Окончательно
				И Докум.Сумма &gt; 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;&gt; Докум.Сумма
									ТОГДА ЗНАЧЕНИЕ(Перечисление.Долги.Частично)
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Неоплачено)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Полностью)
				КОНЕЦ
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.НеЗакрыто)
	КОНЕЦ КАК Состояние,
	Докум.Ссылка.Куда КАК Куда,
	ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) КАК Долг
ИЗ
	ЖурналДокументов.ЖурналЗакупокИПродаж КАК Докум
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки КАК Рег
		ПО Докум.Ссылка = Рег.Док</QueryText>
				<MainTable>DocumentJournal.ЖурналЗакупокИПродаж</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:item>
							<dcsset:selection>
								<dcsset:item>
									<dcsset:field>СтрПроцент</dcsset:field>
								</dcsset:item>
							</dcsset:selection>
							<dcsset:filter>
								<dcsset:item xsi:type="dcsset:FilterItemComparison">
									<dcsset:left xsi:type="dcscor:Field">СтрПроцент</dcsset:left>
									<dcsset:comparisonType>Less</dcsset:comparisonType>
									<dcsset:right xsi:type="xs:string">0</dcsset:right>
								</dcsset:item>
							</dcsset:filter>
							<dcsset:appearance>
								<dcscor:item xsi:type="dcsset:SettingsParameterValue">
									<dcscor:parameter>ЦветТекста</dcscor:parameter>
									<dcscor:value xsi:type="v8ui:Color">style:NegativeTextColor</dcscor:value>
								</dcscor:item>
							</dcsset:appearance>
						</dcsset:item>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
