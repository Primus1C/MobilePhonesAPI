#Область Подсистема_Сообщения
	
	//***Подключение подсистемы "Сообщения"
	
	Процедура ПроверитьПодключениеОбработчикаОжиданияИнформированияОНовыхСообщениях() ЭКСПОРТ
		
		СистемаИспользуется = Сооб_Сервер.ПроверитьИспользованиеСистемыСообщений();
		
		ИнтервалПроверкиНапоминаний = Сооб_Сервер.ПолучитьВремяПовторения()*60;
		
		Если (ИнтервалПроверкиНапоминаний > 0) И СистемаИспользуется Тогда
			
			ПодключитьОбработчикОжидания("ПроверитьНапоминанияОбСообщениях", ИнтервалПроверкиНапоминаний);
			
		Иначе
			
			ОтключитьОбработчикОжидания("ПроверитьНапоминанияОбСообщениях");
			
		КонецЕсли; 
		
	КонецПроцедуры
	
	Процедура ПроверитьНапоминанияОбСообщениях() ЭКСПОРТ
		
		СписокНапоминаний = Сооб_Сервер.СформироватьСписокНовыхСообщений();
		
		Если СписокНапоминаний <> НЕОПРЕДЕЛЕНО Тогда
			
			ТекСообщНом = 0;
			ВсегоСообщ = СписокНапоминаний.Количество();
			
			Для КАЖДОГО текНапоминание ИЗ СписокНапоминаний Цикл
				
				ТекСообщНом = ТекСообщНом + 1;
				
				ВыВестиТекНапоминание(текНапоминание, ТекСообщНом, ВсегоСообщ);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецПроцедуры
	
	Процедура ВыВестиТекНапоминание(ТекН, ТекНом, ВсегоН) ЭКСПОРТ
		
		ТекСообСсылка = ПолучитьНавигационнуюСсылку(ТекН.Ключ);
		Если ТекН.Реквизиты["ТипСообщения"] = ПредопределенноеЗначение("Перечисление.Сооб_ТипСообщения.Сообщение") Тогда
			лКартинка = БиблиотекаКартинок.СообщениеСинее;	
		ИначеЕсли ТекН.Реквизиты["ТипСообщения"] = ПредопределенноеЗначение("Перечисление.Сооб_ТипСообщения.Напоминание") Тогда
			лКартинка = БиблиотекаКартинок.СообщениеЗеленое;	
		Иначе // поручение	
			лКартинка = БиблиотекаКартинок.СообщениеКрасное;	
		КонецЕсли;
		Сооб_Сервер.ПолучитьКартинкуДляСообщения(ТекН.Реквизиты["ТипСообщения"]);
		
		ПоказатьОповещениеПользователя(
		//НСтр("ru = 'Новое: '; en = 'New: '")+СокрЛП(ТекН.Реквизиты["ТипСообщения"]), 
		СтрШаблон("%1 %2: № %3 (%4)", 
					НСтр("ru = 'Новое: '; en = 'New: '"), СокрЛП(ТекН.Реквизиты["ТипСообщения"]), ТекНом, ВсегоН), 
		ТекСообСсылка, 
		//"№ "+ТекНом+" ("+ВсегоН+")"+Символы.ПС+"Тема: "+СокрЛП(ТекН.Реквизиты["Тема"])+Символы.ПС+"Автор: "+СокрЛП(ТекН.Реквизиты["Автор"]),
		СтрШаблон("%1: %2
					|%3: %4", 
					НСтр("ru = 'Тема'; en = 'Theme'"), СокрЛП(ТекН.Реквизиты["Тема"]), 
					НСтр("ru = 'Автор'; en = 'Author'"), СокрЛП(ТекН.Реквизиты["Автор"])),
					лКартинка,
					СтатусОповещенияПользователя.Важное,
					);
		
	КонецПроцедуры
	
	//===Подключение подсистемы "Сообщения"
	
	
Процедура ПроверитьПодключениеОбработчикаОжиданияИнформированияОНовыхСообщенияхВнеОчереди() Экспорт 

	ПодключитьОбработчикОжидания("ПроверитьНапоминанияОбСообщенияхВнеОчереди", 60);	

КонецПроцедуры

Процедура ПроверитьНапоминанияОбСообщенияхВнеОчереди() Экспорт

	мас = Сооб_Сервер.СформироватьСписокНовыхСообщенийВнеОчереди();
	
	Для КАЖДОГО эл ИЗ мас Цикл
		
		ПоказатьОповещениеПользователя(эл.Реквизиты.Тема,,
										эл.Реквизиты.Сообщение,
										БиблиотекаКартинок.ДиалогВосклицание, 
										СтатусОповещенияПользователя.Важное);
		Отбор = Новый Структура("Получатель,Автор,ЗапланированнаяДатаДоставки,ТипСообщения,Категория,УникИдент");
		ЗаполнитьЗначенияСвойств(Отбор, эл.реквизиты);
		Сооб_Сервер.УдалитьЗапись(Отбор);
		
	КонецЦикла;

КонецПроцедуры

