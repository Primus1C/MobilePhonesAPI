Процедура ПередНачаломРаботыСистемы(Отказ)
	
	Рез = омСервер.ЕстьЕщеСеансы();
	Если НЕ (Рез = "") Тогда клОшибка(Рез); Отказ = Истина; Возврат; КонецЕсли; 
	
	Если (гоПользовательКод() = "Регистрация") И (гоПараметрСеанса("Настройка") <> "ОК") Тогда
		Отказ = Истина;
		ОткрытьФорму("ОбщаяФорма.Настройка", , , , , , Новый ОписаниеОповещения("ПередНачаломРаботыСистемыПослеНастройки", ОбработчикиКомандКлиент));
	// © Primus1C  07.02.2024  НАЧАЛО ► 
	ИначеЕсли НЕ омСервер.ВходВПрограммуРазрешен() Тогда   
		клВнимание(НСтр("ru = 'Вход в программу запрещен! Обратитесь к администратору'; en = 'Entry to the program is prohibited! Contact your administrator'"),,
				   НСтр("ru = 'Авторизация: '; en = 'Authorization: '")+гоПользователь());
		Отказ = Истина;  
	ИначеЕсли омСервер.ПотребоватьСменуПароляПриВходе() Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ВернутьПарольБезУстановки", Ложь);
		ПараметрыФормы.Вставить("СтарыйПароль", Неопределено);
		ПараметрыФормы.Вставить("Пользователь", Неопределено);
	
		ОткрытьФорму("ОбщаяФорма.СменаПароля", ПараметрыФормы,,,,, );
											
	// © Primus1C  ОКОНЧАНИЕ ◄	
	КонецЕсли;
	
	омСервер2.ПередНачалоРаботыСистемыНаСервере(Отказ);
	
	// © Primus1C  08.08.2025  НАЧАЛО ►
	УстановитьПараметрыФункциональныхОпцийИнтерфейса(Новый Структура("Пользователь", гоПользователь()));
	// © Primus1C  ОКОНЧАНИЕ ◄   
	
КонецПроцедуры

