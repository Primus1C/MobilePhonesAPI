	клСканерШКВключен = Ложь;
	
	//2016.02.02
	клБуферДокумент = Неопределено;
	клБуферНомераСтрок = Новый Массив;  
	
	// © Primus1C  06.09.2023  НАЧАЛО ► 
		//***Подключение подсистемы "Сообщения"
		ПроверитьПодключениеОбработчикаОжиданияИнформированияОНовыхСообщениях();
