Процедура ЗаполнитьДерево()

	НастройкиЭлементы = ДеревоНастроек.ПолучитьЭлементы();
	НастройкиЭлементы.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЦветаОформления.Родитель,
	               |	ЦветаОформления.Ссылка КАК Настройка,
	               |	ЦветаОформления.ЭтоГруппа КАК ЭтоГруппа,
	               |	НЕ ЦветаОформления.ЭтоГруппа КАК НомерКартинки,
	               |	ВЫРАЗИТЬ(Сведения.Значение КАК СТРОКА(13)) КАК Значение
	               |ИЗ
	               |	ПланВидовХарактеристик.ЦветаОформления КАК ЦветаОформления
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦветаОформления КАК Сведения
	               |		ПО (Сведения.Настройка = ЦветаОформления.Ссылка)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ЭтоГруппа ИЕРАРХИЯ,
	               |	ЦветаОформления.Наименование";	
	
	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	ДобавитьСтрокиВДерево(Выборка, НастройкиЭлементы);
	
КонецПроцедуры

//По переданным данным создаем дерево строк на форме
//
// Выборка - выборка запроса с данными в иерархии
// ДеревоЗначени - элементы дерева значения, для которого создаются строки
//
Функция ДобавитьСтрокиВДерево(Выборка, ДеревоЗначений)
	
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрокаНастройки = ДеревоЗначений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаНастройки, Выборка);
		НоваяСтрокаНастройки.Значение = Выборка.Настройка.ТипЗначения.ПривестиЗначение(Выборка.Значение);
		
		СтрокиВыборки = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		Если СтрокиВыборки.Количество() > 0 Тогда
			
			ДобавитьСтрокиВДерево(СтрокиВыборки, НоваяСтрокаНастройки.ПолучитьЭлементы());
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции


// Процедура выполняет запись значений настроек в регистр сведений.
//
Процедура ОбновитьНастройки()
	
	НаборЗаписей = РегистрыСведений.ЦветаОформления.СоздатьНаборЗаписей();
	
	НастройкиГруппы = ДеревоНастроек.ПолучитьЭлементы();
	Для Каждого ГруппаНастроек Из НастройкиГруппы Цикл
		
		НастройкиЭлементы = ГруппаНастроек.ПолучитьЭлементы();
		
		Для Каждого СтрокаНастроек Из НастройкиЭлементы Цикл
			Запись = НаборЗаписей.Добавить();
			Запись.Настройка    = СтрокаНастроек.Настройка;
			Запись.Значение     = СтрокаНастроек.Настройка.ТипЗначения.ПривестиЗначение(СтрокаНастроек.Значение);
		КонецЦикла;
		
	КонецЦикла;
	
	НаборЗаписей.Записать();
	
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры // ОбновитьНастройки()


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗаполнитьДерево();
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ЦветаОформления.Настройка КАК Настройка,
	             |	ВЫРАЗИТЬ(ЦветаОформления.Значение КАК СТРОКА(13)) КАК Значение
	             |ИЗ
	             |	РегистрСведений.ЦветаОформления КАК ЦветаОформления
	             |ГДЕ
	             |	ЦветаОформления.Значение <> """"";  
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл  
		Эле = УсловноеОформление.Элементы.Добавить();
		Эле.Использование 	= Истина;
		Эле.Оформление.УстановитьЗначениеПараметра("ЦветФона", гоЦветРГБ(Выборка.Значение));    
		ЭлементУсловия                = Эле.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементУсловия.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ДеревоНастроек.Значение");
		ЭлементУсловия.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементУсловия.ПравоеЗначение = Выборка.Значение;
		ЭлементУсловия.Использование  = Истина;
		ОформляемоеПоле      = Эле.Поля.Элементы.Добавить();
		ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ДеревоНастроекНастройка");  
	КонецЦикла;	
	
КонецПроцедуры	

&НаКлиенте
Процедура ПриЗакрытии()

	ОбновитьНастройки();

КонецПроцедуры

