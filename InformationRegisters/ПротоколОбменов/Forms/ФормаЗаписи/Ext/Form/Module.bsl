
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Ресурсы ValueStorage недоступны в данных формы (Запись) — читаем отдельно из БД.
	Тексты = ТекстыРесурсовПротокола(Запись.ИдентификаторЗапроса);
	ТекстЗаголовки = Тексты.Заголовки;
	ТекстТелоЗапроса = Тексты.ТелоЗапроса;
	ТекстТелоОтвета = Тексты.ТелоОтвета;
	
КонецПроцедуры

&НаСервере
Функция ТекстыРесурсовПротокола(ИдентификаторЗапроса)
	
	Результат = Новый Структура("Заголовки, ТелоЗапроса, ТелоОтвета", "", "", "");
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ПротоколОбменов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ИдентификаторЗапроса = ИдентификаторЗапроса;
	МенеджерЗаписи.Прочитать();
	
	Если НЕ ЗначениеЗаполнено(МенеджерЗаписи.Дата) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Заголовки = ТекстИзХранилища(МенеджерЗаписи.ЗаголовкиЗапроса);
	Результат.ТелоЗапроса = ТекстИзХранилища(МенеджерЗаписи.ТелоЗапроса);
	Результат.ТелоОтвета = ТекстИзХранилища(МенеджерЗаписи.ТелоОтвета);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ТекстИзХранилища(ЗначениеХранилища)
	
	Если НЕ ЗначениеЗаполнено(ЗначениеХранилища) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		Если ТипЗнч(ЗначениеХранилища) = Тип("ХранилищеЗначения") Тогда
			Значение = ЗначениеХранилища.Получить();
		Иначе
			Значение = ЗначениеХранилища;
		КонецЕсли;
		
		Если Значение = Неопределено Тогда
			Возврат "";
		КонецЕсли;
		
		Если ТипЗнч(Значение) = Тип("Строка") Тогда
			Возврат Значение;
		КонецЕсли;
		
		Возврат Строка(Значение);
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции
