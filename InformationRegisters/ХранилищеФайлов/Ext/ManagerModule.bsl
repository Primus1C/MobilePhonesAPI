Функция ПолучитьСтрокуФайлов(Ссылка, Назначение) Экспорт
	
	л_Строка = ""; 
	л_Разделитель = ";  ";
	л_Запрос = Новый Запрос;
	л_Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ХранилищеФайлов.ИмяФайла КАК ИмяФайла,
	|	ХранилищеФайлов.РасширениеИмениФайла КАК РасширениеИмениФайла
	|ИЗ
	|	РегистрСведений.ХранилищеФайлов КАК ХранилищеФайлов
	|ГДЕ
	|	ХранилищеФайлов.ОбъектСсылка = &ОбъектСсылка"; 
	Если ЗначениеЗаполнено(Назначение) Тогда
		л_Запрос.Текст = л_Запрос.Текст + " И ХранилищеФайлов.НазначениеФайла = &Назначение";
		л_Запрос.УстановитьПараметр("Назначение", Назначение);
	КонецЕсли;
	л_Запрос.УстановитьПараметр("ОбъектСсылка", Ссылка);
	л_ТЗ = л_Запрос.Выполнить().Выгрузить();
	Для Каждого л_Стр Из л_ТЗ Цикл 
		л_Строка = л_Строка + л_Стр[0] + л_Стр[1] + л_Разделитель;
	КонецЦикла;
	Возврат Лев(л_Строка, СтрДлина(л_Строка) - СтрДлина(л_Разделитель)); 
	
КонецФункции // ПолучитьСтрокуФайлов()

Функция ИмяПапкиОбъекта(СсылкаОбъект, НастройкаХраненияФайлов) Экспорт

	//получить имя общей папки на сервере
	л_ОбщаяПапка = НастройкаХраненияФайлов.КаталогФайлов;
	Если Прав(л_ОбщаяПапка, 1) = "\" Тогда 
		л_ПапкаОбъекта = л_ОбщаяПапка + Формат(ТекущаяДата(), "ДФ=""ггггММдд""") + "\" + СсылкаОбъект.УникальныйИдентификатор();
	Иначе 
		л_ПапкаОбъекта = л_ОбщаяПапка + "\" + Формат(ТекущаяДата(), "ДФ=""ггггММдд""") + "\" + СсылкаОбъект.УникальныйИдентификатор();
	КонецЕсли;
	Возврат  л_ПапкаОбъекта;

КонецФункции 

Функция ПриведенноеИмя(ИмяФайлаСРасширением)
	
	Если Сред(ИмяФайлаСРасширением, СтрДлина(ИмяФайлаСРасширением)-3, 1) = "." Тогда
		поз = 4;
	Иначе
		поз = 5;
	КонецЕсли;
	Расширение = Прав(ИмяФайлаСРасширением, поз);
	ПриведенноеИмя = Лев(ИмяФайлаСРасширением, СтрДлина(ИмяФайлаСРасширением)-поз);
	ПриведенноеИмя = СтрЗаменить(ПриведенноеИмя, "    ", "_");
	ПриведенноеИмя = СтрЗаменить(ПриведенноеИмя, "   ", "_");
	ПриведенноеИмя = СтрЗаменить(ПриведенноеИмя, "  ", "_");
	ПриведенноеИмя = СтрЗаменить(ПриведенноеИмя, " ", "_");

	Возврат Новый Структура("Имя,Расширение", ПриведенноеИмя, Расширение);
	
КонецФункции 

//добавление (загрузка) файлов на диск сервера
Процедура СохранитьФайлНаДиск(Знач АдресВременногоХранилища, знач п_НастройкаХраненияФайлов, знач п_Объект, п_Файл, Отказ, ТекстСообщения="") Экспорт  

	л_ПапкаОбъекта = ИмяПапкиОбъекта(п_Объект, п_НастройкаХраненияФайлов);
	
	//Создать папку, если такой не существует
	СоздатьКаталогНаСервере (л_ПапкаОбъекта, Отказ, ТекстСообщения);
	Если Отказ Тогда  
		Возврат;
	КонецЕсли;
	
	ПриведенноеИмя = ПриведенноеИмя(п_Файл.Имя);
	
	//получить полное имя файла на сервере
	//л_ПолноеИмяСохраняемогоФайла = л_ПапкаОбъекта + "\" + п_Файл.Имя;
	л_ПолноеИмяСохраняемогоФайла = л_ПапкаОбъекта + "\" + ПриведенноеИмя.Имя + ПриведенноеИмя.Расширение;
	
	//проверить существование такого файла на сервере
	л_СохраняемыйФайл = Новый Файл(л_ПолноеИмяСохраняемогоФайла);
	Если л_СохраняемыйФайл.Существует() Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Файл с именем %1%2%1 уже существует в базе данных'; en = 'A file named %1%2%1 already exists in the database'"), "'", ПриведенноеИмя.Имя + ПриведенноеИмя.Расширение);
		Отказ = Истина;
		Возврат;
	КонецЕсли;

 	//копировать файл из временного хранилища базы на диск сервера
	Попытка
		СохранитьФайлНаСервере(АдресВременногоХранилища, л_ПолноеИмяСохраняемогоФайла);
		п_Файл.ПолноеИмя		= л_ПолноеИмяСохраняемогоФайла;    
		п_Файл.Имя              = л_ПолноеИмяСохраняемогоФайла; 
		п_Файл.ИмяБезРасширения	= ПриведенноеИмя.Имя;
		п_Файл.Путь				= л_ПапкаОбъекта;
	Исключение
		ТекстСообщения 			= ОписаниеОшибки();
		Отказ 					= Истина;
	КонецПопытки;
	
КонецПроцедуры

Процедура ПоместитьФайлВоВременноеХранилище(Знач КлючЗаписи, АдресХранилища) 
	
	л_Запись = ПолучитьЗапись(КлючЗаписи);
	
	Если л_Запись.МестоХраненияФайлов = Перечисления.МестоХраненияПрикрепленныхФайлов.ИнформационнаяБаза Тогда 
		
		л_ДвоичныеДанныеФайла = л_Запись.ХранилищеДвоичныхДанных.Получить();
		АдресХранилища = ПоместитьВоВременноеХранилище(л_ДвоичныеДанныеФайла);
		
	ИначеЕсли л_Запись.МестоХраненияФайлов = Перечисления.МестоХраненияПрикрепленныхФайлов.ОбщийДисковыйРесурс Тогда 
		
		//л_НастройкаХраненияФайлов = РегистрыСведений.НастройкаХраненияФайлов.ПолучитьПоследнее(л_Запись.Период); 
		л_НастройкаХраненияФайлов = ОбщегоНазначенияПовтИсп.НастройкаХраненияФайлов();
		Если ЗначениеЗаполнено(л_НастройкаХраненияФайлов) Тогда 
			л_ПолноеИмяФайла = л_Запись.ПутьФайла + "\" + л_Запись.ИмяФайла + л_Запись.РасширениеИмениФайла; //л_НастройкаХраненияФайлов.КаталогФайлов+"\"+л_Запись.Объект+"\"+л_Запись.ИмяФайла+л_Запись.РасширениеИмениФайла;
			АдресХранилища = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(л_ПолноеИмяФайла));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьАдресФайлаВоВременномХранилище(Знач КлючЗаписи) Экспорт 
	
	л_Адрес = "";
	ПоместитьФайлВоВременноеХранилище(КлючЗаписи, л_Адрес);
	Возврат л_Адрес; 
	
КонецФункции 

Процедура ДобавитьЗаписьВРегистр(знач ДатаЗагрузки, знач п_ОбъектСсылка, знач п_Файл, знач п_НастройкаХраненияФайлов, п_Отказ, п_ИзменитьСуществующуюЗапись=Ложь, п_Запись="", ТекстСообщения="") Экспорт 
	
	л_Запись 				= СоздатьМенеджерЗаписи();
	л_МестоХраненияФайлов 	= п_НастройкаХраненияФайлов.МестоХраненияФайлов;
	Если п_ИзменитьСуществующуюЗапись Тогда 
		л_Запись = п_Запись;
	Иначе 
		л_Запись.Период					= ДатаЗагрузки;
		л_Запись.Активность				= Истина;
		л_Запись.ОбъектУИД				= п_ОбъектСсылка.УникальныйИдентификатор();
		л_Запись.ОбъектСсылка			= п_ОбъектСсылка;
		л_Запись.ИмяФайла				= п_Файл.ИмяБезРасширения;
		л_Запись.МестоХраненияФайлов	= л_МестоХраненияФайлов;
		л_Запись.РасширениеИмениФайла	= п_Файл.Расширение;
		л_Запись.Автор					= ПараметрыСеанса.Пользователь; 
		Если п_Файл.Свойство("Назначение") Тогда
			л_Запись.НазначениеФайла	= п_Файл.Назначение;	
		КонецЕсли;
		л_Запись.ПутьФайла				= п_Файл.Путь;
		л_Запись.РазмерФайла            = п_Файл.Размер;
	КонецЕсли;
	
	ИмяВременногоФайла = КаталогВременныхФайлов() + п_Файл.Имя; 
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(п_Файл.АдресВременногоХранилища);
	ДвоичныеДанные.Записать(ИмяВременногоФайла);
	п_Файл.ПолноеИмя = ИмяВременногоФайла; 
	
	Если л_МестоХраненияФайлов = Перечисления.МестоХраненияПрикрепленныхФайлов.ИнформационнаяБаза Тогда 
		Если п_НастройкаХраненияФайлов.ИспользоватьСжатие Тогда 
			л_Запись.ХранилищеДвоичныхДанных = Новый ХранилищеЗначения(Новый ДвоичныеДанные (п_Файл.ПолноеИмя), Новый СжатиеДанных(п_НастройкаХраненияФайлов.МетодСжатия));
		Иначе 
			л_Запись.ХранилищеДвоичныхДанных = Новый ХранилищеЗначения(Новый ДвоичныеДанные (п_Файл.ПолноеИмя));
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		л_Запись.Записать(п_ИзменитьСуществующуюЗапись);
		п_Запись = л_Запись;
		ТекстСообщения = СтрШаблон( НСтр("ru = 'Файл %1 успешно загружен!'; en = 'File %1 uploaded successfully!'"), п_Файл.ИмяБезРасширения + п_Файл.Расширение);
	Исключение
		п_Отказ	= Истина;
		ТекстСообщения = "Ошибка в процедуре РС 'ХранилищеФайлов' - 'ДобавитьЗаписьВРегистр(...)'" + Символы.ПС + ОписаниеОшибки();
	КонецПопытки;
	
КонецПроцедуры

//Удаление файлов
Процедура УдалитьФайлСДиска(знач КлючЗаписи, Отказ, ТекстСообщения="") Экспорт  
	
	л_Запись = ПолучитьЗапись(КлючЗаписи);	
	//л_НастройкаХраненияФайлов	= РегистрыСведений.НастройкаХраненияФайлов.ПолучитьПоследнее(л_Запись.Период);
	л_НастройкаХраненияФайлов	= ОбщегоНазначенияПовтИсп.НастройкаХраненияФайлов();
	л_ПапкаДляУдаления			= л_Запись.ПутьФайла + "\"; //л_НастройкаХраненияФайлов.КаталогФайлов+"\"+л_Запись.Объект+"\";
	л_ИмяФайла					= л_Запись.ИмяФайла + л_Запись.РасширениеИмениФайла;
	
	Если л_ИмяФайла = "" Тогда
	    Возврат;
	КонецЕсли;

	УдалитьФайлыНаСервере(л_ПапкаДляУдаления, л_ИмяФайла, Отказ, ТекстСообщения);
	Если НЕ Отказ Тогда 
		ТекстСообщения = СтрШаблон( НСтр("ru = 'Файл %1 успешно удален!'; en = 'File %1 deleteded successfully!'"), л_ИмяФайла);
	КонецЕсли;;

КонецПроцедуры

Процедура УдалитьЗаписьИзРегистра(знач КлючЗаписи, Отказ, ТекстСообщения="") Экспорт     
	
	л_Запись = ПолучитьЗапись(КлючЗаписи);
	Если л_Запись.Выбран() Тогда 
		л_Запись.Удалить();
	Иначе 
		ТекстСообщения = НСтр("ru = 'Запись не найдена!'; en = 'Record not found!'");
		Отказ = Истина;
	КонецЕсли;  
	
КонецПроцедуры

