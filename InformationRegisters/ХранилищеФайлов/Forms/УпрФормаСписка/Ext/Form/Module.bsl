#Область ДействияФормы  

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Список.Параметры.УстановитьЗначениеПараметра("ОбъектУИД", Параметры.ОбъектУИД);
	Если Параметры.Свойство("ВладелецСсылка") Тогда
		ВладелецСсылка = Параметры.ВладелецСсылка;               
		Если ТипЗнч(ВладелецСсылка) = Тип("ДокументСсылка.ИнвойсЗакупки") Тогда 
			ВладелецПредставление = СтрШаблон(НСтр("ru = 'Инвойс закупки %1 от %2'; en = 'Purchase invoice %1 от %2'"), 
												ВладелецСсылка.НомерИнвойсаПоставщика, 
												Формат(ВладелецСсылка.ДатаИнвойсаПоставщика, "ДФ=dd.MM.yyyy"));
		Иначе
			ВладелецПредставление = Строка(ВладелецСсылка);
		КонецЕсли;
	КонецЕсли;
	Если Параметры.Свойство("НазначениеФайла") Тогда
		Если ЗначениеЗаполнено(Параметры.НазначениеФайла) Тогда
			Список.ТекстЗапроса = Список.ТекстЗапроса + " И РСХранФайлов.НазначениеФайла = &НазначениеФайла";
			Список.Параметры.УстановитьЗначениеПараметра("НазначениеФайла", Параметры.НазначениеФайла);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)    
	
	//Заголовок = "Прикрепленные файлы: " + ЭтотОбъект.ВладелецФормы.Объект.Ссылка; 
	Заголовок = НСтр("ru = 'Прикрепленные файлы: '; en = 'Attached files: '") + ВладелецПредставление;
	НачатьПодключениеРасширенияРаботыСФайлами(Новый ОписаниеОповещения("РасширениеПоключено", ЭтаФорма));
	
КонецПроцедуры

#КонецОбласти

