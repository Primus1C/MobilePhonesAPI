&НаКлиенте
Процедура ОтчетСреднийКурс(Команда)
	
	ФормаОтчета = ПолучитьФорму("Отчет.СреднийКурс.Форма");
	
	ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Дата", Запись.Период);
	ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Валюта", Запись.Валюта);
	
	//ФормаОтчета.Элементы.ФормаВарианты.Видимость = Ложь;
	ФормаОтчета.Открыть();
	ФормаОтчета.СкомпоноватьРезультат();  

КонецПроцедуры

