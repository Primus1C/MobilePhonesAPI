Процедура ОбычнаяПечать()
	//здесь, по идее, заполненные при открытии и возможно, измененные поля, вот и проверим
	
	ПечТаб = ?(Элементы.Таб.Редактирование, Таб, СохТаб);
	
	ПечТаб.ПолеСлева = ПолеСлева;
	ПечТаб.ПолеСправа = ПолеСправа;
	ПечТаб.ПолеСверху = ПолеСверху;
	ПечТаб.ПолеСнизу = ПолеСнизу;
		
	Если СпрашиватьПринтер Тогда
		
		//вот здесь непонятно, отказались от печати или нет, но так, вроде бы и в 1с77 было
		
		ПечТаб.Напечатать(РежимИспользованияДиалогаПечати.Использовать);
	Иначе
		Если гоАдминистратор() Тогда
			ПечТаб.Показать(ЭтаФорма.Заголовок);
		Иначе
			ПечТаб.Напечатать();
		КонецЕсли; 
	КонецЕсли; 
