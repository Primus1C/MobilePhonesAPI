&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Таб.Очистить();
	
	Если Параметры.Свойство("Таб") Тогда 
		СохТаб = Параметры.Таб;
		
		Таб.Вывести(СохТаб); 
	КонецЕсли; 
	
	//2014.06.20
	Если Параметры.Свойство("КлючСохраненияПоложенияОкна") Тогда 
		ЭтаФорма.КлючСохраненияПоложенияОкна = Параметры.КлючСохраненияПоложенияОкна;
	КонецЕсли; 
	
	СразуРедактировать = ?(Параметры.Свойство("СразуРедактировать"), Параметры.СразуРедактировать, Ложь);
	
	Если СразуРедактировать Тогда  
		Элементы.Таб.Редактирование = Истина;
	КонецЕсли; 
	
	Имя = "";
	Если Параметры.Свойство("Имя") Тогда 
		Имя = Параметры.Имя;
		
		НеДляПечати = Параметры.НеДляПечати;
		
		Если НеДляПечати Тогда 
			Таб.ФоноваяКартинка = БиблиотекаКартинок.НеДляПечати; 
			
			Элементы.СохранитьВФайл.Доступность = Ложь;
			
			Таб.ВерхнийКолонтитул.Выводить = Истина;
			Таб.ВерхнийКолонтитул.НачальнаяСтраница = 1;
			Таб.ВерхнийКолонтитул.ТекстВЦентре = "Н Е Д Е Й С Т В И Т Е Л Ь Н Ы Й     Д О К У М Е Н Т";
			
			Таб.НижнийКолонтитул.Выводить = Истина;
			Таб.НижнийКолонтитул.НачальнаяСтраница = 1;
			Таб.НижнийКолонтитул.ТекстВЦентре = "Н Е Д Е Й С Т В И Т Е Л Ь Н Ы Й     Д О К У М Е Н Т";
		КонецЕсли; 
		
		//не работает почему-то
		//Таб.Вывод = ИспользованиеВывода.Запретить;
	КонецЕсли; 
	
	Если Параметры.Свойство("Имя") Тогда ЭтаФорма.Заголовок = Параметры.Имя КонецЕсли; 
	
	Таб.ОриентацияСтраницы = СохТаб.ОриентацияСтраницы;
КонецПроцедуры

