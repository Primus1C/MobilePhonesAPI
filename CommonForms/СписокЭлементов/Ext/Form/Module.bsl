&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Тип = ?(Параметры.Свойство("Тип"), Параметры.Тип, "");
	Если Тип = "" Тогда Отказ = Истина; Возврат; КонецЕсли; 
	
	Заголовок = ?(Параметры.Свойство("Заголовок"), Параметры.Заголовок, "Список элементов справочника");
	
	локСписок = ?(Параметры.Свойство("Список"), Параметры.Список, Новый СписокЗначений);
	
	СписокДокументов = ?(Параметры.Свойство("СписокДокументов"), Параметры.СписокДокументов, Ложь);
	
	локИсключить = ?(Параметры.Свойство("Исключить"), Параметры.Исключить, "не надо");
	
	Если локИсключить = "не надо" Тогда 
		Исключить = Ложь;
		Элементы.Исключить.Видимость = Ложь;
	Иначе 
		Исключить = локИсключить;
	КонецЕсли; 
	
	//это нужно сохранить для добавления в справочник, чтобы группы отличались от списка товаров
	ТипДляСправочника = Тип;
	
	ТолькоГруппы = Ложь;
	Если Тип = "ГруппыНоменклатуры" Тогда  
		ТолькоГруппы = Истина;
		Тип = "Номенклатура";
	КонецЕсли; 
	
	Если СписокДокументов Тогда 
		Список.ТипЗначения = Новый ОписаниеТипов("ДокументСсылка." + Тип);	
	Иначе 
		Список.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка." + Тип);	
	КонецЕсли; 
	
	Если ТолькоГруппы Тогда  
		Элементы.СписокЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Группы;
	КонецЕсли; 
	
	Список.ЗагрузитьЗначения(локСписок.ВыгрузитьЗначения());
	
	ЭтаФорма.Заголовок = Заголовок;
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	Пар = Новый СписокЗначений;
	Пар.ЗагрузитьЗначения(Список.ВыгрузитьЗначения());
	
	гоСвернутьСписокЗначений(Пар, "Возр");
	
	Рез = Новый Структура("Список, Исключить", Пар, Исключить);
	
	ОповеститьОВыборе(Рез);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтбор()
	гоСтандартныйОтбор(Списки, 0, Истина, ТипДляСправочника);
	гоСтандартныйОтбор(Списки, 1, ТолькоСвои, гоПользователь());
КонецПроцедуры

&НаКлиенте
Процедура ТолькоСвоиПриИзменении(Элемент)
	УстановитьОтбор();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьОтбор();
КонецПроцедуры

&НаКлиенте
Процедура СпискиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Загрузить(0);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДобавитьИмя(Имя, локТип)
	Нов = Справочники.СпискиЭлементов.СоздатьЭлемент();
	Нов.Наименование = Имя;
	Нов.Автор = гоПользователь();
	Нов.Тип = локТип;
	Нов.Записать();
	
	Возврат Нов.Ссылка;
КонецФункции 

&НаКлиенте
Процедура СпискиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Отказ = Истина;
	
	Имя = "";
	Тек = Элементы.Списки.ТекущаяСтрока;
	Если НЕ Тек = Неопределено Тогда Имя = гоРеквизит(Тек, "Наименование") КонецЕсли;
	
	ПоказатьВводСтроки(Новый ОписаниеОповещения("СпискиПередНачаломДобавленияПослеВводаИмени", ЭтотОбъект), Имя, "Новый список элементов (введите название)", 30);
КонецПроцедуры

&НаКлиенте
Процедура СпискиПередНачаломДобавленияПослеВводаИмени(Имя, ДопПараметры) Экспорт
	Если Имя = Неопределено Тогда Возврат КонецЕсли; 
	Если Имя = "" Тогда Возврат КонецЕсли; 
	
	Элементы.Списки.ТекущаяСтрока = ДобавитьИмя(Имя, ТипДляСправочника);
	
	Элементы.Списки.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура СпискиПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УдалитьИмя(Тек)
    Спр = Тек.ПолучитьОбъект();
	Спр.Удалить();
КонецПроцедуры 

&НаКлиенте
Процедура СпискиПередУдалением(Элемент, Отказ)
	Отказ = Истина;
	
	Тек = Элементы.Списки.ТекущаяСтрока;
	Если Тек = Неопределено Тогда Возврат КонецЕсли; 
	
	Авт = гоРеквизит(Тек, "Автор");
	Если НЕ Авт = гоПользователь() Тогда клОшибка("Чужой список!" + гоРС() + "Удаление запрещено!"); Возврат; КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("СпискиПередУдалениемЗавершение", ЭтотОбъект, Тек), "Удалить список " + гоИмя(Тек) + "?");
КонецПроцедуры

&НаКлиенте
Процедура СпискиПередУдалениемЗавершение(Результат, Тек) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли; 
	
	УдалитьИмя(Тек);
	
	Элементы.Списки.Обновить();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИмя(Тек)
	Список.ЗагрузитьЗначения(Тек.Список.ВыгрузитьКолонку("Элемент"));
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	Тек = Элементы.Списки.ТекущаяСтрока;
	Если Тек = Неопределено Тогда Возврат КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("ЗагрузитьЗавершение", ЭтотОбъект, Тек), "Загрузить элементы списка из " + гоИмя(Тек) + "?");
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЗавершение(Результат, Тек) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли; 
	
	ЗагрузитьИмя(Тек);
КонецПроцедуры

&НаСервере
Процедура СохранитьИмя(Тек)
    Спр = Тек.ПолучитьОбъект();
	
	Спр.Список.Очистить();
	
	Для Каждого Стр Из Список Цикл
		Нов = Спр.Список.Добавить();
		Нов.Элемент = Стр.Значение;
	КонецЦикла; 
	
	Спр.Записать();
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда)
	Тек = Элементы.Списки.ТекущаяСтрока;
	Если Тек = Неопределено Тогда Возврат КонецЕсли; 
	
	Авт = гоРеквизит(Тек, "Автор");
	Если НЕ Авт = гоПользователь() Тогда клОшибка("Чужой список!" + гоРС() + "Изменение запрещено!"); Возврат; КонецЕсли; 
	
	гоСвернутьСписокЗначений(Список, "Возр");
	
	клНетДа(Новый ОписаниеОповещения("СохранитьЗавершение", ЭтотОбъект, Тек), "Сохранить элементы списка в " + гоИмя(Тек) + "?");
КонецПроцедуры

&НаКлиенте
Процедура СохранитьЗавершение(Результат, Тек) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли; 
	
	СохранитьИмя(Тек);
КонецПроцедуры

&НаКлиенте
Процедура СписокПередУдалением(Элемент, Отказ)
	Отказ = Истина;
	
	ТекЭлемент = Элемент.ТекущиеДанные;
	Если ТекЭлемент = Неопределено Тогда Возврат КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("СписокПередУдалениемЗавершение", ЭтотОбъект, ТекЭлемент), "Удалить из списка?");
КонецПроцедуры

&НаКлиенте
Процедура СписокПередУдалениемЗавершение(Результат, ТекЭлемент) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	Список.Удалить(ТекЭлемент);
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	клНетДа(Новый ОписаниеОповещения("ОчиститьЗавершение", ЭтотОбъект), "Очистить список?");
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЗавершение(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Список.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура СписокПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

