&НаСервере
Функция КтоЕщеСканируетНаСервере()
	
	Стр = "";
	Запр = Новый Запрос;
	//Запр.УстановитьПараметр("Пользователь", гоПользователь());
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	БуферСканирования.ДокументОснование КАК ДокументОснование,
	             |	БуферСканирования.ДокументОснование.Контрагент КАК Контрагент,
	             |	БуферСканирования.Пользователь КАК Пользователь
	             |ИЗ
	             |	РегистрСведений.БуферСканирования КАК БуферСканирования
	             //|ГДЕ
	             //|	БуферСканирования.Пользователь <> &Пользователь
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Пользователь";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Стр = СтрШаблон("%1%2: %3 (%4)%5",
						Стр,
						Выборка.Пользователь,
						ОбщегоНазначения.ПредставлениеДокументаДляПечати(Выборка.ДокументОснование),
						Выборка.Контрагент,
						Символы.ПС);
	КонецЦикла;	
	Возврат ?(Стр = "", НСтр("ru = 'Другие пользователи буфер сканирования не используют'; en = 'Other users do not use the scan buffer'"), Стр);
	
КонецФункции

