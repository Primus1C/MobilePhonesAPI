&НаКлиенте
Процедура БуферНоменклатураПриАктивизацииСтроки(Элемент)     
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда 
		Номенклатура = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
	Иначе	
		Номенклатура = Элемент.ТекущиеДанные.Номенклатура;
	КонецЕсли;
	
	Заголовок = НСтр("ru = 'Буфер сканирования: '; en = 'Scan buffer: '") + Номенклатура;
	// установим отбор для ДС серий     
	ЭлементОтбораНоменклатура = Неопределено;
	Для каждого ЭлементОтбора Из БуферСерии.КомпоновщикНастроек.ФиксированныеНастройки.Отбор.Элементы Цикл
		Если ЭлементОтбора.ИдентификаторПользовательскойНастройки = "Номенклатура" Тогда
			ЭлементОтбораНоменклатура = ЭлементОтбора;
			Прервать;	
		КонецЕсли;
	КонецЦикла;
	Если ЭлементОтбораНоменклатура = Неопределено Тогда
		ЭлементОтбораНоменклатура = БуферСерии.КомпоновщикНастроек.ФиксированныеНастройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбораНоменклатура.ИдентификаторПользовательскойНастройки = "Номенклатура";
		ЭлементОтбораНоменклатура.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Номенклатура");
		ЭлементОтбораНоменклатура.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	КонецЕсли;
	ЭлементОтбораНоменклатура.ПравоеЗначение = Номенклатура;
	
	УстановитьДоступностьЭлементов();
	
КонецПроцедуры

