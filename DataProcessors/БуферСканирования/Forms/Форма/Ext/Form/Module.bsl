	Набор.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ВставитьИзБуфера(Команда)
	
	Буф = РаботаСоСканеромШК.ПолучитьИМЕИИзБуфера();
	
	КвоСтрок = СтрЧислоСтрок(Буф);
	Для Н = 1 По КвоСтрок Цикл
		НовСер = "";
		С = СтрПолучитьСтроку(Буф, Н);
		Пока (НовСер = "") И (С <> "") Цикл
			НовСер = гоСледПолеТаб(С);
		КонецЦикла;	
		серия = СокрЛП(НовСер);
		Если серия = "" Тогда
			Продолжить;		
		Иначе
			ДобавитьСерию(серия)
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

