&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Пользователь = гоПользователь();
	
	Если Параметры.Свойство("ДокументОснование") Тогда
		ДокументОснование = Параметры.ДокументОснование;   
		Попытка
		    Если ДокументОснование.Окончательно Тогда
				Отказ = Истина;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	ОбновитьТаблицы();
	
	ЭлементОтбора = БуферСерии.КомпоновщикНастроек.ФиксированныеНастройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ИдентификаторПользовательскойНастройки = "Пользователь";
	ЭлементОтбора.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("Пользователь");
	ЭлементОтбора.ВидСравнения 		= ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение 	= Пользователь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ) 

	Заголовок = НСтр("ru = 'Буфер сканирования'; en = 'Scan buffer'");
	УстановитьДоступностьЭлементов();    
	БуферНоменклатураПриАктивизацииСтроки(Элементы.БуферНоменклатура);
	
КонецПроцедуры

&НаКлиенте
