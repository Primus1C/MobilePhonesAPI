			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТЧ.Номенклатура КАК Номенклатура,
	СУММА(ТЧ.Количество) КАК ВДокументе,
	БуфСкан.Отсканировано КАК Отсканировано,
	БуфСкан.ОтсканированоДругимиПользователями КАК ОтсканированоДругимиПользователями,
	ВЫБОР
		КОГДА СУММА(ТЧ.Количество) = ЕСТЬNULL(БуфСкан.Отсканировано, 0) + ЕСТЬNULL(БуфСкан.ОтсканированоДругимиПользователями, 0)
			ТОГДА 2
		КОГДА ЕСТЬNULL(БуфСкан.Отсканировано, 0) = 0
				И ЕСТЬNULL(БуфСкан.ОтсканированоДругимиПользователями, 0) = 0
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК Состояние
ИЗ
	Документ.ПриходнаяНакладная.Товары КАК ТЧ
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			БуферСканирования.Номенклатура КАК Номенклатура,
			СУММА(БуферСканирования.Отсканировано) КАК Отсканировано,
			СУММА(БуферСканирования.ОтсканированоДругимиПользователями) КАК ОтсканированоДругимиПользователями
		ИЗ
			(ВЫБРАТЬ
				БуферСканирования.Номенклатура КАК Номенклатура,
				КОЛИЧЕСТВО(РАЗЛИЧНЫЕ БуферСканирования.Серия) КАК Отсканировано,
				0 КАК ОтсканированоДругимиПользователями
			ИЗ
				РегистрСведений.БуферСканирования КАК БуферСканирования
			ГДЕ
				БуферСканирования.Пользователь = &amp;Пользователь
				И БуферСканирования.ДокументОснование = &amp;ДокументОснование
			
			СГРУППИРОВАТЬ ПО
				БуферСканирования.Номенклатура
			
			ОБЪЕДИНИТЬ
			
			ВЫБРАТЬ
				БуферСканирования.Номенклатура,
				0,
				КОЛИЧЕСТВО(РАЗЛИЧНЫЕ БуферСканирования.Серия)
			ИЗ
				РегистрСведений.БуферСканирования КАК БуферСканирования
			ГДЕ
				БуферСканирования.Пользователь &lt;&gt; &amp;Пользователь
				И БуферСканирования.ДокументОснование = &amp;ДокументОснование
			
			СГРУППИРОВАТЬ ПО
				БуферСканирования.Номенклатура) КАК БуферСканирования
		
		СГРУППИРОВАТЬ ПО
			БуферСканирования.Номенклатура) КАК БуфСкан
		ПО ТЧ.Номенклатура = БуфСкан.Номенклатура
ГДЕ
	ТЧ.Ссылка = &amp;ДокументОснование
	И ТЧ.Серия = &amp;ПустаяСерия

СГРУППИРОВАТЬ ПО
	ТЧ.Номенклатура,
	БуфСкан.Отсканировано,
	БуфСкан.ОтсканированоДругимиПользователями</QueryText>
