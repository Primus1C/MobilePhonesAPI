		Имя = Элемент.ТекущийЭлемент.Имя;
	Исключение
	    Сообщить("ПривязкиПриОкончанииРедактирования: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Стр = Элемент.ТекущиеДанные;
	
	Если Имя = "ПривязкиКроссКурс" Тогда
		КК = Стр.КроссКурс;
		КО = Стр.ОбратныйКурс;
		ВД = Стр.ВалютаДолга;
		
		Для Каждого Стр Из Объект.Привязки Цикл
			Если Стр.ВалютаДолга <> ВД Тогда Продолжить КонецЕсли; 
			Если (Стр.СуммаДокумента <> 0) ИЛИ (Стр.СуммаДолга <> 0) Тогда Продолжить КонецЕсли;
			Если Стр.КроссКурс = КК Тогда Продолжить КонецЕсли; 
			
			Стр.КроссКурс = КК;
			Стр.ПересчетДолга = ?(Стр.ОбратныйКурс, Окр(Стр.СуммаДолга / Стр.КроссКурс, 2), Окр(Стр.СуммаДолга * Стр.КроссКурс, 2));
		КонецЦикла; 
	КонецЕсли; 
	
	Объект.УжеПривязано = Объект.Привязки.Итог("СуммаДокумента");
	Объект.СтрокаИтого = ?(Объект.ПривязаноИзвне = 0, "", 
							СтрШаблон(НСтр("ru = 'Привязано извне: %1     Еще можно привязать: %2'; en = 'Binded from outside: %1     You can also bind: %2'"),
                                гоСуммаЗнВал(Объект.ПривязаноИзвне, Объект.Валюта),
								гоСуммаЗнВал(Объект.ОбщаяСумма - Объект.УжеПривязано, Объект.Валюта) ));
	// © Primus1C  17.03.2024  НАЧАЛО ►
	Объект.СтрокаИтого = СтрШаблон( НСтр("ru = '%1Еще можно привязать: %2'; en = '%1You can also bind: %2'"), 
							?(Объект.ПривязаноИзвне = 0, "", СтрШаблон(НСтр("ru = 'Привязано извне: %1     '; en = 'Binded from outside: %1     '"), гоСуммаЗнВал(Объект.ПривязаноИзвне, Объект.Валюта))),
				  			гоСуммаЗнВал(Объект.ОбщаяСумма - Объект.УжеПривязано, Объект.Валюта) );
	СтруктураИтогов = омСервер.МоиИтогиФорматированные(Объект, Истина, Ложь);
	Элементы.ДекорацияИтого.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураИтогов.Итоги));
	// © Primus1C  ОКОНЧАНИЕ ◄
	Модиф = Истина;
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	Если Объект.Привязки.Итог("СуммаДокумента") = 0 Тогда Возврат КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("ОчиститьЗавершение", ЭтотОбъект), НСтр("ru = 'Очистить суммы во всех строках?'; en = 'Clear amounts in all rows?'"), , Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЗавершение(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Для Каждого Стр Из Объект.Привязки Цикл
		Стр.СуммаДокумента = 0;
		Стр.СуммаДолга = 0;
		Стр.ЕщеДолг = Стр.ОстатокДолга;
	КонецЦикла; 
	
	Объект.УжеПривязано = Объект.Привязки.Итог("СуммаДокумента");
	Объект.СтрокаИтого = ?(Объект.ПривязаноИзвне = 0, "", 
							СтрШаблон(НСтр("ru = 'Привязано извне: %1     Еще можно привязать: %2'; en = 'Binded from outside: %1     You can also bind: %2'"),
	                              гоСуммаЗнВал(Объект.ПривязаноИзвне, Объект.Валюта),
								  гоСуммаЗнВал(Объект.ОбщаяСумма - Объект.УжеПривязано, Объект.Валюта) ));
	
	Модиф = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	Если ПравильныйВыход Тогда Возврат КонецЕсли; 
	Если НЕ Модиф Тогда Возврат КонецЕсли; 
	
	//клОшибка("Используйте кнопку " + гоИмя("Сохранить и выйти") + "!");
	клОшибка(СтрШаблон(НСтр("ru = 'Используйте кнопку %1!'; en = 'Use button %1!'"), гоИмя("Сохранить и выйти")));
	
	Отказ = Истина;
КонецПроцедуры

&НаСервере
Функция ПривязкиВСтроку()
	Табл = Объект.Привязки.Выгрузить();
	Возврат ЗначениеВСтрокуВнутр(Табл);
КонецФункции

&НаКлиенте
Процедура СохранитьИВыйти(Команда)
	ПравильныйВыход = Истина;
	
	клДаНет(Новый ОписаниеОповещения("СохранитьИВыйтиЗавершение", ЭтотОбъект), НСтр("ru = 'Сохранить изменения?'; en = 'Save changes?'"));
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИВыйтиЗавершение(Результат, ДопПараметры) Экспорт
	Пар = Неопределено;
	
	Если Результат Тогда 
		
		//проверяем число привязок
		Если НЕ ПривязкиБезОграничений Тогда 
		    Если Объект.Привязки.Итог("ЕстьСумма") > 30 Тогда клОшибка(НСтр("ru = 'Достигнуто ограничение по числу привязок!'; en = 'The limit on the number of bindings has been reached!'")); Отказ = Истина; Возврат; КонецЕсли; КонецЕсли;

		//если уже на все согласились, удалим строки, где нет суммы документа
		
		Нашли = Объект.Привязки.НайтиСтроки(Новый Структура("СуммаДокумента", 0));
		Для Каждого Стр Из Нашли Цикл
			Объект.Привязки.Удалить(Стр);
		КонецЦикла; 
		
		Пар = Новый Структура;
		Пар.Вставить("ПривязкиСтрока", ПривязкиВСтроку());
	КонецЕсли;
	
	ОповеститьОВыборе(Пар);
КонецПроцедуры

&НаКлиенте
Процедура ПривязкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	//иногда возникает ошибка
	Попытка
		Имя = Элемент.ТекущийЭлемент.Имя;
	Исключение
	    Сообщить("ПривязкиВыбор: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Стр = Элемент.ТекущиеДанные;
	
	Если Имя = "ПривязкиДок" Тогда
		СтандартнаяОбработка = Ложь;
		Пар = Стр.Док;
		ОткрытьЗначение(Пар);
	КонецЕсли; 
КонецПроцедуры

