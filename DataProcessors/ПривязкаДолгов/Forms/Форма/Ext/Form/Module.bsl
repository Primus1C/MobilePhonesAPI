&НаКлиенте
Процедура ПривязкиПередНачаломИзменения(Элемент, Отказ)
	Если ПравильныйВыход Тогда Отказ = Истина; Возврат; КонецЕсли; 
	
	//иногда возникает ошибка
	Попытка
		Имя = Элемент.ТекущийЭлемент.Имя;
	Исключение
	    Сообщить("ПривязкиПередНачаломИзменения: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Стр = Элемент.ТекущиеДанные;
	
	Объект.УжеПривязано = Объект.Привязки.Итог("СуммаДокумента");
	МожноСуммаДокумента = Объект.ОбщаяСумма - (Объект.УжеПривязано - Стр.СуммаДокумента);
	
	Если Имя = "ПривязкиСуммаДокумента" Тогда
		
		Если НЕ РазрешитьПервуюКолонкуПривязкиДолгов Тогда Отказ = Истина; Возврат; КонецЕсли;
		
		Если Стр.СуммаДокумента = 0 Тогда
			
			Если Стр.НельзяПривязывать Тогда Отказ = Истина; Возврат; КонецЕсли; 
			
			//сказали проверять и пустой счет тоже, чтобы оба были пустые
			Если Стр.СчетДолга <> Объект.СчетДокументаОплаты Тогда клОшибка(НСтр("ru = 'Не соответствуют счета!'; en = 'The acounts don't match!'")); Отказ = Истина; Возврат; КонецЕсли; 
			
			//проверяем число привязок
			Если НЕ ПривязкиБезОграничений Тогда 
				Если Объект.Привязки.Итог("ЕстьСумма") >= 30 Тогда клОшибка(НСтр("ru = 'Достигнуто ограничение по числу привязок!'; en = 'The limit on the number of bindings has been reached!'")); Отказ = Истина; Возврат; КонецЕсли; КонецЕсли;
			
			ЛокСум = МожноСуммаДокумента;
			ЛокДол = Стр.ПересчетДолга;
			
			Если Объект.ОбщаяСумма < 0 Тогда
				//проверяем сумму, чтобы не превысила долг, только для обычного режима
				Если НЕ ХитроеУвеличениеДолга ИЛИ ЛокДол < 0 Тогда  
					Если ЛокСум < ЛокДол Тогда ЛокСум = ЛокДол КонецЕсли; 
				КонецЕсли; 
			Иначе
				Если ЛокСум > ЛокДол Тогда ЛокСум = ЛокДол КонецЕсли; 
			КонецЕсли;
			
			Стр.СуммаДокумента = ЛокСум;
		КонецЕсли; 
	ИначеЕсли Имя = "ПривязкиСуммаДолга" Тогда
		Если Стр.КроссКурс = 0 Тогда Стр.КроссКурс = 1 КонецЕсли;
		
		МожноСуммаДолга = ?(Стр.ОбратныйКурс, Окр(МожноСуммаДокумента / Стр.КроссКурс, 2), Окр(МожноСуммаДокумента * Стр.КроссКурс, 2));
		
		// © Primus1C  28.10.2024  НАЧАЛО ►
		Если БазоваяВалюта(Стр.ВалютаДокумента) = Стр.ВалютаОстатка Тогда
			//МожноСуммаДолга = МожноСуммаДокумента;
		КонецЕсли;
		// © Primus1C  ОКОНЧАНИЕ ◄
		
		Если Стр.СуммаДолга = 0 Тогда
			
			Если Стр.НельзяПривязывать Тогда Отказ = Истина; Возврат; КонецЕсли; 
			
			//сказали проверять и пустой счет тоже, чтобы оба были пустые
			Если Стр.СчетДолга <> Объект.СчетДокументаОплаты Тогда клОшибка(НСтр("ru = 'Не соответствуют счета!'; en = 'The acounts don't match!'")); Отказ = Истина; Возврат; КонецЕсли; 
			
			//проверяем число привязок
			Если НЕ ПривязкиБезОграничений Тогда 
				Если Объект.Привязки.Итог("ЕстьСумма") >= 30 Тогда клОшибка(НСтр("ru = 'Достигнуто ограничение по числу привязок!'; en = 'The limit on the number of bindings has been reached!'")); Отказ = Истина; Возврат; КонецЕсли; КонецЕсли;
			
			ЛокСум = МожноСуммаДолга;
			ЛокДол = Стр.ОстатокДолга;
			
			Если Объект.ОбщаяСумма < 0 Тогда
				//проверяем сумму, чтобы не превысила долг, только для обычного режима
				Если НЕ ХитроеУвеличениеДолга ИЛИ ЛокДол < 0 Тогда  
					Если ЛокСум < ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
				КонецЕсли; 
			Иначе
				Если ЛокСум > ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
			КонецЕсли;
			
			Стр.СуммаДолга = ЛокСум;
		КонецЕсли;
	ИначеЕсли Имя = "ПривязкиКроссКурс" Тогда
		
		//если уже есть суммы, курс не редактируем
		Если (Стр.СуммаДокумента <> 0) ИЛИ (Стр.СуммаДолга <> 0) Тогда Отказ = Истина; Возврат; КонецЕсли;
		
		//если валюты одинаковые, зачем менять курс?
		Если Стр.ВалютаДокумента = Стр.ВалютаДолга Тогда клОшибка("Странное желание!"); Отказ = Истина; Возврат; КонецЕсли; 
		
		//2013.12.14
		//получается, что это лишнее, и так всем запретили менять КК
		//Если ТолькоПривязки = 2 Тогда клОшибка("Без К/К!"); Отказ = Истина; Возврат; КонецЕсли; 
		
		//2013.12.02
		//здесь хотят менять в текущем дне для всей бухгалтерии
		
		//2014.04.21
		//не только Мельник, будут еще люди, именно в текущем дне
		
		//Если НачалоДня(Объект.ДокументОплаты.Дата) = гоТекущаяДата() Тогда 
		//	Если НЕ (гоМельник() ИЛИ гоКолинко() ИЛИ гоЕстьРоль("ОплатыКурсТекущийДень")) Тогда клНетПрав(); Отказ = Истина; Возврат; КонецЕсли; 
		//Иначе 
		//	Если НЕ (гоМельник() ИЛИ гоКолинко()) Тогда клНетПрав(); Отказ = Истина; Возврат; КонецЕсли; 
		//КонецЕсли; 
		
	ИначеЕсли Имя = "ПривязкиПримечание" Тогда
		
		//зачем примечание, если нет сумм привязки
		Если (Стр.СуммаДокумента = 0) И (Стр.СуммаДолга = 0) Тогда Отказ = Истина; Возврат; КонецЕсли;
		
	ИначеЕсли Имя = "ПривязкиДок" Тогда
		
		Пар = Стр.Док;
		ОткрытьЗначение(Пар);
		Отказ = Истина;
		
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ПривязкиПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	//иногда возникает ошибка
	Попытка
		Имя = Элемент.ТекущийЭлемент.Имя;
	Исключение
	    Сообщить("ПривязкиПередОкончаниемРедактирования: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки; 
	
	Стр = Элемент.ТекущиеДанные;
	
	Если Имя = "ПривязкиСуммаДокумента" Тогда
		ЛокСум = Стр.СуммаДокумента;
		ЛокДол = Стр.ПересчетДолга;
		
		//для минусоов - свой алгоритм
		Если Объект.ОбщаяСумма < 0 Тогда
			//проверяем сумму, чтобы не превысила долг, только для обычного режима
			Если НЕ ХитроеУвеличениеДолга ИЛИ ЛокДол < 0 Тогда
				Если ЛокСум < ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
			КонецЕсли; 
		Иначе
			Если ЛокСум > ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
		КонецЕсли;
		
		Если гоАбс(ЛокСум) > гоАбс(МожноСуммаДокумента) Тогда ЛокСум = МожноСуммаДокумента КонецЕсли; 
		
		Если Стр.КроссКурс = 0 Тогда Стр.КроссКурс = 1 КонецЕсли;
		
		Стр.СуммаДокумента = ЛокСум;
		
		Стр.СуммаДолга = ?(Стр.ОбратныйКурс, Окр(ЛокСум / Стр.КроссКурс, 2), Окр(ЛокСум * Стр.КроссКурс, 2));
		
		Стр.ЕщеДолг = Стр.ОстатокДолга - Стр.СуммаДолга;
		
		Если Стр.СуммаДокумента = 0 Тогда Стр.Примечание = "" КонецЕсли; 
		
		//новое для подсчета
		Стр.ЕстьСумма = ?(Стр.СуммаДокумента = 0, 0, 1);
	ИначеЕсли Имя = "ПривязкиСуммаДолга" Тогда
		ЛокСум = Стр.СуммаДолга;
		ЛокДол = Стр.ОстатокДолга;
		
		//для минусоов - свой алгоритм
		Если Объект.ОбщаяСумма < 0 Тогда
			//проверяем сумму, чтобы не превысила долг, только для обычного режима
			Если НЕ ХитроеУвеличениеДолга ИЛИ ЛокДол < 0 Тогда
				Если ЛокСум < ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
			КонецЕсли; 
		Иначе
			Если ЛокСум > ЛокДол Тогда ЛокСум = ЛокДол 	КонецЕсли; 
		КонецЕсли;
		
		Стр.СуммаДолга = ЛокСум;
		Стр.СуммаДокумента = ?(Стр.ОбратныйКурс, Окр(ЛокСум * Стр.КроссКурс, 2), Окр(ЛокСум / Стр.КроссКурс, 2));
		
		Если гоАбс(Стр.СуммаДокумента) > гоАбс(МожноСуммаДокумента) Тогда 
			
			Стр.СуммаДокумента = МожноСуммаДокумента;
			Стр.СуммаДолга = ?(Стр.ОбратныйКурс, Окр(Стр.СуммаДокумента / Стр.КроссКурс, 2), Окр(Стр.СуммаДокумента * Стр.КроссКурс, 2));

		КонецЕсли;
		
		Стр.ЕщеДолг = Стр.ОстатокДолга - Стр.СуммаДолга;
		
		Если Стр.СуммаДокумента = 0 Тогда Стр.Примечание = "" КонецЕсли; 
		
		//новое для подсчета
		Стр.ЕстьСумма = ?(Стр.СуммаДокумента = 0, 0, 1);
	КонецЕсли;
КонецПроцедуры

