&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Номенклатура = Параметры.Номенклатура;  
	Если Параметры.Свойство("СформироватьПриОткрытии") Тогда
		СформироватьПриОткрытии =	Параметры.СформироватьПриОткрытии;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПоказатьЦеныНаСервере()
	
	ДиаграммаЦен.Обновление = Ложь;
	ДиаграммаЦен.Очистить();
	ДиаграммаЦен.АвтоТранспонирование = Ложь;
	ДиаграммаЦен.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки, -1);
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Номенклатура", Номенклатура); 
	Запр.УстановитьПараметр("Валюта", Валюта); 
	Запр.Текст = "ВЫБРАТЬ
	             |	ЦеныЗакупки.Номенклатура,
	             |	ЦеныЗакупки.Поставщик,
	             |	ЦеныЗакупки.Цена,
	             |	ЦеныЗакупки.Регистратор,
	             |	ЦеныЗакупки.Регистратор.Валюта КАК Валюта,
	             |	НАЧАЛОПЕРИОДА(ЦеныЗакупки.Период, ДЕНЬ) КАК Период
	             |ИЗ
	             |	РегистрСведений.ЦеныЗакупки КАК ЦеныЗакупки
	             |ГДЕ
	             |	ЦеныЗакупки.Номенклатура = &Номенклатура
	             |	И ЦеныЗакупки.Валюта = &Валюта
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Период,
	             |	Поставщик"; 
	
	МаксЗначение = 0;
	МинЗначение = 1000000000;
	НачалоСерий = Новый Соответствие;
	
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		Серия = ДиаграммаЦен.УстановитьСерию(Строка(Выборка.Поставщик));
		//Серия.Цвет = Обработки.УдалитьМониторыРуководителя.ЦветДляМониторов("Синий");
		//Серия.Линия = Новый Линия(ТипЛинииДиаграммы.Сплошная, 2);
		// Маркер отключен: платформа рисует маркер даже в точках с базовым значением,
		// игнорируя ПропускатьБазовоеЗначение — иначе перед первой закупкой видна "нулевая" точка.
		Серия.Маркер = ТипМаркераДиаграммы.Нет;
		
		Точка = ДиаграммаЦен.УстановитьТочку(Формат(Выборка.Период, "ДФ=dd.MM.yy"));
		Точка.Расшифровка = Выборка.Цена;
		Если НачалоСерий.Получить(Серия.Текст) = Неопределено Тогда
			НачалоСерий.Вставить(Серия.Текст, ДиаграммаЦен.Точки.Индекс(Точка));
		КонецЕсли;
		Подсказка = СтрШаблон("%1 %2
							|%3 
							|%4",
							Выборка.Цена, Валюта.Символ, Выборка.Регистратор, Выборка.Поставщик);
		
		ДиаграммаЦен.УстановитьЗначение(Точка, Серия, Выборка.Цена, Точка.Расшифровка, Подсказка);

		Цена = Выборка.Цена;
			Если Цена > МаксЗначение Тогда
				МаксЗначение = Цена;
			КонецЕсли;
			Если Цена < МинЗначение Тогда
				МинЗначение = Цена;
			КонецЕсли;

		//	Сообщить(Строка(ВыборкаПоставщик.Поставщик) + ": "+ Точка.Текст);

	КонецЦикла; 

	// © Primus1C  19.06.2026  НАЧАЛО ►
	
	// Протягиваем последнюю известную цену поставщика вперед, но не раньше его первой закупки
	Для ИндексТочки = 0 По ДиаграммаЦен.Точки.Количество() - 1 Цикл
		ТекТочка = ДиаграммаЦен.Точки[ИндексТочки];
		
		Для Каждого ТекСерия Из ДиаграммаЦен.Серии Цикл
			НачалоИндекса = НачалоСерий.Получить(ТекСерия.Текст);
			Если НачалоИндекса = Неопределено Или ИндексТочки <= НачалоИндекса Тогда
				Продолжить;
			КонецЕсли;
			
			ТекЗначение = ДиаграммаЦен.ПолучитьЗначение(ТекТочка, ТекСерия).Значение;
			Если ТекЗначение = Неопределено Или ТекЗначение = 0 Тогда
				ПредТочка = ДиаграммаЦен.Точки[ИндексТочки - 1];
				ПрошлаяЦена = ДиаграммаЦен.ПолучитьЗначение(ПредТочка, ТекСерия).Значение;
				Если ПрошлаяЦена <> Неопределено Тогда
					ДиаграммаЦен.УстановитьЗначение(ТекТочка, ТекСерия, ПрошлаяЦена);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	РасчетныйМинимум = Окр(МинЗначение * 0.95, -2);
	
	ДиаграммаЦен.БазовоеЗначение = РасчетныйМинимум - 100;
	ДиаграммаЦен.ПропускатьБазовоеЗначение = Истина;
	ДиаграммаЦен.СоединениеТочекПриПропущенныхЗначениях = ТипСоединенияТочекПриПропущенныхЗначенияхДиаграммы.СоединениеНеПропущенных;
	
	ДиаграммаЦен.АвтоМинимальноеЗначение = Ложь;
	ДиаграммаЦен.МинимальноеЗначение = РасчетныйМинимум;
	
	СкрытьЗначенияДоНачалаСерий(ДиаграммаЦен, НачалоСерий);
	
	// © Primus1C  ОКОНЧАНИЕ ◄   
	
	ДиаграммаЦен.АвтоТранспонирование = Истина;
	СкрытьЗначенияДоНачалаСерий(ДиаграммаЦен, НачалоСерий);
	ДиаграммаЦен.Обновление = Истина;
		
КонецПроцедуры

&НаСервере
Процедура СкрытьЗначенияДоНачалаСерий(Диаграмма, НачалоСерий)
	
	// Платформа заполняет пустые ячейки нулём; при ПропускатьБазовоеЗначение
	// скрываются только значения, равные БазовомуЗначению — поэтому заменяем явно.
	Базовое = Диаграмма.БазовоеЗначение;
	
	Для ИндексТочки = 0 По Диаграмма.Точки.Количество() - 1 Цикл
		Точка = Диаграмма.Точки[ИндексТочки];
		
		Для Каждого Серия Из Диаграмма.Серии Цикл
			НачалоИндекса = НачалоСерий.Получить(Серия.Текст);
			Если НачалоИндекса = Неопределено Или ИндексТочки < НачалоИндекса Тогда
				Диаграмма.УстановитьЗначение(Точка, Серия, Базовое);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьЦены(Команда)
	ПоказатьЦеныНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРСПоПриходнымНаСервере(Ном)
	
	Запр = Новый Запрос;    
	Запр.УстановитьПараметр("Номенклатура", Номенклатура);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ПриходнаяНакладнаяТовары.Ссылка КАК Регистратор,
	             |	ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
	             |	ПриходнаяНакладнаяТовары.ЦенаЗакупки КАК ЦенаЗакупки
	             |ИЗ
	             |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	             |ГДЕ
	             |	ПриходнаяНакладнаяТовары.Ссылка В
	             |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |				ПНТовары.Ссылка
	             |			ИЗ
	             |				Документ.ПриходнаяНакладная.Товары КАК ПНТовары
	             |			ГДЕ
	             |				ПНТовары.Ссылка.Проведен
	             |				И ПНТовары.Ссылка.Окончательно
	             |				И ПНТовары.Номенклатура = &Номенклатура)
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ПриходнаяНакладнаяТовары.Ссылка.Дата,
	             |	Номенклатура
	             |ИТОГИ
	             |	СРЕДНЕЕ(ЦенаЗакупки)
	             |ПО
	             |	Регистратор,
	             |	Номенклатура";	
	ВыборкаР = Запр.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаР.Следующий() Цикл 
		НаборЗаписей = РегистрыСведений.ЦеныЗакупки.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(ВыборкаР.Регистратор); 
		лДата 		= ВыборкаР.Регистратор.Дата;
		лВалюта 	= ВыборкаР.Регистратор.Валюта; 
		лПоставщик 	= ВыборкаР.Регистратор.Контрагент;
		//Сообщить("==============================");
		//Сообщить(ВыборкаР.Регистратор);
		ВыборкаН = ВыборкаР.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаН.Следующий() Цикл
			НоваяЗапись = НаборЗаписей.Добавить(); 
			НоваяЗапись.Регистратор 	= ВыборкаР.Регистратор;
			НоваяЗапись.Номенклатура	= ВыборкаН.Номенклатура;	
			НоваяЗапись.Поставщик		= лПоставщик;	
			НоваяЗапись.Цена			= ВыборкаН.ЦенаЗакупки;  
			НоваяЗапись.Валюта			= лВалюта;  
			НоваяЗапись.Период			= лДата;
			//Сообщить(СтрШаблон("   %1 (%2)", ВыборкаН.Номенклатура, лПоставщик));
		КонецЦикла; 
		//Сообщить("   = " + ВыборкаН.Количество());
		НаборЗаписей.Записать(Истина);
		Ном = Ном + 1; 
		
		//Прервать;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРСПоПриходным(Команда)
	Ном = 0;
	ЗаполнитьРСПоПриходнымНаСервере(Ном); 
	Сообщить("Добавлено записей: "+Ном);
КонецПроцедуры

&НаСервере
Процедура ОчиститьРСНаСервере(Ном)  
	
	Запр = Новый Запрос;     
	Запр.УстановитьПараметр("БезВалюты", Справочники.Валюты.ПустаяСсылка());
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 100
	             |	ЦеныЗакупки.Регистратор
	             |ИЗ
	             |	РегистрСведений.ЦеныЗакупки КАК ЦеныЗакупки
	             |ГДЕ
	             |	ЦеныЗакупки.Валюта = &БезВалюты"; 
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Набор = РегистрыСведений.ЦеныЗакупки.СоздатьНаборЗаписей(); 
		Набор.Отбор.Регистратор.Установить(Выборка.Регистратор);
		Набор.Записать(); 
		Ном = Ном + 1;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьРС(Команда) 
	Ном = 0;
	ОчиститьРСНаСервере(Ном);
	Сообщить("Удалено наборов записей: "+Ном);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если СформироватьПриОткрытии Тогда
	   ПоказатьЦеныНаСервере();
   КонецЕсли;
   
КонецПроцедуры

