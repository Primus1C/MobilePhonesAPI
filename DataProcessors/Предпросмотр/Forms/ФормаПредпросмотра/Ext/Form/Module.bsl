КонецФункции


&НаСервере
Функция ОткрытиеPDF(ПутьКВременномуФайлу)
	
	Элементы.HTML.Видимость = Истина;
	Элементы.АдресКартинки.Видимость = Ложь;

	HTML = СтрЗаменить(Обработки.Предпросмотр.ПолучитьМакет("Предпросмотр_Макет").ПолучитьТекст(), "<TextScript111>", Обработки.Предпросмотр.ПолучитьМакет("Предпросмотр_СкриптБиблиотека").ПолучитьТекст());
  
  	HTML = СтрЗаменить(HTML,"<TextScript112>", Обработки.Предпросмотр.ПолучитьМакет("Предпросмотр_СкриптWorker").ПолучитьТекст());
	  
	HTML = СтрЗаменить(HTML, "<url1S>","file:///" + СтрЗаменить(ПутьКВременномуФайлу, "\", "//"));
	
	Возврат HTML;

КонецФункции

&НаСервере
Процедура ОткрытиеКартинки(ПутьКВременномуФайлу)
	
	Элементы.HTML.Видимость = Ложь;
	Элементы.АдресКартинки.Видимость  = Истина;
	АдресДанные = Новый ДвоичныеДанные(ПутьКВременномуФайлу);
	АдресКартинки = ПоместитьВоВременноеХранилище(АдресДанные, УникальныйИдентификатор);

КонецПроцедуры

