#Область СобытияФормы      

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента);  
	
	ЭтоСтараяСерия = Истина;
	
	// Создаем новый элемент отбора для нашего динамического списка
    ЭлементОтбора = ВыполненныеЗамены.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    // Указываем поле регистра, по которому фильтруем
    ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Регистратор");
    // Устанавливаем вид сравнения "Равно"
    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
    // Передаем ссылку на текущий документ. 
    // Если документ новый и еще не записан, ссылка будет пустой, и список логично будет пустым.
    ЭлементОтбора.ПравоеЗначение = Объект.Ссылка;
    // Включаем отбор
    ЭлементОтбора.Использование = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);

	РаботаСоСканеромШК.СканерШКПодключить(); 
	
	УстановитьВидимость();
    УстановитьИнфо();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)

	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
    УстановитьИнфо();
	
КонецПроцедуры

#КонецОбласти    


#Область РеквизитыФормы
	
&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии") Тогда
		ЭтоСтараяСерия = Истина;
	КонецЕсли;
	
	УстановитьВидимость();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()
	
	Режим = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии");
	Элементы.ТоварыНоменклатураНовая.Видимость = Режим;
	Элементы.ТоварыСерияНовая.Видимость = НЕ Режим;
	Элементы.ЭтоСтараяСерия.Видимость = НЕ Режим;
	Элементы.ТоварыСерия.Заголовок = ?(Режим, "Серия", "Старая серия");
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура УстановитьИнфо()
	
	Если Объект.ЗаменаПроведена Тогда
		// !
		Если НЕ омСервер.ЕстьРоль("Разработка") Тогда
			ТолькоПросмотр = Истина;    
		КонецЕсли;
		// !
		Элементы.ДекорацияИнфо.Заголовок = НСтр("ru = 'Замена проведена. Документ заблокирован'; en = 'Замена проведена. Документ заблокирован'");
		Элементы.ДекорацияИнфо.ЦветТекста = WebЦвета.Красный;
	Иначе
		Элементы.ДекорацияИнфо.Заголовок = НСтр("ru = 'После проведения документ нельзя будет сделать непроведенным, или пометить на удаление'; en = 'После проведения документ нельзя будет сделать непроведенным, или пометить на удаление'");
		Элементы.ДекорацияИнфо.ЦветТекста = WebЦвета.ЗеленыйЛес;
	КонецЕсли;
	
КонецПроцедуры


