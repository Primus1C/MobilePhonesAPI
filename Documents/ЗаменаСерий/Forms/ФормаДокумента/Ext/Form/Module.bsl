&НаКлиенте
Процедура РучнойШКПриИзменении(Элемент)

	ЛюбаяСерия(РучнойШК, Истина, Элементы.Товары.ТекущаяСтрока);

КонецПроцедуры  

&НаКлиенте
Процедура ЛюбаяСерия(НовСер, СтатьНаРучной = Ложь, СтрокаФормы = Неопределено)

	ШК = СокрЛП(НовСер);
	Если ШК = "" Тогда Возврат КонецЕсли; 

	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии") Тогда
		
		СтрокаТЧ = Объект.Товары.Добавить(); 
		СтрокаТЧ.Партия 		= ПартияПоСерии(ШК);
		СтрокаТЧ.Серия 			= ШК;  
		СтрокаТЧ.Номенклатура 	= гоРеквизит(СтрокаТЧ.Партия, "Владелец");    
		
	ИначеЕсли ЭтоСтараяСерия Тогда   
		
		СписокПартий = омСервер.ПартииПоСерииОстатки(ШК, , ); 
		КвоПартий = СписокПартий.Количество();
	
		Если КвоПартий = 0 Тогда
			Сигнал();
			клОшибка(СтрШаблон("%1: %2 %3", 
								омСервер.Фрмт(НСтр("ru = 'Нет остатков по серии'; en = 'There are no remaining goods for the series!'"), "НАДПИСЬ_ЦВ1"), 
								омСервер.Фрмт(ШК, "НАДПИСЬ_ЦВ2"),
								омСервер.Фрмт("!", "НАДПИСЬ_ЦВ1")));
			Возврат;
		ИначеЕсли КвоПартий > 1 Тогда
			Сигнал();
			Эле = СписокПартий.ВыбратьЭлемент(НСтр("ru = 'Найдено несколько партий с такой серией, выберите:'; en = 'Several batches with this series have been found, please select:'"));
			Если Эле = Неопределено Тогда Возврат КонецЕсли;
			Партия = Эле.Значение;
		Иначе
			Партия = СписокПартий[0].Значение;   
		КонецЕсли; 
		Если ЕстьДубли(ШК) Тогда
			Сообщить(НСтр("ru = 'Серия уже есть в документе!'; en = 'The series is already in the document!'"));
			Возврат;
		КонецЕсли;
		
		СтрокаТЧ = Объект.Товары.Добавить(); 
		СтрокаТЧ.Партия 		= Партия;
		СтрокаТЧ.Серия 			= ШК;  
		СтрокаТЧ.Номенклатура 	= гоРеквизит(Партия, "Владелец");    
		
	Иначе
		
		СтрокаТЧ = Элементы.Товары.ТекущаяСтрока;
		Если СтрокаТЧ = Неопределено Тогда
			Сообщить(НСтр("ru = 'Не выбрана строка табличной части!'; en = 'No table section row selected!'"));		
		//ИначеЕсли КвоПартий > 1 Тогда
		//	Сигнал();
		//	Эле = СписокПартий.ВыбратьЭлемент(НСтр("ru = 'Найдено несколько партий с такой серией, выберите:'; en = 'Several batches with this series have been found, please select:'"));
		//	Если Эле = Неопределено Тогда Возврат КонецЕсли;
		//	Партия = Эле.Значение;
		//Иначе      
		//	Партия = СписокПартий[0].Значение;   
		КонецЕсли;
		//СтрокаТЧ.Партия = Партия;  
		Если ЕстьДубли(ШК) Тогда
			Сообщить(НСтр("ru = 'Серия уже есть в документе!'; en = 'The series is already in the document!'"));
			Возврат;
		КонецЕсли;

		Элементы.Товары.ТекущиеДанные.СерияНовая = ШК;  

	КонецЕсли; 
	
	//Если СтатьНаРучной Тогда 
	//	РучнойШК = "";
	//	ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
	//КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
Процедура МоеОжидание()
	
	ЭтаФорма.ТекущийЭлемент = Элементы.РучнойШК;

КонецПроцедуры

&НаКлиенте
Функция ЕстьДубли(ШК)
	
	Если ЭтоСтараяСерия Тогда
		Имя = "Серия";
	Иначе
		Имя = "СерияНовая";
	КонецЕсли;
	НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура(Имя, ШК));
	Возврат НайдСтроки.Количество() > 0;
	
КонецФункции // ЕстьДубли()

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Объект.Проведен Тогда 
		Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
			клОшибка(НСтр("ru = 'Документ уже проведен! Вы можете только создать следующий, чтобы записать обратную замену'; en = 'The document is already posted!'"));
		ИначеЕсли ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			клОшибка(НСтр("ru = 'Документ уже проведен!'; en = 'The document is already posted!'"));
		КонецЕсли;
		Отказ = Истина;
	ИначеЕсли ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Если Вопрос("Вы действительно хотите провести документ? 
					|Отменить действие будет невозможно!", РежимДиалогаВопрос.ДаНет, , , "Будьте бдительны") <> КодВозвратаДиалога.Да Тогда
			Отказ = Истина;	
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполненныеЗаменыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	Если Поле.Имя = "ВыполненныеЗаменыОбъектЗамены" Тогда
		СтандартнаяОбработка = Ложь;
        ОткрытьЗначение(Элемент.ТекущиеДанные.ОбъектЗамены);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСерияПриИзменении(Элемент)
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацииЗаменаСерий.ЗаменаНоменклатурыВОднойСерии") Тогда
		СтрокаТЧ = Элементы.Товары.ТекущаяСтрока;
	    СтрокаТЧ.Партия = ПартияПоСерии(СтрокаТЧ.Серия);
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПартияПоСерии(Серия)

	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Партии.Ссылка КАК Ссылка
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Серия = &Серия
	             |
	             |ОБЪЕДИНИТЬ
	             |
	             |ВЫБРАТЬ
	             |	Партии.Ссылка
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Серия = &Серия";
	Запр.УстановитьПараметр("Серия", Серия);
    Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
	    Возврат Выборка.Ссылка;
	Иначе	
	     Возврат Справочники.Партии.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции // ()

#КонецОбласти
