&НаКлиенте
Процедура ТоварыПриАктивизацииСтроки(Элемент)
	
	// 1. Отключаем предыдущий вызов, чтобы они не накапливались при быстром скроллинге
    ОтключитьОбработчикОжидания("ОбновитьИнфоСтрокуАсинхронно");
    
    // 2. Подключаем обработчик однократно с задержкой 0.2 секунды
    ПодключитьОбработчикОжидания("ОбновитьИнфоСтрокуАсинхронно", 0.2, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнфоСтрокуАсинхронно()
    
    ТекДанные = Элементы.Товары.ТекущиеДанные;
    
    Если ТекДанные = Неопределено Тогда 
        Элементы.ДекорацияИнфоСтроки.Заголовок = "";
        Возврат;
    КонецЕсли;
    
    Ит = 0;
    НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", ТекДанные.Номенклатура));
    Для каждого НайдСтрока Из НайдСтроки Цикл
        Ит = Ит + НайдСтрока.Количество;
    КонецЦикла;
    
    Если Ит > 0 Тогда
        Стр = СтрШаблон("%1: %2", 
                        НСтр("ru = 'Количество товара текущей строки'; en = 'Quantity of the current line good'"),
                        омСервер.Фрмт(Ит, "ЧИСЛОЦЕЛ_ЦВ1"));
                        
        Элементы.ДекорацияИнфоСтроки.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(Стр));                
    Иначе
        Элементы.ДекорацияИнфоСтроки.Заголовок = "";
    КонецЕсли;    
    
КонецПроцедуры  

&НаКлиенте
Процедура ТоварыПартияПриИзменении(Элемент)
	
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	ТекДанные.Серия 				= гоРеквизит(ТекДанные.Партия, "Серия");
	ТекДанные.ЦенаЗакупки			= гоРеквизит(ТекДанные.Партия, "ЦенаЗакупкиВБазВалюте");
	ТекДанные.ЦенаЗакупкиСЗатратами	= ТекДанные.ЦенаЗакупки + ЗатратыПартии(ТекДанные.Партия); 
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыЦенаКомитентаПриИзменении(Элемент)

	ТекДанные = Элементы.Товары.ТекущиеДанные;
    ТекДанные.Сумма = ТекДанные.ЦенаКомитента * ТекДанные.Количество;
	
	Если ТекДанные.ЦенаКомитента > 0 Тогда
		НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", ТекДанные.Номенклатура));
		Если НайдСтроки.Количество() > 0 Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПодтвержденияЦены", ЭтаФорма, 
															Новый Структура("Цена,СтрокиТЧ", ТекДанные.ЦенаКомитента, НайдСтроки));
			ПоказатьВопрос(ОписаниеОповещения, "Установить эту цену для всех таких же товаров?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПодтвержденияЦены(Результат, Параметры) Экспорт  
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Для каждого СтрокаТЧ Из Параметры.СтрокиТЧ Цикл
			СтрокаТЧ.ЦенаКомитента = Параметры.Цена;
			СтрокаТЧ.Сумма = СтрокаТЧ.ЦенаКомитента * СтрокаТЧ.Количество;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ТоварыСуммаПриИзменении(Элемент)

	ТекДанные = Элементы.Товары.ТекущиеДанные;
	Если ТекДанные.Количество = 0 Тогда
	 	ТекДанные.Количество = 1;
	КонецЕсли;	
	ТекДанные.ЦенаКомитента = ТекДанные.Сумма / ТекДанные.Количество;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)

	ТекДанные = Элементы.Товары.ТекущиеДанные;
    ТекДанные.Сумма = ТекДанные.ЦенаКомитента * ТекДанные.Количество;
	
КонецПроцедуры

&НаСервере
Функция ЗатратыПартии(Партия)
	
	СтруктураЗатрат = ПроведениеДокументов.ЗатратыПартий(Партия);
	ЗатратыПартии = СтруктураЗатрат.ЗатратыПартии + СтруктураЗатрат.ЗатратыПартииИнвойсов;
	Возврат ЗатратыПартии;	
	
КонецФункции // ЗатратыПартии()

#КонецОбласти  


#Область ПодключаемаяПечать
	
&НаКлиенте
Процедура ВыполнитьПодключеннуюПечать(Команда)
	
	ВариантПечатнойФормы = СтрЗаменить(Команда.Имя, "ПодключеннаяПечать_", "");   
	ТабДок = ПечатнаяФорма(ВариантПечатнойФормы);
	ПараметрыПечати = Новый Структура("Таб, Имя, НеДляПечати", ТабДок, гоИмя(Объект.Ссылка, Ложь), Ложь);
	ОткрытьФорму("ОбщаяФорма.ПечатьБезЗащиты", ПараметрыПечати, , Истина); 
		
КонецПроцедуры  

&НаСервере
Функция ПечатнаяФорма(ВариантПечатнойФормы)

	ТабДок = Новый ТабличныйДокумент;
	Документы.ПередачаНаКомиссию.ПечатьДокумента(Объект.Ссылка, ВариантПечатнойФормы, ТабДок);
	Возврат ТабДок;
	
КонецФункции 

#КонецОбласти

