&НаКлиенте
Процедура ПослеВводаНаценки(Число, Параметры) Экспорт
	
	Если Число <> Неопределено Тогда
		Для каждого СтрокаТЧ Из Товары Цикл
			Для каждого Префикс Из КэшДанных.ПрефиксыВидовЦен Цикл 
				Преф = Префикс.Значение;
				СтрокаТЧ[Преф + "_Цена0"] = СтрокаТЧ[Преф + "_ЦенаСтар"] * Число / 100;
			КонецЦикла;
		КонецЦикла;
    КонецЕсли;

КонецПроцедуры
 
&НаКлиенте
Процедура ПоВсемСкладамПриИзменении(Элемент) 
	
	ОбновитьОтображениеЭлементов();   
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображениеЭлементов()

	Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.ТоварыПродаватьВсе.Пометка = ПродаватьВсе;
	УстановитьИндикаторКоманды("ПродаватьВсе", ПродаватьВсе);
	Элементы.СкладыСтрокой.Видимость = НЕ ПоВсемСкладам;
	Если Склады.Количество() = 0 Тогда
		СкладыСтрокой = НСтр("ru = '<не выбраны>'; en = '<not selected>'")	
	Иначе 
		Загл = "";
		Для каждого Эл Из Склады Цикл
		 	Загл = Загл + Эл.Значение + ", ";
		КонецЦикла;
		СкладыСтрокой = Загл;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СкладыСтрокойНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Оповещение = Новый ОписаниеОповещения("ПослеОтметкиЭлементов", ЭтотОбъект);
	СладыДляВыбора = СладыДляВыбора(Склады);
	СладыДляВыбора.ПоказатьОтметкуЭлементов(Оповещение, НСтр("ru = 'Остатки на складах'; en = 'Warehouse balances'"));

КонецПроцедуры

  
&НаСервереБезКонтекста
Функция СладыДляВыбора(СписокПомеченных)
	
	Спис = Новый СписокЗначений;
	Запр = новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             |	Склады.Ссылка КАК Ссылка,
	             |	ИСТИНА КАК Пометка
	             |ИЗ
	             |	Справочник.Склады КАК Склады
	             |ГДЕ
	             |	НЕ Склады.ПометкаУдаления
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Склады.Наименование";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	 	Спис.Добавить(Выборка.Ссылка, , СписокПомеченных.НайтиПоЗначению(Выборка.Ссылка) <> Неопределено);
	КонецЦикла;
	Возврат Спис;
	
КонецФункции // СладыДляВыбора()


&НаКлиенте
Процедура ПослеОтметкиЭлементов(Список, Параметры) Экспорт
	
	Если Список <> Неопределено Тогда  
		Склады.Очистить();
        Для каждого Элемент из Список Цикл
            Если Элемент.Пометка Тогда
				Склады.Добавить(Элемент.Значение); 
            КонецЕсли;
        КонецЦикла;
	КонецЕсли; 
	ОбновитьОтображениеЭлементов();

КонецПроцедуры


