#Область ДействияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПоказыватьСпецификацию		= Истина;
	ПоказыватьДействующуюЦену	= Истина;
	ПоказыватьИзменениеЦен		= Ложь;
	ПоказыватьЦенуЗакупки		= Истина;        
	
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 

	ГруппаПодменю	 			= Элементы.Товары.КоманднаяПанель.ПодчиненныеЭлементы.ТоварыПодменюЗаполнить;
	
	// Сгенерим префиксы ВидовЦен; Заполним и  проптичим СписокВыбранныеВидыЦен; добавим колонки ТЗ Товары 
	
	ПрефиксыВидовЦен = Новый Соответствие;
	
	Выборка = Справочники.ВидыЦен.Выбрать();
	Пока Выборка.Следующий() Цикл
		
	    ИмяПредопределенныхДанных = Выборка.Ссылка.ИмяПредопределенныхДанных;
		Если ЗначениеЗаполнено(ИмяПредопределенныхДанных) Тогда 
			Префикс = ИмяПредопределенныхДанных;
		Иначе
			Префикс = СтрЗаменить(Выборка.Наименование, " ", "");
		КонецЕсли; 
		ПрефиксыВидовЦен.Вставить(Выборка.Ссылка, Префикс);
		ДобавитьРеквизитыИЭлементыТабличнойЧастиПоВидуЦен(Выборка.Ссылка, Префикс);
		
		Если НЕ Выборка.ПометкаУдаления Тогда 
			Пометка = Объект.ВидыЦен.Выгрузить().ВыгрузитьКолонку("ВидЦены").Найти(Выборка.Ссылка) <> Неопределено;
			СписокВыбранныеВидыЦен.Добавить(Выборка.Ссылка, , Пометка); 
		КонецЕсли;
		
	КонецЦикла;
	
	КэшДанных = Новый Структура("ЗначенияПодбора,ПрефиксыВидовЦен", Новый Соответствие(), ПрефиксыВидовЦен);

	// создадим меню заполнения по группам подбора номенклатуры 
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	Номенклатура.ГруппаПодбора
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	НЕ Номенклатура.ГруппаПодбора ЕСТЬ NULL
	             |	И Номенклатура.ГруппаПодбора <> ЗНАЧЕНИЕ(Справочник.ГруппыПодбораНоменклатуры.ПустаяСсылка)";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Истина Тогда 
			
			Представление = СтрокаБуквами(Выборка.ГруппаПодбора);
			ЭлементПодменю = ЭтаФорма.Элементы.Добавить("Подменю_" + Представление, Тип("ГруппаФормы"), 
														ГруппаПодменю.ПодчиненныеЭлементы.ПодменюЗаполнитьПоТоварнойГруппе);
			ЭлементПодменю.Вид = ВидГруппыФормы.Подменю;   
			ЭлементПодменю.Заголовок = Выборка.ГруппаПодбора;
			запрВлож = Новый Запрос;  
			запрВлож.УстановитьПараметр("Ссылка", Выборка.ГруппаПодбора);
			запрВлож.Текст = "ВЫБРАТЬ
			             |	Номенклатура.Ссылка КАК Ссылка
			             |ИЗ
			             |	Справочник.Номенклатура КАК Номенклатура
			             |ГДЕ
			             |	Номенклатура.ЭтоГруппа
			             |	И НЕ Номенклатура.ПометкаУдаления
			             |	И Номенклатура.ГруппаПодбора В ИЕРАРХИИ(&Ссылка)";   
			ВыборкаВлож = запрВлож.Выполнить().Выбрать();
			Пока ВыборкаВлож.Следующий() Цикл 
				ПредставлениеВлож = СтрокаБуквами(ВыборкаВлож.Ссылка);
				Кмд = ЭтаФорма.Команды.Добавить("Команда_" + ПредставлениеВлож);
				Кмд.Действие = "НажатиеКнопкиПодбораМеню";
				Кмд.Заголовок = ВыборкаВлож.Ссылка;
				Элемент = ЭтаФорма.Элементы.Добавить("Кнопка_" + ПредставлениеВлож, Тип("КнопкаФормы"), ЭлементПодменю);
				Элемент.Вид 		= ВидКнопкиФормы.КнопкаКоманднойПанели;
				Элемент.ИмяКоманды 	= "Команда_" + ПредставлениеВлож;
				КэшДанных.ЗначенияПодбора.Вставить(Элемент.ИмяКоманды, ВыборкаВлож.Ссылка); 
			КонецЦикла;
			
		Иначе
			
			Представление = СтрокаБуквами(Выборка.ГруппаПодбора);
			Кмд = ЭтаФорма.Команды.Добавить("Команда_" + Представление);
			Кмд.Действие = "НажатиеКнопкиГруппыПодбора";
			Кмд.Заголовок = Выборка.ГруппаПодбора;

			Элемент = ЭтаФорма.Элементы.Добавить("Кнопка_"+Представление, Тип("КнопкаФормы"), ГруппаПодменю);
			Элемент.Вид 		= ВидКнопкиФормы.ОбычнаяКнопка;
			Элемент.ИмяКоманды 	= "Команда_" + Представление;
			Элемент.Картинка 	= БиблиотекаКартинок.ПерейтиНазад; 
			Элемент.Отображение = ОтображениеКнопки.КартинкаИТекст;
		
			запр = Новый Запрос;  
			запр.УстановитьПараметр("Ссылка", Выборка.ГруппаПодбора);
			запр.Текст = "ВЫБРАТЬ
			             |	Номенклатура.Ссылка КАК Ссылка
			             |ИЗ
			             |	Справочник.Номенклатура КАК Номенклатура
			             |ГДЕ
			             |	Номенклатура.ЭтоГруппа
			             |	И НЕ Номенклатура.ПометкаУдаления
			             |	И Номенклатура.ГруппаПодбора В ИЕРАРХИИ(&Ссылка)";
			МассивГрупп = Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
			КэшДанных.ГруппыПодбора.Вставить(Элемент.ИмяКоманды, Новый Структура("ГруппаПодбора, ГруппыНоменклатуры", Выборка.ГруппаПодбора, МассивГрупп));  
			
		КонецЕсли;
		
	КонецЦикла;

	// создадим меню заполнения по производителям              
	
	Запр2 = Новый Запрос;
	Запр2.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	Номенклатура.Производитель КАК Производитель
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	Номенклатура.Производитель <> ЗНАЧЕНИЕ(Справочник.Производители.ПустаяСсылка)
	             |	И НЕ Номенклатура.ПометкаУдаления";
	Выборка2 = запр2.Выполнить().Выбрать();
	Пока Выборка2.Следующий() Цикл 
		Представление2 = СтрокаБуквами(Выборка2.Производитель);
		Кмд = ЭтаФорма.Команды.Добавить("Команда2_" + Представление2);
		Кмд.Действие = "НажатиеКнопкиПодбораМеню";
		Кмд.Заголовок = Выборка2.Производитель;
		Элемент = ЭтаФорма.Элементы.Добавить("Кнопка2_" + Представление2, Тип("КнопкаФормы"), 
											ГруппаПодменю.ПодчиненныеЭлементы.ПодменюЗаполнитьПоБренду);
		Элемент.Вид 		= ВидКнопкиФормы.КнопкаКоманднойПанели;
		Элемент.ИмяКоманды 	= "Команда2_" + Представление2;
		КэшДанных.ЗначенияПодбора.Вставить(Элемент.ИмяКоманды, Выборка2.Производитель); 
	КонецЦикла;

	// заполним ТЗ на форме значениями ТЧ
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	УстановкаЦенТовары.Номенклатура КАК Номенклатура,
	             |	УстановкаЦенТовары.ВидЦены КАК ВидЦены,
	             |	УстановкаЦенТовары.Цена0 КАК Цена0,
	             |	УстановкаЦенТовары.Цена1 КАК Цена1,
	             |	УстановкаЦенТовары.Порог1 КАК Порог1,
	             |	УстановкаЦенТовары.Цена2 КАК Цена2,
	             |	УстановкаЦенТовары.Порог2 КАК Порог2,
	             |	УстановкаЦенТовары.Цена3 КАК Цена3,
	             |	УстановкаЦенТовары.Порог3 КАК Порог3,
	             |	УстановкаЦенТовары.РазрешитьПродажу КАК РазрешитьПродажу,
	             |	УстановкаЦенТовары.НомСтроки КАК НомСтроки
	             |ИЗ
	             |	Документ.УстановкаЦен.Товары КАК УстановкаЦенТовары
	             |ГДЕ
	             |	УстановкаЦенТовары.Ссылка = &Ссылка
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	УстановкаЦенТовары.НомСтроки"; 
	РезультатЗапроса = Запр.Выполнить();
	Выборка = РезультатЗапроса.Выбрать(); 
	Пока Выборка.Следующий() Цикл 
		Префикс = КэшДанных.ПрефиксыВидовЦен.Получить(Выборка.ВидЦены);       
		Если Товары.Количество() < Выборка.НомСтроки Тогда
			СтрокаТЗ = Товары.Добавить(); 
			СтрокаТЗ.Номенклатура = Выборка.Номенклатура;
		Иначе
		    СтрокаТЗ = Товары[Товары.Количество()-1];
		КонецЕсли;
		СтрокаТЗ[Префикс + "_Цена0"] = Выборка.Цена0;
		СтрокаТЗ[Префикс + "_Цена1"] = Выборка.Цена1;
		СтрокаТЗ[Префикс + "_Цена2"] = Выборка.Цена2;
		СтрокаТЗ[Префикс + "_Цена3"] = Выборка.Цена3;
		СтрокаТЗ[Префикс + "_Порог1"] = Выборка.Порог1;
		СтрокаТЗ[Префикс + "_Порог2"] = Выборка.Порог2;
		СтрокаТЗ[Префикс + "_Порог3"] = Выборка.Порог3;
		СтрокаТЗ["РазрешитьПродажу"] = Выборка.РазрешитьПродажу;
	КонецЦикла;
	
	
	ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);
	
	КоличествоПороговЦенПриИзменении(Неопределено);
	СписокТипыЦенПометкаПриИзменении(Неопределено);
	
	ОбновитьОтображениеЭлементов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	// проверка дублей строк     
	
	Ошибки = Новый Соответствие;
	Для каждого СтрокаТЧ Из Товары Цикл
		НайдСтроки = Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаТЧ.Номенклатура));
		Если НайдСтроки.ВГраница() > 0 Тогда  
			Стр = "";
			Для Инд = 0 По НайдСтроки.ВГраница() Цикл
				Стр = Стр + НайдСтроки[Инд].Номер + ", ";
			КонецЦикла;
			Ошибки.Вставить(СтрокаТЧ.Номенклатура, Стр);
		КонецЕсли;	
	КонецЦикла;
	Если Ошибки.Количество() > 0 Тогда
		ТекстОшибки = НСтр("ru = 'Найдены дубли в строках: '; en = 'Duplicates found in the lines: '") + Символы.ПС;
		Для каждого Ош Из Ошибки Цикл
			ТекстОшибки = СтрШаблон(НСтр("ru = '%1 %2 - строки %3%4'; en = '%1 %2 - lines %3%4'"), ТекстОшибки, Ош.Ключ, Ош.Значение, Символы.ПС);
		КонецЦикла;
		ТекстОшибки = Лев(ТекстОшибки, СтрДлина(ТекстОшибки)-3);	
		//Сообщить(ТекстОшибки);
		клОшибка(ТекстОшибки);
	КонецЕсли;
	
	// заполнение ТЧ ТипыЦен
	
	Объект.ВидыЦен.Очистить();
	Для каждого эл Из СписокВыбранныеВидыЦен Цикл
		Если эл.Пометка Тогда
		 	Объект.ВидыЦен.Добавить().ВидЦены = эл.Значение;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// перенесем данные из ТЗ формы в ТЧ док-та
	
	ТекущийОбъект.Товары.Очистить();
 	ТЗ = Товары.Выгрузить();
   	Для каждого СтрокаТЗ Из ТЗ Цикл
		Для каждого СтрокаВЦ Из Объект.ВидыЦен Цикл
			Префикс = КэшДанных.ПрефиксыВидовЦен.Получить(СтрокаВЦ.ВидЦены);
			НовСтрока = ТекущийОбъект.Товары.Добавить();
			НовСтрока.НомСтроки 		= СтрокаТЗ.Ном;
			НовСтрока.ВидЦены 			= СтрокаВЦ.ВидЦены; 
			НовСтрока.Номенклатура 		= СтрокаТЗ.Номенклатура;   
			НовСтрока.РазрешитьПродажу 	= СтрокаТЗ.РазрешитьПродажу;
			НовСтрока.Цена0	= СтрокаТЗ[Префикс+"_Цена0"];
			Если Объект.ПороговЦен > 0 Тогда
				НовСтрока.Цена1		= СтрокаТЗ[Префикс+"_Цена1"];
				НовСтрока.Порог1	= СтрокаТЗ[Префикс+"_Порог1"];   
			КонецЕсли;	
			Если Объект.ПороговЦен > 1 Тогда
				НовСтрока.Цена2		= СтрокаТЗ[Префикс+"_Цена2"];
				НовСтрока.Порог2	= СтрокаТЗ[Префикс+"_Порог2"];   
			КонецЕсли;	
			Если Объект.ПороговЦен > 2 Тогда
				НовСтрока.Цена3		= СтрокаТЗ[Префикс+"_Цена3"];
				НовСтрока.Порог3	= СтрокаТЗ[Префикс+"_Порог3"];   
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
 
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Номенклатура") Тогда
			ЗаполнитьТаблицуЗначенийТовары(ВыбранноеЗначение); 
		ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Пользователи") Тогда
		    Номенклатура = ОтобраннаяНоменклатура("Менеджер", ВыбранноеЗначение);
			//         
		ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Производители") Тогда
			ЗаполнитьТаблицуЗначенийТовары(ВыбранноеЗначение); 
		ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда 
			ЗаполнитьТаблицуЗначенийТовары(ВыбранноеЗначение); 
		Иначе
		
		КонецЕсли;
		Модифицированность = Истина;
	КонецЕсли;                               
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПересчетЦен" Тогда
		Если Параметр.Было <> 0 И Параметр.Стало <> 0 Тогда
			Для каждого СтрокаТЧ Из Товары Цикл 
				Для каждого ТипЦены Из КэшДанных.ТипыЦен Цикл
					Префикс = ТипЦены.Представление;
					СтрокаТЧ[Префикс + "_ЦенаНовая"] = СтрокаТЧ[Префикс + "_ЦенаНовая"] / Параметр.Было * Параметр.Стало;
					СтрокаТЧ[Префикс + "_ЦенаКНовая"] = СтрокаТЧ[Префикс + "_ЦенаКНовая"] / Параметр.Было * Параметр.Стало;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

