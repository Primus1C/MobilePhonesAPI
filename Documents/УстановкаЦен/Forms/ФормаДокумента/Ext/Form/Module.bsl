Процедура ПересчитатьСНаценкой(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ПослеВводаНаценки", ЭтотОбъект);
	ПоказатьВводЧисла(Оповещение, 1, НСтр("ru = 'Наценка, %'; en = 'Наценка, %'"), 5, 1);
	
