&НаСервере
Процедура ЗаполнитьПоОстаткамНаСервере()
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ОстаткиТовара.Номенклатура КАК Номенклатура,
	             |	ОстаткиТовара.ОстатокОстаток КАК Остаток
	             |ИЗ
	             |	РегистрНакопления.ОстаткиТовара.Остатки(&ДатаОстатков, Склад = &Склад) КАК ОстаткиТовара
	             |ГДЕ
	             |	НЕ ОстаткиТовара.Номенклатура.ЗапретОтгрузки
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Номенклатура";
	Запр.УстановитьПараметр("ДатаОстатков", Объект.Дата);
	Запр.УстановитьПараметр("Склад", Объект.Склад); 
    Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл  
		НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура",Выборка.Номенклатура));
		Если НайдСтроки.Количество() = 0 Тогда
			СтрокаТЗ = Товары.Добавить();
			СтрокаТЗ.Номенклатура = Выборка.Номенклатура;
		Иначе
			СтрокаТЗ = НайдСтроки[0];
		КонецЕсли;
		СтрокаТЗ.Остаток = Выборка.Остаток;
		СтрокаТЗ.Картинка = Выборка.Картинка;
	
	КонецЦикла;
	
	
КонецПроцедуры

