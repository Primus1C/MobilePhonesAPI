&НаСервере
Функция РеквизитДобавленРаннее(ИмяТабличнойЧасти, ПутьКРеквизитуИИмяЭлемента)
	
	МассивРеквизитов = ПолучитьРеквизиты(ИмяТабличнойЧасти);
	Для каждого РеквизитФормы Из МассивРеквизитов Цикл
		
		Если РеквизитФормы.Имя = ПутьКРеквизитуИИмяЭлемента Тогда
			
			Возврат Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Процедура ДобавитьРеквизитыИЭлементыТабличнойЧастиПоВидуЦен(ВыбранныйВидЦен, ПрефиксРеквизитов)
	
	КонстПорог = 3;
	ПутьРеквизита = "Товары";
	ШиринаКолонки = 11;
	
	// ::: СОЗДАНИЕ РЕКВИЗИТОВ
	//ПрефиксРеквизитов = КэшДанных.ПрефиксыВидовЦен.Получить(ВыбранныйВидЦен);

	МассивРеквизитов 	= Новый Массив;

	ТипЧислоЦелое 		= Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(6, 0, ДопустимыйЗнак.Неотрицательный));
	ТипЧислоПлюс 		= Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Неотрицательный));
	ТипЧислоЛюбое 		= Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой));
	ТипСтрока			= Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(20));
	ТипБулево			= Новый ОписаниеТипов("Булево");
	
	// Цена старая (относительно Цены0)
	
	РеквизитЦенаСтар	= Новый РеквизитФормы(ПрефиксРеквизитов + "_ЦенаСтар",		ТипЧислоПлюс,	ПутьРеквизита, НСтр("ru = 'Цена старая'; en = 'Price before'"));
	РеквизитДельта		= Новый РеквизитФормы(ПрефиксРеквизитов + "_Дельта",		ТипЧислоЛюбое,	ПутьРеквизита, "Δ");
		
		МассивРеквизитов.Добавить(РеквизитЦенаСтар);
		МассивРеквизитов.Добавить(РеквизитДельта);
		
	// Цена0
	
	РеквизитЦена		= Новый РеквизитФормы(ПрефиксРеквизитов + "_Цена0",			ТипЧислоПлюс,	ПутьРеквизита, НСтр("ru = 'Цена новая'; en = 'Price new'"));
	РеквизитЦенуИзменили= Новый РеквизитФормы(ПрефиксРеквизитов + "_ЦенуИзменили0",	ТипБулево,		ПутьРеквизита, НСтр("ru = 'Служебный'; en = 'Служебный'"));

	МассивРеквизитов.Добавить(РеквизитЦена);
	МассивРеквизитов.Добавить(РеквизитЦенуИзменили);
		
