&НаКлиенте
Процедура Подбор(Команда) 
	
	Номенклатура = Новый СписокЗначений;
	Для каждого СтрокаТЗ Из Товары Цикл
		Номенклатура.Добавить(СтрокаТЗ.Номенклатура);	
	КонецЦикла;

	///Создаем структуру с отбором и добавляем значения
	ПараметрыОтбора = Новый Структура;
	//ПараметрыОтбора.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийРеализацияТоваров.Товары"));
	//ПараметрыОтбора.Вставить("Дата", ТекущаяДата());   ///Дополнительный отбор
 
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", ПараметрыОтбора); ///Добавляем отбор в параметры формы

	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыФормы.Вставить("ВыбраннаяНоменклатура", Номенклатура);

	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма,"Подбор");

	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыФормы, ЭтаФорма, , , , ОбработкаВыбора); 
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьНезаполненные(Команда)
	
	Ном = Товары.Количество() - 1;
	Пока Ном >= 0 Цикл     
		ЕстьДанные = Ложь;
		Для каждого ТипЦены Из КэшДанных.ТипыЦен Цикл
			Префикс = ТипЦены.Представление;
			СтрокаТЗ = Товары[Ном];
			Если СтрокаТЗ[Префикс + "_ЦенаНовая"] > 0 ИЛИ СтрокаТЗ[Префикс + "_ЦенаКНовая"] > 0 ИЛИ СтрокаТЗ[Префикс + "_Количество"] > 0 Тогда
				ЕстьДанные = Истина;
			КонецЕсли;	
		КонецЦикла; 	
		Если НЕ ЕстьДанные Тогда
			Товары.Удалить(Ном); 
			Модифицированность = Истина;
		КонецЕсли;
		Ном = Ном - 1;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)  
	
	Номенклатура = Новый Массив;
	Для каждого СтрокаТЗ Из Товары Цикл
		Номенклатура.Добавить(СтрокаТЗ.Номенклатура);	
	КонецЦикла;
	ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(Номенклатура); 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТЧСВопросом(РежимЗаполнения)

	Если Товары.Количество() = 0 Тогда 
		Если РежимЗаполнения = "ЗаполнитьПоОстаткам" Тогда
			ОткрытьФорму("Справочник.Номенклатура.ФормаВыбораГруппы",,ЭтаФорма);
		ИначеЕсли РежимЗаполнения = "ЗаполнитьПоГруппеТоваров" Тогда
			ЗаполнитьПоОстаткамНаСервере(); 
		ИначеЕсли РежимЗаполнения = "ЗаполнитьПоБренду" Тогда
			
		КонецЕсли;	
	Иначе	
		Режим = РежимДиалогаВопрос.ДаНет; 
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОчистки", ЭтотОбъект, Новый Структура("РежимЗаполнения", РежимЗаполнения));
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Табличная часть не пуста! Очистить?'; en = 'The table part is not empty! Clear?'"), Режим, 0);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаОчистки(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
        Товары.Очистить();
	КонецЕсли;
	
	Если Параметры.РежимЗаполнения = "ЗаполнитьПоОстаткам" Тогда
		ЗаполнитьПоОстаткамНаСервере(); 
	ИначеЕсли Параметры.РежимЗаполнения = "ЗаполнитьПоГруппеТоваров" Тогда
		ОткрытьФорму("Справочник.Номенклатура.ФормаВыбораГруппы",,ЭтаФорма);
	ИначеЕсли Параметры.РежимЗаполнения = "ЗаполнитьПоБренду" Тогда
		
	КонецЕсли;	

КонецПроцедуры 

#КонецОбласти    


&НаСервере 
// В таб.части заполняет колонки: Картинка, Остаток, Закупка, ЦеныДо
//
Процедура ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(Номенклатура = Неопределено)
	
	Если Номенклатура = Неопределено Тогда
	    масНоменклатура = Товары.Выгрузить(,"Номенклатура").ВыгрузитьКолонку(0);
	Иначе	
		масНоменклатура = Номенклатура;
	КонецЕсли;
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Номенклатура", масНоменклатура);
	Запр.УстановитьПараметр("ДатаОстатков", Объект.Дата);   
	Запр.Текст = "ВЫБРАТЬ
	             |	СпрНоменклатура.Ссылка КАК Номенклатура,
	             |	ЗначенияСвойств.ЗначениеСвойства.Наименование КАК Картинка,
	             |	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток,
	             |	ЦеныПродажи.ВидЦены КАК ВидЦены,
	             |	ЦеныПродажи.Цена0 КАК Цена0,
	             |	ЦеныЗакупки.Цена КАК ЦенаЗакупки,
	             |	ЦеныЗакупки.Валюта КАК ВалютаЗакупки
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Номенклатура.Ссылка КАК Ссылка
	             |	ИЗ
	             |		Справочник.Номенклатура КАК Номенклатура
	             |	ГДЕ
	             |		Номенклатура.Ссылка В(&Номенклатура)) КАК СпрНоменклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ЗначенияСвойствОбъектов.Объект КАК Объект,
	             |			ЗначенияСвойствОбъектов.ЗначениеСвойства КАК ЗначениеСвойства
	             |		ИЗ
	             |			РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	             |		ГДЕ
	             |			ЗначенияСвойствОбъектов.ЗначениеСвойства.Владелец.Наименование = ""Спецификация"") КАК ЗначенияСвойств
	             |		ПО СпрНоменклатура.Ссылка = ЗначенияСвойств.Объект
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(&ДатаОстатков, Номенклатура В (&Номенклатура)) КАК ОстаткиТовараОстатки
	             |		ПО СпрНоменклатура.Ссылка = ОстаткиТовараОстатки.Номенклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныПродажи.СрезПоследних(&ДатаОстатков, Номенклатура В (&Номенклатура)) КАК ЦеныПродажи
	             |		ПО СпрНоменклатура.Ссылка = ЦеныПродажи.Номенклатура
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныЗакупки.СрезПоследних КАК ЦеныЗакупки
	             |		ПО СпрНоменклатура.Ссылка = ЦеныЗакупки.Номенклатура";
	ОбщегоНазначения.ДополнитьТекстЗапросаСпецификациями(Запр.Текст, "ЗначенияСвойств.ЗначениеСвойства.Наименование");
	Выгрузка = Запр.Выполнить().Выгрузить();
	
	Для Каждого СтрокаДанных ИЗ Выгрузка Цикл
		СтрокаТЗ = Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаДанных.Номенклатура))[0];
		СтрокаТЗ.Картинка 					= СтрокаДанных.Картинка; 
		СтрокаТЗ.Остаток 					= СтрокаДанных.Остаток; 
		СтрокаТЗ.Закупка 					= СтрШаблон("%1 %2", Формат(СтрокаДанных.ЦенаЗакупки, "ЧДЦ=2"), СтрокаДанных.ВалютаЗакупки); 
		//Если СтрокаДанных.ВидЦены <> Null Тогда
		//	Префикс = КэшДанных.ПрефиксыВидовЦен.Получить(СтрокаДанных.ВидЦены);
		//	СтрокаТЗ[Префикс + "_ЦенаДо"] = СтрокаДанных.Цена;
		//	СтрокаТЗ[Префикс + "_ЦенаКДо"] = СтрШаблон("%1 %2 %3", Формат(СтрокаДанных.ЦенаОтКоличества, "ЧДЦ=2"), НСтр("ru = 'от'; en = 'from'"), СтрокаДанных.Количество);
		//КонецЕсли;
	КонецЦикла;  	
	
	Ном = 0;
	Для каждого СтрокаТЗ Из Товары Цикл
		Ном = Ном + 1;
		СтрокаТЗ.Ном = Ном;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуЗначенийТовары(ЗначениеОтбора)

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("МассивНоменклатуры", ЗначениеОтбора); 
	Запр.УстановитьПараметр("Исключения", Товары.Выгрузить(,"Номенклатура").ВыгрузитьКолонку(0)); 
	Запр.Текст = "ВЫБРАТЬ
	             |	Номенклатура.Ссылка КАК Номенклатура
	             |ИЗ
	             |	Справочник.Номенклатура КАК Номенклатура
	             |ГДЕ
	             |	Номенклатура.Ссылка В(&МассивНоменклатуры)
	             |	И НЕ Номенклатура.Ссылка В (&Исключения)
				 |	И НЕ Номенклатура.ЭтоГруппа
				 |	И НЕ Номенклатура.ПометкаУдаления";  
	Если ТипЗнч(ЗначениеОтбора) = Тип("СправочникСсылка.Номенклатура") Тогда
		Если ЗначениеОтбора.ЭтоГруппа Тогда
			Запр.Текст = СтрЗаменить(Запр.Текст, 
									"В(&МассивНоменклатуры)", 
									"В ИЕРАРХИИ(&МассивНоменклатуры)");	
		КонецЕсли; 
	ИначеЕсли ТипЗнч(ЗначениеОтбора) = Тип("СправочникСсылка.ГруппыПодбораНоменклатуры") Тогда
		Запр.Текст = СтрЗаменить(Запр.Текст, 
									"Номенклатура.Ссылка В(&МассивНоменклатуры)", 
									"Номенклатура.ГруппаПодбора В ИЕРАРХИИ(&МассивНоменклатуры)");	   
	ИначеЕсли ТипЗнч(ЗначениеОтбора) = Тип("СправочникСсылка.Производители") Тогда
		Запр.Текст = СтрЗаменить(Запр.Текст, 
									"Номенклатура.Ссылка В(&МассивНоменклатуры)", 
									"Номенклатура.Производитель = &МассивНоменклатуры");	   
	КонецЕсли;  
	РезультатЗапроса = Запр.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НовСтрока = Товары.Добавить();
		НовСтрока.Номенклатура 	= Выборка.Номенклатура; 
		НовСтрока.Ном 			= Товары.Количество();
	КонецЦикла;
	ЗаполнитьТЗИсторическимиДаннымиНоменклатуры(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Номенклатура"));

КонецПроцедуры


&НаКлиенте
