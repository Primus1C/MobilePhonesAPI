&НаКлиенте
Процедура МоеДобавление()
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда Возврат КонецЕсли;
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если гоПЗ(Объект.Валюта) Тогда клОшибка("Не задана валюта!"); Возврат; КонецЕсли; 
	
	Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли; 
	
	Попытка
		НовНом = Элементы.Товары.ТекущиеДанные.Номенклатура;
	Исключение 
		НовНом = гоПустой("Номенклатура");
	КонецПопытки;
	
	КонстантаНеВыходить = 1;	//пока все без настроек
	
	НеВыходить = Истина;
	Пока НеВыходить Цикл
		Если НЕ ВвестиЗначение(НовНом, "Выберите номенклатуру") Тогда Возврат КонецЕсли; 
		
		Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
		Если НЕ (Нашли.Количество() = 0) Тогда клОшибка(гоИмя(НовНом) + ": уже есть в документе!" + гоРС() + "Нужно просто отредактировать количество!!!"); Возврат; КонецЕсли;
		
		НовЦен = 0;
			 
		Пар = Новый Структура;
		Пар.Вставить("Фирма", Объект.Фирма);
		Пар.Вставить("Номенклатура", НовНом);
		Пар.Вставить("Валюта", Объект.Валюта);
		Пар.Вставить("Поставщик", Объект.Контрагент);
		Пар.Вставить("Количество", 0);
		Пар.Вставить("Цена", НовЦен);
		
		НовПар = ОткрытьФормуМодально("ОбщаяФорма.ВводСтрокиЗТ", Пар);
		Если гоПЗ(НовПар) Тогда Продолжить КонецЕсли; 
		
		НовЦен = НовПар.Цена;
		НовКол = НовПар.Количество;
		Если НовКол = 0 Тогда клОшибка("Не введено количество!"); Продолжить; КонецЕсли;
		
		Если НЕ клСохранитьИзменения() Тогда Продолжить КонецЕсли; 
		
		НовСтр = Объект.Товары.Добавить();
		
		НовСтр.Номенклатура = НовНом;
		НовСтр.Количество = НовКол;
		НовСтр.ЦенаЗакупки = НовЦен;
		
		ИДИ = НовСтр.ПолучитьИдентификатор();
		
		МояЗаписать(Ложь);
		
		гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
		
		Элементы.Товары.ТекущаяСтрока = ИДИ;
		
		НеВыходить = КонстантаНеВыходить;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактирование(Кол)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	
	Если Кол = "ЦенаЗакупки" Тогда
		Цена = Стр[Кол];
		Было = Цена;
		Если НЕ ВвестиЧисло(Цена, НСтр("ru = 'Цена закупки'; en = 'Purchase price'"), 19, ЧислоЗнаковЦенаЗакупки) Тогда Возврат КонецЕсли; 
		Если Было = Цена Тогда Возврат КонецЕсли; 
		Стр[Кол] = Цена;
	ИначеЕсли Кол = "Количество" Тогда
		Колв = Стр.Количество;
		Было = Колв;
		Если НЕ ВвестиЧисло(Колв, НСтр("ru = 'Количество'; en = 'Quantity'"), 14, ЧислоЗнаковКоличество) Тогда Возврат КонецЕсли; 
		Если Было = Колв Тогда Возврат КонецЕсли; 
		Стр.Количество = Колв;
		
		Колич =	Колв;
		СЦена = Стр.ЦенаЗакупки;
		Номен =	Стр.Номенклатура;
		гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Редактирование количества", Номен, 2);
		гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Редактирование количества", Объект.Ссылка, 2);
	КонецЕсли; 
	
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура МоеУдаление()
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда 
		Если гоАдминистратор() Тогда 
			Сообщить("Под ответственность Администратора!");
		Иначе 
			Возврат;
		КонецЕсли; 
	КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	Если клНетДа("Удалить строку?") Тогда Возврат КонецЕсли; 
	
	Номен = Стр.Номенклатура;
	СЦена = Стр.ЦенаЗакупки;
	Колич = Стр.Количество;
	
	Удаляем = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Удаляем = Неопределено Тогда клОшибка("Странно, не нашли текущую строку!"); Возврат; КонецЕсли; 
	
	Объект.Товары.Удалить(Удаляем);
	
	гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удаление строки", Объект.Ссылка, 2);
	
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
КонецПроцедуры

&НаКлиенте
Процедура Установить(Команда)
	Если Объект.Окончательно Тогда Возврат КонецЕсли;
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Товары.Количество() = 0 Тогда Возврат КонецЕсли;
	
	Если клНетДа(НСтр("ru = 'Установить флаг <Окончательно>?'; en = 'Set flag <Finaly>?'")) Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Истина;
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации("Установили", ИмяДокумента, "Установка {Окончательно}", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура Снять(Команда)
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли; 
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если клНетДа("Снять флаг {Окончательно}?") Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Ложь;
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации("Сняли", ИмяДокумента, "Снятие {Окончательно}", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсе(Команда)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если клНетДа("Удалить все строки?") Тогда Возврат КонецЕсли; 
	
	Объект.Товары.Очистить();
	
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЦены(Команда)
//2015.12.18

	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если клНетДа("Очистить цены во всех строках?") Тогда Возврат КонецЕсли;
	
	Для Каждого Стр Из Объект.Товары Цикл
		Стр.ЦенаЗакупки = 0;
	КонецЦикла; 
	
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЦены(Команда)
//2015.12.18

	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если клНетДа("Заполнить цены (последние приходы от " + гоИмя(Объект.Контрагент) + ") во всех строках?") Тогда Возврат КонецЕсли;
	ИскатьБез = клДаНет("Искать цену другого поставщика, если не было прихода от " + гоИмя(Объект.Контрагент) + "?");
	
	Для Каждого Стр Из Объект.Товары Цикл
		ВернутьЦену = 0;
		ВернутьВалюту = 0;
		ВернутьДату = 0;
		омСервер.ПоследняяЦенаЗакупки(Стр.Номенклатура, Объект.Фирма, Объект.Контрагент, ВернутьЦену, ВернутьВалюту, ВернутьДату, Объект.Валюта);
		
		Если (ВернутьЦену = 0) И ИскатьБез Тогда
			ВернутьЦену = 0;
			ВернутьВалюту = 0;
			ВернутьДату = 0;
			омСервер.ПоследняяЦенаЗакупки(Стр.Номенклатура, Объект.Фирма, 0, ВернутьЦену, ВернутьВалюту, ВернутьДату, Объект.Валюта);
		КонецЕсли; 
		
		Стр.ЦенаЗакупки = ВернутьЦену;
	КонецЦикла; 
	
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ИскатьКонтрагента(Команда)
//2016.06.09

	НовКон = клИскатьКонтрагента(Объект.Контрагент);
	Если НовКон = Неопределено Тогда Возврат КонецЕсли; 
	Объект.Контрагент = новКон;
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Вставить содержимое обработчика.
КонецПроцедуры
