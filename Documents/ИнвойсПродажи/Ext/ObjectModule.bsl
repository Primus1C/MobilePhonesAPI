Функция ТаблицаТоваров()
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	ИнвойсПродажиТовары.Номенклатура КАК Номенклатура,
	             |	СУММА(ИнвойсПродажиТовары.Количество) КАК Количество,
	             |	СУММА(ИнвойсПродажиТовары.Сумма) КАК Сумма
	             |ИЗ
	             |	Документ.ИнвойсПродажи.Товары КАК ИнвойсПродажиТовары
	             |ГДЕ
	             |	ИнвойсПродажиТовары.Ссылка = &Ссылка
	             |	И ИнвойсПродажиТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ИнвойсПродажиТовары.Номенклатура";
	
	Возврат Запр.Выполнить().Выгрузить();

КонецФункции 

