Функция ПолучитьВыборкуПоПродажам(ТекСтрока)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Продажи.Период КАК Период,
	               |	Продажи.Регистратор КАК Регистратор,
	               |	Продажи.Фирма КАК Фирма,
	               |	Продажи.Покупатель КАК Покупатель,
	               |	Продажи.Поставщик КАК Поставщик,
	               |	Продажи.Автор КАК Автор,
	               |	Продажи.Валюта КАК Валюта,
	               |	Продажи.Номенклатура КАК Номенклатура,
	               |	Продажи.Партия КАК Партия,
	               |	Продажи.ДокументПрихода КАК ДокументПрихода,
	               |	Продажи.Сумма КАК Сумма,
	               |	Продажи.Количество КАК Количество,
	               |	Продажи.Наценка КАК Наценка,
	               |	Продажи.Склад КАК Склад,
	               |	Продажи.СуммаВБазВалюте КАК СуммаВБазВалюте,
	               |	Продажи.НаценкаВБазВалюте КАК НаценкаВБазВалюте
	               |ИЗ
	               |	РегистрНакопления.Продажи КАК Продажи
	               |ГДЕ
	               |	Продажи.Регистратор = &Регистратор
	               |	И Продажи.Партия = &Партия
	               |	И Продажи.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("Регистратор",	ТекСтрока.РасходняНакладная);
	Запрос.УстановитьПараметр("Номенклатура",	ТекСтрока.Номенклатура);
	Запрос.УстановитьПараметр("Партия",	 		ТекСтрока.Партия);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;

КонецФункции // ПолучитьВыборкуПоПродажам()

Функция ПолучитьВыборкуПоВзаиморасчетам(ТекСтрока)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Долги.Период,
	               |	Долги.Регистратор,
	               |	Долги.Фирма,
	               |	Долги.Док,
	               |	Долги.Валюта,
	               |	Долги.Контрагент,
	               |	Долги.ДолгПокупателя,
	               |	Долги.ПредоплатаПокупателя,
	               |	Долги.ДолгПоставщику,
	               |	Долги.ПредоплатаПоставщику,
	               |	Долги.Покупатель,
	               |	Долги.Поставщик,
	               |	Долги.Чем
	               |ИЗ
	               |	РегистрНакопления.Долги КАК Долги
	               |ГДЕ
	               |	Долги.Регистратор = &Регистратор";
	Запрос.УстановитьПараметр("Регистратор",	 ТекСтрока.РасходняНакладная);
	Запрос.УстановитьПараметр("Номенклатура",	 ТекСтрока.Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;
	
КонецФункции // ПолучитьВыборкуПоВзаиморасчетам()

Функция ВКД_ПолучитьНаценкуПоНаменклатуре(Ссылка,Серия)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РасходнаяНакладнаяТовары.ЦенаЗакупки,
	               |	РасходнаяНакладнаяТовары.ВКД_ЦенаСоСкидкой,
	               |	РасходнаяНакладнаяТовары.ВКД_ЦенаСЗатратами,
	               |	ВЫБОР
	               |		КОГДА РасходнаяНакладнаяТовары.ВКД_ЦенаСЗатратами = 0
	               |			ТОГДА РасходнаяНакладнаяТовары.СуммаПродажи - РасходнаяНакладнаяТовары.ЦенаЗакупки
	               |		КОГДА РасходнаяНакладнаяТовары.ВКД_ЦенаСоСкидкой = 0
	               |			ТОГДА РасходнаяНакладнаяТовары.СуммаПродажи - РасходнаяНакладнаяТовары.ЦенаЗакупки
	               |		ИНАЧЕ РасходнаяНакладнаяТовары.СуммаПродажи - РасходнаяНакладнаяТовары.ВКД_ЦенаСЗатратами
	               |	КОНЕЦ КАК Наценка,
	               |	РасходнаяНакладнаяТовары.СуммаПродажи
	               |ИЗ
	               |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
	               |ГДЕ
	               |	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
	               |	И РасходнаяНакладнаяТовары.Серия = &Серия";
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	Запрос.УстановитьПараметр("Серия",Серия);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Если Выборка.ВКД_ЦенаСЗатратами = 0 и Выборка.ВКД_ЦенаСоСкидкой = 0 Тогда  //стандартная процедура
		Наценка = Выборка.СуммаПродажи - Выборка.ЦенаЗакупки
	ИначеЕсли Выборка.ВКД_ЦенаСоСкидкой <> 0 И Выборка.ВКД_ЦенаСЗатратами = 0 Тогда  //есть только скидка
		Наценка = Выборка.СуммаПродажи - Выборка.ВКД_ЦенаСоСкидкой 
	Иначе
		Наценка = Выборка.СуммаПродажи - Выборка.ВКД_ЦенаСЗатратами  // есть конечная цена с затратами
	КонецЕсли;
	
	Возврат Выборка.Наценка;
	
КонецФункции





