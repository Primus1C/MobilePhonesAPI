Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// © Primus1C  02.04.2025  НАЧАЛО ► 

	Для каждого СтрокаТЧ Из Товары Цикл
		Если СтрокаТЧ.Партия.ДатаПартии > Дата Тогда
			Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: дата возврата меньше даты партии!'; en = 'Row %1: The document date is less than the lot date!'"), СтрокаТЧ.НомерСтроки));
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Запр = Новый Запрос;        
	Запр.УстановитьПараметр("Фирма", 	Фирма);
	//Запр.УстановитьПараметр("Склад",	Склад);
	Запр.УстановитьПараметр("Дата",		Дата);
