		////ВКД--

		// © Primus1C  ОКОНЧАНИЕ ◄

	КонецЦикла;
	
	
	// © Primus1C  22.07.2026  НАЧАЛО ►
	
	// РН РезервыТовара  
	
	Движения.РезервыТовара.Записывать = Истина;
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	_ВозвратОтПокупателяТовары.Номенклатура КАК Номенклатура,
	             |	-СУММА(_ВозвратОтПокупателяТовары.Количество) КАК Количество,
	             |	_ВозвратОтПокупателяТовары.РасходняНакладная.ДокументОснование КАК Заказ
	             |ИЗ
	             |	Документ._ВозвратОтПокупателя.Товары КАК _ВозвратОтПокупателяТовары
