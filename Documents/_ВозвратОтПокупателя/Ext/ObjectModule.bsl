	КонецЕсли;

	// © Primus1C  ОКОНЧАНИЕ ◄
	
	Движения.Продажи.Записывать			 = Истина;
	Движения.ОстаткиТовара.Записывать	 = Истина;
	Движения.Долги.Записывать			 = Истина;
