&НаСервереБезКонтекста
Функция ПолучитьВыборкуПоШКНаСервере(ШК_Серии, ДатаВозврата)
	
	Результат = Новый Структура;
	Результат.Вставить("Номенклатура");
	Результат.Вставить("Партия");
	Результат.Вставить("Серия");
	Результат.Вставить("Контрагент");
	Результат.Вставить("ЦенаПродажи");
	Результат.Вставить("Количество");
	Результат.Вставить("СуммаПродажи");
	Результат.Вставить("Регистратор");
	Результат.Вставить("Валюта");
	Результат.Вставить("ТекстПредупреждения", НСтр("ru = 'Для выбраного штрихкода не найдена история реализации!'; en = 'No sales history found for the selected barcode!'"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Партии.Ссылка
	               |ПОМЕСТИТЬ втПартииСЗаданойСерией
	               |ИЗ
	               |	Справочник.Партии КАК Партии
	               |ГДЕ
	               |	Партии.Серия = &Серия
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ОстаткиТовараОстаткиИОбороты.Номенклатура,
	               |	ОстаткиТовараОстаткиИОбороты.Партия,
	               |	ОстаткиТовараОстаткиИОбороты.Партия.Серия КАК Серия,
	               |	ОстаткиТовараОстаткиИОбороты.Регистратор,
	               |	ПродажиОбороты.Валюта КАК Валюта,
	               |	ПродажиОбороты.Покупатель КАК Контрагент,
	               |	ПродажиОбороты.СуммаОборот / ПродажиОбороты.КоличествоОборот КАК СуммаПродажи
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара.ОстаткиИОбороты(
	               |			,
	               |			,
	               |			Регистратор,
	               |			,
	               |			Партия В
	               |				(ВЫБРАТЬ
	               |					втПартииСЗаданойСерией.Ссылка
	               |				ИЗ
	               |					втПартииСЗаданойСерией КАК втПартииСЗаданойСерией)) КАК ОстаткиТовараОстаткиИОбороты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты(, , Регистратор, ) КАК ПродажиОбороты
	               |		ПО ОстаткиТовараОстаткиИОбороты.Регистратор = ПродажиОбороты.Регистратор
	               |			И ОстаткиТовараОстаткиИОбороты.Номенклатура = ПродажиОбороты.Номенклатура
	               |ГДЕ
	               |	(ОстаткиТовараОстаткиИОбороты.Регистратор ССЫЛКА Документ.РасходнаяНакладная
	               |			ИЛИ ОстаткиТовараОстаткиИОбороты.Регистратор ССЫЛКА Документ._ВозвратОтПокупателя)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ОстаткиТовараОстаткиИОбороты.Период УБЫВ";
	Запрос.УстановитьПараметр("Серия", ШК_Серии);
	//Запрос.УстановитьПараметр("Дата", ДатаВозврата);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			Если ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
				ЗаполнитьЗначенияСвойств(Результат, Выборка); 
				// © Primus1C  18.03.2024  НАЧАЛО ►
				// исправим цену (в Расх.накл. м.быть один товар с разными ценами; если при этом серии различны, уточним цену)  
				// 				 (не решает ситуацию, если одна серия продавалась по разными ценам)
				Запр = Новый Запрос;
				Запр.Текст = "ВЫБРАТЬ
				             |	СРЕДНЕЕ(РасходнаяНакладнаяТовары.СуммаПродажи / РасходнаяНакладнаяТовары.Количество) КАК ЦенаПродажи
				             |ИЗ
				             |	Документ.РасходнаяНакладная.Товары КАК РасходнаяНакладнаяТовары
				             |ГДЕ
				             |	РасходнаяНакладнаяТовары.Ссылка = &Ссылка
				             |	И РасходнаяНакладнаяТовары.Серия = &Серия";
				Запр.УстановитьПараметр("Ссылка", Выборка.Регистратор);
				Запр.УстановитьПараметр("Серия", ШК_Серии); 
				Выб = Запр.Выполнить().Выбрать();
				Если Выб.Следующий() Тогда
					Результат.Вставить("СуммаПродажи", Выб.ЦенаПродажи);
				КонецЕсли;
				// © Primus1C  ОКОНЧАНИЕ ◄
			ИначеЕсли ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка._ВозвратОтПокупателя") Тогда
				Результат.Вставить("ТекстПредупреждения", НСтр("ru = 'Эта позиция уже была возвращена документом '; en = 'This position has already been returned by the document '") + Выборка.Регистратор);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ПолучитьВыборкуПоШКНаСервере()

&НаКлиенте
Процедура ДобавитьДанныеПоВозвратуСерии(ШК_Серии, ОчищатьПолеВвода = Истина)
	
	Если НЕ ЗначениеЗаполнено(ШК_Серии) Тогда Возврат КонецЕсли;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Серия", ШК_Серии);
	
	РезультатПоиска = Объект.Товары.НайтиСтроки(СтруктураПоиска);
	
	Если РезультатПоиска.Количество() > 0 Тогда
		ПоказатьПредупреждение(Новый ОписаниеОповещения("ДобавитьДанныеПоВозвратуСерииПослеПредупрежденияДубля", ЭтотОбъект,
			Новый Структура("ШК_Серии,ОчищатьПолеВвода", ШК_Серии, ОчищатьПолеВвода)),
			НСтр("ru = 'Данный штрих код уже отсканирован в документе!'; en = 'This barcode has already been scanned in the document!'"));
		Возврат;
	КонецЕсли;
	
	ДобавитьДанныеПоВозвратуСерииШаг2(ШК_Серии, ОчищатьПолеВвода);
	
КонецПроцедуры // ПолучитьВыборкуПоШКНаСервере()

&НаКлиенте
Процедура ДобавитьДанныеПоВозвратуСерииПослеПредупрежденияДубля(ДопПараметры) Экспорт
	ШК_Серии = ДопПараметры.ШК_Серии;
	ОчищатьПолеВвода = ДопПараметры.ОчищатьПолеВвода;
	
	Если ОчищатьПолеВвода Тогда
		РучнойШК = "";
		Возврат;
	КонецЕсли;
	
	ДобавитьДанныеПоВозвратуСерииШаг2(ШК_Серии, ОчищатьПолеВвода);
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДанныеПоВозвратуСерииШаг2(ШК_Серии, ОчищатьПолеВвода)
	
	Выборка = ПолучитьВыборкуПоШКНаСервере(ШК_Серии, Объект.Дата);
	
	Если Выборка.Номенклатура = Неопределено Тогда
		ПоказатьПредупреждение(Новый ОписаниеОповещения("ДобавитьДанныеПоВозвратуСерииПослеЗавершения", ЭтотОбъект, ОчищатьПолеВвода), Выборка.ТекстПредупреждения);
		Возврат;
	Иначе
		НоваяСтрока						 = Объект.Товары.Добавить();
		НоваяСтрока.Номенклатура		 = Выборка.Номенклатура;
		НоваяСтрока.Партия				 = Выборка.Партия;
		НоваяСтрока.Серия				 = Выборка.Серия;
		НоваяСтрока.Контрагент			 = Выборка.Контрагент;;
		НоваяСтрока.Количество			 = 1;
		НоваяСтрока.ЦенаПродажи			 = Выборка.СуммаПродажи;
		НоваяСтрока.СуммаПродажи		 = Выборка.СуммаПродажи;
		НоваяСтрока.РасходняНакладная	 = Выборка.Регистратор;
		НоваяСтрока.Валюта				 = Выборка.Валюта;
	КонецЕсли;
	
	ДобавитьДанныеПоВозвратуСерииЗавершение(ОчищатьПолеВвода);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДанныеПоВозвратуСерииПослеЗавершения(ОчищатьПолеВвода) Экспорт
	ДобавитьДанныеПоВозвратуСерииЗавершение(ОчищатьПолеВвода);
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДанныеПоВозвратуСерииЗавершение(ОчищатьПолеВвода)
	Если ОчищатьПолеВвода Тогда
		РучнойШК = "";
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РучнойШКПриИзменении(Элемент)
	
	// © Primus1C  31.12.2025  НАЧАЛО ►
	//ДобавитьДанныеПоВозвратуСерии(РучнойШК);   
	мас = Новый массив;
	мас.Добавить(РучнойШК);
	ДобавитьВТЧСтрокиСерии(мас);
	// © Primus1C  ОКОНЧАНИЕ ◄
	
КонецПроцедуры





