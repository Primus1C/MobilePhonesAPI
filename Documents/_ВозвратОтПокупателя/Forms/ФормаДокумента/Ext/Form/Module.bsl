&НаСервере
Функция СведенияПартий(МассивСерий)
	
	МассивВРег = Новый Массив;
	МассивНРег = Новый Массив;
	Для каждого Эл Из МассивСерий Цикл
		МассивВРег.Добавить(Врег(Эл));
		МассивНРег.Добавить(Нрег(Эл));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаПартии", Объект.Дата);
	Запрос.УстановитьПараметр("Серии",  	МассивСерий);
	Запрос.УстановитьПараметр("СерииНРег",  МассивВРег);
	Запрос.УстановитьПараметр("СерииВРег",  МассивНРег);
	Запрос.Текст = "ВЫБРАТЬ
	               |	Партии.Ссылка КАК Ссылка
	               |ПОМЕСТИТЬ втПартииСЗаданойСерией
	               |ИЗ
	               |	Справочник.Партии КАК Партии
	               |ГДЕ
	               |	(Партии.Серия В (&Серии)
	               |			ИЛИ Партии.Серия В (&СерииНРег)
	               |			ИЛИ Партии.Серия В (&СерииВРег))
	               |	И Партии.ДатаПартии < &ДатаПартии
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Продажи.Номенклатура КАК Номенклатура,
	               |	Продажи.Партия КАК Партия,
	               |	Продажи.Партия.Серия КАК Серия,
	               |	Продажи.Регистратор КАК Регистратор,
	               |	Продажи.Валюта КАК Валюта,
	               |	Продажи.Покупатель КАК Контрагент,
	               |	Продажи.СуммаОборот / Продажи.КоличествоОборот КАК Цена,
	               |	(Продажи.СуммаОборот + Продажи.НаценкаОборот) / Продажи.КоличествоОборот КАК ЦенаСНаценкой
	               |ИЗ
	               |	РегистрНакопления.Продажи.Обороты(
	               |			,
	               |			,
	               |			Запись,
	               |			Партия В
	               |				(ВЫБРАТЬ
	               |					ВТ.Ссылка
	               |				ИЗ
	               |					втПартииСЗаданойСерией КАК ВТ)) КАК Продажи
	               |ГДЕ
	               |	Продажи.Регистратор ССЫЛКА Документ.РасходнаяНакладная
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Продажи.Период";
	Выборка = Запрос.Выполнить().Выбрать(); 
	СоотвПартий = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СведенияПартии = Новый Структура("Партия,Серия,Номенклатура,Регистратор,Валюта,Контрагент,Цена,ЦенаСНаценкой", 
										Выборка.Партия, Выборка.Серия, Выборка.Номенклатура, Выборка.Регистратор, Выборка.Валюта, Выборка.Контрагент, Выборка.Цена, Выборка.ЦенаСНаценкой);
		СоотвПартий.Вставить(Выборка.Серия, СведенияПартии);
		СоотвПартий.Вставить(ВРег(Выборка.Серия), СведенияПартии);
		СоотвПартий.Вставить(НРег(Выборка.Серия), СведенияПартии);
	КонецЦикла;
	Возврат СоотвПартий;
	
КонецФункции 

&НаКлиенте
Процедура ДобавитьВТЧСтрокиСерии(МассивСерий)

	СоотвПартий = СведенияПартий(МассивСерий);
	
	Ошибки = Новый СписокЗначений;
	НовыхСтрок = 0;
	Для каждого Эл Из МассивСерий Цикл
		СведенияПартии = СоотвПартий.Получить(Эл);
		Если СведенияПартии = Неопределено Тогда
			Ошибки.Добавить(СтрШаблон("%1: %2", НСтр("ru = 'Нет продаж серии'; en = 'No series sales'"), Эл));
		Иначе
			//НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Партия", СведенияПартии.Партия));  
			НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Серия", Эл));
			Если НайдСтроки.Количество() > 0 Тогда
				Ошибки.Добавить(СтрШаблон("%1 %2 %3 !", НСтр("ru = 'Cерия'; en = 'Series'"), Эл, НСтр("ru = 'уже есть в накладной'; en = 'is already in document'")));   
			    Продолжить;
			КонецЕсли;
			НовСтр = Объект.Товары.Добавить();
			НовСтр.Серия 			= Эл;
			НовСтр.Номенклатура 	= СведенияПартии.Номенклатура;
			НовСтр.Партия 			= СведенияПартии.Партия; 
			НовСтр.ЦенаПродажи 		= СведенияПартии.Цена; 
			НовСтр.СуммаПродажи		= СведенияПартии.Цена; 
			НовСтр.Количество 		= 1; 
			НовСтр.Валюта 			= СведенияПартии.Валюта; 
			НовСтр.Контрагент 		= СведенияПартии.Контрагент; 
			НовСтр.РасходняНакладная= СведенияПартии.Регистратор;
			НовыхСтрок = НовыхСтрок + 1;
		КонецЕсли;
	КонецЦикла;	
	
	//МояЗаписать(Ложь);
	Если МассивСерий.ВГраница() > 0 Тогда
		гоЗаписьЖурналаРегистрации("Добавлено из буфера обмена строк: " + НовыхСтрок, ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строк", Объект.Ссылка, 2);
	КонецЕсли; 

	РучнойШК = "";
		
	Если Объект.Товары.Количество() > 0  Тогда
		ИДИ = Объект.Товары[Объект.Товары.Количество()-1].ПолучитьИдентификатор();
	    Элементы.Товары.ТекущаяСтрока = ИДИ;
	КонецЕсли;

	ОбновитьИтоги();

	Если Ошибки.Количество() > 0 Тогда   
		ТекстОшибок = "";
		Для каждого Ош Из Ошибки Цикл
			ТекстОшибок = ТекстОшибок + Ош.Значение + Символы.ПС;
		КонецЦикла;
		клОшибка(ТекстОшибок, , НСтр("ru = 'Ошибки заполнения'; en = 'Filling Errors'"));
	КонецЕсли;

КонецПроцедуры

