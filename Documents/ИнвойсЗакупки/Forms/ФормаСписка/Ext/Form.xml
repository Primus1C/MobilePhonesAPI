	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Контрагент</Field>
				<Field>Список.ЛокальныйСтатус</Field>
				<Field>Список.ПометкаУдаления</Field>
				<Field>Список.Состояние</Field>
				<Field>Список.Ссылка</Field>
				<Field>Список.Статус</Field>
				<Field>Список.СтатусИнспекции</Field>
				<Field>Список.СтатусОплаты</Field>
				<Field>Список.Сумма</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	ДокументИнвойсЗакупки.Ссылка,
	ДокументИнвойсЗакупки.ПометкаУдаления,
	ДокументИнвойсЗакупки.Номер,
	ДокументИнвойсЗакупки.Дата,
	ДокументИнвойсЗакупки.Проведен,
	ДокументИнвойсЗакупки.Контрагент,
	ДокументИнвойсЗакупки.Сумма,
	ДокументИнвойсЗакупки.Валюта,
	ДокументИнвойсЗакупки.Количество,
	ДокументИнвойсЗакупки.НомерИнвойсаПоставщика,
	ДокументИнвойсЗакупки.ДатаИнвойсаПоставщика,
	ДокументИнвойсЗакупки.СкладОтправитель,
	ДокументИнвойсЗакупки.ДатаНаСкладеОтправителя,
	ДокументИнвойсЗакупки.СкладПолучатель,
	ДокументИнвойсЗакупки.ДатаИнспекции,
	ДокументИнвойсЗакупки.ДатаОплаты,
	ДокументИнвойсЗакупки.Комиссия,
	ДокументИнвойсЗакупки.ДопРасходы,
	ДокументИнвойсЗакупки.Авианакладная, 
	ДокументИнвойсЗакупки.ЛокальныйСтатус, 
	ДокументИнвойсЗакупки.Менеджер,  
	ДокументИнвойсЗакупки.МетодОплаты,
	НЕ ЕСТЬNULL(СостоянияИнвойсов.Расхождения, ИСТИНА) КАК РасхожденияОК,
	ВЫБОР
		КОГДА ХранилищеФайлов.ОбъектСсылка ЕСТЬ NULL
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Вложения,
	ДокументИнвойсЗакупки.КемСоздан КАК Автор,
	ВЫБОР
		КОГДА ЕСТЬNULL(СообщенияОбъекта.КоличествоСообщений, 0) = 0
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК КоличествоСообщений,
	//СостоянияИнвойсов.Статус,  
	выбор 
		когда СостоянияИнвойсов.Статус = Значение(Перечисление.СтатусыИнвойса.ПустаяСсылка) Тогда "-" 
		иначе ЕСТЬNULL(СостоянияИнвойсов.Статус, "-") 
	конец КАК Статус,

	//СостоянияИнвойсов.СтатусИнспекции,
	выбор 
		когда СостоянияИнвойсов.СтатусИнспекции = Значение(Перечисление.СтатусыИнспекции.ПустаяСсылка) Тогда "-" 
		иначе ЕСТЬNULL(СостоянияИнвойсов.СтатусИнспекции, "-") 
	конец КАК СтатусИнспекции,
	
	//СостоянияИнвойсов.СтатусОплаты,   
	выбор 
		когда СостоянияИнвойсов.СтатусОплаты = Значение(Перечисление.СтатусыОплаты.ПустаяСсылка) Тогда "-" 
		иначе ЕСТЬNULL(СостоянияИнвойсов.СтатусОплаты, "-") 
	конец КАК СтатусОплаты,
	
	СостоянияИнвойсов.Состояние КАК Состояние,
	
	ОплатыИнвойсов.СуммаВВалютеИнвойса КАК СуммаОплатыВВалютеИнвойса,
	СтрокиИнвойсов.КолвоСтрок,
	ВЫБОР
		КОГДА СтрокиИнвойсов.КолвоСтрок = 1
			ТОГДА ПервыеОплатыИнвойсов.Валюта
	КОНЕЦ КАК ВалютаОплаты,
	ВЫБОР
		КОГДА СтрокиИнвойсов.КолвоСтрок = 1
			ТОГДА ПервыеОплатыИнвойсов.Курс
	КОНЕЦ КАК КурсОплаты
ИЗ
	Документ.ИнвойсЗакупки КАК ДокументИнвойсЗакупки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
		ПО (СостоянияИнвойсов.Инвойс = ДокументИнвойсЗакупки.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			ХранилищеФайлов.ОбъектСсылка КАК ОбъектСсылка
		ИЗ
			РегистрСведений.ХранилищеФайлов КАК ХранилищеФайлов) КАК ХранилищеФайлов
		ПО ДокументИнвойсЗакупки.Ссылка = ХранилищеФайлов.ОбъектСсылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сооб_Сообщения.УникИдент) КАК КоличествоСообщений,
			Сооб_Сообщения.СсылкаНаОбъект КАК СсылкаНаОбъект
		ИЗ
			РегистрСведений.Сооб_Сообщения КАК Сооб_Сообщения
		
		СГРУППИРОВАТЬ ПО
			Сооб_Сообщения.СсылкаНаОбъект) КАК СообщенияОбъекта
		ПО ДокументИнвойсЗакупки.Ссылка = СообщенияОбъекта.СсылкаНаОбъект
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ИнвойсЗакупкиОплаты.Ссылка КАК Ссылка,
			ИнвойсЗакупкиОплаты.Сумма КАК Сумма,
			ИнвойсЗакупкиОплаты.Валюта КАК Валюта,
			ИнвойсЗакупкиОплаты.Курс КАК Курс
		ИЗ
			Документ.ИнвойсЗакупки.Оплаты КАК ИнвойсЗакупкиОплаты
		ГДЕ
			ИнвойсЗакупкиОплаты.НомерСтроки = 1) КАК ПервыеОплатыИнвойсов
		ПО ДокументИнвойсЗакупки.Ссылка = ПервыеОплатыИнвойсов.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			СУММА(ИнвойсЗакупкиОплаты.СуммаВВалютеИнвойса) КАК СуммаВВалютеИнвойса,
			ИнвойсЗакупкиОплаты.Ссылка КАК Ссылка
		ИЗ
			Документ.ИнвойсЗакупки.Оплаты КАК ИнвойсЗакупкиОплаты
		
		СГРУППИРОВАТЬ ПО
			ИнвойсЗакупкиОплаты.Ссылка) КАК ОплатыИнвойсов
		ПО ДокументИнвойсЗакупки.Ссылка = ОплатыИнвойсов.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ИнвойсЗакупкиОплаты.Ссылка КАК Ссылка,
			МАКСИМУМ(ИнвойсЗакупкиОплаты.НомерСтроки) КАК КолвоСтрок
		ИЗ
			Документ.ИнвойсЗакупки.Оплаты КАК ИнвойсЗакупкиОплаты
		
		СГРУППИРОВАТЬ ПО
			ИнвойсЗакупкиОплаты.Ссылка) КАК СтрокиИнвойсов
		ПО (ДокументИнвойсЗакупки.Ссылка = ОплатыИнвойсов.Ссылка)</QueryText>
