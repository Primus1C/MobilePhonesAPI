&НаКлиенте
Процедура ПлатежиПриИзменении(Элемент)
	
	Если Элемент <> Неопределено Тогда // нажатие переключателя
		Если Платежи = 1 И Объект.Оплаты.Количество() > 1 Тогда
			клПредупреждение(НСтр("ru = 'Сначала удалите строки с ненужными платежами!'; en = 'First, remove lines with unnecessary payments!'"), 10, НСтр("ru = 'Оплаты инвойса'; en = 'Invoice payments'"));
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	лОдинПлатеж = Платежи = 1;
	Элементы.ГруппаОднаОплата.Видимость 	= лОдинПлатеж;
	Элементы.ГруппаНесколькоОплат.Видимость = НЕ лОдинПлатеж;
	Если лОдинПлатеж Тогда 
		Если Объект.Оплаты.Количество() = 0 Тогда
			Если Объект.ДатаОплаты<> Дата(1,1,1) ТОгда
				Объект.ДатаОплаты		= Дата(1,1,1); 
			КонецЕсли;
			СуммаОплаты					= 0;
			ВалютаОплаты_				= ПредопределенноеЗначение("Справочник.Валюты.ПустаяСсылка");
			КурсОплаты					= 0;
			СуммаОплатыВВалютеИнвойса	= 0;
		Иначе	
			СтрокаТЧ = Объект.Оплаты[0];        
			Если Объект.ДатаОплаты <> СтрокаТЧ.Дата Тогда
				Объект.ДатаОплаты		= СтрокаТЧ.Дата;
			КонецЕсли;
			СуммаОплаты					= СтрокаТЧ.Сумма;
			ВалютаОплаты_				= СтрокаТЧ.Валюта;
			КурсОплаты					= СтрокаТЧ.Курс;
			СуммаОплатыВВалютеИнвойса	= СтрокаТЧ.СуммаВВалютеИнвойса;
		КонецЕсли;
	Иначе	
		Если Элемент <> Неопределено Тогда // нажатие переключателя
			Если Объект.Оплаты.Количество() = 0 Тогда
				СтрокаТЧ = Объект.Оплаты.Добавить();
			Иначе
				СтрокаТЧ = Объект.Оплаты[0];
			КонецЕсли;
			СтрокаТЧ.Дата 					= Объект.ДатаОплаты;
			СтрокаТЧ.Сумма 					= СуммаОплаты;
			СтрокаТЧ.Валюта 				= ВалютаОплаты_;
			СтрокаТЧ.Курс 					= КурсОплаты;
			СтрокаТЧ.СуммаВВалютеИнвойса	= СуммаОплатыВВалютеИнвойса; 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры  
  
