&НаКлиенте
Процедура ОбновитьСообщенияНаФорме()

	КэшСообщений = Сооб_Сервер.СообщенияОбъекта(Объект.Ссылка);
	Элементы.КнопкаСообщения.Заголовок = НСтр("ru = 'Сообщения'; en = 'Messages'") + Формат(КэшСообщений.КоличествоСообщений, "ЧДЦ=0; ЧН=' '; ЧФ=' :Ч'");
	СообщенияОбъекта = КэшСообщений.СтрокаHTML;
	 
