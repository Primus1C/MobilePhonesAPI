&НаКлиенте
Процедура СтатусОплатыПриИзменении(Элемент) Экспорт 

	Если Объект.ДатаОплаты = Дата(1,1,1) И
		  (СтатусОплаты = ПредопределенноеЗначение("Перечисление.СтатусыОплаты.PartlyPaid") ИЛИ 
			СтатусОплаты = ПредопределенноеЗначение("Перечисление.СтатусыОплаты.PaidNotReceivded") ИЛИ 
			СтатусОплаты = ПредопределенноеЗначение("Перечисление.СтатусыОплаты.Paid"))
					Тогда
		Объект.ДатаОплаты = ОбщегоНазначенияСервер.Сейчас(); 
		ДатаОплатыПриИзменении(Неопределено);
	КонецЕсли;
	
	Если СтатусОплаты = ПредопределенноеЗначение("Перечисление.СтатусыОплаты.NotPaid") Тогда
		Объект.ДатаОплаты = Дата(1,1,1); 
		ДатаОплатыПриИзменении(Неопределено);
	КонецЕсли;

	УстановитьВидимостьПоСтатусуОплаты();

	ОтобразитьЦветСтатусов();

КонецПроцедуры

