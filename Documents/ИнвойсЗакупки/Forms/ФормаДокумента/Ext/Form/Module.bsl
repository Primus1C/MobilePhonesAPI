&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//Запрет копирования документа
    Если НЕ Параметры.ЗначениеКопирования.Пустая() Тогда
        Отказ = Истина;
        СтандартнаяОбработка = Ложь;
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = НСтр("ru = 'Копирование запрещено, создайте новый документ'; en = 'Copying is prohibited, create a new document'");
        Сообщение.Сообщить(); 
        Возврат;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запр = Новый Запрос;   
		Запр.УстановитьПараметр("ИнвойсЗакупки", Объект.Ссылка);
		Запр.Текст ="ВЫБРАТЬ РАЗРЕШЕННЫЕ
		            |	СостоянияИнвойсов.Статус КАК Статус,
		            |	СостоянияИнвойсов.СтатусИнспекции,
		            |	СостоянияИнвойсов.СтатусОплаты
		            |ИЗ
		            |	РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
		            |ГДЕ
		            |	СостоянияИнвойсов.Инвойс = &ИнвойсЗакупки"; 
		Выборка = Запр.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			СтатусДокумента = Выборка.Статус;
			СтатусИнспекции = Выборка.СтатусИнспекции;
			СтатусОплаты	= Выборка.СтатусОплаты;
		КонецЕсли; 
	Иначе   
		//СтатусДокумента = Перечисления.СтатусыИнвойса.НеОтправлен;
		СтатусДокумента = Перечисления.СтатусыИнвойса.ПустаяСсылка();
		СтатусИнспекции = Перечисления.СтатусыИнспекции.NotInspected;
		СтатусОплаты 	= Перечисления.СтатусыОплаты.NotPaid;
	КонецЕсли;
	
	лРежим = РольДоступна("Администратор") 
			ИЛИ РольДоступна("ИнвойсЗакупки") 
			ИЛИ РольДоступна("МетреонПолный")
			ИЛИ РольДоступна("МетреонЛогистика");
	//Элементы.СтатусДокумента.ТолькоПросмотр = НЕ лРежим;
	Элементы.СтатусДокумента.ТолькоПросмотр = НЕ РольДоступна("Администратор");
	Элементы.СтатусИнспекции.ТолькоПросмотр = НЕ лРежим;
	Элементы.СтатусОплаты.ТолькоПросмотр = НЕ лРежим;
	
	Элементы.СкладОтправитель.СписокВыбора.Очистить();
	Элементы.СкладОтправитель.СписокВыбора.ЗагрузитьЗначения(ОбщегоНазначенияСервер.СкладыКонтрагентов(Истина,Ложь));
	Элементы.СкладПолучатель.СписокВыбора.Очистить();
	Элементы.СкладПолучатель.СписокВыбора.ЗагрузитьЗначения(ОбщегоНазначенияСервер.СкладыКонтрагентов(Ложь,Истина));
	
	лБыстрыйВыборВалют = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("БыстрыйВыборВалют");
	Элементы.Валюта.БыстрыйВыбор 			= лБыстрыйВыборВалют; 
	Элементы.ВалютаОплаты.БыстрыйВыбор 		= лБыстрыйВыборВалют; 
	Элементы.ОплатыВалюта.БыстрыйВыбор  	= лБыстрыйВыборВалют;
	Элементы.ВалютаОплатыАвто.БыстрыйВыбор 	= лБыстрыйВыборВалют; 
	//глПокраситьВалюты(ЭтаФорма, "Валюта", "Оплаты"); 
	
	ЗаполнитьКэш();  
	
	//Файлы 		= ОбщегоНазначенияСервер.СтрокаФайлов(Объект.Ссылка, ПредопределенноеЗначение("Перечисление.НазначениеФайлов.Прочее"));	
	//ФайлыОплаты = ОбщегоНазначенияСервер.СтрокаФайлов(Объект.Ссылка, ПредопределенноеЗначение("Перечисление.НазначениеФайлов.Оплата"));
	//+++
	//ОбщегоНазначенияСервер.СформироватьГиперссылкиФайловНаФорме(Объект.Ссылка, 
	//															ЭтаФорма, 
	//															Элементы.ГруппаФайлы, 
	//															ПредопределенноеЗначение("Перечисление.НазначениеФайлов.Прочее"), 
	//															"НажатиеГиперссылкиФайла");
	//ОбщегоНазначенияСервер.СформироватьГиперссылкиФайловНаФорме(Объект.Ссылка, 
	//															ЭтаФорма, 
	//															Элементы.ГруппаФайлыОплаты, 
	//															ПредопределенноеЗначение("Перечисление.НазначениеФайлов.Оплата"), 
	//															"НажатиеГиперссылкиФайлаОплаты");
	СформироватьГиперссылкиФайловНаФорме();
	//---
	
	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Валюта 			= ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("Валюта");
		Объект.СкладОтправитель = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("СкладОтправителя");
	КонецЕсли;	
	
	Попытка
	ЭтаФорма.КоманднаяПанель.ПодчиненныеЭлементы.ФормаСоздатьНаОсновании.ПодчиненныеЭлементы.ФормаДокумент_ИнвойсСоздатьНаОсновании.Видимость = Ложь;
	Исключение
	КонецПопытки;
	
	Загл = НСтр("ru = 'Сумма в '; en = 'Sum in '") + ПараметрыСеанса.БазоваяВалюта;
	Элементы.СуммаОплатыВВалюте.Заголовок 			= Загл;
	Элементы.ОплатыСуммаВВалютеИнвойса.Заголовок 	= Загл;
	
	//Запр = Новый Запрос;
	//Запр.Текст = "ВЫБРАТЬ
	//             |	Сотрудники.Ссылка КАК Ссылка
	//             |ИЗ
	//             |	Справочник.Сотрудники КАК Сотрудники
	//             |ГДЕ
	//             |	НЕ Сотрудники.ПометкаУдаления
	//             |	И Сотрудники.Менеджер
	//             |АВТОУПОРЯДОЧИВАНИЕ";
	//Элементы.Менеджер.СписокВыбора.ЗагрузитьЗначения(Запр.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	Элементы.Менеджер.СписокВыбора.ЗагрузитьЗначения(омСервер.Менеджеры());
	
	//ОбновитьСтатусТрека();
	    запр = Новый Запрос;
		Запр.УстановитьПараметр("Перевозчик", Объект.Перевозчик);
		Запр.УстановитьПараметр("Трек", Объект.Авианакладная);
		запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		             |	Треки.Статус КАК Статус
		             |ИЗ
		             |	РегистрСведений.Треки КАК Треки
		             |ГДЕ
		             |	Треки.Трек = &Трек
		             |	И Треки.Перевозчик = &Перевозчик";
	    РезультатЗапроса = Запр.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда  
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			Элементы.ДекорацияСтатусТрека.Заголовок = Выборка.Статус;	
		КонецЕсли; 
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// © Primus1C  15.03.2024  НАЧАЛО ► 
	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);
	//
	// === закомментирована работа с план.оплатами =====
	//
	Платежи = ?(Объект.Оплаты.Количество()<2, 1, 2);
	ПлатежиПриИзменении(Неопределено);
	//      
	
	СкрытьТреки(Неопределено);
	ОтобразитьКоличествоТреков();

	// © Primus1C  ОКОНЧАНИЕ ◄

	ОтобразитьРазницуИнвойсов();
	УстановитьВидимостьИнспекции();  
	УстановитьВидимостьПоСтатусуОплаты();
	ОтобразитьЦветСтатусов();
	ОтобразитьЦветВалюты();   
	//ОтобразитьРазницуОплат();
	//Элементы.Недоплата.ЦветРамки = ?(Объект.Недоплата=0, WebЦвета.ТемноЗеленый, WebЦвета.Красный);
	РассчитатьНедоплату(Истина);
	
	ВидимостьПанелиСообщений = ВидимостьПанелиСообщений И Сооб_Сервер.ПроверитьНаличиеРоли(гоПользователь());
	Элементы.КнопкаСообщения.Пометка = ВидимостьПанелиСообщений;
	ПоказатьСкрытьПанельСообщений();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Платежи = 1 Тогда
		Если Объект.Оплаты.Количество() = 0 Тогда
			СтрокаТЧ = Объект.Оплаты.Добавить();
		Иначе
			СтрокаТЧ = Объект.Оплаты[0];
		КонецЕсли; 		
		СтрокаТЧ.Сумма 					= СуммаОплаты;
		СтрокаТЧ.Валюта					= ВалютаОплаты_;
		СтрокаТЧ.Курс					= КурсОплаты;
		СтрокаТЧ.СуммаВВалютеИнвойса	= Объект.СуммаОплатыВВалютеИнвойса; 
	//Иначе
	//	Объект.СуммаОплатыВВалютеИнвойса = Объект.Оплаты.Итог("СуммаВВалютеИнвойса");
	КонецЕсли; 

	//Если Элементы.ГруппаТТН.Видимость Тогда // 1 трек
	//
	//Иначе // список треков	
	//
	//КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)

	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	РаботаСИнвойсами.ЗаписатьСтатусыИнвойса(Объект.Ссылка, СтатусДокумента, СтатусИнспекции, СтатусОплаты, , , , , Объект.Ссылка);

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновитьСтрокуПрикреплений" Тогда
		СформироватьГиперссылкиФайловНаФорме();
	ИначеЕсли ИмяСобытия = "ИзмененСтатусОплаты" Тогда 
		СтатусОплаты = Параметр;
		СтатусОплатыПриИзменении(Неопределено);
		
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти	   


