&НаСервере
Процедура ЗаполнитьКэш()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда

		Запр = Новый Запрос;
		Запр.УстановитьПараметр("ДокументОснование", Объект.Ссылка);
		Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		             |	Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойсаПоставщика,
		             |	Инвойс.ВКД_ДатаИнвойсаПоставщика КАК ДатаИнвойсаПоставщика,
		             |	СУММА(ВЫБОР
		             |			КОГДА Инвойс.ТолькоУслуги
		             |				ТОГДА 0
		             |			ИНАЧЕ Инвойс.ВКД_Количество
		             |		КОНЕЦ) КАК Количество,
		             |	СУММА(Инвойс.Сумма) КАК Сумма,
		             |	Инвойс.Контрагент КАК Контрагент,
		             |	Инвойс.Валюта КАК Валюта,
		             |	Инвойс.Курс КАК Курс
		             |ИЗ
		             |	Документ._Инвойс КАК Инвойс
		             |ГДЕ
		             |	Инвойс.ДокументОснование = &ДокументОснование
		             |	И НЕ Инвойс.ПометкаУдаления
		             |
		             |СГРУППИРОВАТЬ ПО
		             |	Инвойс.ВКД_НомерИнвойсаПоставщика,
		             |	Инвойс.ВКД_ДатаИнвойсаПоставщика,
		             |	Инвойс.Контрагент,
		             |	Инвойс.Валюта,
		             |	Инвойс.Курс";
		Выгрузка = Запр.Выполнить().Выгрузить();
		Если Выгрузка.Количество() = 0 Тогда   
		    КэшДанных = Неопределено;
		Иначе
			КэшДанных = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выгрузка[0], "Валюта,Курс"); 
			КэшДанных.Сумма = КэшДанных.Сумма * Выгрузка[0].Курс;
		КонецЕсли; 
		
		
	Иначе
	    КэшДанных = Неопределено;
	КонецЕсли;                     
	
	КэшЦветов = Новый Структура;
    КэшЦветов.Вставить("РаскрашиватьВалюты", 	ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("РаскрашиватьВалюты"));
	КэшЦветов.Вставить("ЦветаВалют", 			ОбщегоНазначенияПовтИсп.ЦветаВалют());
    КэшЦветов.Вставить("РаскрашиватьСтатусы", 	ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("РаскрашиватьСтатусыВФормеДокумента"));
	КэшЦветов.Вставить("ЦветаСтатусов", 		ОбщегоНазначенияПовтИсп.ЦветаСтатусов());
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьРазницуИнвойсов()

	Если КэшДанных = Неопределено Тогда
		Возврат;	
	КонецЕсли;	
	
	Для каждого Эл Из КэшДанных Цикл  
		Если ТипЗнч(Эл.Значение) = Тип("Число") Тогда
			лРавны = Объект[Эл.Ключ] - Эл.Значение;
		    Если лРавны < 0 Тогда
				лРавны = - лРавны;
			КонецЕсли;
			//лРавны = лРавны < 0.01;
			лРавны = лРавны < 0.9;
		Иначе
			лРавны = Объект[Эл.Ключ] = Эл.Значение;
		КонецЕсли;
		
		Если лРавны Тогда
			Элементы["Контроль"+Эл.Ключ].Картинка = БиблиотекаКартинок.ОформлениеЗнакФлажок;	
		Иначе	
			Элементы["Контроль"+Эл.Ключ].Картинка = БиблиотекаКартинок.ОформлениеЗнакКрест;	
		КонецЕсли;	
	КонецЦикла;
	
	//лДатаОплаты = ?(Объект.Оплаты.Количество() = 0, Дата(1,1,1),  Объект.Оплаты[0].Дата); 
	//Элементы.ОплатыДата.КартинкаШапки = ?(КэшДанных.ДатаОплаты = лДатаОплаты, БиблиотекаКартинок.ОформлениеЗнакФлажок, БиблиотекаКартинок.ОформлениеЗнакКрест);
	
КонецПроцедуры

