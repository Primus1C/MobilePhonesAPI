&НаКлиенте 
Процедура ПересчитатьВалютныеСуммы(ЭлементВалюта, ЭлементКурс, ЭлементСумма, ЭлементСуммаВВалюте)
	
	Если ЭлементВалюта = гоПараметрСеанса("БазоваяВалюта") Тогда
		ЭлементСуммаВВалюте = ЭлементСумма;
	Иначе	
		Если ЭлементКурс <> 0 Тогда
			ЭлементСуммаВВалюте = ЭлементСумма / ЭлементКурс;
		КонецЕсли;
	КонецЕсли; 
	РассчитатьНедоплату();
	
КонецПроцедуры

&НаКлиенте 
Процедура ОшибкаРасчетаНедоплаты(ТекстСообщения, Недопл, Ошибка=Ложь)

	клНамекнуть("Недоплата", ТекстСообщения, БиблиотекаКартинок.ВниманиеКрасный);
	Элементы.ДекорацияНедоплата.Заголовок = СтрШаблон("%1   ???", Формат(Недопл, "ЧДЦ=2; ЧН=ОК"));
    Ошибка = Истина;
	
КонецПроцедуры	
	
&НаКлиенте 
Процедура РассчитатьНедоплату(ТолькоОтобразить=Ложь)
	
	//Элементы.КурсОплаты.Видимость =  Объект.Валюта = ВалютаОплаты 
	
	//Если КурсОплаты = 0 ИЛИ НЕ ЗначениеЗаполнено(Объект.Валюта) Тогда
	//    Элементы.Недоплата.Видимость = Ложь;
	//Иначе	 
	
		//Элементы.Недоплата.Видимость = Истина;  
		лНедоплата = Объект.Недоплата; 
		лЕстьОшибка = Ложь;
		Элементы.ДекорацияНедоплата.Заголовок = "";

		лДоллар = гоПараметрСеанса("БазоваяВалюта");
		Если Объект.Валюта = лДоллар И ВалютаОплаты_ = лДоллар Тогда
			лНедоплата = Объект.СуммаОплатыВВалютеИнвойса - Объект.Сумма;
		ИначеЕсли Объект.Валюта = ВалютаОплаты_ Тогда
			Если СуммаОплаты = Объект.Сумма Тогда
				лНедоплата = 0;	         
			ИначеЕсли БазоваяВалютаДоллар(Объект.Валюта) Тогда
				лНедоплата = (СуммаОплаты - Объект.Сумма) / гоКурс(Объект.Валюта, Объект.Фирма, Объект.Дата);
			Иначе	
				ОшибкаРасчетаНедоплаты(СтрШаблон("Расчет недоплаты невозможен: нет данных о курсах %1 - %2 !", Объект.Валюта, лДоллар), лНедоплата, лЕстьОшибка);
			КонецЕсли;
		ИначеЕсли Объект.Валюта = лДоллар Тогда
			Если КурсОплаты = 0 Тогда
				ОшибкаРасчетаНедоплаты("Невозможно рассчитать недоплату: не заполнен курс!", лНедоплата, лЕстьОшибка);
			Иначе	
				//лНедоплата = ?(КурсОплаты=0, 0, Объект.СуммаОплатыВВалютеИнвойса / КурсОплаты - Объект.Сумма );	
				лНедоплата = ?(КурсОплаты=0, 0, Объект.СуммаОплатыВВалютеИнвойса - Объект.Сумма );	
			КонецЕсли;
		ИначеЕсли ВалютаОплаты_ = лДоллар Тогда
			Если КурсОплаты = 0 Тогда
				ОшибкаРасчетаНедоплаты("Невозможно рассчитать недоплату: не заполнен курс!", лНедоплата, лЕстьОшибка);
			Иначе	
				лНедоплата = Объект.Сумма * КурсОплаты - Объект.СуммаОплатыВВалютеИнвойса;   
			КонецЕсли;    
		Иначе // не приводится к доллару
			ОшибкаРасчетаНедоплаты("Невозможно рассчитать недоплату: не заполнен курс!", лНедоплата, лЕстьОшибка);
		КонецЕсли;
		
		//Объект.Недоплата = Объект.СуммаОплатыВВалютеИнвойса - Объект.Сумма / КурсОплаты;
		//Элементы.Недоплата.ЦветРамки = ?(Объект.Недоплата=0, WebЦвета.ТемноЗеленый, WebЦвета.Красный);
		//////Если Элементы.ДекорацияНедоплата.Заголовок <> "" Тогда
		//////	Элементы.ДекорацияНедоплата.Заголовок = Формат(Объект.Недоплата, "ЧДЦ=2; ЧН=ОК"); 
		//////КонецЕсли;
	//КонецЕсли;
	
	лЦвет = ?(лНедоплата=0 И НЕ лЕстьОшибка, WebЦвета.ТемноЗеленый, WebЦвета.Красный);
	Элементы.ДекорацияНедоплата.ЦветТекста = лЦвет;
	Элементы.ДекорацияНедоплата.ЦветРамки = лЦвет;

	Если НЕ ТолькоОтобразить Тогда
		Объект.Недоплата = лНедоплата;
	КонецЕсли;

	Если НЕ лЕстьОшибка Тогда
		Элементы.ДекорацияНедоплата.Заголовок = Формат(Объект.Недоплата, "ЧДЦ=2; ЧН=ОК"); 
	КонецЕсли;
	
КонецПроцедуры

