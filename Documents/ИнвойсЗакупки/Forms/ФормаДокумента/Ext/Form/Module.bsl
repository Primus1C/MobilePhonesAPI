#Область Треки
	
&НаКлиенте
Процедура ПоказатьТреки(Команда)
	
	Элементы.ГруппаТреки.Видимость 	= истина;
    Элементы.ГруппаТТН.Видимость	= Ложь; 
	ОтобразитьКоличествоТреков();
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьТреки(Команда)

	Элементы.ГруппаТреки.Видимость 	= Ложь;
    Элементы.ГруппаТТН.Видимость	= Истина; 
    ОтобразитьКоличествоТреков();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьКоличествоТреков()

	Элементы.ПоказатьТреки.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Треки'; en = 'Tracks'"), Объект.Треки.Количество());	

КонецПроцедуры

&НаКлиенте
Процедура ТрекиПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	Если Объект.Треки.Количество() > 0 Тогда
		Объект.Авианакладная = Объект.Треки[0].Трек;
		Объект.ДатаТТН = Объект.Треки[0].Дата;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТрекиПослеУдаления(Элемент)

	Если Объект.Треки.Количество() = 0 Тогда
		Объект.Авианакладная = "";
		Объект.ДатаТТН = Дата(1,1,1);	
	Иначе	
		Объект.Авианакладная = Объект.Треки[0].Трек;
		Объект.ДатаТТН = Объект.Треки[0].Дата;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура АвианакладнаяПриИзменении(Элемент)
	
	Если Объект.Треки.Количество() = 0 Тогда
   		СтрокаТЧ = Объект.Треки.Добавить();
	Иначе
		СтрокаТЧ = Объект.Треки[0];
	КонецЕсли;
	СтрокаТЧ.Трек = Объект.Авианакладная;
	
	Если НЕ ЗначениеЗаполнено(Объект.Авианакладная) И Объект.ДатаТТН = Дата(1,1,1) Тогда
		Если Объект.Треки.Количество() > 0 Тогда
		 	Объект.Треки.Удалить(0);
			ТрекиПослеУдаления(Неопределено);
		    ОтобразитьКоличествоТреков();
			клНамекнуть(НСтр("ru = 'Удаление данных'; en = 'Data deleting'"), НСтр("ru = 'Один трек удален из табличной части!'; en = 'One track has been removed from the tabular section!'"),  БиблиотекаКартинок.УдалитьЭлементСписка);
		КонецЕсли;;
	КонецЕсли;   
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаТТНПриИзменении(Элемент)

	Если Объект.Треки.Количество() = 0 Тогда
   		СтрокаТЧ = Объект.Треки.Добавить();
	Иначе
		СтрокаТЧ = Объект.Треки[0];
	КонецЕсли;
	СтрокаТЧ.Дата = Объект.ДатаТТН;
	
КонецПроцедуры

#КонецОбласти