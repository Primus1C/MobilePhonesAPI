&НаКлиенте
Процедура КонтрольНажатие(Элемент)  
	
	Если КэшДанных = Неопределено Тогда
		Возврат;	
	КонецЕсли;	
	
	Ключ = СтрЗаменить(Элемент.Имя, "Контроль", ""); 
	Если ТипЗнч(КэшДанных[Ключ]) = Тип("Дата") Тогда 
		Если КэшДанных[Ключ] = Дата(1,1,1) Тогда
		  	лЗнач = НСтр("ru = '<не задана>'; en = '<not specified>'");
		Иначе
			лЗнач = Формат(КэшДанных[Ключ], "ДФ=dd.MM.yyyy");
		КонецЕсли;
	Иначе
	   лЗнач = КэшДанных[Ключ] 
	КонецЕсли;
	 
	Сообщить(Элемент.Заголовок + НСтр("ru = ' в инвойсе: '; en = ' in invoice: '") + лЗнач, СтатусСообщения.Информация);  
	
КонецПроцедуры

