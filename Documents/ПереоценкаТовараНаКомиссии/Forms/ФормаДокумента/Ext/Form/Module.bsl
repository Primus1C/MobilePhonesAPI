#Область ДействияТабличнойЧасти

&НаКлиенте
Процедура ТоварыСерияПриИзменении(Элемент)
	
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	
	СписокПартий = ОстаткиПартий(ТекДанные.Серия);        
	КолвоПартий = СписокПартий.Количество();
	Если КолвоПартий = 0 Тогда
		Сигнал();
		клОшибка("Нет остатков по серии: " + ТекДанные.Серия + "!");
		Возврат;
	ИначеЕсли КолвоПартий > 1 Тогда
		Сигнал();
		ВыбратьВариант(СписокПартий);
	Иначе
		//ТекПартия = СписокПартий[0]; 
		ЗаполнитьРеквизитыПоСерии(ТекДанные, СписокПартий.Получить(0).Значение); 
	КонецЕсли;
	
КонецПроцедуры   
 
&НаКлиенте
Процедура ЗаполнитьРеквизитыПоСерии(СтрокаТЧ, СтруктураДанных)
	
	СтрокаТЧ.Номенклатура 	= СтруктураДанных.Номенклатура;
	СтрокаТЧ.Партия 		= СтруктураДанных.Партия;  
	СтрокаТЧ.Цена 			= СтруктураДанных.СуммаКомиссионера / СтруктураДанных.Количество;
	СтрокаТЧ.Количество 	= 1;
	
    ЗаполнитьСтарыеЦены();

КонецПроцедуры

&НаСервере
Функция ОстаткиПартий(Серия)
	
	спис = Новый СписокЗначений;
	ТаблицаПартий =	Комиссия.ОстаткиПартийНаКомиссии(Серия, Объект.Ссылка.МоментВремени(), Объект.Фирма, Объект.СкладКомиссии);
	Для каждого парт Из ТаблицаПартий Цикл
		СтруктураПартии = Новый Структура("Номенклатура,ИмяНоменклатуры,Партия,Количество,Сумма,СуммаКомиссионера");
		ЗаполнитьЗначенияСвойств(СтруктураПартии, парт);
		спис.Добавить(СтруктураПартии, парт.ИмяНоменклатуры);	
	КонецЦикла;	
    Возврат спис;
	
КонецФункции 

&НаКлиенте
Процедура ВыбратьВариант(СписокВариантов) Экспорт

	// Создаем описание оповещения. 
	// 1-й параметр: Имя процедуры, которая сработает после закрытия
	// 2-й параметр: Модуль, где находится эта процедура (ЭтаФорма)
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ПослеЗакрытияФормыВыбораВарианта", ЭтаФорма);
	
	// Открываем форму. ОписаниеОповещения передается 7-м параметром  
	ПараметрыОткрытия = Новый Структура("Список, Заголовок", СписокВариантов, НСтр("ru = 'Выберите партию'; en = 'Select tha batch'"));
	ОткрытьФорму("ОбщаяФорма.ВыборПростогоВарианта", ПараметрыОткрытия, ЭтаФорма, , , , ОповещениеОЗакрытии);	

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыВыбораВарианта(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия <> Неопределено Тогда
		ЗаполнитьРеквизитыПоСерии(Элементы.Товары.ТекущиеДанные, РезультатЗакрытия.ВыбранноеЗначение)
	КонецЕсли;
	
КонецПроцедуры



#КонецОбласти 


&НаСервере
Процедура ЗаполнитьСтарыеЦены()
	
	Соотв = Новый Соответствие;
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ТоварыНаКомиссии.СуммаКомиссионераОстаток / ТоварыНаКомиссии.КоличествоОстаток КАК Цена,
	             |	ТоварыНаКомиссии.Партия КАК Партия
	             |ИЗ
	             |	РегистрНакопления.ТоварыНаКомиссии.Остатки(&Дата, Партия В (&Партии)) КАК ТоварыНаКомиссии";
	Запр.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка.МоментВремени(), ТекущаяДатаСеанса()));
	Запр.УстановитьПараметр("Партии", объект.Товары.Выгрузить().ВыгрузитьКолонку("Партия"));	
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Соотв.Вставить(Выборка.Партия, Выборка.Цена);
	КонецЦикла;
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		Цена = Соотв.Получить(СтрокаТЧ.Партия);	
		Если Цена = Неопределено Тогда
			СтрокаТЧ.ЦенаСтарая = 0;
		Иначе	
			СтрокаТЧ.ЦенаСтарая = Цена;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры


#Область Команды
	
&НаКлиенте
Процедура ЗагрузитьИзЭкселя(Команда)
	
	Загрузка = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    Загрузка.ПолноеИмяФайла = "";
    Загрузка.Фильтр = ("Файлы xlsx | *.xlsx");
    Загрузка.МножественныйВыбор = ложь;
    Загрузка.Заголовок = "Выберите файл";
    Оп = Новый ОписаниеОповещения("ЗавершениеВыбораФайла", ЭтаФорма);  
    Загрузка.Показать(Оп);

КонецПроцедуры   

&НаКлиенте
Процедура ЗавершениеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры)Экспорт
	
	Если ВыбранныеФайлы <> Неопределено Тогда
        Если ВыбранныеФайлы.Количество() > 0 Тогда
            ИмяФайла = ВыбранныеФайлы[0];
            Ог = Новый ОписаниеОповещения("ЗавершениеЗагрузкиФайла", ЭтаФорма);
            НачатьПомещениеФайлаНаСервер(Ог,,,,ИмяФайла, УникальныйИдентификатор);
        КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ЗавершениеЗагрузкиФайла(ОписаниеПомещенногоФайла, ДополнительныеПараметры)Экспорт
    Если ОписаниеПомещенногоФайла <> Неопределено Тогда
        ИмпортВТабЧасть(ОписаниеПомещенногоФайла.Адрес);        
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ИмпортВТабЧасть(АдресФайла)  
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресФайла) Тогда 
		Возврат;
	КонецЕсли;
	
    ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла);
    ИмяВремФайла = ПолучитьИмяВременногоФайла("xlsx");
    ДвоичныеДанные.Записать(ИмяВремФайла);
    табДок = Новый ТабличныйДокумент;
    
    Попытка
        табДок.Прочитать(ИмяВремФайла);
	Исключение
		Сообщить(ОписаниеОшибки());
        Возврат;
	КонецПопытки;
	
    фЧитаем = Истина;
    СЧ = 2;
    Пока фЧитаем Цикл         
		
		Попытка
			СтрокаТЧ = Объект.Товары.Добавить(); 
			ПустаяСтрока = Истина;
			Для каждого Настр Из НастройкиЗагрузки Цикл
				АдресЯчейки = СтрШаблон("R%1C%2:R%1C%2", Формат(СЧ,"ЧГ="), Формат(Настр.НомерКолонки,"ЧГ="));
				ЗначЯчейки = Строка(табДок.ПолучитьОбласть(АдресЯчейки).ТекущаяОбласть.Текст); 
				Если ЗначениеЗаполнено(ЗначЯчейки) Тогда   
					ПустаяСтрока = Ложь;
					Если Настр.ЭтоЧисло Тогда
						СтрокаТЧ[Настр.ИмяПоля] = Число(СтрЗаменить(ЗначЯчейки," ",""));	
					Иначе	
						СтрокаТЧ[Настр.ИмяПоля] = ЗначЯчейки;	
					КонецЕсли; 
				КонецЕсли;  
			КонецЦикла;
			
			Если ПустаяСтрока Тогда
			    Объект.Товары.Удалить( Объект.Товары.Количество()-1);
				фЧитаем = Ложь;	
			КонецЕсли;
        Исключение
            Сообщение        = Новый СообщениеПользователю;
            Сообщение.Текст   = "Не удалось загрузить строку " + Строка(сч) + ОписаниеОшибки();
            Сообщение.Сообщить();
        КонецПопытки;
        СЧ = СЧ + 1; 
	КонецЦикла;
	
	Соотв = Новый Соответствие;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Серии", Объект.Товары.Выгрузить().ВыгрузитьКолонку("Серия"));
	Запр.Текст = "ВЫБРАТЬ
	             |	Партии.Владелец КАК Номенклатура,
	             |	Партии.Серия КАК Серия,
	             |	Партии.Ссылка КАК Партия
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Серия В(&Серии)";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Соотв.Вставить(Выборка.Серия, Новый Структура("Номенклатура,Партия", Выборка.Номенклатура, Выборка.Партия));
	КонецЦикла;  
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		ЗначенияСерии = Соотв.Получить(СтрокаТЧ.Серия);
		Если ЗначенияСерии <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, ЗначенияСерии);
		КонецЕсли;
	КонецЦикла;	
	
	ЗаполнитьСтарыеЦены();
	 
КонецПроцедуры

#КонецОбласти


#Область РаботаСоШтрихкодом

&НаКлиенте
Процедура ЛюбаяСерия(ШК, СтатьНаРучной = Ложь) 
	
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	//Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	//МоиИтоги(Объект.Товары.Количество()-1);
	Если НЕ ЗначениеЗаполнено(ШК) Тогда
		Возврат;
	КонецЕсли;
	
	Ошибки = Новый СписокЗначений;  
	Если НЕ ЗначениеЗаполнено(Объект.СкладКомиссии) Тогда
		Ошибки.Добавить("Не выбран склад комиссии");
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Ошибки.Добавить("Не выбран контрагент");
	КонецЕсли; 
	Если Ошибки.Количество() > 0  Тогда
		Для каждого ош Из Ошибки Цикл
		    Сообщить(ош.Значение);
		КонецЦикла;
		Возврат;
	КонецЕсли;
	СписокПартий = омСервер.ПартииПоСерииОстатки(ШК, Объект.Фирма, Объект.СкладКомиссии);
	
	КолвоПартий = СписокПартий.Количество();
	Если КолвоПартий = 0 Тогда
		Сигнал();
		клОшибка("Нет остатков по серии: " + ШК + "!");
		Возврат;
	ИначеЕсли КолвоПартий > 1 Тогда
		Сигнал();
		Эле = СписокПартий.ВыбратьЭлемент("Найдено несколько партий с такой серией, выберите:");
		Если Эле = Неопределено Тогда Возврат КонецЕсли;
		ТекПартия = Эле.Значение;
	Иначе
		ТекПартия = СписокПартий[0].Значение;
	КонецЕсли; 
	
	НовНоменклатура = гоРеквизит(ТекПартия, "Владелец");
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНоменклатура;
	НовСтр.Партия 		= ТекПартия;  
	НовСтр.Серия 		= гоРеквизит(ТекПартия, "Серия");
	НовСтр.ЦенаСтарая 	= гоРеквизит(ТекПартия, "ЦенаЗакупки");
	НовСтр.Количество 	= 1;
	
	//гоЗаписьЖурналаРегистрации(ШК + "|" + Строка(НовКол) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = НовСтр.ПолучитьИдентификатор();
	
	Если СтатьНаРучной Тогда 
		РучнойШК = "";
		ПодключитьОбработчикОжидания("ОжиданиеШК", 0.1, Истина);
	КонецЕсли;  
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОжиданиеШК()
	
	ЭтаФорма.ТекущийЭлемент = Элементы.РучнойШК;
	
