							НСтр("ru='Приходная накладная (без серий)';en='Incoming waybill (no series)'"), 
							НСтр("ru='Приходная накладная (по сериям)';en='Incoming waybill (with series)'"));		

КонецФункции 

Процедура ПечатьДокумента(ДокСсылка, ВариантПечатнойФормы, ТабДокумент, Параметры = 0) Экспорт
	
	ТабДокумент.Очистить();  

	Если РольДоступна("Администратор") ИЛИ РольДоступна("ЗакупкаПродажаВозврат") ИЛИ РольДоступна("Бухгалтерия") ИЛИ РольДоступна("МетреонПолный") Тогда
		ИмяМакета = "НакладнаяСуммы";
	Иначе
		ИмяМакета = "НакладнаяБезСумм";
	КонецЕсли;
	Макет = Документы.ПриходнаяНакладная.ПолучитьМакет(ИмяМакета);
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", ДокСсылка);
	Запр.УстановитьПараметр("ПредставлениеДокумента",  ОбщегоНазначения.ПредставлениеДокументаДляПечати(ДокСсылка, ));
	Запр.Текст = "ВЫБРАТЬ
	             |	Накладная.Номер КАК Номер,
	             |	Накладная.Дата КАК Дата,
	             |	Накладная.Контрагент КАК Контрагент,
	             |	Накладная.Фирма.ПолнНаименование КАК Покупатель,
	             |	Накладная.Сумма КАК Сумма,
	             |	Накладная.Валюта КАК Валюта,
	             |	Накладная.Склад КАК Склад,
	             |	Накладная.ВКД_Количество КАК Количество,
	             |	Накладная.Поставка КАК Поставка,
	             |	ВЫРАЗИТЬ(Накладная.Примечание КАК СТРОКА(1000)) КАК Примечание,
	             |	&ПредставлениеДокумента КАК ПредставлениеДокумента
	             |ИЗ
	             |	Документ.ПриходнаяНакладная КАК Накладная
	             |ГДЕ
	             |	Накладная.Ссылка = &Ссылка
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	0 КАК Ном,
	             |	Товары.Ссылка.Валюта КАК Валюта,
	             |	Товары.Номенклатура КАК Номенклатура,
	             |	Товары.Серия КАК Серия,
	             |	Товары.ЦенаЗакупки КАК Цена,
	             |	Товары.Количество КАК Количество,
	             |	Товары.СуммаЗакупки КАК Сумма
	             |ИЗ
	             |	Документ.ПриходнаяНакладная.Товары КАК Товары
	             |ГДЕ
	             |	Товары.Ссылка = &Ссылка
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Номенклатура,
	             |	Серия,
	             |	Цена";   
	ОбщегоНазначенияСервер.УстановитьПредставлениеКонтрагентаВЗапросе(Запр.Текст, "Накладная.Контрагент");	
	РезультатЗапроса = Запр.ВыполнитьПакет();
	
	Шапка = РезультатЗапроса[0].Выбрать();
	Шапка.Следующий(); 
	ВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка); 

	Выгрузка = РезультатЗапроса[1].Выгрузить();
	Если ВариантПечатнойФормы = "ПоСериям" Тогда  
		Если ИмяМакета = "НакладнаяСуммы" Тогда
			Поля = ",Серия,Цена"; 
		Иначе
			Поля = ",Серия"; 
		КонецЕсли;
	Иначе
		Если ИмяМакета = "НакладнаяСуммы" Тогда
			Поля = ",Цена"; 
		Иначе
			Поля = ""; 
		КонецЕсли;	
	КонецЕсли;  
	Выгрузка.Свернуть("Валюта,Номенклатура" + Поля, "Ном,Количество,Сумма");
	
	Товары = Выгрузка.Скопировать(); 
	Если ИмяМакета = "НакладнаяСуммы" Тогда
		Товары.Свернуть("Ном,Валюта,Номенклатура,Цена", "Количество,Сумма");
	Иначе
		Товары.Свернуть("Ном,Валюта,Номенклатура", "Количество");
	КонецЕсли;
	
	Ном = 0;
	ТабДокумент.НачатьАвтогруппировкуСтрок();
	Для каждого СтрокаТовар Из Товары Цикл 
		Ном = Ном + 1;
		СтрокаТовар.Ном = Ном;	
		ВывестиСекцию(ТабДокумент, Макет, "Строка", СтрокаТовар, 1);
		Если ВариантПечатнойФормы = "ПоСериям" Тогда
			Если ИмяМакета = "НакладнаяСуммы" Тогда
				Отбор = Новый Структура("Номенклатура,Цена", СтрокаТовар.Номенклатура, СтрокаТовар.Цена)	
			Иначе
				Отбор = Новый Структура("Номенклатура", СтрокаТовар.Номенклатура)	
			КонецЕсли;	
			СтрокиСерии = Выгрузка.НайтиСтроки(Отбор);
			Для каждого НайдСтрока Из СтрокиСерии Цикл
				ВывестиСекцию(ТабДокумент, Макет, "Серия", НайдСтрока, 2);
			КонецЦикла;   
	    КонецЕсли;
	КонецЦикла;	
	ТабДокумент.ЗакончитьАвтогруппировкуСтрок();
	
	ОбластьДно = Макет.ПолучитьОбласть("Дно");
	ОбластьДно.Параметры.Заполнить(Шапка);
	ОбластьДно.Параметры.СуммаПрописью = гоСуммаПрописьюВал(Шапка.Сумма, Шапка.Валюта);
	ТабДокумент.Вывести(ОбластьДно);
	
КонецПроцедуры

Функция ЗатратыОтправки(Инвойс, Поставка) Экспорт

 	СоотвЗатрат = Новый Соответствие; 
	Если НЕ ЗначениеЗаполнено(Инвойс) Тогда
		Возврат СоотвЗатрат;
	КонецЕсли;
	 Запр = Новый Запрос; 
	 Запр.УстановитьПараметр("Инвойс", 		Инвойс);
	 Запр.УстановитьПараметр("Поставка", 	Поставка);
	 Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	              |	ОтправкаРаспределениеЗатрат.Номенклатура КАК Номенклатура,
	              |	ОтправкаРаспределениеЗатрат.Цена КАК Цена
	              |ИЗ
	              |	Документ.Отправка.РаспределениеЗатрат КАК ОтправкаРаспределениеЗатрат
	              |ГДЕ
	              |	ОтправкаРаспределениеЗатрат.Ссылка В
	              |			(ВЫБРАТЬ
	              |				ОтправкаИнвойсы.Ссылка
	              |			ИЗ
	              |				Документ.Отправка.Инвойсы КАК ОтправкаИнвойсы
	              |			ГДЕ
	              |				ОтправкаИнвойсы.Инвойс = &Инвойс
	              |				И ОтправкаИнвойсы.Поставка = &Поставка
	              |				И ОтправкаИнвойсы.Ссылка.Проведен)"; 
	 Выборка = Запр.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
		СоотвЗатрат.Вставить(Выборка.Номенклатура, Выборка.Цена); 
	 КонецЦикла;
	 
	 Возврат СоотвЗатрат;

КонецФункции

Процедура ВывестиСекцию(Таб, Макет, Область, Параметры, Уровень=Неопределено) 
	Ш = Макет.ПолучитьОбласть(Область); 
	Ш.Параметры.Заполнить(Параметры);  
	Если Уровень=Неопределено Тогда
		Таб.Вывести(Ш);
	Иначе
		Таб.Вывести(Ш, Уровень);
	КонецЕсли;
КонецПроцедуры

