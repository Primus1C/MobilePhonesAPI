// Функция проверяет остатки вне зависимости от даты
// (чтобы задним числом нельзя было сделать повторное оприходование).
// Поставка=0 -- для инвойсов, не разделенных на поставки
Функция НеоприходованныеТоварыИнвойса(СсылкаИнвойс, Поставка=0) Экспорт
	
	Результат = Новый Структура("ЕстьНеоприходованныеТовары", Ложь); 
	
	ПоставкиИсх = Новый Соответствие;
	ЗапрП = Новый Запрос; 
	ЗапрП.УстановитьПараметр("Инвойс",   СсылкаИнвойс);
	ЗапрП.Текст = "ВЫБРАТЬ
	              |	СУММА(_ИнвойсПоставки.Количество) КАК Количество,
	              |	_ИнвойсПоставки.Поставка КАК Поставка
	              |ИЗ
	              |	Документ._Инвойс.Поставки КАК _ИнвойсПоставки
	              |ГДЕ
	              |	_ИнвойсПоставки.Ссылка = &Инвойс
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	_ИнвойсПоставки.Поставка";
	ВыборкаП = ЗапрП.Выполнить().Выбрать();
    Пока ВыборкаП.Следующий() Цикл
		ПоставкиИсх.Вставить(ВыборкаП.Поставка, ВыборкаП.Количество);	
	КонецЦикла;
	
	Запр = Новый Запрос; 
	Запр.УстановитьПараметр("Инвойс",   СсылкаИнвойс);
	Запр.Текст = "ВЫБРАТЬ
	             |	ОприходНоменклатуры.Поставка КАК Поставка,
	             |	ОприходНоменклатуры.Номенклатура КАК Номенклатура,
	             |	ОприходНоменклатуры.КоличествоОстаток КАК Количество,
	             |	ОприходНоменклатуры.СуммаЗакупкиОстаток КАК СуммаЗакупки,
	             |	ОприходНоменклатуры.СуммаСоСкидкойОстаток КАК СуммаСоСкидкой
	             |ИЗ
	             |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Остатки(
	             |			,
	             |			Документ = &Инвойс
	             |				И ИСТИНА = ИСТИНА) КАК ОприходНоменклатуры
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Поставка";
	Если Поставка <> 0 Тогда 
		Запр.Текст = СтрЗаменить(Запр.Текст, "ИСТИНА = ИСТИНА", "Поставка = &Поставка");
		Запр.УстановитьПараметр("Поставка", Поставка);
	КонецЕсли;
	
	КоличествоНеоприходованныхПоставок = 0;  
	масПоставки = Новый Массив;
	Выгрузка = Запр.Выполнить().Выгрузить(); 
	НачПоставка = ?(СсылкаИнвойс.КоличествоПоставок=0, 0, 1);
	Для П = НачПоставка По СсылкаИнвойс.КоличествоПоставок Цикл
		НайдСтроки = Выгрузка.НайтиСтроки(Новый Структура("Поставка", П)); 
		масТоваров = Новый Массив;
		лКоличество = 0;
		Для каждого НайдСтрока Из НайдСтроки Цикл
			масТоваров.Добавить(Новый Структура("Номенклатура, Количество, СуммаЗакупки, СуммаСоСкидкой", 
												НайдСтрока.Номенклатура, НайдСтрока.Количество, НайдСтрока.СуммаЗакупки, НайдСтрока.СуммаСоСкидкой)); 
			лКоличество = лКоличество + НайдСтрока.Количество;
		КонецЦикла;   
		масПоставки.Добавить(Новый Структура("НомерПоставки, Количество, КоличествоИсх, Товары", П, лКоличество, ПоставкиИсх.Получить(П), масТоваров)); 
		Если лКоличество > 0 Тогда
			Результат.Вставить("ЕстьНеоприходованныеТовары", Истина);
			Результат.Вставить("НомерНеоприходованнойПоставки", П);
			КоличествоНеоприходованныхПоставок = КоличествоНеоприходованныхПоставок + 1;
		КонецЕсли;
	КонецЦикла;
	Результат.Вставить("КоличествоНеоприходованныхПоставок", КоличествоНеоприходованныхПоставок);
	Результат.Вставить("Поставки", масПоставки);
	
	Возврат Результат; 
	
КонецФункции 

