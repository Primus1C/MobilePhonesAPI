#Если Сервер Тогда
	
Процедура ПечатьДокумента_(Тек, Поз, Таб, Параметры = 0) Экспорт
	
	Таб.Очистить();
	
	М = Документы.ПриходнаяНакладная.ПолучитьМакет("Печать");
	С = Новый Структура;
	гоВставитьКучу(С, "Загол, ИмяПокупателя1, ИмяПокупателя2, ИмяПокупателя3, ИмяПоставщика1, ИмяПоставщика2, ИмяПоставщика3, ИмяПоставщика4, ИмяПоставщика5, ИмяПоставщика6");
	гоВставитьКучу(С, "ИмяСклада, ДопНомера, НомерПП, лНоменклатура, лЕИ, лКоличество, лЦена, лСумма, сКоличество, СтрСНДС");
	гоВставитьКучу(С, "лВалюта");
	//2016.04.07
	гоВставитьКучу(С, "лСерия");
	
	С.Загол = "Приходная накладная № " + Тек.Номер + " от " + гоДата(Тек.Дата);
	С.ИмяСклада = "";
	С.ИмяПоставщика1 = "";
	С.ИмяПоставщика2 = "";
	С.ИмяПоставщика3 = "";
	С.ИмяПоставщика4 = "";
	С.ИмяПоставщика5 = "";
	С.ИмяПоставщика6 = "";
	С.ИмяПокупателя1 = "";
	С.ИмяПокупателя2 = "";
	С.ИмяПокупателя3 = "";

	Если гоНПЗ(Тек.Контрагент) Тогда        
		Если РольДоступна("ЧтениеИзменениеНаименованийКонтрагентов") Тогда
			С.ИмяПоставщика1 = СокрЛП(Тек.Контрагент.ПолнНаименование);
			Если С.ИмяПоставщика1 = "" Тогда С.ИмяПоставщика1 = СокрЛП(Тек.Контрагент.Наименование) КонецЕсли;
		Иначе
			С.ИмяПоставщика1 = СокрЛП(Тек.Контрагент.Псевдоним);
			Если С.ИмяПоставщика1 = "" Тогда С.ИмяПоставщика1 = СокрЛП(Тек.Контрагент.Псевдоним) КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если гоНПЗ(Тек.Фирма) Тогда
		С.ИмяПокупателя1 = СокрЛП(Тек.Фирма.ПолнНаименование);
	КонецЕсли;
	
	Фикс = 4;
	ВывестиСекцию(Таб, М, "ШапкаП1", С); гоПлюс(Фикс);
	Если С.ИмяПоставщика2 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП2", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика3 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП3", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика4 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП4", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика5 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП5", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика6 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП6", С); гоПлюс(Фикс); КонецЕсли;
	ВывестиСекцию(Таб, М, "ШапкаК1", С); гоПлюс(Фикс);
	Если С.ИмяПокупателя2 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаК2", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПокупателя3 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаК3", С); гоПлюс(Фикс); КонецЕсли;
	
	ВывестиСекцию(Таб, М, "Шапка", С);
	
	Табл = Тек.Товары.Выгрузить();
	
	//2016.04.07
	Если Поз = 2 Тогда 
		Сабл = Табл.Скопировать();
		Сабл.Свернуть("Номенклатура, ЦенаЗакупки, Серия", "Количество, СуммаЗакупки");
		Сабл.Сортировать("Номенклатура ВОЗР, ЦенаЗакупки ВОЗР, Серия ВОЗР");
		Сабл.Индексы.Добавить("Номенклатура, ЦенаЗакупки");
	КонецЕсли; 
	
	Табл.Свернуть("Номенклатура, ЦенаЗакупки", "Количество, СуммаЗакупки");
	
	С.лВалюта = СокрЛП(Тек.Валюта);
	
	ЧислоЗнаковЦена = Тек.Фирма.ЧислоЗнаковЦенаЗакупки;
	
	НомерПП = 0;
	Для Каждого _Табл Из Табл Цикл
		гоПлюс(НомерПП);
		
		С.лНоменклатура = гоИмя(_Табл.Номенклатура, Ложь);
		С.НомерПП = НомерПП;
		С.лЕИ = "шт.";
		С.лКоличество = _Табл.Количество;
		С.лЦена = гоСуммаЗн(_Табл.ЦенаЗакупки, ЧислоЗнаковЦена);
		С.лСумма = гоЦена2(_Табл.СуммаЗакупки);
		
		ВывестиСекцию(Таб, М, "Строка", С);
		
		//2016.04.07
		Если Поз = 2 Тогда
			Мас = Сабл.НайтиСтроки(Новый Структура("Номенклатура, ЦенаЗакупки", _Табл.Номенклатура, _Табл.ЦенаЗакупки));
			Для Каждого _Сабл Из Мас Цикл
				С.лСерия = _Сабл.Серия;
				С.лКоличество = _Сабл.Количество;
				ВывестиСекцию(Таб, М, "СтрокаС", С);
			КонецЦикла; 
		КонецЕсли; 
	КонецЦикла;
	
	С.лКоличество = Табл.Итог("Количество");
	С.лСумма = гоЦена2(Тек.Сумма);
	С.СтрСНДС = гоСуммаПрописьюВал(Тек.Сумма, Тек.Валюта);
		
	ВывестиСекцию(Таб, М, "Подвал", С);
	
	глПараметрыСтраницы(Таб, 1);
	глПовторятьПриПечатиСтроки(Таб, Фикс, Фикс); 
	
КонецПроцедуры

