Процедура ПроверкаВозможностиПроведения(ТаблицаТоваров, Отказ)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	              |	ПриходнаяНакладнаяТовары.Номенклатура,
	              |	СУММА(ПриходнаяНакладнаяТовары.Количество) КАК Количество
	              |ПОМЕСТИТЬ ВТ
	              |ИЗ
	              |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	              |ГДЕ
	              |	ПриходнаяНакладнаяТовары.Ссылка = &Ссылка
	              |	И НЕ ПриходнаяНакладнаяТовары.Ссылка.ПометкаУдаления
	              |	И ПриходнаяНакладнаяТовары.Ссылка.Проведен
	              |
	              |СГРУППИРОВАТЬ ПО
	              |	ПриходнаяНакладнаяТовары.Номенклатура
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	ВТ.Номенклатура,
	              |	ВТ.Количество,
	              |	ЕСТЬNULL(ВКД_ОприходованиеНоменклатурыОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
	              |	ЕСТЬNULL(ВКД_ОприходованиеНоменклатурыОстатки.СуммаСоСкидкойОстаток, 0) КАК СуммаСоСкидкойОстаток,
	              |	ЕСТЬNULL(ВКД_ОприходованиеНоменклатурыОстатки.СуммаЗакупкиОстаток, 0) КАК СуммаЗакупкиОстаток
	              |ИЗ
	              |	ВТ КАК ВТ
	              |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Остатки(
	              |				&Период,
				  |				Документ = &Инвойс И	
	              |				Номенклатура В
	              |					(ВЫБРАТЬ
	              |						ВТ.Номенклатура
	              |					ИЗ
	              |						ВТ КАК ВТ)) КАК ВКД_ОприходованиеНоменклатурыОстатки
	              |		ПО ВТ.Номенклатура = ВКД_ОприходованиеНоменклатурыОстатки.Номенклатура" ;
	Запрос.УстановитьПараметр("Инвойс", ВКД_Инвойс);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	//МоментИтогов = ?(РежимПроведения = РежимПроведенияДокумента.Оперативный, Неопределено, МоментВремени());
	МоментИтогов = МоментВремени();
	Запрос.УстановитьПараметр("Период", МоментИтогов);
	РезультатЗапроса = Запрос.Выполнить();  
	ТаблицаТоваров = РезультатЗапроса.Выгрузить();

	Если ЗначениеЗаполнено(ВКД_Инвойс) Тогда 
		
		Выборка = РезультатЗапроса.Выбрать(); 
		Пока Выборка.Следующий() Цикл
			Если Выборка.Количество > Выборка.КоличествоОстаток Тогда  
				Отказ = Истина;      
				//+
				// проверим на пересорт с инвойсом
				ТекстПересорта = "";
				Если ЗначениеЗаполнено(ВКД_Инвойс) Тогда          
					ТекстПересорта = ВозможенПересорт(Выборка.Номенклатура);
					Если ТекстПересорта <> "" Тогда
						ТекстПересорта = НСтр("ru = 'В инвойсе указана похожая номенклатура: '; en = 'The invoice indicates a similar good: '") + ТекстПересорта; 				
					КонецЕсли;
				КонецЕсли;
				//-
				Сообщение = Новый СообщениеПользователю;
				//Сообщение.Текст = "Не хватает номенклатуры: " + Выборка.Номенклатура + " для оприходования в количестве " + СокрЛП(Выборка.Количество - Выборка.КоличествоОстаток) + " шт!";
				Сообщение.Текст = СтрШаблон(НСтр("ru = 'Не хватает номенклатуры: %1 для оприходования в количестве %2 шт!'; en = 'There is not enough %2 items: %1 for capitalization!'"),Выборка.Номенклатура,СокрЛП(Выборка.Количество - Выборка.КоличествоОстаток));
				Если ТекстПересорта <> "" Тогда
					Сообщение.Текст  = Сообщение.Текст + Символы.ПС + ТекстПересорта;
				КонецЕсли;
				Сообщение.Сообщить();
			КонецЕсли;
		КонецЦикла;
		Если Отказ И ПараметрыСеанса.БезусловноеПроведениеДокументов Тогда
			Отказ = Ложь;      
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Документ проведен, несмотря на ошибки!'; en = 'The document was posted despite the error(s)!'");
			Сообщение.Сообщить();
		КонецЕсли;  
		
	КонецЕсли;	
	
КонецПроцедуры

