Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)   
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;  
	
	Если глЗапретЗаписиПоДате(Ссылка) Тогда Отказ = Истина; Возврат; КонецЕсли;
	
	омСервер.ЗаписатьОбщиеРеквизиты(ЭтотОбъект);
	
	// © Primus1C  17.09.2024  НАЧАЛО ►  
	
	// 0. Перезаполним цены из инвойса

	Если ЗначениеЗаполнено(ВКД_Инвойс) Тогда
	
		Запр = Новый Запрос;
		Запр.УстановитьПараметр("Регистратор", ВКД_Инвойс);
		Запр.УстановитьПараметр("Поставка", Поставка);
		Запр.Текст = "ВЫБРАТЬ
		             |	ВКД_ОприходованиеНоменклатуры.Номенклатура КАК Номенклатура,
		             |	ВКД_ОприходованиеНоменклатуры.ЦенаЗакупки КАК ЦенаЗакупки,
		             |	ВКД_ОприходованиеНоменклатуры.ЦенаСоСкидкой КАК ЦенаСоСкидкой
		             |ИЗ
		             |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ВКД_ОприходованиеНоменклатуры
		             |ГДЕ
		             |	ВКД_ОприходованиеНоменклатуры.Регистратор = &Регистратор
		             |	И ВКД_ОприходованиеНоменклатуры.Поставка = &Поставка";
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НайдСтроки = Товары.НайтиСтроки(Новый Структура("Номенклатура", Выборка.Номенклатура));
			Для каждого СтрокаТЧ Из НайдСтроки Цикл
				Если СтрокаТЧ.ЦенаЗакупки <> Выборка.ЦенаЗакупки Тогда
					СтрокаТЧ.ЦенаЗакупки = Выборка.ЦенаЗакупки; 
					СтрокаТЧ.СуммаЗакупки = СтрокаТЧ.ЦенаЗакупки * СтрокаТЧ.Количество;
				КонецЕсли;
				Если СтрокаТЧ.ВКД_ЦенаСоСкидкой <> Выборка.ЦенаСоСкидкой Тогда
					СтрокаТЧ.ВКД_ЦенаСоСкидкой = Выборка.ЦенаСоСкидкой;	
					СтрокаТЧ.СуммаЗакупкиСоСкидкой = СтрокаТЧ.ВКД_ЦенаСоСкидкой * СтрокаТЧ.Количество;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;

	КонецЕсли;	
	
	// 1. Распределим в ТЧ затраты "док-тов доп.затрат"
	
	//ТаблицаТовары = Товары.Выгрузить();  
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Приходная", Ссылка);	
	Запрос.УстановитьПараметр("ДопЗатраты", Затраты.Выгрузить(,"ДокументЗатрат").ВыгрузитьКолонку(0));	
	Запрос.Текст = "ВЫБРАТЬ 
	               |	ЕСТЬNULL(СУММА(ВКД_ДополнительныеЗатратыДокументы.СуммаНаценки), 0) КАК СуммаНаценки
	               |ИЗ
	               |	Документ.ВКД_ДополнительныеЗатраты.Документы КАК ВКД_ДополнительныеЗатратыДокументы
	               |ГДЕ
	               |	ВКД_ДополнительныеЗатратыДокументы.Ссылка В(&ДопЗатраты)
	               |	И ВКД_ДополнительныеЗатратыДокументы.Документ = &Приходная";
    Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий(); 
	ОбщаяСуммаКРаспределению = омСервер.ПересчетЗн(Выборка.СуммаНаценки, Валюта, ПараметрыСеанса.БазоваяВалюта, Фирма, Дата, 5);
	//Для каждого Стр из ТаблицаТовары Цикл	  
	Для каждого Стр из Товары Цикл	  
		Если ОбщаяСуммаКРаспределению = 0 Тогда 
			ДельтаЦены = 0;
		Иначе
			Если ВариантРаспределения = 1 Тогда
				лВесоваяЧасть = Стр.СуммаЗакупки / Сумма * 100  ;
				лСуммаКРаспределению = ОбщаяСуммаКРаспределению * лВесоваяЧасть / 100;
				ДельтаЦены = лСуммаКРаспределению / Стр.Количество;
			ИначеЕсли ВариантРаспределения = 2 Тогда
				ДельтаЦены = ОбщаяСуммаКРаспределению / ВКД_Количество;
			Иначе
				ДельтаЦены = 0;
			КонецЕсли;         
		КонецЕсли; 		
		Стр.ВКД_ЦенаСЗатратами = Стр.ЦенаЗакупки + ДельтаЦены;
		Стр.ВКД_СуммаСЗатратами = Стр.ВКД_ЦенаСЗатратами * Стр.Количество;
	КонецЦикла;
	
	// 2. Подготовим затраты док-тов "Отправка" для дальнейшего распределения
	
	ЗатратыОтправки = Документы.ПриходнаяНакладная.ЗатратыОтправки(ВКД_Инвойс, Поставка);
	
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	// 3. Создание/обновление партий
	
	ИзмененныеПартии = Новый Массив;
	НеактуальныеПартии = ПолучитьПартии(Ссылка);
	
	Для Каждого Стр Из Товары Цикл 
		
		ТекПар = Стр.Партия;
		Если НЕ ЗначениеЗаполнено(ТекПар) Тогда Продолжить КонецЕсли; 
		
		СтаПар = ТекПар.ПолучитьОбъект();
		ЕстИзм = 0;
		
		Если СтаПар.ПометкаУдаления Тогда СтаПар.УстановитьПометкуУдаления(Ложь); КонецЕсли;
		
		Имя = "ПН_" + Лев(гоМгновение(Дата), 8);
		
		ОбновитьРеквизитПартии(СтаПар.Наименование,	 	Имя, 					ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.Контрагент, 		Контрагент, 			ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.Док, 				Ссылка, 				ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.ДатаПартии, 		НачалоДня(Дата), 		ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.Валюта, 			Валюта, 				ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.Фирма, 			Фирма, 					ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.Консигнация, 		Консигнация, 			ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.ЦенаЗакупки,  	Стр.ЦенаЗакупки, 		ЕстИзм);
		ОбновитьРеквизитПартии(СтаПар.ВКД_ЦенаСоСкидкой,Стр.ВКД_ЦенаСоСкидкой, 	ЕстИзм);
		
		Если ЕстИзм > 0 Тогда 
			СтаПар.Записать();
			ИзмененныеПартии.Добавить(Стр.Партия); 
		КонецЕсли;
		
		Если НеактуальныеПартии.Количество() > 0 Тогда
			ПаблСтр = НеактуальныеПартии.Найти(ТекПар, "Ссылка");
			Если НЕ (ПаблСтр = Неопределено) Тогда НеактуальныеПартии.Удалить(ПаблСтр) КонецЕсли;
		КонецЕсли;  
		
		// © Primus1C  17.09.2024  НАЧАЛО ►
		//ПересчитатьСтроку(Стр);
		ПересчитатьСтроку(Стр, ЗатратыОтправки);
		// © Primus1C  ОКОНЧАНИЕ ◄    
		
	КонецЦикла; 
	
	Для Каждого ПаблСтр Из НеактуальныеПартии Цикл
		Тек = ПаблСтр.Ссылка.ПолучитьОбъект();
		Тек.УстановитьПометкуУдаления(Истина);
	КонецЦикла;  

	ДополнительныеСвойства.Вставить("ИзмененныеПартии", ИзмененныеПартии);  // для пересчета расх/возвр.накладных

	// 4. Итоги - реквизиты шапки 
	
	//ПересчитатьИтоги();
	Сумма = Товары.Итог("СуммаЗакупки");
	Строк = Товары.Количество();
	СуммаПривязано = Привязки.Итог("Сумма1");
	//ВКД++
	ВКД_СуммаСоСкидкой = Товары.Итог("ВКД_СуммаСоСкидкой");
	ВКД_СуммаСЗатратами = Товары.Итог("ВКД_СуммаСЗатратами");
	ВКД_Количество = Товары.Итог("Количество");
	//ВКД--
	ЕстьЗатраты = Товары.Итог("ЦенаЗакупки") <> Товары.Итог("ВКД_ЦенаСЗатратами");
	
	//2015.11.27
	//изначально суммы КР у нас нет
	СуммаКР = 0;
	
	//2016.01.30
	//есть флаг, когда долги не возникают, поэтому привязки не трогаем
	Если НЕ ТоварУжеОплачен Тогда  
		//а тут нужно подумать, есть 2 варианта, когда закрывается предоплата или когда приход выступает оплатой покупателя
		Для Каждого Стр Из Привязки Цикл
			//итак, мы закрываем для начала предоплату поставщика
			//когда то мы заплатили 100 долларов, сейчас приходуем в ГРН и указываем свой курс в окне привязок
			//все как в ДД для поставщиков
			//второй вариант - мы закрываем долг покупателя, тоже по своему курсу, например, там 100 доларов, а тут рубли - тоже потеря
			правильнаяСумма = омСервер.ПересчетЗн(Стр.Сумма2, Стр.Валюта2, Валюта, Фирма, Дата, 2);
			//ТУТ ПОМЕНЯЛИ МЕСТАМИ, а то неправильно получается при закрытии рублевой предоплаты по курсу 65
			Если правильнаяСумма <> Стр.Сумма1 Тогда гоПлюс(СуммаКР, Стр.Сумма1 - правильнаяСумма) КонецЕсли; 
		КонецЦикла; 
	КонецЕсли;  
	
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Префикс = глПрефиксДефис(Фирма);
