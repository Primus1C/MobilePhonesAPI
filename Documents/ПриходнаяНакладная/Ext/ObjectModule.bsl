Процедура ВКД_ЗаполнитьНаОснованииИнвойса(ДанныеЗаполнения)
		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка._Инвойс") Тогда
		
		ВКД_НеСоздаватьПриходную = Истина; // надо ли создавать приходную
		
		Для Каждого ТекСтрокаВКД_Товары Из ДанныеЗаполнения.ВКД_Товары Цикл
			
			Количество = ВКД_ОпределитьКоличествоНоменклатуры(ДанныеЗаполнения.Ссылка, ТекСтрокаВКД_Товары.Номенклатура); //по которым созданы приходные
			
			//++
			Количество = Количество + ОпределитьКоличествоКорректировок(ДанныеЗаполнения.Ссылка, ТекСтрокаВКД_Товары.Номенклатура);
			//--
					
			Если Количество = ТекСтрокаВКД_Товары.Количество Тогда 
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "По номенклатуре: " + ТекСтрокаВКД_Товары.Номенклатура + " в количестве: " + Количество + " шт. приходные накладные созданы!";
				Сообщение.Сообщить();
				
			ИначеЕсли Количество < ТекСтрокаВКД_Товары.Количество Тогда //если не все оприходовано
				Разница = ТекСтрокаВКД_Товары.Количество - Количество;
				Сч = 0;
				Пока Сч < Разница Цикл  //построчно выводим перечень номенклатуры
					НоваяСтрока = Товары.Добавить();
					НоваяСтрока.Количество = 1;	 
					НоваяСтрока.Номенклатура = ТекСтрокаВКД_Товары.Номенклатура;
					НоваяСтрока.СуммаЗакупки = ТекСтрокаВКД_Товары.ЦенаЗакупки ; // сумма равна цене закупки 
					НоваяСтрока.ЦенаЗакупки = ТекСтрокаВКД_Товары.ЦенаЗакупки;
					НоваяСтрока.ВКД_ЦенаСоСкидкой = ТекСтрокаВКД_Товары.ЦенаСоСкидкой;
					НоваяСтрока.ВКД_СуммаСоСкидкой = ТекСтрокаВКД_Товары.ЦенаСоСкидкой;
					Сч = Сч + 1;
				КонецЦикла;
				
				// Заполнение шапки
				Валюта 		= ДанныеЗаполнения.Валюта;
				Контрагент 	= ДанныеЗаполнения.Контрагент;
				Примечание 	= ДанныеЗаполнения.Примечание;
				ВКД_Инвойс 	= ДанныеЗаполнения.Ссылка;
				ВКД_ДокументСкидки 	= ДанныеЗаполнения.ВКД_ДокументСкидки;
				ВКД_СуммаСкидки 	= ДанныеЗаполнения.ВКД_Скидка;
				ВКД_ИнвойсПоставщика 		= ДанныеЗаполнения.ВКД_НомерИнвойсаПоставщика;
				ВКД_ДатаИнвойсаПоставщика 	= ДанныеЗаполнения.ВКД_ДатаИнвойсаПоставщика;
				Сумма 						= ДанныеЗаполнения.Сумма;
				
				ВКД_НеСоздаватьПриходную = Ложь; // приходную надо создать, есть неоприходованная номенклатура
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если ВКД_НеСоздаватьПриходную = Истина Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'По данному инвойсу приходные накладные уже созданы!'; en = 'Incoming waybills have already been created for this invoice!'");
		Сообщение.Сообщить();
	КонецЕсли;
	

КонецПроцедуры

Функция ВКД_ОпределитьКоличествоНоменклатуры(Ссылка,Номенклатура) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПриходнаяНакладнаяТовары.Номенклатура,
	               |	СУММА(ПриходнаяНакладнаяТовары.Количество) КАК Количество
	               |ИЗ
	               |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	               |ГДЕ
	               |	ПриходнаяНакладнаяТовары.Ссылка.ВКД_Инвойс = &Ссылка
	               |	И ПриходнаяНакладнаяТовары.Номенклатура = &Номенклатура
	               |	И НЕ ПриходнаяНакладнаяТовары.Ссылка.ПометкаУдаления
	               |	И ПриходнаяНакладнаяТовары.Ссылка.Проведен
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПриходнаяНакладнаяТовары.Номенклатура";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат	Выборка.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

Процедура ВКД_ЗаполнитьДанныеПартий()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПриходнаяНакладнаяТовары.Номенклатура,
	               |	ПриходнаяНакладнаяТовары.Серия,
	               |	ПриходнаяНакладнаяТовары.ВКД_ЦенаСоСкидкой КАК ВКД_ЦенаСоСкидкой,
	               |	ПриходнаяНакладнаяТовары.ВКД_ЦенаСЗатратами КАК ВКД_ЦенаСЗатратами,
	               |	ПриходнаяНакладнаяТовары.ЦенаЗакупки КАК ЦенаЗакупки,
	               |	Партии.Ссылка КАК Партия
	               |ИЗ
	               |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партии КАК Партии
	               |		ПО ПриходнаяНакладнаяТовары.Партия = Партии.Ссылка
	               |			И ПриходнаяНакладнаяТовары.Серия = Партии.Серия
	               |ГДЕ
	               |	ПриходнаяНакладнаяТовары.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка",Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Партия = Выборка.Партия;
		Если ЗначениеЗаполнено(Партия) Тогда
			ОбъектПартия = Выборка.Партия.ПолучитьОбЪект();
			//ОбъектПартия.ВКД_ЦенаСЗатратами = Выборка.ВКД_ЦенаСЗатратами;
			ОбъектПартия.ВКД_ЦенаСоСкидкой  = Выборка.ВКД_ЦенаСоСкидкой;
			//ОбъектПартия.ВКД_ЦенаСЗатратами = Выборка.ВКД_ЦенаСЗатратами;	
			ОбъектПартия.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

