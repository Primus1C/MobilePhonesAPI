Функция ПолучитьПартии(ТекДок)
	Если НЕ ЗначениеЗаполнено(ТекДок) Тогда Возврат Новый ТаблицаЗначений КонецЕсли; 
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	Партии.Ссылка
	                      |ИЗ
	                      |	Справочник.Партии КАК Партии
	                      |ГДЕ
	                      |	Партии.Док = &ДокПартии");
	Запрос.УстановитьПараметр("ДокПартии", ТекДок);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ОбновитьРеквизитПартии(Ста, Нов, Сч)

	Если Ста <> Нов Тогда   
		Ста = Нов;
		Сч = Сч + 1; 
	КонецЕсли;
	
КонецПроцедуры

