Функция НайтиИлиСоздатьПартию(Номенклатура, Серия)

	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Владелец", Номенклатура);
	Запр.УстановитьПараметр("Док", Ссылка);
	Запр.УстановитьПараметр("Серия", Серия);
	Запр.УстановитьПараметр("Фирма", Фирма);
	Запр.Текст = "ВЫБРАТЬ
	             |	Партии.Ссылка КАК Ссылка
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Владелец = &Владелец
	             |	И Партии.Док = &Док
	             |	И Партии.Серия = &Серия
	             |	И НЕ Партии.ПометкаУдаления
	             |	И Партии.Фирма = &Фирма
	             |
	             |ОБЪЕДИНИТЬ
	             |
	             |ВЫБРАТЬ
	             |	Партии.Ссылка
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Владелец = &Владелец
	             |	И Партии.Док = &Док
	             |	И Партии.Серия = &Серия
	             |	И Партии.ПометкаУдаления
	             |	И Партии.Фирма = &Фирма";
    Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
	 	П = Справочники.Партии.СоздатьЭлемент();
		П.Владелец 	= Номенклатура;
		П.Док 		= Ссылка;
		П.Серия 	= Серия;
		П.Фирма 	= Фирма; 
		П.Записать();
		Возврат П.Ссылка;
	КонецЕсли;
	
КонецФункции // НайтиИлиСоздатьПартию()

Функция СтатусПоПоступлениям(СсылкаИнвойс, СУчетомТекущейПриходнойНакладной)
	
	// 	Проверим полноту поступлений по инвойсу 
	Запр = Новый запрос; 
	Запр.УстановитьПараметр("Инвойс", 				СсылкаИнвойс);
	Запр.УстановитьПараметр("ПриходнаяНакладная", 	Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	Свод.Номенклатура КАК Номенклатура,
	             |	СУММА(Свод.КоличествоНеПоступило) КАК КоличествоНеПоступило,
	             |	СУММА(Свод.КоличествоПоИнвойсу) КАК КоличествоПоИнвойсу,
	             |	ВЫБОР
	             |		КОГДА СУММА(Свод.КоличествоПоИнвойсу) > 0
	             |			ТОГДА ВЫБОР
	             |					КОГДА СУММА(Свод.КоличествоНеПоступило) = 0
	             |						ТОГДА ""ПрибылПолностью""
	             |					КОГДА СУММА(Свод.КоличествоНеПоступило) = СУММА(Свод.КоличествоПоИнвойсу)
	             |						ТОГДА ""Отправлен""
	             |					ИНАЧЕ ""ПрибылЧастично""
	             |				КОНЕЦ
	             |		ИНАЧЕ ""НеОтправлен""
	             |	КОНЕЦ КАК Статус
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Оприходование.Номенклатура КАК Номенклатура,
	             |		СУММА(Оприходование.КоличествоОборот) КАК КоличествоНеПоступило,
	             |		СУММА(Оприходование.КоличествоПриход) КАК КоличествоПоИнвойсу
	             |	ИЗ
	             |		РегистрНакопления.ВКД_ОприходованиеНоменклатуры.ОстаткиИОбороты(, , Регистратор, , Документ = &Инвойс) КАК Оприходование
	             |	ГДЕ
	             |		Оприходование.Регистратор <> &ПриходнаяНакладная
	             |	
	             |	СГРУППИРОВАТЬ ПО
	             |		Оприходование.Номенклатура
	             |	
	             |	ОБЪЕДИНИТЬ
	             |	
	             |	ВЫБРАТЬ
	             |		ПриходнаяНакладнаяТовары.Номенклатура,
	             |		-СУММА(ПриходнаяНакладнаяТовары.Количество),
	             |		0
	             |	ИЗ
	             |		Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
	             |	ГДЕ
	             |		ПриходнаяНакладнаяТовары.Ссылка = &ПриходнаяНакладная
	             |	
	             |	СГРУППИРОВАТЬ ПО
	             |		ПриходнаяНакладнаяТовары.Номенклатура) КАК Свод
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	Свод.Номенклатура";  
	Если НЕ СУчетомТекущейПриходнойНакладной Тогда
		Запр.Текст = СтрЗаменить(Запр.Текст, "СУММА(ПриходнаяНакладнаяТовары.Количество)", "0");	
	КонецЕсли;
	Выгрузка = Запр.Выполнить().Выгрузить(); 
	НайдСтроки = Выгрузка.НайтиСтроки(Новый Структура("Статус", "ПрибылПолностью"));
	лПрибылПолностью = НайдСтроки.Количество() > 0;
	НайдСтроки = Выгрузка.НайтиСтроки(Новый Структура("Статус", "ПрибылЧастично"));
	лПрибылЧастично = НайдСтроки.Количество() > 0;
	НайдСтроки = Выгрузка.НайтиСтроки(Новый Структура("Статус", "Отправлен"));
	лОтправлен = НайдСтроки.Количество() > 0;
	НайдСтроки = Выгрузка.НайтиСтроки(Новый Структура("Статус", "НеОтправлен"));
	лНеОтправлен = НайдСтроки.Количество() > 0;
	
	Если лПрибылЧастично Тогда
		Возврат Перечисления.СтатусыИнвойса.ЧастичноПрибыл; 
	ИначеЕсли лПрибылПолностью И лОтправлен Тогда // несколько поставок, есть прибывшие
		Возврат Перечисления.СтатусыИнвойса.ЧастичноПрибыл;
	ИначеЕсли лОтправлен Тогда
		Возврат Перечисления.СтатусыИнвойса.ВПути;
	ИначеЕсли лНеОтправлен и не	лПрибылПолностью и не лПрибылЧастично и не лОтправлен Тогда
		Возврат Неопределено; // не отправлен
	ИначеЕсли лПрибылПолностью И НЕ лНеОтправлен И НЕ лПрибылЧастично И НЕ лНеОтправлен Тогда 
		Возврат Перечисления.СтатусыИнвойса.Прибыл;
	Иначе	
		Возврат Перечисления.СтатусыИнвойса.ЧастичноПрибыл;
	КонецЕсли;
	
КонецФункции // ПоступленияПоИнвойсу()

Функция ВозможенПересорт(Номенклатура)
	
	Наименование = СокрЛП(Номенклатура.Наименование);   
	Если Сред(Наименование, СтрДлина(Наименование)-2, 1) = " " Тогда
		Спецификация = Прав(Наименование, 2);
		НаименованиеБезСпц = Лев(Наименование, СтрДлина(Наименование)-3);
	Иначе	
	     Возврат "";
	КонецЕсли;
	
	Результат = "";
	Запр = Новый Запрос; 
	Запр.УстановитьПараметр("Ссылка", ВКД_Инвойс);
	Запр.УстановитьПараметр("Наименование", Наименование);
	Запр.УстановитьПараметр("НаименованиеБезСпц", НаименованиеБезСпц+"%");
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	_ИнвойсВКД_Товары.Номенклатура.Наименование КАК Наименование
	             |ИЗ
	             |	Документ._Инвойс.ВКД_Товары КАК _ИнвойсВКД_Товары
	             |ГДЕ
	             |	_ИнвойсВКД_Товары.Номенклатура.Наименование ПОДОБНО &НаименованиеБезСпц
	             |	И _ИнвойсВКД_Товары.Номенклатура.Наименование <> &Наименование
	             |	И _ИнвойсВКД_Товары.Ссылка = &Ссылка"; 
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат = Результат + Выборка.Наименование + ", ";
	КонецЦикла; 
	Если Результат <> "" Тогда
		Результат	= Лев(Результат, СтрДлина(Результат)-2);
	КонецЕсли;
	Возврат	Результат;
	
КонецФункции

