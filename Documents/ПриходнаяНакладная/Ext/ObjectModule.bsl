	Мас = ОбщегоНазначенияПовтИсп.МассивДоступныхСкладов();
	Если Мас.Количество() <> 0 Тогда Склад = Мас[0] КонецЕсли;
	
	
	// © Primus1C  01.07.2023  НАЧАЛО ►
	
