				Движение.СуммаСоСкидкой = ?(стр.Количество = стр.КоличествоОстаток, стр.СуммаСоСкидкойОстаток, стр.Количество/стр.КоличествоОстаток*стр.СуммаСоСкидкойОстаток);
				Движение.Количество 	= стр.Количество;   
				Движение.ЦенаЗакупки	= ?(Движение.Количество = 0, Движение.СуммаЗакупки, Движение.СуммаЗакупки/Движение.Количество);
				Движение.Поставка		= Поставка;
