Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	//Если Товары.Количество() = 0 Тогда
	//	Сообщить(НСтр("ru = 'Табличная часть пуста!'; en = 'There are no goods in the document!'"));
	//	Отказ = Истина;	
	//КонецЕсли;	
	
	Для Каждого Стр Из Товары Цикл 
		Если НЕ ЗначениеЗаполнено(Стр.Номенклатура) Тогда
			Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: не заполнен товар!'; en = 'Line %1: good not filled!'"), СокрЛП(Стр.НомерСтроки))); 
			Отказ = Истина;	
		КонецЕсли;
		Если Стр.Количество = 0 Тогда
			Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: не заполнено количество!'; en = 'Line %1: quantity not filled!'"), СокрЛП(Стр.НомерСтроки))); 
			Отказ = Истина;	
		КонецЕсли;
		//Если Стр.ЦенаЗакупки = 0 Тогда 
		//	Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: нулевая цена!'; en = 'Line %1: zero price!'"), СокрЛП(Стр.НомерСтроки))); 
		//	Отказ = Истина;	
		//КонецЕсли; 
	КонецЦикла; 
	
	Если НЕ ПараметрыСеанса.БезусловноеПроведениеДокументов Тогда
		// проверка серийных товаров, зарегистрированных инвойсами (неоприходованных)
		Запр = Новый Запрос; 
		Запр.УстановитьПараметр("Ссылка", 	Ссылка);
		Запр.УстановитьПараметр("Дата", 	?(ЗначениеЗаполнено(Ссылка), МоментВремени(), ТекущаяДата()));
		Запр.УстановитьПараметр("Фирма", 	Фирма);
		Запр.УстановитьПараметр("Склад", 	Склад);
		Запр.Текст = "ВЫБРАТЬ
		             |	ПриходнаяНакладнаяТовары.Номенклатура КАК Номенклатура,
		             |	ПриходнаяНакладнаяТовары.Серия КАК Серия,
		             |	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток,
		             |	ПриходнаяНакладнаяТовары.НомерСтроки КАК НомерСтроки
		             |ИЗ
		             |	Документ.ПриходнаяНакладная.Товары КАК ПриходнаяНакладнаяТовары
		             |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(
		             |				&Дата,
		             |				Фирма = &Фирма
		             |					И Склад = &Склад) КАК ОстаткиТовараОстатки
		             |		ПО ПриходнаяНакладнаяТовары.Номенклатура = ОстаткиТовараОстатки.Номенклатура
		             |			И ПриходнаяНакладнаяТовары.Серия = ОстаткиТовараОстатки.Партия.Серия
		             |ГДЕ
		             |	ПриходнаяНакладнаяТовары.Ссылка = &Ссылка
		             |	И ПриходнаяНакладнаяТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		             |	И ПриходнаяНакладнаяТовары.Номенклатура.УчетПоСериям
		             |	И ОстаткиТовараОстатки.ОстатокОстаток > 0
		             |
		             |УПОРЯДОЧИТЬ ПО
		             |	НомерСтроки";  
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл   
			Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: серия %2 товара %3 найден остаток %4 шт.'; en = 'Line %1: series %2 of product %3 remaining %4 pcs found!'"), 
									Выборка.НомерСтроки, Выборка.Серия, Выборка.Номенклатура, Формат(Выборка.Остаток, "ЧДЦ=0")));
			Отказ = Истина;
		КонецЦикла; 
	КонецЕсли;

