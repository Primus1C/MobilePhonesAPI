Функция ОпределитьКоличествоКорректировок(СсылкаИнвойс, Номенклатура)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КорректировкаИнвойса.Номенклатура,
	               |	СУММА(КорректировкаИнвойса.Количество - КорректировкаИнвойса.КоличествоДоКорректировки) КАК Количество
	               |ИЗ
	               |	Документ.КорректировкаИнвойса.Товары КАК КорректировкаИнвойса
	               |ГДЕ
	               |	КорректировкаИнвойса.Ссылка.Инвойс = &Инвойс
	               |	И КорректировкаИнвойса.Номенклатура = &Номенклатура
	               |	И КорректировкаИнвойса.Ссылка.Проведен
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	КорректировкаИнвойса.Номенклатура";
	Запрос.УстановитьПараметр("Инвойс", СсылкаИнвойс);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат	Выборка.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;

