	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Докум.Ссылка КАК Ссылка,
	Докум.ПометкаУдаления КАК ПометкаУдаления,
	Докум.Номер КАК Номер,
	Докум.Дата КАК Дата,
	Докум.Проведен КАК Проведен,
	Докум.Контрагент КАК Контрагент,
	Докум.ДатаПоставщика КАК ДатаПоставщика,
	Докум.НомерПоставщика КАК НомерПоставщика,
	Докум.Сумма КАК Сумма,
	Докум.Валюта КАК Валюта,
	Докум.Строк КАК Строк,
	Докум.СуммаПривязано КАК СуммаПривязано,
	Докум.Склад КАК Склад,
	Докум.КемСоздан КАК КемСоздан,
	Докум.Создан КАК Создан,
	Докум.КемСохранен КАК КемСохранен,
	Докум.Сохранен КАК Сохранен,
	Докум.Фирма КАК Фирма,
	Докум.Примечание КАК Примечание,
	Докум.Окончательно КАК Окончательно,
	Докум.МоментВремени КАК МоментВремени,
	Докум.ТоварУжеОплачен КАК УжеОпл,
	ВЫБОР
		КОГДА ЕСТЬNULL(Рег.ДолгПоставщикуОстаток, 0) &lt;= 0
			ТОГДА ""
		КОГДА Докум.СрокОплаты = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА "?"
		ИНАЧЕ РАЗНОСТЬДАТ(&amp;ТекущаяДата, Докум.СрокОплаты, ДЕНЬ)
	КОНЕЦ КАК Оплатить,
	ЕСТЬNULL(Рег.ДолгПоставщикуОстаток, 0) КАК Долг,
	ВЫБОР
		КОГДА Докум.Окончательно
				И Докум.Сумма &gt; 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(Рег.ДолгПоставщикуОстаток, 0) &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ДолгПоставщикуОстаток, 0) &lt;&gt; Докум.Сумма
									ТОГДА ЗНАЧЕНИЕ(Перечисление.Долги.Частично)
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Неоплачено)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Полностью)
				КОНЕЦ
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.НеЗакрыто)
	КОНЕЦ КАК Состояние
ИЗ
	Документ.ПриходнаяНакладная КАК Докум
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки КАК Рег
		ПО Докум.Ссылка = Рег.Док
ГДЕ
	ВЫБОР
			КОГДА &amp;Граница = НЕОПРЕДЕЛЕНО
				ТОГДА ИСТИНА
			ИНАЧЕ Докум.Дата &gt; &amp;Граница
		КОНЕЦ</QueryText>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>СрокОплаты</dcssch:dataPath>
					<dcssch:field>СрокОплаты</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>УжеОпл</dcssch:dataPath>
					<dcssch:field>УжеОпл</dcssch:field>
					<dcssch:title xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Уже опл</v8:content>
						</v8:item>
					</dcssch:title>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ВКД_СуммаЗатрат</dcssch:dataPath>
					<dcssch:field>ВКД_СуммаЗатрат</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Склад</dcssch:dataPath>
					<dcssch:field>Склад</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ВКД_Инвойс</dcssch:dataPath>
					<dcssch:field>ВКД_Инвойс</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>СуммаКР</dcssch:dataPath>
					<dcssch:field>СуммаКР</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Привязки</dcssch:dataPath>
					<dcssch:field>Привязки</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ТоварУжеОплачен</dcssch:dataPath>
					<dcssch:field>ТоварУжеОплачен</dcssch:field>
