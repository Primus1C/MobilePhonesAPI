&НаКлиенте
Процедура РассчитатьЦенуСЗатратамиПоСумме(ОбщаяСуммаКРаспределению)
	
	СуммаПриходной = Объект.Товары.Итог("СуммаЗакупки");
	Если ОбщаяСуммаКРаспределению <> 0 Тогда
		Для каждого Стр из Объект.Товары Цикл	
			ВесоваяЧасть = Стр.СуммаЗакупки / СуммаПриходной * 100  ;
			СуммаКРаспределению = ОбщаяСуммаКРаспределению * ВесоваяЧасть / 100;
			ДельтаЦены = СуммаКРаспределению / Стр.Количество;
			ЦенаСЗатратами = ?(ЗначениеЗаполнено(Стр.ВКД_ЦенаСоСкидкой),Стр.ВКД_ЦенаСоСкидкой + ДельтаЦены,Стр.ЦенаЗакупки + ДельтаЦены);
			Стр.ВКД_ЦенаСЗатратами = ЦенаСЗатратами;
			Стр.ВКД_СуммаСЗатратами = Стр.Количество * ЦенаСЗатратами;
		КонецЦикла;
	Иначе
		клПредупреждение(НСтр("ru = 'Расчет не проведен. Сумма затрат равна 0! Воможно, не выбран документ затрат!'; en = 'The calculation has not been carried out. The total expenses is 0! The expenses document may not have been selected!'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьЦенуСЗатратамиПоКоличеству(ОбщаяСуммаКРаспределению) 
	
	ОбщееКоличество = Объект.ВКД_Количество;
	
	Если ОбщаяСуммаКРаспределению <> 0 Тогда
		
		ДельтаЦены = ОбщаяСуммаКРаспределению / ОбщееКоличество;
		
		Для каждого Стр из Объект.Товары Цикл		
			ЦенаСЗатратами = ?(ЗначениеЗаполнено(Стр.ВКД_ЦенаСоСкидкой), Стр.ВКД_ЦенаСоСкидкой + ДельтаЦены, Стр.ЦенаЗакупки + ДельтаЦены);
			//Стр.ЦенаЗакупки + ДельтаЦены;
			Стр.ВКД_ЦенаСЗатратами = ЦенаСЗатратами;
			Стр.ВКД_СуммаСЗатратами = Стр.Количество * ЦенаСЗатратами;			
		КонецЦикла;
	Иначе
		клПредупреждение(НСтр("ru = 'Расчет не проведен. Сумма затрат равна 0! Воможно, не выбран документ затрат!'; en = 'The calculation has not been carried out. The total expenses is 0! The expenses document may not have been selected!'"));
	КонецЕсли;
			
КонецПроцедуры

