Функция СоздатьПартию(Ссылка, НовНом, НовЦен, НовСер = "", Валюта, Дата, Фирма) 
	
	Спр = Справочники.Партии.СоздатьЭлемент();
	
	Спр.Владелец = НовНом;
	Спр.Док = Ссылка;
	Спр.Наименование = "ПН_" + Лев(гоМгновение(Дата), 8);
