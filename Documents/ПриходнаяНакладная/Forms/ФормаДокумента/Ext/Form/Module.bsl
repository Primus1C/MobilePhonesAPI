&НаКлиенте
Процедура РассчитатьЦенуСЗатратами()
	
	Объект.ВКД_СуммаЗатрат = ПолучитьСуммуЗатратПоДокументу();
	
	ОбщаяСуммаКРаспределению = Объект.ВКД_СуммаЗатрат;
	Если ОбщаяСуммаКРаспределению <> 0 Тогда 
		Если Объект.ВариантРаспределения = 0 Тогда
			клПредупреждение(НСтр("ru = 'Скидка не будет распределена! Не выбран вид расчета!'; en = 'The discount will not be distributed! Distributed option not selected!'"));
		ИначеЕсли Объект.ВариантРаспределения = 1 Тогда
			РассчитатьЦенуСЗатратамиПоСумме(ОбщаяСуммаКРаспределению);	
		ИначеЕсли Объект.ВариантРаспределения = 2 Тогда
			РассчитатьЦенуСЗатратамиПоКоличеству(ОбщаяСуммаКРаспределению);
		КонецЕсли;
	КонецЕсли;
	
	// © Primus1C  12.03.2024  НАЧАЛО ► 
	РаспределитьЗатратыОтправки();
	МоиИтоги();
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры 

&НаСервере
Функция ПолучитьСуммуЗатратПоДокументу()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СУММА(ВКД_ДополнительныеЗатратыДокументы.СуммаНаценки) КАК СуммаНаценки
	               |ИЗ
	               |	Документ.ВКД_ДополнительныеЗатраты.Документы КАК ВКД_ДополнительныеЗатратыДокументы
	               |ГДЕ
	               |	ВКД_ДополнительныеЗатратыДокументы.Ссылка В(&Ссылка)
	               |	И ВКД_ДополнительныеЗатратыДокументы.Документ = &Приходная";
	// CN_^ - 12.02.2020 - начало.
	//было
	//Запрос.УстановитьПараметр("Ссылка",Объект.ВКД_ДокументЗатрат);
	ВтЗатрат = Объект.Затраты.Выгрузить(, "ДокументЗатрат");
	ВтЗатрат.Свернуть("ДокументЗатрат");
	СписокОтбора = Новый СписокЗначений;
	СписокОтбора.ЗагрузитьЗначения(ВтЗатрат.ВыгрузитьКолонку("ДокументЗатрат"));
	Если НЕ Объект.Ссылка.Метаданные().Реквизиты.Найти("ВКД_ДокументСкидки") = Неопределено Тогда
		Если СписокОтбора.НайтиПоЗначению(Объект.ВКД_ДокументЗатрат) = Неопределено И ЗначениеЗаполнено(Объект.ВКД_ДокументЗатрат) Тогда
			СписокОтбора.Добавить(Объект.ВКД_ДокументЗатрат);
			Стр = ВтЗатрат.Добавить();
			Стр.ДокументЗатрат = Объект.ВКД_ДокументЗатрат;
		КонецЕсли;	
	КонецЕсли;
	Объект.Затраты.Загрузить(ВтЗатрат);
	Если СписокОтбора.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;
	Запрос.УстановитьПараметр("Ссылка", СписокОтбора);
	// CN_^ - 12.02.2020 - конец.
	Запрос.УстановитьПараметр("Приходная",Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Если Выборка.СуммаНаценки <> Неопределено Тогда
			Возврат Выборка.СуммаНаценки; 
		Иначе
			Возврат 0;
		КонецЕсли;		
	КонецЕсли;
				   	
КонецФункции

