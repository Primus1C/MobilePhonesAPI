	Спр.ЦенаЗакупки = НовЦен;
	Спр.Валюта = Валюта;
	Спр.ДатаПартии = Дата;
	Спр.Фирма = Фирма;
	Спр.Серия = НовСер;
	Спр.ЦенаЗакупкиВБазВалюте = РаботаСВалютой.Пересчитать2025(Спр.ЦенаЗакупки, Валюта, ПараметрыСеанса.БазоваяВалюта, Фирма, Дата);
	Спр.Записать();
	
	Возврат Спр.Ссылка; 
	
