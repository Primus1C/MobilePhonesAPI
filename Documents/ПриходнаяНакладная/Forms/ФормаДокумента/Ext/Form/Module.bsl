&НаКлиенте
Процедура РаспределитьЗатратыОтправки(СтрокаТЧ = Неопределено)
	
	Если НЕ КэшДанных.Свойство("ЗатратыОтправки") Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаТЧ = Неопределено Тогда
		Для каждого СтрокаТ Из Объект.Товары Цикл
			лЗатратаОтправки = КэшДанных.ЗатратыОтправки.Получить(СтрокаТ.Номенклатура); 
			Если лЗатратаОтправки <> Неопределено Тогда
				СтрокаТ.ВКД_ЦенаСЗатратами = СтрокаТ.ЦенаЗакупки + лЗатратаОтправки;
			КонецЕсли;
		КонецЦикла;
	Иначе
		лЗатратаОтправки = КэшДанных.ЗатратыОтправки.Получить(СтрокаТЧ.Номенклатура); 
		Если лЗатратаОтправки <> Неопределено Тогда
			СтрокаТЧ.ВКД_ЦенаСЗатратами = СтрокаТЧ.ЦенаЗакупки + лЗатратаОтправки;
		КонецЕсли;
	КонецЕсли;	

