&НаКлиенте
Процедура МоеРедактирование(Кол)    
	
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	//2016.02.22
	//ну мы тут слишком жестко, почему нельзя редактировать даже после окончательно?
	//а вот менеджерам не нужно
	//Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно И гоМенеджер() Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	
	Партия = Стр.Партия;
	Нельзя = НельзяРедактироватьЦену(Партия);
	
	Если гоЭто("ЦенаЗакупки", Кол) Тогда
		//2016.04.14
		//у нас массовое изменение возможно, поэтому проверяем тут окончательно, а не есть движения одной партии или нет
		//Если Нельзя Тогда 
		Если Объект.Окончательно Тогда 
			//2016.02.22
			Если гоМонопольныйРежим() Тогда
				клНетДа(Новый ОписаниеОповещения("МоеРедактированиеПослеВопросаПроведения", ЭтотОбъект, Новый Структура("Кол,ИДИ,Нельзя", Кол, ИДИ, Нельзя)),
					НСтр("ru = 'Внимание! Документ закрыт {Окончательно}! Будем редактировать цену закупки и проводить связанные документы? ВСЕ ЛИШНИЕ ОКНА ДОЛЖНЫ БЫТЬ ЗАКРЫТЫ!'; en = 'Attention! The document is closed <Finally>! Will You edit the purchase price and post related documents? ALL EXTRA WINDOWS MUST BE CLOSED!'"));
				Возврат;
			Иначе 
				//2016.04.14
				//клОшибка("Внимание! Есть движения партии, редактирование цены запрещено! Нужен МОНОПОЛЬНЫЙ РЕЖИМ!"); 
				клОшибка(НСтр("ru = 'Внимание! Документ закрыт {Окончательно}, редактирование цены закупки запрещено! Нужен МОНОПОЛЬНЫЙ РЕЖИМ!'; en = 'Attention! The document is closed <Finaly>, editing the purchase price is prohibited! You need a MONOPOLY MODE!'")); 
				Возврат; 
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли;
	
	МоеРедактированиеШагВвода(Кол, ИДИ, Нельзя, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВопросаПроведения(Результат, Параметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли; 
	МоеРедактированиеШагВвода(Параметры.Кол, Параметры.ИДИ, Параметры.Нельзя, Истина);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеШагВвода(Кол, ИДИ, Нельзя, БудемПроводить)
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	Партия = Стр.Партия;
	
	Если Кол = "ЦенаЗакупки" Тогда
		Цена = гоРеквизит(Партия, Кол);	
		ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаЦены", ЭтотОбъект, Новый Структура("ИДИ,Кол,БудемПроводить,Было", ИДИ, Кол, БудемПроводить, Цена)),
			Цена, НСтр("ru = 'Цена закупки'; en = 'Purchase price'"), 19, ЧислоЗнаковЦенаЗакупки);
	ИначеЕсли Кол = "Количество" Тогда
		УчетПоСериям = гоРеквизит(Стр.Номенклатура, "УчетПоСериям");
		Если УчетПоСериям Тогда клОшибка(НСтр("ru = 'Включен учет по сериям, просто удалите строку!'; en = 'Series accounting is enabled, just delete the line!'")); Возврат; КонецЕсли; 
		
		Если Нельзя Тогда клОшибка(НСтр("ru = 'Внимание! Есть движения партии, осторожнее с количеством!'; en = 'Attention! The batches movements are recorded, be careful with quantity!'")) КонецЕсли;
		Колв = Стр.Количество;
		ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаКоличества", ЭтотОбъект, Новый Структура("ИДИ,Было", ИДИ, Колв)),
			Колв, НСтр("ru = 'Количество'; en = 'Quantity'"), 14, ЧислоЗнаковКоличество);
	Иначе
		МоеРедактированиеЗавершение(ИДИ, БудемПроводить, Новый СписокЗначений);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаЦены(Цена, Параметры) Экспорт
	Если Цена = Неопределено Тогда Возврат КонецЕсли; 
	Если Параметры.Было = Цена Тогда Возврат КонецЕсли; 
	
	ИДИ = Параметры.ИДИ;
	Кол = Параметры.Кол;
	БудемПроводить = Параметры.БудемПроводить;
	
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	Партия = Стр.Партия;
	
	УстановитьЦеныПартииСервер(Партия, Цена, Кол); 
	// © Primus1C  05.03.2025  НАЧАЛО ►
	Стр.ЦенаЗакупки = Цена;  
	Стр.СуммаЗакупки = Цена * Стр.Количество;
	// © Primus1C  ОКОНЧАНИЕ ◄

	//2016.04.14
	СпиПар = Новый СписокЗначений;
	СпиПар.Добавить(Партия);
	
	//2016.04.07
	//2016.04.14 + ИЛИ гоМонопольныйРежим()
	//не проверяем на окончательно, точнее, для монопольного режима нам все равно, будем перепроводить
	Если (НЕ Объект.Окончательно) ИЛИ гоМонопольныйРежим() Тогда  
		Нашли = ЕстьЕще(ИДИ, Стр.Номенклатура);
		Если НЕ (Нашли.Количество() = 0) Тогда
			клДаНет(Новый ОписаниеОповещения("МоеРедактированиеПослеВопросаОстальных", ЭтотОбъект, Новый Структура("ИДИ,Кол,Цена,БудемПроводить,СпиПар", ИДИ, Кол, Цена, БудемПроводить, СпиПар)),
				НСтр("ru = 'В документе есть еще такая же номенклатура! Проставить новую цену закупки и на нее тоже?'; en = 'The document also contains the same good! Set a new purchase price on it too?'"));
			Возврат;
		КонецЕсли;
	КонецЕсли; 
	
	МоеРедактированиеЗавершение(ИДИ, БудемПроводить, СпиПар);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВопросаОстальных(Результат, Параметры) Экспорт
	ИДИ = Параметры.ИДИ;
	Кол = Параметры.Кол;
	Цена = Параметры.Цена;
	СпиПар = Параметры.СпиПар;
	
	Если Результат Тогда
		Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
		Нашли = ЕстьЕще(ИДИ, Стр.Номенклатура);
		Для Каждого Стр Из Нашли Цикл
			БылЦен = гоРеквизит(Стр.Партия, Кол);
			Если БылЦен = Цена Тогда Продолжить КонецЕсли; 
			УстановитьЦеныПартииСервер(Стр.Партия, Цена, Кол); 
			// © Primus1C  05.03.2025  НАЧАЛО ►
			Стр.ЦенаЗакупки = Цена;
			Стр.СуммаЗакупки = Цена * Стр.Количество;
			// © Primus1C  ОКОНЧАНИЕ ◄
			ОповеститьОбИзменении(Стр.Партия);
			//2016.04.14
			СпиПар.Добавить(Стр.Партия);
		КонецЦикла;
		МояЗаписать(Ложь);
	КонецЕсли;
	
	МоеРедактированиеЗавершение(ИДИ, Параметры.БудемПроводить, СпиПар);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаКоличества(Колв, Параметры) Экспорт
	Если Колв = Неопределено Тогда Возврат КонецЕсли; 
	Было = Параметры.Было;
	Если Было = Колв Тогда Возврат КонецЕсли; 
	
	ИДИ = Параметры.ИДИ;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	Если Объект.Окончательно Тогда
		Ост = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, Стр.Партия) - Было + Колв;
		Если Ост < 0 Тогда 
			клОшибка(НСтр("ru = 'Остаток СТАНЕТ ОТРИЦАТЕЛЬНЫМ! Такое количество вводить запрещено!'; en = 'The remainder WILL BE NEGATIVE! This quantity is prohibited!'")); 
			
			Номен =	Стр.Номенклатура;
			гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колв) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента, "Попытка исправить в минус", Номен, 2);
			гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колв) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Попытка исправить в минус", Объект.Ссылка, 2);
			
			Если НЕ гоАдминистратор() Тогда Возврат КонецЕсли; 
		КонецЕсли;
	КонецЕсли;
	
	Стр.Количество = Колв;
	
	Колич =	Колв;
	СЦена = Стр.ЦенаЗакупки;
	Номен =	Стр.Номенклатура;
	гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Редактирование количества", Номен, 2);
	гоЗаписьЖурналаРегистрации(Строка(Было) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Редактирование количества", Объект.Ссылка, 2);
	
	МоеРедактированиеЗавершение(ИДИ, Ложь, Новый СписокЗначений);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеЗавершение(ИДИ, БудемПроводить, СпиПар)
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	//2016.02.22
	СпиДок = 0;
	//2016.04.14 + СпиПар вместо 
	Если БудемПроводить Тогда СпиДок = гоЕстьДвиженияПартии(СпиПар, Объект.Ссылка, Истина) КонецЕсли; 
	
	ОповеститьОбИзменении(Стр.Партия);
	МояЗаписать(Ложь);
	
	//2016.02.22
	Если БудемПроводить Тогда
		Если СпиДок.Количество() <> 0 Тогда  
			РезСче = 0;
			РезСоо = "";
			гоПровестиДокументыСервер(СпиДок, РезСоо, РезСче);
			Если НЕ (РезСоо = "") Тогда клОшибка(РезСоо) КонецЕсли;
			клВнимание(НСтр("ru = 'Обработано документов: '; en = 'Processed documents: '") + РезСче + "...");
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Функция НельзяРедактироватьЦену(ТекПар)
	Возврат омСервер.ЕстьДвиженияПартии(ТекПар, Объект.Ссылка);
КонецФункции

&НаКлиенте
Процедура МоеУдаление()     
	
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	//2016.02.22
	//та пусть удаляет, если надо, но менеджерам запретим
	//Если Объект.Окончательно Тогда 
	//	Если гоАдминистратор() Тогда 
	//		Сообщить("Под ответственность Администратора!");
	//	Иначе 
	//		Возврат;
	//	КонецЕсли; 
	//КонецЕсли; 
	Если Объект.Окончательно И гоМенеджер() Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	//ПРОВЕРКА ПО ПАРТИИ
	Если НельзяРедактироватьЦену(Стр.Партия) Тогда клОшибка(НСтр("ru = 'Удаление запрещено! Есть движения партии!'; en = 'Removal is prohibited! The batches movements are posted!'")); Возврат; КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("МоеУдалениеЗавершение", ЭтотОбъект, ИДИ),
		СтрШаблон("%1 %2: %3 ?", НСтр("ru = 'Удалить строку'; en = 'Delete a line'"), ИДИ+1, Стр.Номенклатура));
	
КонецПроцедуры

&НаКлиенте
Процедура МоеУдалениеЗавершение(Результат, ИДИ) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли; 
	
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	Номен = Стр.Номенклатура;
	СЦена = Стр.ЦенаЗакупки;
	Колич = Стр.Количество;
	
	Удаляем = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Удаляем = Неопределено Тогда клОшибка("Странно, не нашли текущую строку!"); Возврат; КонецЕсли; 
	
	Объект.Товары.Удалить(Удаляем);
	
	гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удаление строки", Объект.Ссылка, 2);
	
	//партия сама пометится на удаление при записи
	МояЗаписать(Ложь, Истина); 
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Если гоПЗ(Объект.Контрагент) Тогда Возврат КонецЕсли;
	Если омСервер.ЕстьНезакрытыеДокументы(Объект.Контрагент, Объект.Ссылка) Тогда клВнимание(НСтр("ru = 'ВНИМАНИЕ! Есть незакрытые документы!!!'; en = 'ATTENTION! There are unclosed documents!!!'")) КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НомерПоставщикаПриИзменении(Элемент)
	Если СокрЛП(Объект.НомерПоставщика) = "" Тогда Возврат КонецЕсли;
	Если гоНПЗ(Объект.ДатаПоставщика) Тогда Возврат КонецЕсли;
	Объект.ДатаПоставщика = Объект.Дата;
КонецПроцедуры

&НаКлиенте
Процедура Установить(Команда) 
	
	Если Объект.Окончательно Тогда Возврат КонецЕсли;
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Товары.Количество() = 0 Тогда 
		клНамекнуть(ИмяДокумента, НСтр("ru = 'Документ пуст!'; en = 'The document is empty!'"), БиблиотекаКартинок.ПоискДанных);
		Возврат;
	КонецЕсли;
	
	//2016.01.31
	//вводится новый тип прихода - консигнация, он допускает нулевые цены, но количество в строке должно быть = 1
	//и наоборот, не может быть нулевых цен без этого флага
	Сч = 0;
	Для Каждого Стр Из Объект.Товары Цикл
		Если Объект.Консигнация Тогда
			Если (Стр.ЦенаЗакупки = 0) И (Стр.Количество <> 1) Тогда Сообщить(СокрЛП(Стр.НомерСтроки) + ": кол-во <> 1 при нулевой цене!"); гоПлюс(Сч); КонецЕсли;
		Иначе 
			Если Стр.ЦенаЗакупки = 0 Тогда Сообщить(СтрШаблон(НСтр("ru = 'Строка %1: нулевая цена!'; en = 'Line %1: zero price!'"), СокрЛП(Стр.НомерСтроки))); гоПлюс(Сч); КонецЕсли;
		КонецЕсли; 
	КонецЦикла; 
	Если Сч <> 0 Тогда  
		Если Объект.Консигнация Тогда 
			клОшибка("Есть строки: " + Сч + " с количеством <> 1 при нулевой цене!");
		Иначе 
			клОшибка(СтрШаблон(НСтр("ru = 'Есть строки: %1 с нулевыми ценами!'; en = 'There are lines: %1 with zero prices!'"), Сч));
		КонецЕсли; 
		Возврат;
	КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("УстановитьЗавершение", ЭтотОбъект), НСтр("ru = 'Установить флаг <Окончательно>?'; en = 'Set flag <Finaly>?'"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗавершение(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Истина;
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(СтрШаблон("Установили. Строк %1, сумма %2",Объект.Товары.Количество(),Формат(Объект.Сумма,"ЧДЦ=2")), ИмяДокумента, "Установка {Окончательно}", Объект.Ссылка, 2);	// + ?(НеНадоБЦена, " (без обновления цен)", "")  
	
КонецПроцедуры

&НаКлиенте
Процедура Снять(Команда)
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли; 
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	
	// © Primus1C  06.02.2024  НАЧАЛО ►
	Если ОбщегоНазначенияПовтИсп.ДоступБухгалтерии() Тогда
		клНетДа(Новый ОписаниеОповещения("СнятьЗавершениеБухгалтерия", ЭтотОбъект), НСтр("ru = 'Снять флаг {Окончательно}?'; en = 'Unset flag <Finaly>?'"));
		Возврат;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄

	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Сч = 0;
	Для Каждого Стр Из Объект.Товары Цикл
		Нельзя = ?(НельзяРедактироватьЦену(Стр.Партия), 1, 0);
		Сч = Сч + Нельзя;
		Если Нельзя = 0 Тогда Продолжить КонецЕсли;
		Сообщить(НСтр("ru = 'Есть движения партии: '; en = 'Batches movements are posted: '") + гоИмя(Стр.Партия));
	КонецЦикла;
	
	//Если НЕ гоЕстьРоль("Оператор") Тогда
		Если Сч <> 0 Тогда клОшибка(НСтр("ru = 'Есть движения партий '; en = 'Batches movements are posted '") + гоИмя(Сч) + "!"); Возврат; КонецЕсли;
	//КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("СнятьЗавершение", ЭтотОбъект), НСтр("ru = 'Снять флаг {Окончательно}?'; en = 'Unset flag <Finaly>?'"));
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьЗавершениеБухгалтерия(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Ложь;
	МояЗаписать(Ложь);    
	МоиИтоги();
	гоЗаписьЖурналаРегистрации("Сняли", ИмяДокумента, "Снятие {Окончательно}", Объект.Ссылка, 2);    
КонецПроцедуры

&НаКлиенте
Процедура СнятьЗавершение(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Ложь;
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации("Сняли", ИмяДокумента, "Снятие {Окончательно}", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсе(Команда)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("УдалитьВсеЗавершение", ЭтотОбъект), НСтр("ru = 'Удалить все строки?'; en = 'Delete all lines?'"));
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВсеЗавершение(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	//2016.10.21
	//предлагаю по всем строкам пройтись и записать в журнал
	Для Каждого Стр Из Объект.Товары Цикл
		Номен = Стр.Номенклатура;
		СЦена = Стр.ЦенаЗакупки;
		Колич = Стр.Количество;
		гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удалить все", Объект.Ссылка, 2);
	КонецЦикла;
	
	Объект.Товары.Очистить();
	
	//партии сами пометятся на удаление при записи
	МояЗаписать(Ложь);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПривязки(Откуда)
	локПривязки = ЗначениеИзСтрокиВнутр(Откуда);
	
	Если Объект.Привязки.Количество() <> 0 Тогда Объект.Привязки.Очистить() КонецЕсли; 
	
	Для Каждого Стр Из локПривязки Цикл
		Если Стр.СуммаДокумента = 0 Тогда Продолжить КонецЕсли;
		
		Нов = Объект.Привязки.Добавить();
		
		Нов.Сумма1 = Стр.СуммаДокумента;
		Нов.Валюта1 = Стр.ВалютаДокумента;
		Нов.Сумма2 = Стр.СуммаДолга;
		Нов.Валюта2 = Стр.ВалютаДолга;
		Нов.КроссКурс = Стр.КроссКурс;
		Нов.ОбратныйКурс = Стр.ОбратныйКурс;
		Нов.Док2 = Стр.Док;
		Нов.Примечание = Стр.Примечание;
		Нов.ЭтоПредоплата = Стр.ЭтоПредоплата;
	КонецЦикла; 
КонецПроцедуры

&НаКлиенте
Процедура МоиПривязки()
	Если гоПЗ(Объект.Контрагент) Тогда Возврат КонецЕсли;
	Если гоПЗ(Объект.Валюта) Тогда Возврат КонецЕсли;
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли;
	//2016.01.30
	//есть флаг, когда долги не возникают, поэтому привязки не трогаем
	Если Объект.ТоварУжеОплачен Тогда Возврат КонецЕсли;
	//2016.08.26
	//Если гоЧужойДокумент(Объект.КемСоздан) Тогда Возврат КонецЕсли; 
	
	лПривязать = Объект.Сумма;
	Если лПривязать = 0 Тогда Возврат КонецЕсли; 
	
	МояЗаписать(Ложь);
	
	Если НЕ Объект.Проведен Тогда клОшибка(НСтр("ru = 'Документ не проведен!'; en = 'Document is not posted!'")); Возврат; КонецЕсли;
	
	Пар = Новый Структура("Док, Привязки, ТолькоПривязки", Объект.Ссылка, Объект.Привязки, 0);
	
	ОткрытьФорму("Обработка.ПривязкаДолгов.Форма.Форма", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("МоиПривязкиЗавершение", ЭтотОбъект));
КонецПроцедуры

&НаКлиенте
Процедура МоиПривязкиЗавершение(Рез, ДопПараметры) Экспорт
	Если Рез = Неопределено Тогда Возврат КонецЕсли; 
	
	//2015.11.27
	//сохраним старые связи, чтобы потом оповестить об их изменении
	СохМасПривязки = клПривязкиВМассив(Объект);
	
	ЗаполнитьПривязки(Рез.ПривязкиСтрока);
	
	МояЗаписать(Ложь);
	
	//2015.11.27
	//вот тут только мы можем оповестить все связанные документы об изменении и прошлые, что сохранились в массиве
	клОповеститьПривязки(Объект, СохМасПривязки);
КонецПроцедуры

&НаКлиенте
Процедура ОплатыЗачет(Команда)
	МоиПривязки();
КонецПроцедуры

