&НаКлиенте
Процедура МояЗаписать(ПроверятьМодифицированность = Истина, ЗаписатьБезусловно = Ложь)
	УстановитьВидимостьДоступность();
	
	Если ПроверятьМодифицированность Тогда
		Если НЕ Модифицированность Тогда Возврат КонецЕсли; КонецЕсли; 
		
	//ВКД++
	Если Не ЗначениеЗаполнено(Объект.ВКД_Инвойс) Тогда  
		Если ЗаписатьБезусловно Тогда
			омСервер.УстановитьПараметрСеанса("БезусловноеПроведениеДокументов", Истина);
		КонецЕсли;
		Записать(РежимЗаписиПроведение);
		Если ЗаписатьБезусловно Тогда
			омСервер.УстановитьПараметрСеанса("БезусловноеПроведениеДокументов", Ложь);
		КонецЕсли;
	КонецЕсли;
	//ВКД--

	МоиОстатки();
	МоиИтоги();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность() 
	
	// © Primus1C  01.02.2024  НАЧАЛО ►
	Если ТолькоПросмотр Тогда
		Элементы.Установить.Доступность = Ложь;
		Возврат;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	НетСтрок = Объект.Товары.Количество() = 0;
	ЕстьСтроки = НЕ НетСтрок;
	
	Закрыто = Объект.Окончательно;	
	НеЗакрыто = НЕ Закрыто;
	
	//2015.12.08 попробуем только по закрыто
	Элементы.Дата.ТолькоПросмотр = Закрыто;		//Объект.Проведен ИЛИ 
	Элементы.Склад.ТолькоПросмотр = Закрыто;
	
	Элементы.Валюта.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	//2016.10.22
	Элементы.ИзменитьВалюту.Видимость = ЕстьСтроки И НеЗакрыто;
	
	Элементы.Установить.Доступность = НеЗакрыто;
	Элементы.Снять.Доступность = Закрыто;
	
	//2015.12.12
	Элементы.Контрагент.ТолькоПросмотр = Закрыто;
	
	//2016.01.30
	Если гоАдминистратор() Тогда 
		Элементы.ТоварУжеОплачен.ТолькоПросмотр = ЭтаФорма.ТолькоПросмотр;
	Иначе 
		Элементы.ТоварУжеОплачен.ТолькоПросмотр = Закрыто;
	КонецЕсли;
	
	//ВКД++
	Элементы.ВКД_Инвойс.ТолькоПросмотр = Закрыто;
	Элементы.ВКД_ДокументЗатрат.ТолькоПросмотр = Закрыто;
	Элементы.ВКД_Скидка.ТолькоПросмотр = Закрыто;
	Элементы.ВариантРаспределения.ТолькоПросмотр = Закрыто;
	Элементы.РассчитатьЗатраты.Доступность = Не Закрыто; 
	Элементы.Затраты.ТолькоПросмотр = Закрыто;  
	
	Элементы.Товары.ТолькоПросмотр = Закрыто; 
	Элементы.ТоварыУдалитьВыделенные.Видимость = НЕ Закрыто;
	Элементы.ТоварыУдалитьВсе.Видимость = НЕ Закрыто;
	//ВКД--
	
	//2016.01.31
	Если гоАдминистратор() Тогда 
		Элементы.Консигнация.ТолькоПросмотр = ЭтаФорма.ТолькоПросмотр;
	Иначе 
		Элементы.Консигнация.ТолькоПросмотр = Закрыто;
	КонецЕсли;  
	
КонецПроцедуры


