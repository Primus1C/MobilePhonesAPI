&НаСервереБезКонтекста
Функция ВКД_СоздатьПартию(Ссылка, НовНом, НовЦен, НовСер = "", ВКД_ЦенаСоСкидкой, ВКД_ЦенаСЗатратами)
	Спр = Справочники.Партии.СоздатьЭлемент();
	
	Спр.Владелец = НовНом;
	Спр.Док = Ссылка;
	Спр.Наименование = "ПН_" + Лев(гоМгновение(Ссылка.Дата), 8);
	Спр.Контрагент = Ссылка.Контрагент;
	Спр.ЦенаЗакупки = НовЦен;
	Спр.Валюта = Ссылка.Валюта;
	Спр.ДатаПартии = Ссылка.Дата;
	Спр.Фирма = Ссылка.Фирма;
	Спр.Серия = НовСер;
	Спр.ВКД_ЦенаСоСкидкой = ВКД_ЦенаСоСкидкой;
	
	Спр.Записать();
	
	Возврат Спр.Ссылка;
КонецФункции

