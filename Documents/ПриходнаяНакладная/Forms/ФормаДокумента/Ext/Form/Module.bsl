&НаСервереБезКонтекста
Функция СвободныеПоставкиИнвойса(Инвойс)
	
	СписокПоставок = Новый СписокЗначений;

	//// если по инвойсу были прих.накладные, распределение по поставкам невозможно
	//ЗапрПН = Новый Запрос; 
	//ЗапрПН.УстановитьПараметр("Инвойс", Инвойс);
	//ЗапрПН.Текст = "ВЫБРАТЬ
	//               |	Оприходование.Регистратор
	//               |ИЗ
	//               |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК Оприходование
	//               |ГДЕ
	//               |	Оприходование.Регистратор ССЫЛКА Документ.ПриходнаяНакладная
	//               |	И Оприходование.Документ = &Инвойс"; 
	//ВыборкаПН = ЗапрПН.Выполнить().Выбрать();
	//Если ВыборкаПН.Следующий() Тогда
	//	Возврат СписокПоставок;
	//КонецЕсли;
	

	СписокПоставок.Добавить(-1, НСтр("ru = 'Все товары текущего инвойса, отсутствующие в приходных накладных'; en = 'All goods on the current invoice that are not included in incoming waybills'")); 
	
	// получим поставки инвойса
	ЗапрПоставки = Новый Запрос;
	ЗапрПоставки.УстановитьПараметр("Инвойс", Инвойс);
	ЗапрПоставки.Текст = "ВЫБРАТЬ
	                     |	ИнвойсПоставки.Поставка КАК Поставка,
	                     |	СУММА(ИнвойсПоставки.Количество) КАК Количество,
	                     |	СУММА(ИнвойсПоставки.Сумма) КАК Сумма
	                     |ИЗ
	                     |	Документ._Инвойс.Поставки КАК ИнвойсПоставки
	                     |ГДЕ
	                     |	ИнвойсПоставки.Ссылка = &Инвойс
	                     |	И ИнвойсПоставки.Поставка > 0
	                     |
	                     |СГРУППИРОВАТЬ ПО
	                     |	ИнвойсПоставки.Поставка
	                     |
	                     |УПОРЯДОЧИТЬ ПО
	                     |	Поставка"; 
	ВыборкаПоставки = ЗапрПоставки.Выполнить().Выбрать();
	Пока ВыборкаПоставки.Следующий() Цикл                       
		СписокПоставок.Добавить(ВыборкаПоставки.Поставка, СтрШаблон(НСтр("ru = 'Поставка %1: кол-во %2 шт., сумма %3'; en = 'Delivery %1: quant. %2 pc., sum %3'"), 
																	ВыборкаПоставки.Поставка, 
																	ВыборкаПоставки.Количество, 
																	Формат(ВыборкаПоставки.Сумма,"ЧДЦ=2")));
	КонецЦикла;
	
	Возврат СписокПоставок;
	
