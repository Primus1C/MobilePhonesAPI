&НаСервере
Функция НайтиКоличествоСерийНаСкладе(Серия)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОстаткиТовараОстатки.ОстатокОстаток,
	               |	ОстаткиТовараОстатки.РезервОстаток,
	               |	ОстаткиТовараОстатки.Партия.Серия
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара.Остатки(, Партия.Серия = &Серия) КАК ОстаткиТовараОстатки
	               |ГДЕ
	               |	(ОстаткиТовараОстатки.ОстатокОстаток > 0
	               |			ИЛИ ОстаткиТовараОстатки.РезервОстаток > 0)";
	Запрос.УстановитьПараметр("Серия", Серия);

	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		Возврат 1
	Иначе
		Возврат 0
	КонецЕсли;

КонецФункции

