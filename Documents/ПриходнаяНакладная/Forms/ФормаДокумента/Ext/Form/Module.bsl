#Область ДействияФормы        

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// © Primus1C  07.10.2023  НАЧАЛО ►
	Если Объект.ВКД_НеСоздаватьПриходную Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;
	
	Если гоНПЗ(Параметры.ЗначениеКопирования) Тогда Сообщить(НСтр("ru = 'Копирование приходных накладных запрещено!'; en = 'Incoming waybills copying is prohibited!'")); Отказ = Истина; Возврат; КонецЕсли; 
	
	РежимЗаписиПроведение = Новый Структура ("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	Избранный = гоИзбранный(Объект.Ссылка);
	
	ЧислоЗнаковКоличество = Объект.Фирма.ЧислоЗнаковКоличество;
	ЧислоЗнаковЦенаЗакупки = Объект.Фирма.ЧислоЗнаковЦенаЗакупки;
	
	Элементы.ТоварыКоличество.Формат = "ЧДЦ=" + ЧислоЗнаковКоличество;
	Элементы.ТоварыЦенаЗакупки.Формат = "ЧДЦ=" + ЧислоЗнаковЦенаЗакупки;
	Элементы.ТоварыНоменклатураРодитель.Видимость = Объект.Фирма.ВыводитьГруппа;
	Элементы.ТоварыНоменклатураПроизводитель.Видимость = Объект.Фирма.ВыводитьПроизводитель;
	Элементы.ТоварыСерия.Видимость = Объект.Фирма.ВыводитьСерия;
	Элементы.ТоварыПартияСрокГодности.Видимость = Объект.Фирма.ВыводитьСрокГодности;
	
	//Элементы.ТоварыУдалитьВсе.Видимость = гоАдминистратор();
	//2016.10.21
	//ХОТЯТ ВСЕМ
	
	Попытка
		Элементы.ФормаИзменитьФорму.Видимость = Ложь;
	Исключение
	КонецПопытки; 
	
	//2017.02.05
	ДобавлениеСерийВПриходеВТранзакцииНаСервере = Объект.Фирма.ДобавлениеСерийВПриходеВТранзакцииНаСервере;
	
	//2017.03.24
	//Мас = омСервер.МассивСкладов();
	//Если Мас.Количество() <> 0 Тогда
	//Если Мас.Найти(Объект.Склад) = Неопределено Тогда Отказ = Истина; Возврат; КонецЕсли; КонецЕсли;
	
	//ВКД++
	ВКД_УстановитьВидимостьПолей();
	//ВКД--  
	
	// © Primus1C  25.07.2023  НАЧАЛО ►   
	ЗаполнитьКэшДанных();
	
	Элементы.Валюта.БыстрыйВыбор = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("БыстрыйВыборВалют"); 
	//глПокраситьУслуги(ЭтаФорма, "Товары");
	
	Если ЗначениеЗаполнено(Объект.ВКД_Инвойс) И НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда // ввод на основании
		НеоприходованныеТоварыИнвойса = Документы.ПриходнаяНакладная.НеоприходованныеТоварыИнвойса(Объект.ВКД_Инвойс, Объект.Поставка);
	КонецЕсли;	
	//Элементы.Поставка.Видимость = Объект.Поставка > 0;
	
	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента);  
	
	//ОбщегоНазначенияСервер.ПроверитьВозможностьРедактированияПоДатеДокумента(Объект, ЭтаФорма);  

	//глПокраситьУслуги(ЭтаФорма, "Товары");
	
	Если ЗначениеЗаполнено(Объект.ВКД_Инвойс) И НЕ ОбщегоНазначенияПовтИсп.ДоступныЦеныЗакупки() Тогда
		//Элементы.ВКД_Инвойс.Доступность 			= Ложь;
		Элементы.ТоварыЦенаЗакупки.Видимость 		= Ложь;
		Элементы.ТоварыСуммаЗакупки.Видимость 		= Ложь;
		Элементы.ТоварыВКД_ЦенаСоСкидкой.Видимость 	= Ложь;
		Элементы.ТоварыВКД_СуммаСоСкидкой.Видимость = Ложь;
		Элементы.ТоварыВКД_ЦенаСЗатратами.Видимость = Ложь;
		Элементы.ТоварыВКД_СуммаСЗатратами.Видимость= Ложь;
		Элементы.ГрЗатраты.ТолькоПросмотр 			= Истина;
	КонецЕсли; 
	
	СтруктураПечатныхФорм = Документы.ПриходнаяНакладная.ПолучитьСтруктуруПечатныхФорм();  
	ПараметрыРазмещения = Новый Структура("Форма, ЭтоФормаОбъекта, КоманднаяПанель", ЭтаФорма, Истина, Неопределено);
	ОбщегоНазначенияСервер.ПодключитьКомандыПечати(ПараметрыРазмещения, СтруктураПечатныхФорм);   
	
	Если Объект.Проведен Тогда
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |	ОстаткиТовара.Партия КАК Партия
		             |ИЗ
		             |	РегистрНакопления.ОстаткиТовара КАК ОстаткиТовара
		             |ГДЕ
		             |	ОстаткиТовара.Период > &Период
		             |	И ОстаткиТовара.Партия В(&Партии)
		             |	И ОстаткиТовара.Партия <> ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)";
		Запр.УстановитьПараметр("Период", Объект.Дата);
		Запр.УстановитьПараметр("Партии", Объект.Товары.Выгрузить(,"Партия").ВыгрузитьКолонку(0));
	    Выборка = Запр.Выполнить().Выбрать();
	    Пока Выборка.Следующий() Цикл
			ПартииИмеющиеДвижения.Добавить(Выборка.Партия);
		КонецЦикла;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)  
	
	//Если НЕ клФормаДокументаПриОткрытии(ЭтаФорма, Объект) Тогда Отказ = Истина; Возврат; КонецЕсли; 
	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);
	
	ТолПро = ЭтаФорма.ТолькоПросмотр; 
	
	ЕстьОплата = Ложь;
	//2016.08.26
	//этоЧужой = Ложь;
	Если НЕ Объект.Ссылка.Пустая() Тогда 
		ЕстьОплата = омСервер.ЕстьОплатаДокумента(Объект.Ссылка); 
		//2016.08.26
		//этоЧужой = гоЧужойДокумент(Объект.КемСоздан);
	КонецЕсли; 
	
	//2016.08.26 + ИЛИ этоЧужой
	Если Избранный ИЛИ ЕстьОплата ИЛИ (Объект.СуммаПривязано <> 0) 
		//ИЛИ этоЧужой 
		Тогда ТолПро = Истина КонецЕсли;
	
	ЭтаФорма.ТолькоПросмотр = ТолПро;
	
	стрПросмотр = клПросмотр(ЭтаФорма, Избранный, Объект.Ссылка);
	
	УстановитьВидимостьДоступность();
	МоиИтоги();
	
	Если Объект.ВКД_НеСоздаватьПриходную Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
  	// © Primus1C  24.07.2023  НАЧАЛО ►  
	
	ОтобразитьЦветВалюты();
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.ВКД_Инвойс) И Объект.ВариантРаспределения = -1 Тогда // новый, введен на основании инвойса, требует заполнения
		ЗаполнитьПоИнвойсуНаКлиенте();
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.ВКД_Инвойс) И НЕ ТолПро Тогда 
		лКвоПоставокИнвойса = ПоставкиИнвойса(Объект.ВКД_Инвойс).Количество(); 
		ТекстВопроса = "";
		Если лКвоПоставокИнвойса = 0 И Объект.Поставка > 0 Тогда
			ТекстВопроса = стрШаблон("Номер поставки текущей накладной: %1. Но инвойс не разделен на поставки. Сбросить номер поставки в накадной?", Объект.Поставка);
			ПараметрыВопроса = Новый Структура("Действие", "Сброс");
		ИначеЕсли лКвоПоставокИнвойса > 0 И Объект.Поставка = 0 Тогда  
		    ТекстВопроса = "Инвойс разделен на поставки. Но в текущей накладной номер поставки не указан. Установить номер поставки в накладной?";
			ПараметрыВопроса = Новый Структура("Действие,КоличествоПоставок", "Выбор", лКвоПоставокИнвойса);
		ИначеЕсли лКвоПоставокИнвойса > 0 И Объект.Поставка > лКвоПоставокИнвойса Тогда  
		    ТекстВопроса = стрШаблон("Инвойс разделен на %1 поставок. Но в текущей накладной указана поставка %2. Изменить номер поставки в накладной?", лКвоПоставокИнвойса, Объект.Поставка);
			ПараметрыВопроса = Новый Структура("Действие,КоличествоПоставок", "Выбор", лКвоПоставокИнвойса);
		КонецЕсли;   
		Если ТекстВопроса <> "" Тогда
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПоставки", ЭтотОбъект, ПараметрыВопроса);
			ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0, , "Некорректная поставка");
		КонецЕсли;
	КонецЕсли;
	
	ОтобразитьПоказателиЗатрат();  
	
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	клФормаДокументаПередЗаписью(Объект, Отказ);

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	УстановитьВидимостьДоступность();
	МоиОстатки();
	МоиИтоги(); 
	// © Primus1C  25.07.2023  НАЧАЛО ►
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	// © Primus1C  ОКОНЧАНИЕ ◄
КонецПроцедуры

#КонецОбласти         


