&НаКлиенте
Процедура ЗатратыДокументЗатратНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СписокОтбора = Новый СписокЗначений;
	ПолучитьСписокОтбораДокументовЗатрат(СписокОтбора);
	Если Не СписокОтбора.Количество() = 0 Тогда
		СтандартнаяОбработка = Ложь;
		Форма = ОткрытьФорму("Документ.ВКД_ДополнительныеЗатраты.ФормаВыбора", , Элемент); //Открываем форму
		ОтборВладелец = Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); //Добавлям отбор
		ОтборВладелец.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; //Как будем сравнивать
		ОтборВладелец.Использование = Истина; // Устанавливаем галку использованияНовый ПолеКомпоновкиДанных("Номенклатура")
		ОтборВладелец.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка"); //По какому реквизиту будем делать отбор
		ОтборВладелец.ПравоеЗначение = СписокОтбора; // И само значение отбора
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСписокОтбораДокументовЗатрат(СписокОтбора)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ВКД_ДополнительныеЗатратыДокументы.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ВКД_ДополнительныеЗатраты.Документы КАК ВКД_ДополнительныеЗатратыДокументы
		|ГДЕ
		|	ВКД_ДополнительныеЗатратыДокументы.Документ = &Документ";
	Запрос.УстановитьПараметр("Документ", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Попытка
		СписокОтбора.ЗагрузитьЗначения(РезультатЗапроса.ВыгрузитьКолонку("Ссылка"));
	Исключение
	КонецПопытки;	
