&НаСервере
Процедура ОтобразитьПоказателиЗатрат()

	Для каждого СтрокаТЧ Из Объект.Затраты Цикл
		СтрокаТЧ.СтатусПроведения = ОбщегоНазначенияСервер.СтатусПроведения(СтрокаТЧ.ДокументЗатрат);
	КонецЦикла;
	
КонецПроцедуры


&НаСервереБезКонтекста
Функция РольПриходование()

	Возврат РольДоступна("ПриходованиеВводомНаОсновании");	

КонецФункции 

&НаКлиенте
Процедура КонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если РольПриходование() Тогда
		СтандартнаяОбработка = Ложь;	
	КонецЕсли;                      
	
КонецПроцедуры


&НаСервереБезКонтекста
Функция ПоставкиИнвойса(Инвойс)
	
	Список = Новый СписокЗначений;
	запр = Новый Запрос;  
	запр.УстановитьПараметр("Ссылка", Инвойс);
	запр.Текст = "ВЫБРАТЬ
	             |	СУММА(_ИнвойсПоставки.Количество) КАК Количество,
	             |	_ИнвойсПоставки.Поставка КАК Поставка
	             |ИЗ
	             |	Документ._Инвойс.Поставки КАК _ИнвойсПоставки
	             |ГДЕ
	             |	_ИнвойсПоставки.Ссылка = &Ссылка
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	_ИнвойсПоставки.Поставка"; 
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Список.Добавить(Выборка.Поставка, 
						СтрШаблон("     Поставка %1 ( %2 шт. )     ", Выборка.Поставка, Выборка.Количество), ,
						БиблиотекаКартинок.Доставка);
	КонецЦикла;
	Возврат Список;

КонецФункции 

&НаКлиенте
Процедура ПослеЗакрытияВопросаПоставки(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
        Если Параметры.Действие = "Сброс" Тогда
			Объект.Поставка = 0;	
			клНамекнуть("Поставка", "Номер поставки сброшен", БиблиотекаКартинок.ДиалогИнформация);
		    Модифицированность = Истина; 
		Иначе
			Оповещение = Новый ОписаниеОповещения("ПослеВыбораПоставки", ЭтотОбъект, Новый Структура());
			ПоказатьВыборИзСписка(Оповещение, ПоставкиИнвойса(Объект.ВКД_Инвойс), Элементы.Поставка);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораПоставки(Результат, Параметры) Экспорт

	Если Результат <> Неопределено Тогда
		Если ТолькоПросмотр Тогда 
			УстановитьНомерПоставкиБезусловно(Результат.Значение); 
			доп = "(Чтобы обновить отображение, откройте документ заново)";
		Иначе
			Объект.Поставка = Результат.Значение;  
			Модифицированность = Истина;    
			доп = "";
		КонецЕсли;
		клНамекнуть("Поставка приходной накладной", 
					СтрШаблон("Установлен номер поставки: %1.
					  		  |%2", Результат.Значение, доп), 
					БиблиотекаКартинок.ДиалогИнформация); 
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНомерПоставкиБезусловно(П)
	
	УстановитьПривилегированныйРежим(Истина);
	ДокОбъект = Объект.Ссылка.ПолучитьОбъект();
	ДокОбъект.Поставка = П;
	ДокОбъект.Записать();
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоИнвойсуНаКлиенте()

	// НеоприходованныеТоварыИнвойса уже рассчитаны
	
	Если НеоприходованныеТоварыИнвойса.КоличествоНеоприходованныхПоставок = 0 Тогда
		клПредупреждение(НСтр("ru = 'Все поставки инвойса оприходованы!'; en = 'All invoice deliveries have been capitalized!'"), , 
						НСтр("ru = 'Ввод приходной накладной на основании инвойса'; en = 'Creating incoming waybill based on an invoice'"));
		Возврат;
	ИначеЕсли НеоприходованныеТоварыИнвойса.КоличествоНеоприходованныхПоставок = 1 Тогда
		ВыбПоставка = НеоприходованныеТоварыИнвойса.НомерНеоприходованнойПоставки; 
		Объект.ВариантРаспределения = 0;
		Объект.Поставка = ВыбПоставка;	
		ЗаполнитьПоПоставке();
	Иначе                      
		спис = Новый СписокЗначений; 
		Для каждого Пост Из НеоприходованныеТоварыИнвойса.Поставки Цикл
			спис.Добавить(Пост.НомерПоставки,
			СтрШаблон(НСтр("ru = 'Поставка %1: не оприходовано %2 из %3 шт.'; en = 'Delivery %1: not capitalized %2 of %3'"), Пост.НомерПоставки, Пост.Количество, Пост.КоличествоИсх), ,
			?(Пост.Количество=0, БиблиотекаКартинок.ДоставкаНеактивна, БиблиотекаКартинок.Доставка));
		КонецЦикла;
		клВариантСписка(Новый ОписаниеОповещения("ЗаполнитьПоИнвойсуНаКлиентеЗавершение", ЭтотОбъект), НСтр("ru = 'Выберите поставку'; en = 'Select delivery'"), спис);			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоИнвойсуНаКлиентеЗавершение(ВыбПоставка, ДопПараметры) Экспорт
	Если ВыбПоставка <> Неопределено Тогда
		Объект.ВариантРаспределения = 0;
		Объект.Поставка = ВыбПоставка;	
		ЗаполнитьПоПоставке();
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшДанных()
	
	 КэшДанных = Новый Структура;
	 КэшДанных.Вставить("РаскрашиватьВалюты", 	ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("РаскрашиватьВалюты"));
	 КэшДанных.Вставить("ЦветаВалют", 			ОбщегоНазначенияПовтИсп.ЦветаВалют()); 
	 
	 Если ЗначениеЗаполнено(Объект.ВКД_Инвойс) Тогда
		 КэшДанных.Вставить("ЗатратыОтправки", Документы.ПриходнаяНакладная.ЗатратыОтправки(Объект.ВКД_Инвойс, Объект.Поставка));
 	 КонецЕсли;

КонецПроцедуры

// © Primus1C  ОКОНЧАНИЕ ◄


&НаКлиенте
Процедура МоиИтоги()
	// © Primus1C  02.12.2023  НАЧАЛО ►
	//стрИтого = "";
	//стрОплата = "";
	//омСервер.МоиИтоги(Объект, стрИтого, стрОплата);
	СтруктураИтогов = омСервер.МоиИтогиФорматированные(Объект); 
	Элементы.ДекорацияИтого.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураИтогов.Итоги));
	// © Primus1C  ОКОНЧАНИЕ ◄
КонецПроцедуры

&НаКлиенте
Процедура МоиОстатки()
	стрОстатки = "?";
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда 
		Элементы.ДекорацияИнфоСтроки.Заголовок = "";
		Возврат; 
	КонецЕсли; 
