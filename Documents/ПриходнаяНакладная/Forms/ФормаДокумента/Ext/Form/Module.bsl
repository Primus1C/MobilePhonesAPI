&НаКлиенте
Процедура ТоварыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Установите курсор на нужную строку табличной части!'; en = 'Place the cursor on the desired line of the tabular part!'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Если Элементы.Товары.ТекущаяСтрока = Неопределено Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru = 'Все строки табличной части заполнены!'; en = 'All lines of the tabular section are filled!'"), 5, НСтр("ru = 'Внимание!'; en = 'Attention!'"));
		Возврат;
	Иначе  // проверка на дубль серии 
		Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Серия", ВыбранноеЗначение));
		НашлиНаСкладе = НайтиКоличествоСерийНаСкладе(ВыбранноеЗначение);  
		Если (Нашли.Количество() > 0) Тогда 
			//клВнимание(гоИмя(ВыбранноеЗначение) + ": уже есть в документе!" + гоРС() + "Значение пропускается!!!");
			клВнимание(СтрШаблон(НСтр("ru = '%1: уже есть в документе! %2Значение пропускается!!!'; en = '%1: already in the document! %2Value skipped!!!'"), гоИмя(ВыбранноеЗначение), гоРС())); 
			Стр.Серия = "";
			Возврат; 
		ИначеЕсли НашлиНаСкладе = 1 Тогда
			//клВнимание(гоИмя(ВыбранноеЗначение) + ": уже было оприходовано ранее!" + гоРС() + "Значение пропускается!!!");
			клВнимание(СтрШаблон(НСтр("ru = '%1: уже было оприходовано ранее! %2Значение пропускается!!!'; en = '%1: has already been capitalized before! %2Value skipped!!!'"), гоИмя(ВыбранноеЗначение), гоРС()));
			Стр.Серия = "";
			Возврат; 

		Иначе
			Стр.Серия = ВыбранноеЗначение;
			// Стр.Партия = СоздатьПартию(Объект.Ссылка,Стр.Номенклатура,Стр.ЦенаЗакупки,Стр.Серия);     
			// © Primus1C  09.07.2024  НАЧАЛО ► 
			РаспределитьЗатратыОтправки(Стр);
			// © Primus1C  ОКОНЧАНИЕ ◄
			Стр.Партия = ВКД_СоздатьПартию(Объект.Ссылка, Стр.Номенклатура, Стр.ЦенаЗакупки, Стр.Серия, Стр.ВКД_ЦенаСоСкидкой, Стр.ВКД_ЦенаСЗатратами);
			
			Элементы.Товары.ТекущаяСтрока = Элементы.Товары.ТекущаяСтрока + 1;
			
