&НаКлиенте
Процедура УдалитьВыделенные(Команда)
//2017.05.30
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	ВыдСтр = Элементы.Товары.ВыделенныеСтроки;
	ВыдКол = ВыдСтр.Количество();
	Если ВыдКол <= 1 Тогда Возврат КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("УдалитьВыделенныеЗавершение", ЭтотОбъект, ВыдСтр),
		стрШаблон(НСтр("ru = 'Удалить выделенные (%1) строки?'; en = 'Delete selected (%1) lines?'"), ВыдКол));
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВыделенныеЗавершение(Результат, ВыдСтр) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Удалить = Новый Массив;
	
	Для Каждого ИДИ Из ВыдСтр Цикл
		Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
		Если Стр = Неопределено Тогда клОшибка("Странно, не нашли текущую строку по ИДИ=" + ИДИ + "!"); Продолжить; КонецЕсли;
		Удалить.Добавить(Стр);
	КонецЦикла;
		
	Для Каждого Стр Из Удалить Цикл
		Номен = Стр.Номенклатура;
		СЦена = Стр.ЦенаЗакупки;
		Колич = Стр.Количество;
		гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удалить выделенные", Объект.Ссылка, 2);
		
		Объект.Товары.Удалить(Стр);
	КонецЦикла;
	
	//партии сами пометятся на удаление при записи
	МояЗаписать(Ложь);
КонецПроцедуры

