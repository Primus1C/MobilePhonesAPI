&НаКлиенте
Процедура МоеДобавлениеПослеВыбораНоменклатуры(НовНом, ДопПараметры) Экспорт
	Если НовНом = Неопределено Тогда Возврат КонецЕсли; 
	
	УчетТовараПоСериям = гоРеквизит(НовНом, "УчетПоСериям");    
	Если НЕ УчетТовараПоСериям Тогда  
		Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
		Если НЕ (Нашли.Количество() = 0) Тогда 
			//клВнимание(гоИмя(НовНом) + ": уже есть в документе!" + гоРС() + "Возможно, нужно просто отредактировать количество!!!") 
			клВнимание(СтрШаблон("%1: %2!
								|%3!!!", 
								гоИмя(НовНом), 
								НСтр("ru = 'уже есть в документе'; en = 'already is in the document'"),
								НСтр("ru = 'Возможно, нужно просто отредактировать количество'; en = 'Perhaps you just need to edit the quantity'")));
		КонецЕсли;
	КонецЕсли; 
	
	НовЦен = 0;
		 
	Пар = Новый Структура;
	Пар.Вставить("Фирма", Объект.Фирма);
	Пар.Вставить("Номенклатура", НовНом);
	Пар.Вставить("Валюта", Объект.Валюта);
	Пар.Вставить("Количество", 0);
	Пар.Вставить("Цена", НовЦен);
	Пар.Вставить("Док", Объект.Ссылка);
	Пар.Вставить("Контрагент", Объект.Контрагент);
	Пар.Вставить("Склад", Объект.Склад);
	Пар.Вставить("Партия", 0);
	Пар.Вставить("ДатаДок", Объект.Дата);
	
	ОткрытьФорму("ОбщаяФорма.ВводСтрокиПН", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("МоеДобавлениеПослеВводаСтроки", ЭтотОбъект, Новый Структура("НовНом,УчетТовараПоСериям", НовНом, УчетТовараПоСериям)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВводаСтроки(НовПар, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	УчетТовараПоСериям = Параметры.УчетТовараПоСериям;
	
	Если гоПЗ(НовПар) Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	НовЦен = НовПар.Цена;
	//2016.01.30
	//разрешаем нулевую цену
	//Если НовЦен = 0 Тогда клОшибка("Не введена цена закупки!"); Продолжить; КонецЕсли;
	
	НовКол = НовПар.Количество;
	Если НовКол = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введено количество!'; en = 'Quantity is not specified!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	клСохранитьИзменения(Новый ОписаниеОповещения("МоеДобавлениеПослеПодтверждения", ЭтотОбъект, 
		Новый Структура("НовНом,НовПар,НовЦен,НовКол,УчетТовараПоСериям", НовНом, НовПар, НовЦен, НовКол, УчетТовараПоСериям)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеПодтверждения(Результат, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	НовЦен = Параметры.НовЦен;
	НовКол = Параметры.НовКол;
	УчетТовараПоСериям = Параметры.УчетТовараПоСериям;
	
	Если НЕ Результат Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	Если УчетТовараПоСериям Тогда
		Серии = СокрЛП(НовПар.Серии);
		Если Серии = "" Тогда Возврат КонецЕсли;
		
		//2017.02.05
		Если ДобавлениеСерийВПриходеВТранзакцииНаСервере Тогда 
			ИДИ = 0;
			ДобавитьСерии(Серии, ИДИ, НовНом, НовЦен);
		Иначе 
			Для Н = 1 По СтрЧислоСтрок(Серии) Цикл
				НовСер = СокрЛП(СтрПолучитьСтроку(Серии, Н));
				Если НовСер = "" Тогда Продолжить КонецЕсли; 
				
				Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Серия", НовСер));
				Если НЕ (Нашли.Количество() = 0) Тогда 
					клВнимание(гоИмя(НовСер) + ": уже есть в документе!" + гоРС() + "Значение пропускается!!!"); 
					Продолжить; 
				КонецЕсли;
				
				НовПар = СоздатьПартию(Объект.Ссылка, НовНом, НовЦен, НовСер, Объект.Валюта, Объект.Дата, Объект.Фирма);
				
				НовСтр = Объект.Товары.Добавить();
				
				НовСтр.Номенклатура = НовНом;
				НовСтр.Партия = НовПар;
				НовСтр.Количество = 1;
				
				ИДИ = НовСтр.ПолучитьИдентификатор();
			КонецЦикла; 
		КонецЕсли; 
	Иначе 
		НовПар = СоздатьПартию(Объект.Ссылка, НовНом, НовЦен, , Объект.Валюта, Объект.Дата, Объект.Фирма);
		
		НовСтр = Объект.Товары.Добавить();
		
		НовСтр.Номенклатура = НовНом;
		НовСтр.Партия = НовПар;
		НовСтр.Количество = НовКол;
		
		ИДИ = НовСтр.ПолучитьИдентификатор();
	КонецЕсли; 
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	МоеДобавлениеШаг(НовНом);
КонецПроцедуры

&НаСервере
Процедура ДобавитьСерии(Серии, ИДИ, НовНом, НовЦен)
	
	НачатьТранзакцию();
	
	Для Н = 1 По СтрЧислоСтрок(Серии) Цикл
		НовСер = СокрЛП(СтрПолучитьСтроку(Серии, Н));
		Если НовСер = "" Тогда Продолжить КонецЕсли; 
		
		Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Серия", НовСер));
		Если НЕ (Нашли.Количество() = 0) Тогда 
			Сообщить(СтрШаблон("%1: %2!%3%4!!!", гоИмя(НовСер), НСтр("ru = 'уже есть в документе'; en = 'is already in the document'"), гоРС(), НСтр("ru = 'Значение пропускается'; en = 'Value is omitted'"))); 
			Продолжить; 
		КонецЕсли;
		
		НовПар = СоздатьПартию(Объект.Ссылка, НовНом, НовЦен, НовСер, Объект.Валюта, Объект.Дата, Объект.Фирма);
		
		НовСтр = Объект.Товары.Добавить();
		
		НовСтр.Номенклатура = НовНом;
		НовСтр.Партия = НовПар;
		НовСтр.Количество = 1;
		НовСтр.ЦенаЗакупки = НовЦен;
		ИДИ = НовСтр.ПолучитьИдентификатор();
	КонецЦикла;
	
	Записать(РежимЗаписиПроведение);
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

