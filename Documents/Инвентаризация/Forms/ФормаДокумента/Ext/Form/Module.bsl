КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);

	Если НЕ ЗначениеЗаполнено(РежимПредупреждения) Тогда
	 	РежимПредупреждения = Элементы.РежимПредупреждения.СписокВыбора.Получить(0).Значение;
	КонецЕсли; 
	
	РаботаСоСканеромШК.СканерШКПодключить(); 
	
	ОбновитьОтображениеСкладов();
	
	УстановитьДоступность();

	ПредупреждатьОДублях = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
      
	Объект.Склады.Очистить();
	Если ОдинСклад Тогда
		
	Иначе          
		Объект.Склад = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка");
		Для каждого Эл Из СписокСкладов Цикл
			СтрокаТЧ = Объект.Склады.Добавить();
			СтрокаТЧ.Склад = Эл.Значение;  
		КонецЦикла;	
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
		
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)

	Если НЕ (ЭтаФорма.Окно = АктивноеОкно()) Тогда Возврат КонецЕсли; 
	
	ШК = "";
	Если РаботаСоСканеромШК.СканерШКНачатьОбработку(Источник, Событие, Данные, ШК) Тогда  
		ЛюбаяСерия(ШК);
		РаботаСоСканеромШК.СканерШКЗавершитьОбработку();
	КонецЕсли; 

КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура Предупредить(ТекстПредупреждения)
	
	Если СтрНайти(НРег(РежимПредупреждения), "текст") > 0 Тогда
   		клОшибка(ТекстПредупреждения); 	
	КонецЕсли;	
	Если СтрНайти(НРег(РежимПредупреждения), "голос") > 0 Тогда
		клПроизнестиГолосом(ТекстПредупреждения);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РучнойШКПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(РучнойШК) Тогда
		ЛюбаяСерия(РучнойШК, Истина);  
	Иначе
		РучнойШК = "";
	КонецЕсли;

КонецПроцедуры

 &НаКлиенте
Процедура ЛюбаяСерия(НовСер, СтатьНаРучной = Ложь)

	ШК = СокрЛП(НовСер);
	
	НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Серия", ШК)); 
	Если НайдСтроки.Количество() > 0 И ПредупреждатьОДублях Тогда
		Предупредить(НСтр("ru = 'Штрих код уже есть в документе!'; en = 'The barcode is already in the document.!'"));
		Если СтатьНаРучной Тогда 
			РучнойШК = "";
			ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
		КонецЕсли; 
		Возврат;
	КонецЕсли;  
	
	Если ПартияЕстьВДругихИнвентаризациях(ШК, Объект.Дата, Объект.Ссылка) Тогда
		Предупредить(НСтр("ru = 'Штрих код уже есть в других документах инвентаризации!'; en = 'The barcode already exists in other inventory documents.!'"));
		Если СтатьНаРучной Тогда 
			РучнойШК = "";
			ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
		КонецЕсли; 
		Возврат;
	КонецЕсли;
	
	//Если СерияЕстьНаДругихСкладах(ШК, Объект.Склад, Объект.Дата) Тогда
	//	Предупредить(НСтр("ru = 'Штрих код есть на другом складе!'; en = 'Штрих код есть на другом складе!'"));
	//	Если СтатьНаРучной Тогда 
	//		РучнойШК = "";
	//		ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
	//	КонецЕсли; 
	//	Возврат;
	//КонецЕсли;
	
	НайденнаяПартия = Партия(ШК);

	Если НЕ ЗначениеЗаполнено(НайденнаяПартия.Номенклатура) Тогда
		Предупредить(НСтр("ru = 'Не найден товар по штрих коду!'; en = 'Good not found by barcode!'"));
	КонецЕсли;
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НайденнаяПартия.Номенклатура; 
	НовСтр.Партия 		= НайденнаяПартия.Партия;
	НовСтр.Серия 		= ШК;
	НовСтр.Количество 	= 1;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	Записать();
	
	//гоЗаписьЖурналаРегистрации(ШК + "|" + Строка(НовКол) + "|" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦена) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	Если СтатьНаРучной Тогда 
		РучнойШК = "";
		ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
	КонецЕсли; 

КонецПроцедуры

&НаСервереБезКонтекста
Функция СерияЕстьНаДругихСкладах(Серия, Склад, Дата)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОстаткиТовараОстатки.ОстатокОстаток КАК Остаток,
	               |	ОстаткиТовараОстатки.РезервОстаток КАК Резерв,
	               |	ОстаткиТовараОстатки.Партия.Серия КАК ПартияСерия
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара.Остатки(
	               |			&Дата,
	               |			Партия.Серия = &Серия
	               |				И Склад <> &Склад) КАК ОстаткиТовараОстатки
	               |ГДЕ
	               |	ОстаткиТовараОстатки.ОстатокОстаток > 0";
	Запрос.УстановитьПараметр("Серия", 	Серия);
	Запрос.УстановитьПараметр("Склад", 	Склад);
	Запрос.УстановитьПараметр("Дата", 	Дата);

	Результат = Запрос.Выполнить();
	
	Возврат НЕ Результат.Пустой();

КонецФункции 

&НаСервереБезКонтекста
Функция ПартияЕстьВДругихИнвентаризациях(ШК, Дата, ДокСсылка)

	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ИнвентаризацияТовары.Серия КАК Серия
	             |ИЗ
	             |	Документ.Инвентаризация.Товары КАК ИнвентаризацияТовары
	             |ГДЕ
	             |	ИнвентаризацияТовары.Ссылка.Дата МЕЖДУ &ДатаНач И &ДатаКон
	             |	И НЕ ИнвентаризацияТовары.Ссылка.ПометкаУдаления
	             |	И ИнвентаризацияТовары.Серия = &Серия
	             //|	И ИнвентаризацияТовары.Ссылка <> &Ссылка
				 |";
	Запр.УстановитьПараметр("ДатаНач", НачалоДня(Дата));
	Запр.УстановитьПараметр("ДатаКон", КонецДня(Дата));	
	Запр.УстановитьПараметр("Серия", ШК);	
	//Запр.УстановитьПараметр("Ссылка", ДокСсылка);	
	результатЗапроса = Запр.Выполнить();
	Возврат НЕ результатЗапроса.Пустой();
	
КонецФункции 

&НаСервереБезКонтекста
Функция Партия(Серия)

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Серия", Серия);
	Запр.Текст = "ВЫБРАТЬ
	             |	Партии.Ссылка КАК Партия,
	             |	Партии.Владелец КАК Номенклатура
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Серия = &Серия
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Партии.ПометкаУдаления";
	Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Новый Структура("Номенклатура,Партия", Выборка.Номенклатура, Выборка.Партия);
	Иначе
		Возврат Новый Структура("Номенклатура,Партия", Справочники.Номенклатура.ПустаяСсылка(), Справочники.Партии.ПустаяСсылка());
	КонецЕсли;
	
КонецФункции 

