#Область ПодключаемаяПечать
	
&НаКлиенте
Процедура ВыполнитьПодключеннуюПечать(Команда)
	
	ВариантПечатнойФормы = СтрЗаменить(Команда.Имя, "ПодключеннаяПечать_", "");   
	ТабДок = ПечатнаяФорма(ВариантПечатнойФормы);
	ПараметрыПечати = Новый Структура("Таб, Имя, НеДляПечати", ТабДок, гоИмя(Объект.Ссылка, Ложь), Ложь);
	ОткрытьФорму("ОбщаяФорма.ПечатьБезЗащиты", ПараметрыПечати, , Истина); 
		
КонецПроцедуры  

&НаСервере
Функция ПечатнаяФорма(ВариантПечатнойФормы)

	ТабДок = Новый ТабличныйДокумент;
	Документы.Инвентаризация.ПечатьДокумента(Объект.Ссылка, ВариантПечатнойФормы, ТабДок);
	Возврат ТабДок;
	
КонецФункции 

#КонецОбласти


&НаКлиенте
Процедура УстановитьДоступность()

	Для каждого Элемент Из Элементы Цикл 
		Тип = ТипЗнч(Элемент);
		Если Тип = Тип("ПолеФормы") ИЛИ Тип = Тип("ТаблицаФормы") Тогда
			Элемент.ТолькоПросмотр = Объект.Окончательно; 
		ИначеЕсли Тип = Тип("КнопкаФормы") И Элемент.Родитель <> Элементы.ФормаКоманднаяПанель Тогда
			Элемент.Доступность = НЕ Объект.Окончательно;
		КонецЕсли;
	КонецЦикла;	    
	Если Элементы.Найти("Снять") <> Неопределено Тогда
		Элементы.Снять.Доступность = Объект.Окончательно;
	КонецЕсли;
	Если Элементы.Найти("Установить") <> Неопределено Тогда
		Элементы.Установить.Доступность = НЕ Объект.Окончательно;
	КонецЕсли;
	Элементы.Окончательно.ТолькоПросмотр = Истина;
	Элементы.ПредупреждатьОДублях.ТолькоПросмотр = Истина;	
	Элементы.ТоварыСерия.ТолькоПросмотр = Истина;	
	Элементы.ТоварыКоличество.ТолькоПросмотр = Истина;	
	
КонецПроцедуры


#Область Склады
	
&НаСервереБезКонтекста
Функция СкладыДляВыбора(СписокПомеченных)
	
	Спис = Новый СписокЗначений;
	Запр = новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             |	Склады.Ссылка КАК Ссылка,
	             |	ИСТИНА КАК Пометка
	             |ИЗ
	             |	Справочник.Склады КАК Склады
	             |ГДЕ
	             |	НЕ Склады.ПометкаУдаления";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	 	Спис.Добавить(Выборка.Ссылка, , СписокПомеченных.НайтиПОЗначению(Выборка.Ссылка) <> Неопределено);
	КонецЦикла;
	Возврат Спис;
	
КонецФункции // СладыДляВыбора()

&НаКлиенте
Процедура ОбновитьОтображениеСкладов()
	
	Элементы.Склад.Видимость = ОдинСклад;
	Элементы.Склады.Видимость = НЕ ОдинСклад;

	Если СписокСкладов.Количество() = 0 Тогда
		Склады = НСтр("ru = '<не выбраны>'; en = '<not selected>'")	
	Иначе 
		Загл = "";
		Для каждого Эл Из СписокСкладов Цикл
		 	Загл = Загл + Эл.Значение + ", ";
		КонецЦикла;
		Склады = Загл;
	КонецЕсли;

КонецПроцедуры	

&НаКлиенте
Процедура ПослеОтметкиЭлементов(Список, Параметры) Экспорт
	
	Если Список <> Неопределено Тогда  
		СписокСкладов.Очистить();
        Для каждого Элемент из Список Цикл
            Если Элемент.Пометка И СписокСкладов.НайтиПоЗначению(Элемент.Значение) = Неопределено Тогда
				СписокСкладов.Добавить(Элемент.Значение); 
            КонецЕсли;
        КонецЦикла;
		Модифицированность = Истина;
	КонецЕсли;
	ОбновитьОтображениеСкладов();
	
КонецПроцедуры

&НаКлиенте
Процедура ОдинСкладПриИзменении(Элемент)
	
	ОбновитьОтображениеСкладов();
	
КонецПроцедуры

&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	
	СписокСкладов.Очистить();
	СписокСкладов.Добавить(Объект.Склад);
	
КонецПроцедуры

&НаКлиенте
Процедура СкладыНажатие(Элемент, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	Оповещение = Новый ОписаниеОповещения("ПослеОтметкиЭлементов", ЭтотОбъект);
	СкладыДляВыбора = СкладыДляВыбора(СписокСкладов);
	СкладыДляВыбора.ПоказатьОтметкуЭлементов(Оповещение, НСтр("ru = 'Остатки на складах'; en = 'Warehouse balances'"));

КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалением(Элемент, Отказ)
	Отказ = Истина;

	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли;

	клНетДа(Новый ОписаниеОповещения("ТоварыПередУдалениемЗавершение", ЭтотОбъект, Стр),
		НСтр("ru = 'Удалить строку?'; en = 'Delete line?'"));

КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалениемЗавершение(Результат, Стр) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	Объект.Товары.Удалить(Стр);
КонецПроцедуры


&НаКлиенте
Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
КонецПроцедуры

