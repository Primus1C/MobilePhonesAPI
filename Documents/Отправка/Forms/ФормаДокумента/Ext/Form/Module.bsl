#Область ДействияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;

	ОтобразитьТоварныеГруппы();
	
	ЗаполнитьКэшДанных();
	СформироватьГиперссылкиФайловНаФорме();
	
	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	
	Элементы.ВалютаЗатрат.БыстрыйВыбор = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("БыстрыйВыборВалют"); 
	
	СтруктураПечатныхФорм = Документы.Отправка.ПолучитьСтруктуруПечатныхФорм();  
	ПараметрыРазмещения = Новый Структура("Форма, ЭтоФормаОбъекта, КоманднаяПанель", ЭтаФорма, Истина, Неопределено);
	ОбщегоНазначенияСервер.ПодключитьКомандыПечати(ПараметрыРазмещения, СтруктураПечатныхФорм);   
	
	УстановитьУсловноеОформление();
	
	//++
	ИсторияИзменений = Новый Структура("Шапка,ТЧ", Новый Массив, Новый Массив);
	Для каждого Рекв Из Метаданные.Документы.Отправка.Реквизиты Цикл
		ИсторияИзменений.Шапка.Добавить(Новый Структура("Имя,Синоним,Значение", Рекв.Имя, Рекв.Синоним, Объект[Рекв.Имя]));
	КонецЦикла;
    Для каждого ТЧ Из Метаданные.Документы.Отправка.ТабличныеЧасти Цикл
		Строки = Новый Массив;
		Строки.Добавить();
		
		ИсторияИзменений.ТЧ.Добавить(Новый Структура("Имя,Строки", ТЧ.Имя, Строки))	
	КонецЦикла;
	//--

	Элементы.ИнвойсыСумма.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Сумма'; en = 'Sum'"), ПараметрыСеанса.БазоваяВалюта.Символ);	
	
	ЗаполнитьДеревоЗначенийНаСервере();
	
КонецПроцедуры

