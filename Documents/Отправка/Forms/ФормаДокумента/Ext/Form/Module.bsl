&НаСервере
Функция ИнвойсыДокумента()
	
	Спис = Новый СписокЗначений;
	Для каждого СтрокаТЧ Из Объект.Инвойсы Цикл
		Спис.Добавить(СтрШаблон("%1#%2", СтрокаТЧ.Инвойс.Номер, Формат(СтрокаТЧ.Поставка,"")));
	КонецЦикла;
	Возврат Спис;

КонецФункции 

