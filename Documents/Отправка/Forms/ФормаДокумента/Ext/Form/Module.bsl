&НаКлиенте
Процедура ЗаполнитьСписокВыбораПоставок(СтрокаТЧ)

	КвоПоставок = КэшДанных.Инвойсы[СтрокаТЧ.Инвойс].КоличествоПоставокВИнвойсе;
	Если КвоПоставок = 0 Тогда
		//	//Поле.СписокВыбора.Добавить(0, "инвойс полностью");
	Иначе  
		ПолеПоставка = Элементы.Инвойсы.ПодчиненныеЭлементы.ИнвойсыПоставка;
		ПолеПоставка.СписокВыбора.Очистить();
		Для Инд = 1 По КвоПоставок Цикл     
			КвоВПоставке = КэшДанных.Инвойсы[СтрокаТЧ.Инвойс].ПоставкиИнвойсов[Инд].Количество;
			ПолеПоставка.СписокВыбора.Добавить(Инд, СтрШаблон(НСтр("ru = '%1 (из %2), кол-во %3'; en = '%1 (of %2), quantity %3'"), Инд, КвоПоставок, КвоВПоставке));
		КонецЦикла;
		Элементы.Инвойсы.ТекущиеДанные.Поставка = 1;
	КонецЕсли;

КонецПроцедуры

