	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ключ</Field>
				<Field>Список.ПометкаУдаления</Field>
				<Field>Список.Поставка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПоставкиИнвойсы.Ссылка КАК Ссылка,
	ПоставкиИнвойсы.Поставка КАК Поставка,
	ПоставкиИнвойсы.Контрагент КАК Контрагент,
	ПоставкиИнвойсы.Номер КАК Номер,
	ПоставкиИнвойсы.Дата КАК Дата,
	ПоставкиИнвойсы.НомерИнвойса КАК НомерИнвойса,
	ПоставкиИнвойсы.ПометкаУдаления КАК ПометкаУдаления,
	ПоставкиИнвойсы.Номер + "#" + СТРОКА(ПоставкиИнвойсы.Поставка) КАК Ключ,
	ПоставкиИнвойсы.НомерКартинки КАК НомерКартинки,
	ПоставкиИнвойсы.ПоставкаСтрокой КАК ПоставкаСтрокой,
	ПоставкиИнвойсы.Количество КАК Количество,
	ПоставкиИнвойсы.Сумма КАК Сумма,
	Отправки.Количество КАК ПоставленоКоличество,
	Отправки.Сумма КАК ПоставленоСумма,
	//ВЫБОР
	//	КОГДА Отправки.Количество = 0
	//		ТОГДА ИСТИНА
	//	ИНАЧЕ ЛОЖЬ
	//КОНЕЦ КАК Отправлено,
	ВЫБОР
		КОГДА Отправки.ОжидаемыеПоставки &lt; 1
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Отправлено,	
	СостоянияИнвойсов.Статус КАК Статус,
	ПоставкиИнвойсы.Авианакладная
ИЗ
	(ВЫБРАТЬ
		ДокИнвойс.Ссылка КАК Ссылка,
		ЕСТЬNULL(ТЧПоставки.Поставка, 0) КАК Поставка,
		ДокИнвойс.Контрагент КАК Контрагент,
		ДокИнвойс.Номер КАК Номер,
		ДокИнвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойса,
		ДокИнвойс.ВКД_ДатаИнвойсаПоставщика КАК Дата,
		ДокИнвойс.ПометкаУдаления КАК ПометкаУдаления,
		ВЫБОР
			КОГДА ДокИнвойс.Проведен
				ТОГДА 0
			КОГДА ДокИнвойс.ПометкаУдаления
				ТОГДА 2
			ИНАЧЕ 1
		КОНЕЦ КАК НомерКартинки,
		ВЫБОР
			КОГДА ДокИнвойс.КоличествоПоставок &lt; 2
				ТОГДА ""
			ИНАЧЕ СТРОКА(ТЧПоставки.Поставка) + " (" + СТРОКА(ДокИнвойс.КоличествоПоставок) + ")"
		КОНЕЦ КАК ПоставкаСтрокой,
		ЕСТЬNULL(СУММА(ТЧПоставки.Количество), ДокИнвойс.ВКД_Количество) КАК Количество,
		ЕСТЬNULL(СУММА(ТЧПоставки.Сумма), ДокИнвойс.Сумма) КАК Сумма,
		ИнвойсЗакупки.Авианакладная КАК Авианакладная
	ИЗ
		Документ._Инвойс КАК ДокИнвойс
			ЛЕВОЕ СОЕДИНЕНИЕ Документ._Инвойс.Поставки КАК ТЧПоставки
			ПО ДокИнвойс.Ссылка = ТЧПоставки.Ссылка
			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИнвойсЗакупки КАК ИнвойсЗакупки
			ПО ДокИнвойс.ДокументОснование = ИнвойсЗакупки.Ссылка
	
	СГРУППИРОВАТЬ ПО
		ДокИнвойс.Ссылка,
		ТЧПоставки.Поставка,
		ВЫБОР
			КОГДА ДокИнвойс.Проведен
				ТОГДА 0
			КОГДА ДокИнвойс.ПометкаУдаления
				ТОГДА 2
			ИНАЧЕ 1
		КОНЕЦ,
		ВЫБОР
			КОГДА ДокИнвойс.КоличествоПоставок &lt; 2
				ТОГДА ""
			ИНАЧЕ СТРОКА(ТЧПоставки.Поставка) + " (" + СТРОКА(ДокИнвойс.КоличествоПоставок) + ")"
		КОНЕЦ,
		ДокИнвойс.Номер,
		ДокИнвойс.ВКД_ДатаИнвойсаПоставщика,
		ДокИнвойс.ПометкаУдаления,
		ДокИнвойс.Контрагент,
		ДокИнвойс.ВКД_НомерИнвойсаПоставщика,
		ИнвойсЗакупки.Авианакладная,
		ДокИнвойс.ВКД_Количество,
		ДокИнвойс.Сумма) КАК ПоставкиИнвойсы
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ОтправкаИнвойсов.Инвойс КАК Инвойс,
			ОтправкаИнвойсов.Поставка КАК Поставка,
			СУММА(ОтправкаИнвойсов.Количество) КАК Количество,
			СУММА(ОтправкаИнвойсов.Сумма) КАК Сумма,
			СУММА(ОтправкаИнвойсов.ОжидаемыеПоставки) КАК ОжидаемыеПоставки
		ИЗ
			РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
		
		СГРУППИРОВАТЬ ПО
			ОтправкаИнвойсов.Инвойс,
			ОтправкаИнвойсов.Поставка) КАК Отправки
		ПО ПоставкиИнвойсы.Ссылка = Отправки.Инвойс
			И ПоставкиИнвойсы.Поставка = Отправки.Поставка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
		ПО ПоставкиИнвойсы.Ссылка = СостоянияИнвойсов.Инвойс

ГДЕ
	ВЫБОР
			КОГДА &amp;Граница = НЕОПРЕДЕЛЕНО
