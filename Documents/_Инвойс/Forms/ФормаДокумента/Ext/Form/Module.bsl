&НаКлиенте
Процедура КурсПриИзменении(Элемент)
	
	Объект.КурсУстановленВручную = Истина;
	ОбновитьОтображениеДанных(Элементы.КурсУстановленВручную);
	
	Если Объект.Курс = 0 Тогда
		Возврат;
	КонецЕсли;
	
	клВопрос(Новый ОписаниеОповещения("КурсПриИзмененииЗавершение", ЭтотОбъект), 
		НСтр("ru = 'Пересчитать цены и суммы оплаты во всех строках?'; en = 'Convert prices and payment sum in all lines?'"));
	
КонецПроцедуры

&НаКлиенте
Процедура КурсПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		ПересчитатьЦенуИСуммуПоКурсу(СтрокаТЧ);
	КонецЦикла;
	Если КоличествоПоставок > 0 Тогда
		ПересчитатьСуммыПоставокИзТоваров();
		ПеренестиДанныеПоставкиСФормыВТЧ();
	КонецЕсли;
	КурсУстановленВручную = Истина;
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьЦенуИСуммуПоКурсу(СтрокаТЧ, РассчитатьТолькоСуммуИнвойса = Ложь)
	
	Если Объект.Наценка Тогда
		ЦенаБазовая = СтрокаТЧ.ЦенаСНаценкой;
	ИначеЕсли СтрокаТЧ.ЦенаБезНДС = 0 Тогда
		ЦенаБазовая = СтрокаТЧ.ЦенаИнвойса;
	Иначе
		ЦенаБазовая = СтрокаТЧ.ЦенаБезНДС;
	КонецЕсли;
	
	//СтрокаТЧ.СуммаИнвойса = СтрокаТЧ.ЦенаИнвойса * СтрокаТЧ.Количество; 
    СтрокаТЧ.СуммаИнвойса = ЦенаБазовая * СтрокаТЧ.Количество; 
	
	Если Объект.Курс > 0 И НЕ РассчитатьТолькоСуммуИнвойса Тогда 
		//Если СтрокаТЧ.ЦенаИнвойса <> 0 Тогда
		Если ЦенаБазовая <> 0 Тогда
			//СтрокаТЧ.ЦенаЗакупки = СтрокаТЧ.ЦенаИнвойса / Объект.Курс;
			СтрокаТЧ.ЦенаЗакупки = ЦенаБазовая / Объект.Курс;
		КонецЕсли;  
		Если СтрокаТЧ.СуммаИнвойса <> 0 Тогда
			СтрокаТЧ.СуммаЗакупки = СтрокаТЧ.СуммаИнвойса / Объект.Курс;
		КонецЕсли;  
	КонецЕсли;                    
	
	ОбновитьСуммуВВалютеИнвойса();
	ОтобразитьРазницуИнвойсов();

КонецПроцедуры

