&НаКлиенте
Процедура ИзменитьПометки(ЗначениеПометки)
	
	ТекПоставка = Сред(Элементы.ГруппаПоставки.ТекущаяСтраница.Имя, 2, 1);
	ТаблицаФормы = Элементы["П" + ТекПоставка + "Поставки"];
	
	НайдСтроки = Поставки.НайтиСтроки(Новый Структура("Поставка", Число(ТекПоставка)));
	Для каждого ТекСтрока Из НайдСтроки Цикл   
		
		Если ЗначениеПометки = Неопределено Тогда
			ТекСтрока.Пометка = НЕ ТекСтрока.Пометка;
		Иначе
			ТекСтрока.Пометка = ЗначениеПометки;
		КонецЕсли;    
		
		ПрименитьПометкуСтрокиПоставки(ТекСтрока);
		
	КонецЦикла; 

	ПеренестиДанныеПоставкиСФормыВТЧ();
	ОбновитьИнвойсСкорректированный();
	ОбновитьИтогиПоставок(Число(ТекПоставка)); 
	Модифицированность = Истина;
	
КонецПроцедуры	

