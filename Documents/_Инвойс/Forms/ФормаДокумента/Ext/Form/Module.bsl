	ТекДанные = ЭтаФорма.ТекущийЭлемент.ТекущиеДанные; 
	ТекДанные.Остаток = ТекДанные.Остаток + КоличествоПоставкиДоРедактирования - ТекДанные.Количество; 
	ПересчитатьСуммуСтрокиПоставки(ТекДанные);
	ТекДанные.Пометка = ТекДанные.Количество <> 0;	
	
	ПеренестиДанныеПоставкиСФормыВТЧ();
	ОбновитьИнвойсСкорректированный();
