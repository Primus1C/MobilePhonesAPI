#Область ДействияФормы  

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.ВКД_Распределить = 1
	КонецЕсли;

	// © Primus1C  25.06.2023  НАЧАЛО ►  
	
	Если РольДоступна("Администратор") ИЛИ РольДоступна("ИнвойсТоварный") Тогда
		Элементы.ДокументОснование.Вид = ВидПоляФормы.ПолеВвода; 
	КонецЕсли;    
	
	Отправки.Параметры.УстановитьЗначениеПараметра("Инвойс", Объект.Ссылка);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запр = Новый Запрос;   
		Запр.УстановитьПараметр("Инвойс", Объект.Ссылка);
		Запр.Текст ="ВЫБРАТЬ 
		            |	СостоянияИнвойсов.Статус КАК Статус,
		            |	СостоянияИнвойсов.СтатусОплаты КАК СтатусОплаты
		            |ИЗ
		            |	РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
		            |ГДЕ
		            |	СостоянияИнвойсов.Инвойс = &Инвойс"; 
		Выборка = Запр.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			СтатусДокумента = Выборка.Статус; 	
			СтатусОплаты 	= Выборка.СтатусОплаты; 	
		КонецЕсли; 
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |	_Инвойс.Ссылка КАК Инвойс
		             |ИЗ
		             |	Документ._Инвойс КАК _Инвойс
		             |ГДЕ
		             |	НЕ _Инвойс.ПометкаУдаления
		             |	И _Инвойс.ДокументОснование = &ДокументОснование
		             |	И _Инвойс.ВидОперации = &ВидОперации";
	    Запр.УстановитьПараметр("ДокументОснование", Объект.ДокументОснование);
	    Запр.УстановитьПараметр("ВидОперации", Объект.ВидОперации);
		Выборка = Запр.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			Сообщить(СтрШаблон(НСтр("ru = 'Уже есть инвойс (%1), созданный на основании текущего документа!'; en = 'There is already an invoice (%1) created based on the current document!'"), Объект.ВидОперации), СтатусСообщения.ОченьВажное);
			Отказ = Истина;	
		КонецЕсли;
	КонецЕсли;
	
	лРежим = РольДоступна("Администратор") ИЛИ РольДоступна("ИнвойсТоварный");
	Элементы.СтатусДокумента.ТолькоПросмотр = НЕ лРежим;

	ЗаполнитьКэшДанных(Ложь); 
	
	СформироватьГиперссылкиФайловНаФорме();

	Попытка
		Элементы.ПримечаниеЗакупки.Видимость = ЗначениеЗаполнено(Объект.ДокументОснование.Примечание); 
	Исключение
	КонецПопытки;
	Элементы.ПоставкаШаблон.Видимость = Ложь;  // <- отладка

	КоличествоПоставок = 0;
	Для каждого СтрокаТЧ Из Объект.Поставки Цикл
		Если СтрокаТЧ.Поставка > КоличествоПоставок Тогда
			КоличествоПоставок = СтрокаТЧ.Поставка;
		КонецЕсли;	
	КонецЦикла;	
	Для П = 1 По КоличествоПоставок Цикл
		ДобавитьПоставкуНаСервере(П);
	КонецЦикла;        
	
	СведенияОбОтправках = СведенияОбОтправках();
	Элементы.ГруппаОтправки.Заголовок = СтрШаблон(НСтр("ru = 'Отправки (%1)'; en = 'Shipments (%1)'"), СведенияОбОтправках.КоличествоОтправок);
	Если СведенияОбОтправках.Ошибка Тогда
		Элементы.ГруппаОтправки.Заголовок = Элементы.ГруппаОтправки.Заголовок + НСтр("ru = ': ОШИБКА!'; en = ': ERROR!'");
		Элементы.ГруппаОтправки.Картинка = БиблиотекаКартинок.ВниманиеКрасный;
	КонецЕсли;

	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента);  
	
	Элементы.Валюта.БыстрыйВыбор = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("БыстрыйВыборВалют");
	Элементы.ВКД_ТоварыЦенаЗакупки.Заголовок 	= СтрШаблон("%1 (%2)", НСтр("ru = 'Цена закупки'; en = 'Price'"), Объект.Валюта.Символ);
	Элементы.ВКД_ТоварыСуммаЗакупки.Заголовок 	= СтрШаблон("%1 (%2)", НСтр("ru = 'Сумма закупки'; en = 'Sum'"), Объект.Валюта.Символ);
	Элементы.ИнвойсСкорСуммаИнвойса.Заголовок 	= СтрШаблон("%1 (%2)", НСтр("ru = 'Сумма'; en = 'Sum'"), Объект.Валюта.Символ);
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Элементы.ВКД_ТоварыЦенаИнвойса.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Цена инвойса'; en = 'Invoice price'"), Объект.ДокументОснование.Валюта.Символ);
		Элементы.ВКД_ТоварыСуммаИнвойса.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Сумма инвойса'; en = 'Invoice sum'"), Объект.ДокументОснование.Валюта.Символ);
	КонецЕсли;
	
	Элементы.Курс.Заголовок 					= СтрШаблон("%1 1%2", НСтр("ru = 'Курс'; en = 'Rate'"), Объект.ДокументОснование.Валюта.Символ);
	//Элементы.Курс.ФорматРедактирования			= СтрШаблон("ЧФ='Ч %1'", ПараметрыСеанса.БазоваяВалюта.Символ);
	Элементы.ДекорацияКурс.Заголовок 			= ПараметрыСеанса.БазоваяВалюта.Символ;  
	
	Элементы.ДекорацияВалютаЗатрат.Заголовок 	= ПараметрыСеанса.БазоваяВалюта.Символ;
	
	СтруктураПечатныхФорм = Документы._Инвойс.ПолучитьСтруктуруПечатныхФорм();  
	ПараметрыРазмещения = Новый Структура("Форма, ЭтоФормаОбъекта, КоманднаяПанель", ЭтаФорма, Истина, Неопределено);
	ОбщегоНазначенияСервер.ПодключитьКомандыПечати(ПараметрыРазмещения, СтруктураПечатныхФорм);   
	
	// привязки 
	лПривязки = Объект.Контрагент.ПривязыватьИнвойсы;
	Элементы.Привязки.Видимость = лПривязки;
	Если лПривязки Тогда
	    ЗаполнитьТаблицуПривязок();
	КонецЕсли; 
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры   

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	Объект.Сумма = Объект.ВКД_Товары.Итог("СуммаЗакупки");
	Объект.ВКД_Количество = Объект.ВКД_Товары.Итог("Количество");
	
	// © Primus1C  15.08.2023  НАЧАЛО ►  
	
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
			СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыИнвойса.ПустаяСсылка");
			Прервать;
		КонецЕсли;	
	КонецЦикла;  
	
	Инд = Объект.Поставки.Количество() - 1;
	Пока Инд >= 0 Цикл
		НайдСтроки = Объект.ВКД_Товары.НайтиСтроки(Новый Структура("ИдСтроки", Объект.Поставки[Инд].ИдСтроки));
		Если НайдСтроки.Количество() = 0 Тогда
			Объект.Поставки.Удалить(Инд);
		КонецЕсли; 
		Инд = Инд - 1;
	КонецЦикла;
	
	Если КоличествоПоставок > 0 Тогда
		ПересчитатьСуммыПоставокИзТоваров();
		ПеренестиДанныеПоставкиСФормыВТЧ();
	КонецЕсли;
	
	//Если Объект.КоличествоПоставок = 1 Тогда
	//	Если НЕ клВопрос("В документе используется разделение на поставки, но поставок всего 1. Вы действительно хотите сохранить одну поставку в документе?") Тогда
	//		Отказ = Истина;
	//		Возврат;
	//	КонецЕсли;
	//КонецЕсли;  
	
	Если ДоступЛогиста() Тогда
		лКоличествоПоставок = 0;
		Для Каждого Пост Из Объект.Поставки Цикл
			лКоличествоПоставок = Макс(лКоличествоПоставок, Пост.Поставка);                
		КонецЦикла;
		Если лКоличествоПоставок > 0 Тогда
			фЕстьОстаток = Ложь;
			Для каждого СтрокаИнвСкор Из ИнвойсСкорректированный Цикл
				Если СтрокаИнвСкор.Остаток > 0 Тогда
					фЕстьОстаток = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если фЕстьОстаток Тогда
				клВопрос(Новый ОписаниеОповещения("ПередЗаписьюПереносОстаткаЗавершение", ЭтотОбъект), 
					СтрШаблон(НСтр("ru = 'Перенести остаток товаров в новую поставку № %1?'; en = 'Transfer the goods balance to a new delivery № %1?'"), лКоличествоПоставок+1));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписьюПереносОстаткаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	ДобавитьПоставку(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// © Primus1C  12.09.2023  НАЧАЛО ►  
	//клФормаДокументаПриОткрытии(ЭтаФорма, Объект);

	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
