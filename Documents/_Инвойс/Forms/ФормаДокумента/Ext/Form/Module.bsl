		Отказ = Истина;
		Стр = Элементы.ВКД_Товары.ТекущиеДанные;
		Если Стр = Неопределено Тогда Возврат КонецЕсли;
		ИДИ = Стр.ПолучитьИдентификатор();
		клНетДа(Новый ОписаниеОповещения("ВКД_ТоварыПередУдалениемЗавершение", ЭтотОбъект, ИДИ),
			НСтр("ru = 'Удалить строку (также из поставок)?'; en = 'Delete line (also from deliveries?'"));
		Возврат;
	КонецЕсли;
	
	УдСтроки = Поставки.НайтиСтроки(Новый Структура("ИдСтроки", ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ИдСтроки));
	Для каждого Стр Из УдСтроки Цикл
		Поставки.Удалить(Поставки.Индекс(стр));	
	КонецЦикла;
	
	//ОбновитьИнвойсСкорректированный();

