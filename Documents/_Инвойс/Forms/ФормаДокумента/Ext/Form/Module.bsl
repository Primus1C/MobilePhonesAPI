	ПрименитьПометкуСтрокиПоставки(ТекДанные);
	ПеренестиДанныеПоставкиСФормыВТЧ();
	ОбновитьИнвойсСкорректированный();
	ОбновитьИтогиПоставок(ТекДанные.Поставка);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
