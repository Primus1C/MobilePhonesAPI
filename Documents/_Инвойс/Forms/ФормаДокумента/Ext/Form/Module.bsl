#Область Привязки
	
&НаСервере
Процедура ЗаполнитьТаблицуПривязок()
	
	лВалютаИнвойса = Объект.ДокументОснование.Валюта;
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ДвижениеДенегИнвойсы.Ссылка КАК Документ,
	             |	ДвижениеДенегИнвойсы.Сумма КАК Сумма
	             |ИЗ
	             |	Документ.ДвижениеДенег.Инвойсы КАК ДвижениеДенегИнвойсы
	             |ГДЕ
	             |	ДвижениеДенегИнвойсы.Инвойс = &Инвойс
	             |	И ДвижениеДенегИнвойсы.Ссылка.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Поставщики)
	             |	И ДвижениеДенегИнвойсы.Ссылка.Проведен
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	ДвижениеДенегИнвойсы.Ссылка.Дата";
	Запр.УстановитьПараметр("Инвойс", Объект.Ссылка);
	Выгрузка = Запр.Выполнить().Выгрузить();
	Привязки.Загрузить(Выгрузка);
	
	Для каждого СтрокаТЗ Из Привязки Цикл  
		док = СтрокаТЗ.Документ; 
		//СтрокаТЗ.Курс = омСервер.СредневзвешенныйКурс(лВалютаИнвойса, Док.ДСчет, Док.Дата);  
		СтрокаТЗ.Курс = РаботаСВалютой.СредневзвешенныйКурс(лВалютаИнвойса, Док.ДСчет, Док.Ссылка.МоментВремени());
		Если СтрокаТЗ.Курс > 0 Тогда
			СтрокаТЗ.СуммаВБазВалюте = СтрокаТЗ.Сумма / СтрокаТЗ.Курс;
		КонецЕсли;
	КонецЦикла; 
	
	Элементы.ПривязкиСумма.ТекстПодвала = Формат(Привязки.Итог("Сумма"), "ЧДЦ=2");
	Элементы.ПривязкиСуммаВБазВалюте.ТекстПодвала = Формат(Привязки.Итог("СуммаВБазВалюте"), "ЧДЦ=2");
	Элементы.ПривязкиСумма.Заголовок = СтрШаблон("Сумма (%1)", лВалютаИнвойса.Символ);
	Элементы.ПривязкиСуммаВБазВалюте.Заголовок = СтрШаблон("Сумма (%1)", лВалютаИнвойса.БазоваяВалюта.Символ);
	Элементы.СтраницаПривязки.Заголовок = СтрШаблон("%1 (%2)",
													НСтр("ru = 'Привязки'; en = 'Bindings'"),
													Привязки.Количество());
	Если Привязки.Количество() = 1 Тогда
		// берем из единственного док-та оплаты, т.к. обратный расчет от сумм м.давать погрешность	
		СрВзвешКурс = Привязки[0].Курс;
	Иначе
		СрВзвешКурс = ?(Привязки.Итог("СуммаВБазВалюте") = 0, 0, Привязки.Итог("Сумма") / Привязки.Итог("СуммаВБазВалюте"));
	КонецЕсли;
	Элементы.КурсУстановленВручную.Подсказка = СтрШаблон("%1: %2 %3",
														НСтр("ru = 'Cр.взвешенный курс рассчитан'; en = 'Weighted average rate calculated'"),
														СрВзвешКурс,
														лВалютаИнвойса.Символ);
	
КонецПроцедуры

