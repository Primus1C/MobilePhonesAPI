&НаКлиенте
Процедура ВызватьЗаменуРазделение(Режим)

	Перем ВыбНоменклатура;
	
	Если Элементы.ВКД_Товары.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;    
	
	ОбновитьИДСтрок();      
	ЕстьВПоставках = Ложь;
	МассивЗамен = Новый Массив;
	ТекущиеДанные = Элементы.ВКД_Товары.ТекущиеДанные;  
	НайдСтроки = Поставки.НайтиСтроки(Новый Структура("Номенклатура", ТекущиеДанные.Номенклатура));
	Для каждого СтрокаЗамен Из НайдСтроки Цикл
		СтруктураСтроки = Новый Структура("Номенклатура,Количество,Поставка,ИдСтроки,ЦенаЗакупки,ЦенаСоСкидкой,ЦенаИнвойса");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, СтрокаЗамен, "Номенклатура,Количество,Поставка,ИдСтроки"); 
		ЗаполнитьЗначенияСвойств(СтруктураСтроки, ТекущиеДанные, "ЦенаЗакупки,ЦенаСоСкидкой,ЦенаИнвойса"); 
		МассивЗамен.Добавить(СтруктураСтроки);   
		Если СтрокаЗамен.Количество > 0 Тогда
			ЕстьВПоставках = Истина;
		КонецЕсли;
	КонецЦикла;  
	
	Если ЕстьВПоставках Тогда   
		
		ПараметрыЗамены = Новый Структура( "МассивЗамен,Режим,Инвойс,Номенклатура,Количество,ИдСтроки,ЦенаЗакупки,ЦенаСоСкидкой,ЦенаИнвойса",
											МассивЗамен,    
											Режим,
											Объект.Ссылка, 
											ТекущиеДанные.Номенклатура, 
											ТекущиеДанные.Количество, 
											ТекущиеДанные.ИдСтроки, 
											ТекущиеДанные.ЦенаЗакупки, 
											ТекущиеДанные.ЦенаСоСкидкой,
	                                        ТекущиеДанные.ЦенаИнвойса );
		ОткрытьФорму("Документ._Инвойс.Форма.ФормаРазделения", ПараметрыЗамены, ЭтаФорма, ,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца); 
		
	Иначе
		
		ИДИ = ТекущиеДанные.ПолучитьИдентификатор();
		ВыбНоменклатура = ТекущиеДанные.Номенклатура; 
		ПоказатьВводЗначения(Новый ОписаниеОповещения("ВызватьЗаменуРазделениеПослеВыбораНоменклатуры", ЭтотОбъект, ИДИ), 
			ВыбНоменклатура, НСтр("ru = 'Выберите замену'; en = 'Select a substitution'"), Тип("СправочникСсылка.Номенклатура"));
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВызватьЗаменуРазделениеПослеВыбораНоменклатуры(ВыбНоменклатура, ИДИ) Экспорт
	Если ВыбНоменклатура = Неопределено Тогда Возврат КонецЕсли;
	
	ТекущиеДанные = Объект.ВКД_Товары.НайтиПоИдентификатору(ИДИ);
	Если ТекущиеДанные = Неопределено Тогда Возврат КонецЕсли;
	
	клНамекнуть(ТекущиеДанные.Номенклатура, 
				НСтр("ru = 'Номенклатура не участвует в поставках'; en = 'This good not involved in deliveries'"),
				БиблиотекаКартинок.Инфо);
	ТекущиеДанные.Номенклатура = ВыбНоменклатура; 
	НайдСтроки = Поставки.НайтиСтроки(Новый Структура("ИдСТроки", ТекущиеДанные.ИдСтроки));
	Для каждого Стр Из НайдСтроки Цикл
		Стр.Номенклатура = ВыбНоменклатура;	
	КонецЦикла; 
КонецПроцедуры

