&НаКлиенте
Процедура ОбновитьИДСтрок()
	
	Ид = 0;      
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		Ид = Макс(Ид, СтрокаТЧ.ИдСтроки);	
	КонецЦикла;	
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		Ид = Ид + 1;
		Если СтрокаТЧ.ИдСтроки = 0 Тогда
			СтрокаТЧ.ИдСтроки = Ид;	
		КонецЕсли;
	КонецЦикла;
	     
КонецПроцедуры

