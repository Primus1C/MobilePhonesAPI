&НаКлиенте
Процедура ОбновитьДеревоЗатрат(Команда) 
	
	МассивЗатрат = Новый Массив;
	ЗаполнитьДеревоЗначенийНаСервере(МассивЗатрат);  
	
	СтруктураЗатрат = омСервер.МоиИтогиФорматированные(Новый Структура("Ссылка", МассивЗатрат), Ложь, Ложь, Истина); 
    Элементы.ДекорацияЗатраты.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураЗатрат.Затраты));

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоЗначенийНаСервере(МассивЗатрат)
	
	Дер = РеквизитФормыВЗначение("Затраты");
	Дер.Строки.Очистить(); 
	
	УстановитьПривилегированныйРежим(Истина);
	
    Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ 
	             |	ДвижениеДенегИнвойсы.Ссылка.Затрата КАК Затрата,
	             |	ДвижениеДенегИнвойсы.Ссылка КАК Документ,
	             |	ДвижениеДенегИнвойсы.Сумма КАК Сумма,
	             |	ДвижениеДенегИнвойсы.Ссылка.Валюта КАК Валюта
	             |ПОМЕСТИТЬ ВТ
	             |ИЗ
	             |	Документ.ДвижениеДенег.Инвойсы КАК ДвижениеДенегИнвойсы
	             |ГДЕ
	             |	ДвижениеДенегИнвойсы.Инвойс = &Ссылка
	             |	И ДвижениеДенегИнвойсы.Ссылка.Проведен
	             |	И ДвижениеДенегИнвойсы.Ссылка.ВидДвиженияДенег = Значение(Перечисление.ВидДвиженияДенег.Логистика)
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ВТ.Затрата КАК Затрата,
	             |	ВТ.Документ КАК Документ,
	             |	ВТ.Сумма КАК Сумма,
	             |	ВТ.Валюта КАК Валюта
	             |ИЗ
	             |	ВТ КАК ВТ
	             |ИТОГИ
	             |	СУММА(Сумма)
	             |ПО
	             |	Затрата,
	             |	Документ,
	             |	Валюта
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	СУММА(ВТ.Сумма) КАК Сумма,
	             |	ВТ.Валюта КАК Валюта
	             |ИЗ
	             |	ВТ КАК ВТ
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ВТ.Валюта";  
	Пакет = Запр.ВыполнитьПакет();    

	УстановитьПривилегированныйРежим(Ложь);

	ВыборкаЗ = Пакет[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
	Пока ВыборкаЗ.Следующий() Цикл   
		СтрокаЗ = Дер.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаЗ, ВыборкаЗ); 
		ВыборкаД = ВыборкаЗ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаД.Следующий() Цикл
			ВыборкаВ = ВыборкаД.Выбрать();
			ВыборкаВ.Следующий();
			//СтрокаИ.Валюта = ВыборкаВ.Валюта;
			СтрокаВ = СтрокаЗ.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаВ, ВыборкаВ);
		КонецЦикла;
	КонецЦикла;
	ЗначениеВРеквизитФормы(Дер, "Затраты");
	
	Выборка = Пакет[2].Выбрать();	
	Пока Выборка.Следующий() Цикл
		МассивЗатрат.Добавить(Новый Структура("Сумма, Валюта", Выборка.Сумма, Выборка.Валюта));
	КонецЦикла;	
	
КонецПроцедуры

