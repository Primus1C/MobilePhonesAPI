	Возврат Новый Структура("Валюта,ВестиПартионныйУчет", 
							ИнвойсЗакупкиСсылка.Валюта,
							ИнвойсЗакупкиСсылка.Валюта.ВестиПартионныйУчет);	

КонецФункции 

&НаКлиенте 
// Заполняет таблицу формы Поставки
// по данным из ТЧ Товары и ТЧ Поставки
Процедура ПоставкиВФорму()
	
	Поставки.Очистить();
	
	Для Каждого СтрокаТовар ИЗ Объект.ВКД_Товары Цикл 
		Остаток = СтрокаТовар.Количество;
		Для П = 1 По КоличествоПоставок Цикл
			НовСтрока = Поставки.Добавить();                                       
			ЗаполнитьЗначенияСвойств(НовСтрока,	СтрокаТовар, "ИдСтроки,Номенклатура"); 
			НовСтрока.Поставка 			 = П;
			НовСтрока.Цена 				 = СтрокаТовар.ЦенаЗакупки; 
			НовСтрока.НомерСтрокиИнвойса = СтрокаТовар.НомерСтроки; // нач.значение 1
			НайдСтроки = Объект.Поставки.НайтиСтроки(Новый Структура("ИдСтроки,Номенклатура,Поставка", СтрокаТовар.ИдСтроки, СтрокаТовар.Номенклатура, П));	
			Если НайдСтроки.Количество() > 0 Тогда
				НовСтрока.Количество = НайдСтроки[0].Количество;
				НовСтрока.Пометка = НовСтрока.Количество <> 0;
				Остаток = Остаток - НовСтрока.Количество;
			КонецЕсли;
			ПересчитатьСуммуСтрокиПоставки(НовСтрока);
		КонецЦикла; 
		СтрокиОстатка = Поставки.НайтиСтроки(Новый Структура("ИдСтроки,Номенклатура", СтрокаТовар.ИдСтроки, СтрокаТовар.Номенклатура));
		Для Каждого СтрокаОстатка ИЗ СтрокиОстатка Цикл
			СтрокаОстатка.Остаток = Остаток;
		КонецЦикла;	
	КонецЦикла;	
	
	ОбновитьИтогиПоставок();
	ПеренестиДанныеПоставкиСФормыВТЧ();
	
КонецПроцедуры

&НаКлиенте
Функция ЦенаЗакупкиПоИдСтроки(ИдСтроки)
	
	НайдСтроки = Объект.ВКД_Товары.НайтиСтроки(Новый Структура("ИдСтроки", ИдСтроки));
	Если НайдСтроки.Количество() > 0 Тогда
		Возврат НайдСтроки[0].ЦенаЗакупки;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

&НаСервере
Функция ЦенаЗакупкиПоИдСтрокиНаСервере(ИдСтроки)
	
	НайдСтроки = Объект.ВКД_Товары.НайтиСтроки(Новый Структура("ИдСтроки", ИдСтроки));
	Если НайдСтроки.Количество() > 0 Тогда
		Возврат НайдСтроки[0].ЦенаЗакупки;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

&НаКлиенте
Процедура ПересчитатьСуммуСтрокиПоставки(СтрокаПоставки)
	
	Если СтрокаПоставки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Цена = ЦенаЗакупкиПоИдСтроки(СтрокаПоставки.ИдСтроки);
	Если Цена <> 0 Тогда
		СтрокаПоставки.Цена = Цена;
	КонецЕсли;
	СтрокаПоставки.Сумма = СтрокаПоставки.Цена * СтрокаПоставки.Количество;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммыПоставокИзТоваров()
	
	Если КоличествоПоставок = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаПоставки Из Поставки Цикл
		ПересчитатьСуммуСтрокиПоставки(СтрокаПоставки);
	КонецЦикла;
	
	ОбновитьИтогиПоставок();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИтогиПоставок(НомерПоставки = 0)
	
	Если КоличествоПоставок = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПоставкаОт = ?(НомерПоставки = 0, 1, НомерПоставки);
	ПоставкаДо = ?(НомерПоставки = 0, КоличествоПоставок, НомерПоставки);
	
	Для П = ПоставкаОт По ПоставкаДо Цикл
		
		Если Элементы.Найти("П" + П + "ПоставкиСумма") = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Ит = 0;  
		ИтКво = 0;
		НайдСтроки = Поставки.НайтиСтроки(Новый Структура("Поставка", П));
		Для каждого СтрокаПоставки Из НайдСтроки Цикл
			Ит = Ит + СтрокаПоставки.Сумма;	 
			ИтКво = ИтКво + СтрокаПоставки.Количество;
		КонецЦикла;
		Элементы["П" + П + "ПоставкиСумма"].ТекстПодвала = СтрШаблон("%1 %2", КэшДанных.СимволВалюты, Формат(Ит, "ЧДЦ=4"));
		Элементы["П" + П + "ПоставкиКоличество"].ТекстПодвала = Формат(ИтКво, "ЧДЦ=0");
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьПометкуСтрокиПоставки(СтрокаПоставки)
	
	Если СтрокаПоставки.Пометка Тогда
		СтрокаПоставки.Количество = СтрокаПоставки.Остаток;
		СтрокаПоставки.Остаток = 0;
	Иначе           
		СтрокаПоставки.Остаток = СтрокаПоставки.Количество; 
		СтрокаПоставки.Количество = 0;
	КонецЕсли;
	
	ПересчитатьСуммуСтрокиПоставки(СтрокаПоставки);
	
КонецПроцедуры

&НаСервере 
// Заполняет таблицу формы ИнвойсСкорректированный
// по данным из таблицы формы Поставки
Процедура ОбновитьИнвойсСкорректированный()
	
	//+
	ИнвойсСкорректированный.Очистить();
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		НовСтрока = ИнвойсСкорректированный.Добавить();                 
	    ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ, "ИдСтроки,Номенклатура");
		НовСтрока.НомерСтрокиИнвойса	= СтрокаТЧ.НомерСтроки;
		НовСтрока.КоличествоИнвойса     = СтрокаТЧ.Количество;
		НовСтрока.СуммаИнвойса          = СтрокаТЧ.СуммаЗакупки;  
		НовСтрока.Остаток               = СтрокаТЧ.Количество;
	КонецЦикла;
	//-
	
	тз = Поставки.Выгрузить();
	тз.Свернуть("НомерСтрокиИнвойса,Номенклатура", "Количество,Сумма");
	тз.Сортировать("НомерСтрокиИнвойса");
	//ИнвойсСкорректированный.Очистить();
	Для Каждого СтрокаПоставки Из тз Цикл
		//НовСтрока = ИнвойсСкорректированный.Добавить();      
		СтрокаСкорр = ИнвойсСкорректированный[СтрокаПоставки.НомерСтрокиИнвойса - 1];
		//НовСтрока.НомерСтрокиИнвойса 	= СтрокаПоставки.НомерСтрокиИнвойса;
		//НовСтрока.Номенклатура			= СтрокаПоставки.Номенклатура;  
	   	//НовСтрока.КоличествоИнвойса 	= Объект.ВКД_Товары[СтрокаПоставки.НомерСтрокиИнвойса-1].Количество;
		СтрокаСкорр.КоличествоПоставки 	= СтрокаСкорр.КоличествоПоставки + СтрокаПоставки.Количество;
		//НовСтрока.СуммаИнвойса          = СтрокаПоставки.Сумма;
		СтрокаСкорр.Остаток				= СтрокаСкорр.КоличествоИнвойса - СтрокаСкорр.КоличествоПоставки; 
	КонецЦикла;	
	
	Элементы.ИнвойсСкорКоличествоИнвойса.ТекстПодвала 	= ИнвойсСкорректированный.Итог("КоличествоИнвойса");
	Элементы.ИнвойсСкорСуммаИнвойса.ТекстПодвала 		= СтрШаблон("%1 %2", Объект.Валюта.Символ, Формат(ИнвойсСкорректированный.Итог("СуммаИнвойса"), "ЧДЦ=2"));
	Элементы.ИнвойсСкорКоличествоПоставки.ТекстПодвала 	= ИнвойсСкорректированный.Итог("КоличествоПоставки");
	Элементы.ИнвойсСкорОстаток.ТекстПодвала 			= ИнвойсСкорректированный.Итог("Остаток");
	Если КоличествоПоставок > 0 И ИнвойсСкорректированный.Итог("Остаток") > 0 Тогда
		Элементы.ИнвойсСкорОстаток.КартинкаПодвала = БиблиотекаКартинок.ВниманиеКрасный;
	Иначе
		Элементы.ИнвойсСкорОстаток.КартинкаПодвала = Новый Картинка;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СведенияОбОтправках()
	
	лОшибка 		= Ложь;
	лКвоОтправок	= 0;
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	КОЛИЧЕСТВО(ОтправкаИнвойсов.НомерСтроки) КАК КвоСтрок
	             |ИЗ
	             |	РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |ГДЕ
	             |	ОтправкаИнвойсов.Инвойс = &Инвойс
	             |	И ОтправкаИнвойсов.Регистратор ССЫЛКА Документ.Отправка
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ОтправкаИнвойсов.Поставка КАК Поставка,
	             |	КОЛИЧЕСТВО(ОтправкаИнвойсов.Поставка) КАК КоличествоПоставок
	             |ИЗ
	             |	РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |ГДЕ
	             |	ОтправкаИнвойсов.Инвойс = &Инвойс
	             |	И ОтправкаИнвойсов.Регистратор ССЫЛКА Документ.Отправка
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ОтправкаИнвойсов.Поставка";
	Запр.УстановитьПараметр("Инвойс", Объект.Ссылка);
	Пакет = Запр.ВыполнитьПакет();
	Выборка = Пакет[0].Выбрать(); 
	Если Выборка.Следующий() Тогда
		лКвоОтправок = Выборка.КвоСтрок;
	Иначе	
	    лКвоОтправок = 0;
	КонецЕсли;
	Выборка = Пакет[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.КоличествоПоставок > 1 Тогда
			лОшибка = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Новый Структура("Ошибка, КоличествоОтправок", лОшибка, лКвоОтправок);
	
КонецФункции 

&НаКлиенте
Процедура ОбновитьНадписиФормы()

	лКоличествоПоставок = 0;
	Для Каждого Пост Из Объект.Поставки Цикл
		лКоличествоПоставок = Макс(лКоличествоПоставок, Пост.Поставка);                
	КонецЦикла;
	
	Элементы.КорректировкиИПоставки.Заголовок = СтрШаблон(НСтр("ru = 'Корректировки, поставки (%1)'; en = 'Adjustments, deliveries (%1)'"),
						                            		лКоличествоПоставок);
	
КонецПроцедуры 
														
&НаСервере
Процедура ЗаменитьТчТоварыНаСервере(Знач ИдСтроки)
	
	// произведем замены в ТЧ Товары
	ЗаменыТовары = Замены.Выгрузить();
   	ЗаменыТовары.Свернуть("Номенклатура,ИДСтроки,ЦенаЗакупки,ЦенаСоСкидкой,ЦенаИнвойса", "Количество"); // без поставок
	НомСтроки = Объект.ВКД_Товары.Индекс(Объект.ВКД_Товары.НайтиСтроки(Новый Структура("ИдСтроки",ИдСтроки))[0]);	
	Объект.ВКД_Товары.Удалить(НомСтроки);
	Для каждого СтрокаЗамены Из ЗаменыТовары Цикл   
		СтрокаТЧ = Объект.ВКД_Товары.Вставить(НомСтроки);
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаЗамены); 
		СтрокаТЧ.СуммаЗакупки 	= СтрокаТЧ.ЦенаЗакупки * СтрокаТЧ.Количество; 
		СтрокаТЧ.СуммаИнвойса 	= СтрокаТЧ.ЦенаИнвойса * СтрокаТЧ.Количество;  
		СтрокаТЧ.ИдСтроки 		= ИдСтроки;
		СтрокиЗамены = Замены.НайтиСтроки(Новый Структура("Номенклатура,ЦенаЗакупки,ЦенаСоСкидкой,ЦенаИнвойса", 
															 СтрокаТЧ.Номенклатура,
		                                                     СтрокаТЧ.ЦенаЗакупки,
															 СтрокаТЧ.ЦенаСоСкидкой,
															 СтрокаТЧ.ЦенаИнвойса));
		Для каждого СтрЗамены Из СтрокиЗамены Цикл 
			СтрЗамены.ИдСтроки = ИдСтроки;
			СтрЗамены.НомерСтрокиИнвойса = НомСтроки + 1;
		КонецЦикла;	
		ИдСтроки  = ИдСтроки + 1;
		НомСтроки = НомСтроки + 1; 
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаменаРазделение" Тогда
		
		// заполним ТЗ Замены значениями от пользователя
		Замены.Очистить();
		Для каждого стр Из Параметр.ТаблицаЗамен Цикл
			НовСтрока = Замены.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, стр);
		КонецЦикла;                                 
		
		// произведем замены в ТЧ Товары
		ЗаменитьТчТоварыНаСервере(НовСтрока.ИдСтроки);
		
		// произведем замены в ТЧ Поставки
		МассивСтрок = Поставки.НайтиСтроки(Новый Структура("ИдСтроки", Параметр.ИдСтроки));
		Для Каждого ЭлементМассив Из МассивСтрок Цикл
			Поставки.Удалить(ЭлементМассив); 
		КонецЦикла;
		Для каждого СтрокаТз Из Замены Цикл
			НовСтрока = Поставки.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТз);
			НовСтрока.Цена = ЦенаЗакупкиПоИдСтроки(НовСтрока.ИдСтроки);
			Если НовСтрока.Цена = 0 Тогда
				НовСтрока.Цена = СтрокаТз.ЦенаИнвойса;
			КонецЕсли;
			НовСтрока.Сумма = НовСтрока.Количество * НовСтрока.Цена;  
			НовСтрока.Пометка = НовСтрока.Количество > 0;
		КонецЦикла;        
		
		// добавим (если нет) строки с нулевыми кол-вами в ТЧ Поставки 
		Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
			Для П = 1 По КоличествоПоставок Цикл
				НайдСтроки = Поставки.НайтиСтроки(Новый Структура("Номенклатура,Поставка", СтрокаТЧ.Номенклатура, П));
				Если НайдСтроки.Количество() = 0 Тогда
					НовСтрока = Поставки.Добавить();  
					ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ, "Номенклатура,ИдСтроки,ЦенаИнвойса");
					НовСтрока.Поставка = П;
				КонецЕсли;
			КонецЦикла;	
		КонецЦикла;		
		
		// отсортируем строки ТЧ Поставки в соотв.с порядком строк ТЧ Товары
		Соотв = Новый Соответствие;
		Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
			Соотв.Вставить(СтрокаТЧ.идСтроки, СтрокаТЧ.НомерСтроки+1);
		КонецЦикла;
		Для каждого СтрокаПоставки Из Поставки Цикл
			СтрокаПоставки.НомерСтрокиИнвойса = Соотв.Получить(СтрокаПоставки.ИдСтроки) - 1; 
		КонецЦикла;
		Поставки.Сортировать("НомерСтрокиИнвойса");
		
		// заполним колонку Остаток в ТЧ Поставки  
		Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
			Ост = СтрокаТЧ.Количество;
			НайдСтроки = Поставки.НайтиСтроки(Новый Структура("ИдСтроки", СтрокаТЧ.ИдСтроки));
			Для каждого НайдСтрока Из НайдСтроки Цикл
				Ост = Ост - НайдСтрока.Количество;
			КонецЦикла;
			Для каждого НайдСтрока Из НайдСтроки Цикл
				НайдСтрока.Остаток = Ост;
			КонецЦикла;
		КонецЦикла;
		
		ОбновитьИнвойсСкорректированный();
		ОбновитьИтогиПоставок();
		ПеренестиДанныеПоставкиСФормыВТЧ();
		
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

