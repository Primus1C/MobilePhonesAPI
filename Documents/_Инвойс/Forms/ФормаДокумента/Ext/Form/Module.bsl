&НаКлиенте
Процедура КурсУстановленВручнуюПриИзменении(Элемент)
	
	Если Объект.КурсУстановленВручную Тогда 
		Сооб = Новый СообщениеПользователю;
		Сооб.Поле = "Объект.Курс"; 
		Сооб.Текст = НСтр("ru = 'Чтобы задать курс вручную, просто введите его значение'; en = 'To set the rate manually, just enter its value'");
    	Сооб.Сообщить();
	Иначе  
		ВалютаИнвойсаЗакупки = ВалютаИнвойсаЗакупки(Объект.ДокументОснование);
		Если НЕ ВалютаИнвойсаЗакупки.ВестиПартионныйУчет Тогда
			Сооб = Новый СообщениеПользователю;
			Сооб.Поле = "Объект.Курс"; 
			Сооб.Текст = СтрШаблон(НСтр("ru = 'У валюты %1 не ведется партионный учет.%2Возможен только ручной ввод курса!'; en = 'Currency %1 is not accounted for in batches.%2Only manual exchange rate entry is possible!'"),
									ВалютаИнвойсаЗакупки.Валюта, Символы.ПС);
			Сооб.Сообщить();
			Объект.КурсУстановленВручную = Истина;
		Иначе
			Объект.Курс = СрВзвешКурс;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

