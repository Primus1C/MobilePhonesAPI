&НаКлиенте
Процедура РассчитатьСкидку(Команда)
	
	Если Объект.ВКД_Распределить = 0 Тогда		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Скидка не будет распределена! Не выбран вид расчета!'; en = 'The discount will not be distributed! Calculation type not selected!'");
		Сообщение.Сообщить();
	ИначеЕсли Объект.ВКД_Распределить = 1 Тогда
		РассчитатьЦенуЗакупкиПоСумме();	
	ИначеЕсли Объект.ВКД_Распределить = 2 Тогда
		РассчитатьЦенуЗакупкиПоКоличеству();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьЦенуЗакупкиПоСумме()

	ОбщаяСуммаКРаспределению = ПолучитьСуммуСкидки();
	
	СуммаИнвойса = Объект.ВКД_Товары.Итог("СуммаЗакупки");
	Если ОбщаяСуммаКРаспределению <> 0 Тогда
		Для каждого Стр из Объект.ВКД_Товары Цикл	
			ВесоваяЧасть = Стр.СуммаЗакупки / СуммаИнвойса * 100  ;
			СуммаКРаспределению = ОбщаяСуммаКРаспределению * ВесоваяЧасть / 100;
			ДельтаЦены = СуммаКРаспределению / Стр.Количество;
			ЦенаСоСкидкой = Стр.ЦенаЗакупки - ДельтаЦены;
			Стр.ЦенаСоСкидкой = ЦенаСоСкидкой;
			Стр.СуммаЗакупкиСоСкидкой = Стр.Количество * ЦенаСоСкидкой;
		КонецЦикла;
	Объект.ВКД_СуммаЗакупкиСоСкидкой = Объект.ВКД_Товары.Итог("СуммаЗакупкиСоСкидкой");
    Объект.ВКД_Скидка = ОбщаяСуммаКРаспределению;
	//Элементы.ВКД_Скидка.Видимость = Истина;
	//Элементы.СуммаЗакупкиСоСкидкой.Видимость = Истина;
	
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Расчет не проведен. Сумма скидки равна 0! Воможно, не выбран документ скидки!'; en = 'The calculation has not been carried out. The discount amount is 0! Probably the discount document is not selected!'");
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьЦенуЗакупкиПоКоличеству()

	ОбщаяСуммаКРаспределению = ПолучитьСуммуСкидки();
	ОбщееКоличество = Объект.ВКД_Товары.Итог("Количество");
	
	Если ОбщаяСуммаКРаспределению <> 0 Тогда
		
		ДельтаЦены = ОбщаяСуммаКРаспределению / ОбщееКоличество;
		
		Для каждого Стр из Объект.ВКД_Товары Цикл
			
			ЦенаСоСкидкой = Стр.ЦенаЗакупки - ДельтаЦены;

			Если ЦенаСоСкидкой <= 0 Тогда
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон(НСтр("ru = 'При данном виде расчета цена закупки %1 со скидкой меньше 0! Результат не будет записан! Необходимо выбрать вид расчета ПО СУММЕ'; en = 'With this type of calculation, the purchase price %1 with a discount is less than 0! The result will not be recorded! You must select the type of calculation BY SUM'"), Стр.Номенклатура);
				Сообщение.Сообщить();
				Прервать;
			Иначе
				Стр.ЦенаСоСкидкой = ЦенаСоСкидкой;
				Стр.СуммаЗакупкиСоСкидкой = Стр.Количество * ЦенаСоСкидкой;
			КонецЕсли;
			
		КонецЦикла;
		
	Объект.ВКД_СуммаЗакупкиСоСкидкой = Объект.ВКД_Товары.Итог("СуммаЗакупкиСоСкидкой");
    Объект.ВКД_Скидка = ОбщаяСуммаКРаспределению;
	//Элементы.ВКД_Скидка.Видимость = Истина;
	//Элементы.СуммаЗакупкиСоСкидкой.Видимость = Истина;

	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Расчет не проведен. Сумма скидки равна 0! Воможно, не выбран документ скидки!'; en = 'The calculation has not been carried out. The discount amount is 0! The discount document may not have been selected!'");
		Сообщение.Сообщить();
	КонецЕсли;
	
			
КонецПроцедуры

&НаСервере
Функция ПолучитьСуммуСкидки()

	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
              |	ВКД_СкидкаПоставщикаДокументы.СуммаСкидки
              |ИЗ
              |	Документ.ВКД_СкидкаПоставщика.Документы КАК ВКД_СкидкаПоставщикаДокументы
              |ГДЕ
              |	ВКД_СкидкаПоставщикаДокументы.Ссылка = &Ссылка
              |	И ВКД_СкидкаПоставщикаДокументы.Документ = &Документ";			   
			   Запрос.УстановитьПараметр("Ссылка",Объект.ВКД_ДокументСкидки);
			   Запрос.УстановитьПараметр("Документ",Объект.Ссылка);
			   РезультатЗапроса = Запрос.Выполнить();
			   
   Если Не РезультатЗапроса.Пустой() Тогда
	   Выборка = РезультатЗапроса.Выбрать();
	   Выборка.Следующий();
	   Если Выборка.СуммаСкидки <> Неопределено Тогда
		   Возврат Выборка.СуммаСкидки
	   Иначе
		   Возврат 0;
	   КонецЕсли; 
   Иначе Возврат 0;
   КонецЕсли;	   

КонецФункции

&НаКлиенте
Процедура ВКД_РаспределитьПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ВКД_ДокументСкидки) Тогда
		ОчиститьСуммуСкидки();
		
		Если  Объект.ВКД_Распределить = 0 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Скидка не будет распределена! Не выбран вид расчета!'; en = 'The discount will not be distributed! Calculation type not selected!'");
			Сообщение.Сообщить();
			
		ИначеЕсли Объект.ВКД_Распределить = 1 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Скидка будет распределена по сумме!'; en = 'The discount will be distributed according to the amount!'");
			Сообщение.Сообщить();
			
		ИначеЕсли Объект.ВКД_Распределить = 2 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Скидка будет распределена по количеству!'; en = 'The discount will be distributed according to quantity!'");
			Сообщение.Сообщить();
			
		КонецЕсли;
