&НаСервере
Процедура ЗаполнитьКэшДанных(ТолькоКоличествоИСумму)
	
	Если НЕ ТолькоКоличествоИСумму Тогда
	
		Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
			
			Запр = Новый Запрос;
			Запр.УстановитьПараметр("ДокументОснование", Объект.ДокументОснование);
			Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
			Запр.Текст = "ВЫБРАТЬ
			             |	ЕСТЬNULL(СУММА(Инвойс.СуммаВВалютеИнвойса), 0) КАК СуммаВВалютеИнвойса
			             |ИЗ
			             |	Документ._Инвойс КАК Инвойс
			             |ГДЕ
			             |	Инвойс.ДокументОснование = &ДокументОснование
			             |	И НЕ Инвойс.ПометкаУдаления
			             |	И Инвойс.Ссылка <> &Ссылка
			             |;
			             |
			             |////////////////////////////////////////////////////////////////////////////////
			             |ВЫБРАТЬ
			             |	ИнвойсЗакупки.НомерИнвойсаПоставщика КАК ВКД_НомерИнвойсаПоставщика,
			             |	ИнвойсЗакупки.ДатаИнвойсаПоставщика КАК ВКД_ДатаИнвойсаПоставщика,
			             |	ИнвойсЗакупки.Количество КАК ВКД_Количество,
			             |	ИнвойсЗакупки.Сумма КАК СуммаВВалютеИнвойса,
			             |	ИнвойсЗакупки.Контрагент КАК Контрагент
			             |ИЗ
			             |	Документ.ИнвойсЗакупки КАК ИнвойсЗакупки
			             |ГДЕ
			             |	ИнвойсЗакупки.Ссылка = &ДокументОснование";  
			Пакет = Запр.ВыполнитьПакет();
			Выгрузка0 = Пакет[0].Выгрузить();
			Выгрузка1 = Пакет[1].Выгрузить();
			Если Выгрузка1.Количество() = 0 Тогда   
			    КэшДанных = Неопределено;
			Иначе
				КэшДанных = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выгрузка1[0]);
				КэшДанных.Вставить("СуммаДругихИнвойсов", Выгрузка0[0].СуммаВВалютеИнвойса);
			КонецЕсли; 
			
		Иначе
		    КэшДанных = Новый Структура;
		КонецЕсли;
	
	КонецЕсли; 
	
	КэшДанных.Вставить("СимволВалюты", Объект.Валюта.Символ); 
	
	//СкорректированныеДанные = ОбщегоНазначенияСервер.СуммаКоличествоИнвойсаСУчетомКорректировок(Объект.Ссылка);
	//Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
	//	КэшДанных.Вставить("КоличествоКор", СкорректированныеДанные.Количество);
	//	КэшДанных.Вставить("КоличествоСум", СкорректированныеДанные.Сумма);
	//Иначе
	//	КэшДанных.Вставить("Количество", Объект.ВКД_Товары.Итог("Количество"));
	//	КэшДанных.Вставить("Сумма", Объект.ВКД_Товары.Итог("СуммаЗакупки"));
	//КонецЕсли; 
	
	КэшРаскраски = Новый Структура;
    КэшРаскраски.Вставить("РаскрашиватьВалюты", ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("РаскрашиватьВалюты"));
	КэшРаскраски.Вставить("ЦветаВалют", 		ОбщегоНазначенияПовтИсп.ЦветаВалют());
	КэшРаскраски.Вставить("РаскрашиватьСтатусы", ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("РаскрашиватьСтатусыВФормеДокумента"));
	КэшРаскраски.Вставить("ЦветаСтатусов", 		ОбщегоНазначенияПовтИсп.ЦветаСтатусов());
	
КонецПроцедуры

