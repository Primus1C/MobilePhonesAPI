КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьРазницуИнвойсов()
	
	ОбновитьСуммуВВалютеИнвойса();	
	
	Если КэшДанных = Неопределено Тогда
		Возврат;	
	КонецЕсли;	
	
	Для каждого Эл Из КэшДанных Цикл
		Попытка
			Если Эл.Ключ = "СуммаВВалютеИнвойса" Тогда
				РазницаОК = Эл.Значение = ИтогСуммаВВалютеИнвойса + КэшДанных.СуммаДругихИнвойсов;
			Иначе	
				РазницаОК = Объект[Эл.Ключ] = Эл.Значение;
			КонецЕсли;
			Элементы["Контроль"+Эл.Ключ].Картинка = ?(разницаОК, БиблиотекаКартинок.ОформлениеЗнакФлажок, БиблиотекаКартинок.ОформлениеЗнакКрест);	
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	лПривязыватьИнвойсы = омСервер.ПолучитьРеквизит(Объект.Контрагент, "ПривязыватьИнвойсы");
	Если омСервер.ПолучитьРеквизит(Объект.ДокументОснование, "Валюта") = Объект.Валюта Тогда
		Элементы.ГруппаВалюта.Видимость = Ложь;
	Иначе
		Элементы.ГруппаВалюта.Видимость = Истина;
		Элементы.КурсУстановленВручную.Видимость = лПривязыватьИнвойсы; 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьВВалюту(Команда)

	Если Объект.Курс = 0 Тогда
	     клОшибка(НСтр("ru = 'Не указан курс!'; en = 'Rate not specified!'"));
	Иначе	
	    Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
			ПересчитатьЦенуИСуммуПоКурсу(СтрокаТЧ);
		КонецЦикла;
		Модифицированность = Истина;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСуммуВВалютеИнвойса()

	ИтогСуммаВВалютеИнвойса = 0;  
	Для каждого Товар Из Объект.ВКД_Товары Цикл
		ИтогСуммаВВалютеИнвойса = ИтогСуммаВВалютеИнвойса + Товар.Количество * Товар.ЦенаИнвойса;
	КонецЦикла;      
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПроцентНаценки()

	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
    	СтрокаТЧ.ПроцентНаценки = ?(СтрокаТЧ.ЦенаИнвойса=0, "", Формат(СтрокаТЧ.Наценка/СтрокаТЧ.ЦенаИнвойса*100, "ЧДЦ=2"));
		Если СтрокаТЧ.ПроцентНаценки <> "" Тогда
			СтрокаТЧ.ПроцентНаценки = СтрокаТЧ.ПроцентНаценки + "%"
		КонецЕсли;
	КонецЦикла;      
		
КонецПроцедуры	


#Область Поставки

&НаКлиенте
Процедура ДобавитьПоставку(Команда)  
	
	Если КоличествоПоставок = 0 Тогда
		ОбновитьИДСтрок();	
	КонецЕсли;
	
	Если КоличествоПоставок > 8 Тогда
		клОшибка(НСтр("ru = 'Количество поставок слишком велико! Обратитесь к разработчику'; en = 'The supply delivery is too large! Contact the developer!'"));
		Возврат;		                      
	КонецЕсли;                
	
	Если НЕ Объект.Проведен Тогда
		клПредупреждение(НСтр("ru = 'Сначала проведите документ!'; en = 'Post the document first!'"), 5, НСтр("ru = 'Добавление поставки'; en = 'Adding a delivery'"));
		Возврат;
	КонецЕсли;          
	
	КоличествоПоставок = КоличествоПоставок + 1;  

	ОтправкиИнвойса = ОтправкиИнвойса();
	Если ОтправкиИнвойса.Количество() > 0 Тогда  
		Если ОтправкиИнвойса.Количество() = 1 Тогда
			стр = НСтр("ru = 'отправке'; en = 'the shipment'")
		Иначе
			стр = НСтр("ru = 'отправках'; en = 'shipments'")
		КонецЕсли;
	    клИнфоСписок(НСтр("ru = 'Инвойс найден в '; en = 'Invoice found in '") + стр, ОтправкиИнвойса);
		Возврат;
	КонецЕсли;
	
	ДобавитьПоставкуНаСервере(КоличествоПоставок, Истина);  
	
	ОбновитьИтогиПоставок(КоличествоПоставок);
	ОбновитьНадписиФормы();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьПоставкуНаСервере(НомерПоставки, ЭтоНоваяПоставка=Ложь)

	Для каждого СтрокаИнвойсаСкорр Из ИнвойсСкорректированный Цикл
		НовСтрока = Поставки.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаИнвойсаСкорр, "ИдСтроки,Номенклатура");   
		Если ЭтоНоваяПоставка Тогда
			// перенесем кол-во из скорр.инвойса
			НовСтрока.Количество 	= Макс(СтрокаИнвойсаСкорр.Остаток, 0); 
			НовСтрока.Цена			= ЦенаЗакупкиПоИдСтрокиНаСервере(НовСтрока.ИдСтроки);
			Если НовСтрока.Цена = 0 И СтрокаИнвойсаСкорр.КоличествоИнвойса <> 0 Тогда
				НовСтрока.Цена = СтрокаИнвойсаСкорр.СуммаИнвойса / СтрокаИнвойсаСкорр.КоличествоИнвойса;
			КонецЕсли;
			НовСтрока.Сумма 		= НовСтрока.Цена * НовСтрока.Количество;
		Иначе
			// перенесем кол-во из ТЧ			
			НайдСтрокиТЧ = Объект.Поставки.НайтиСтроки(Новый Структура("ИдСтроки,Поставка", НовСтрока.ИдСтроки, НомерПоставки));
			Для каждого СтрокаТЧ Из НайдСтрокиТЧ Цикл
				НовСтрока.Количество = СтрокаТЧ.Количество;
				НовСтрока.Цена = ЦенаЗакупкиПоИдСтрокиНаСервере(НовСтрока.ИдСтроки);
				Если НовСтрока.Цена = 0 И СтрокаТЧ.Количество <> 0 Тогда
					НовСтрока.Цена = СтрокаТЧ.Сумма / СтрокаТЧ.Количество;
				КонецЕсли;
				НовСтрока.Сумма = НовСтрока.Цена * НовСтрока.Количество;
			КонецЦикла;
			// рассчитаем остаток
			Ост = СтрокаИнвойсаСкорр.КоличествоИнвойса;
			НайдСтрокиТЧ = Объект.Поставки.НайтиСтроки(Новый Структура("ИдСтроки", НовСтрока.ИдСтроки));
			Для каждого СтрокаТЧ Из НайдСтрокиТЧ Цикл
				Ост = Ост - СтрокаТЧ.Количество;
			КонецЦикла;
			НовСтрока.Остаток = Ост;
		КонецЕсли;        
		НовСтрока.Поставка				= НомерПоставки;  
		НовСтрока.НомерСтрокиИнвойса 	= СтрокаИнвойсаСкорр.НомерСтрокиИнвойса;
		НовСтрока.Пометка 				= НовСтрока.Количество > 0; 
	КонецЦикла; 
	
	// обновим все остатки 
	Для Каждого СтрокаТовар ИЗ Объект.ВКД_Товары Цикл 
		Остаток = СтрокаТовар.Количество;
        НайдСтроки = Поставки.НайтиСтроки(Новый Структура("ИдСтроки", СтрокаТовар.ИдСтроки)); 
		Для каждого НайдСтрока Из НайдСтроки Цикл
			Остаток = Остаток - НайдСтрока.Количество;
		КонецЦикла;
		Для каждого НайдСтрока Из НайдСтроки Цикл
			НайдСтрока.Остаток = Остаток;
		КонецЦикла;
	КонецЦикла;
	
	//
	ЭлементИсточника 	= Элементы.ПоставкаШаблон;
	ПрефиксКопии 		= "П" + НомерПоставки;
 	ГруппаЭлементов 	= Элементы.ГруппаПоставки;
    СоздатьКопиюЭлемента(ЭлементИсточника, ПрефиксКопии, ГруппаЭлементов);
	
	// Заголовок закладки                                                              
	Элементы[ПрефиксКопии + "ПоставкаШаблон"].Видимость = Истина;
	Элементы[ПрефиксКопии + "ПоставкаШаблон"].Заголовок = НСтр("ru = 'Поставка '; en = 'Delivery '") + НомерПоставки;
	// отбор по номеру поставки
	Элементы[ПрефиксКопии + "Поставки"].ОтборСтрок = Новый ФиксированнаяСтруктура("Поставка", НомерПоставки); 
	//события табл.поля 
	Элементы[ПрефиксКопии + "Поставки"].УстановитьДействие("ПередУдалением", "ПоставкиПередУдалением");
	Элементы[ПрефиксКопии + "Поставки"].УстановитьДействие("ПередНачаломДобавления", "ПоставкиПередНачаломДобавления");
	Элементы[ПрефиксКопии + "Поставки"].ИзменятьПорядокСтрок = Ложь;
	
	// надпись на кнопке
	Если Элементы.Найти(ПрефиксКопии + "УдалитьПоставку") <> Неопределено Тогда
		Элементы[ПрефиксКопии + "УдалитьПоставку"].Заголовок = НСтр("ru = 'Удалить поставку '; en = 'Delete delivery '") + НомерПоставки;
	КонецЕсли;
	
	Если ЭтоНоваяПоставка Тогда
		ПеренестиДанныеПоставкиСФормыВТЧ();
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
Функция ОтправкиИнвойса()

	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Инвойс", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ОтправкаИнвойсов.Регистратор КАК Ссылка
	             |ИЗ
	             |	РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |ГДЕ
	             |	ОтправкаИнвойсов.Инвойс = &Инвойс
	             |	И ОтправкаИнвойсов.Регистратор ССЫЛКА Документ.Отправка"; 
	спис = Новый СписокЗначений; 
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Спис.Добавить(Выборка.Ссылка, Выборка.Ссылка, , БиблиотекаКартинок.ЗаписатьИЗакрыть);
	КонецЦикла;
	Возврат спис;

КонецФункции // ОтправкиИнвойса()

&НаСервере
Процедура ПеренестиДанныеПоставкиСФормыВТЧ()

	Объект.Поставки.Очистить();
	Для каждого СтрокаПоставки Из Поставки Цикл
		Если СтрокаПоставки.Количество <> 0 Тогда
			НовСтрока = Объект.Поставки.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаПоставки, "ИдСтроки,Номенклатура,Количество,Сумма,Поставка"); 
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура УдалитьПоставку(Команда)
	
	Если Элементы.ГруппаПоставки.ТекущаяСтраница = Неопределено Тогда
		ТекПоставка = "1";	
	Иначе
		ТекПоставка = Сред(Элементы.ГруппаПоставки.ТекущаяСтраница.Имя, 2, 1);
	КонецЕсли;
	УдалитьПоставкуНаСервере();

	УдСтроки = Поставки.НайтиСтроки(Новый Структура("Поставка", Число(ТекПоставка)));
	Для каждого УдСтрока Из УдСтроки Цикл
		Поставки.Удалить(УдСтрока);
	КонецЦикла;
	
	Для каждого стрПоставка Из Поставки Цикл
		Если стрПоставка.Поставка > Число(ТекПоставка) Тогда
			стрПоставка.Поставка = стрПоставка.Поставка - 1;
		КонецЕсли;
	КонецЦикла;
	
	КоличествоПоставок = КоличествоПоставок - 1;

	ПеренестиДанныеПоставкиСФормыВТЧ();
	ОбновитьИнвойсСкорректированный();
	ОбновитьИтогиПоставок();
	ОбновитьНадписиФормы();
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьПоставкуНаСервере()
	
	ЭтаФорма.Элементы.Удалить(этаформа.Элементы["П" + КоличествоПоставок + "ПоставкаШаблон"]);  

КонецПроцедуры

