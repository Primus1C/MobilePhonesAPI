	Стр = Объект.ВКД_Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли;
	
	Если Результат Тогда
		УдСтроки = Поставки.НайтиСтроки(Новый Структура("ИдСтроки", Стр.ИдСтроки));
		Для каждого УдСтр Из УдСтроки Цикл
			Поставки.Удалить(Поставки.Индекс(УдСтр));	
		КонецЦикла;
	КонецЕсли;
	
	//ОбновитьИнвойсСкорректированный();
	
	Объект.ВКД_Товары.Удалить(Стр);
