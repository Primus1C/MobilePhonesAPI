Процедура РассчитатьСуммыБезНДС(Команда)
	
	НДС = 0;
	ПоказатьВводЧисла(Новый ОписаниеОповещения("РассчитатьСуммыБезНДСПослеВводаСтавки", ЭтотОбъект), НДС, НСтр("ru = 'Ставка НДС, %'; en = 'WAT, %'"), 5, 1);
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммыБезНДСПослеВводаСтавки(НДС, ДопПараметры) Экспорт 
	
	Если НДС = Неопределено Тогда Возврат КонецЕсли;
	
	//НДС = 1 / (1 + НДС/100);
	//НДС = НДС /100;
	Для каждого СтрокаТЧ Из Объект.ВКД_Товары Цикл
		СтрокаТЧ.ЦенаБезНДС 	= СтрокаТЧ.ЦенаИнвойса / (1 + НДС/100);
		СтрокаТЧ.СуммаНДС 		= СтрокаТЧ.ЦенаИнвойса * СтрокаТЧ.Количество / (1 + НДС/100) * НДС/100;
		СтрокаТЧ.СуммаБезНДС	= СтрокаТЧ.ЦенаБезНДС * СтрокаТЧ.Количество; 
		СтрокаТЧ.ЦенаЗакупки	= СтрокаТЧ.ЦенаБезНДС / ?(Объект.Курс=0, 1, Объект.Курс);
		СтрокаТЧ.СуммаЗакупки 	= СтрокаТЧ.СуммаБезНДС / ?(Объект.Курс=0, 1, Объект.Курс);
	КонецЦикла;
	ОбновитьПроцентНаценки();  
	УстановитьВидимостьНДС();
	Модифицированность = Истина;
	
КонецПроцедуры

