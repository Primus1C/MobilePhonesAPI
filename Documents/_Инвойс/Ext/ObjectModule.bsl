Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	// © Primus1C  28.09.2023  НАЧАЛО ►      
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;	 
	
	ЕстьЗатраты = СуммаЗатрат > 0;
	
	// установим вид операции
	лНомДоставка 	= Константы.НоменклатураУслугаДоставки.Получить();
	лНомСкидка 		= Константы.НоменклатураСкидка.Получить();
	КоличествоПоставок  = 0;
	СуммаВВалютеИнвойса = 0;  
	лТолькоТовары 		= Истина;
	ТолькоУслуги 		= Истина;  
	лЕстьДоставка 		= Неопределено;
	лЕстьСкидка 		= Неопределено;
	Для каждого Товар Из ВКД_Товары Цикл
		СуммаВВалютеИнвойса = СуммаВВалютеИнвойса + Товар.Количество * ?(Товар.ЦенаИнвойса=0, Товар.ЦенаЗакупки, Товар.ЦенаИнвойса);   
		Если Товар.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда 
			лТолькоТовары = Ложь;
		Иначе	
			ТолькоУслуги = Ложь;
		КонецЕсли;   
		Если Товар.Номенклатура = лНомДоставка Тогда
			лЕстьДоставка = Истина;
		ИначеЕсли Товар.Номенклатура = лНомСкидка Тогда	
		    лЕстьСкидка = Истина;
		КонецЕсли;
	КонецЦикла; 
	Если лТолькоТовары Тогда		
		ВидОперации = Перечисления.ВидыОперацииИнвойс.Товар;  
	ИначеЕсли ТолькоУслуги Тогда 
		Если лЕстьДоставка = Истина Тогда
			ВидОперации = Перечисления.ВидыОперацииИнвойс.Доставка;
		ИначеЕсли лЕстьСкидка = Истина Тогда
			ВидОперации = Перечисления.ВидыОперацииИнвойс.Скидка;
		КонецЕсли;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		//КоличествоПоставок = 1;
		Для Каждого Пост Из Поставки Цикл
			КоличествоПоставок = Макс(КоличествоПоставок, Пост.Поставка);                
		КонецЦикла;      
	//Иначе
	//	КоличествоПоставок = 0;
	КонецЕсли;  
	
	
	// Пересчет цен закупки в Прих и Расх Накладных
	
	Если ЦеныБылиИзменены() Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		Запр = Новый Запрос;
		Запр.УстановитьПараметр("Ссылка", Ссылка);
		Запр.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Расход);
		Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |	ВКД_ОприходованиеНоменклатуры.Регистратор КАК ПриходнаяНакладная
		             |ИЗ
		             |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ВКД_ОприходованиеНоменклатуры
		             |ГДЕ
		             |	ВКД_ОприходованиеНоменклатуры.Документ = &Ссылка
		             |	И ВКД_ОприходованиеНоменклатуры.ВидДвижения = &ВидДвижения
		             |	И ВКД_ОприходованиеНоменклатуры.Регистратор ССЫЛКА Документ.ПриходнаяНакладная";
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ОбработкаДокументов.ЗарегистрироватьДокументКПроведению(Выборка.ПриходнаяНакладная, Ссылка);
			// а запись прих.накладных с новыми ценами инициирует регистрацию к проведению зависимых расх.накладных и возвратов покупателя
		КонецЦикла;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);	

	// © Primus1C  ОКОНЧАНИЕ ◄
	
	омСервер.ЗаписатьОбщиеРеквизиты(ЭтотОбъект);
	
КонецПроцедуры      


// © Primus1C  24.06.2023  НАЧАЛО ►

&НаСервере
Функция ЦеныБылиИзменены()

	// 1. Если документ создается впервые
	Если ЭтоНовый() Тогда
		// Любая непустая табличная часть считается изменением (строки были добавлены)
		Возврат ВКД_Товары.Количество() > 0;
	КонецЕсли;
	
	// 2. Быстрая проверка: если количество строк изменилось, 
	// значит было удаление или добавление
	Если ВКД_Товары.Количество() <> Ссылка.ВКД_Товары.Количество() Тогда
		Возврат Истина;
	КонецЕсли;
	
	// 3. Выгружаем колонки в таблицы значений для быстрого построчного сравнения
	// (Выгружать всю ТЧ не нужно, берем только нужное для экономии памяти)
	ТЗТекущие = ВКД_Товары.Выгрузить(, "НомерСтроки, Номенклатура, ЦенаЗакупки");
	ТЗВБазе   = Ссылка.ВКД_Товары.Выгрузить(, "НомерСтроки, Номенклатура, ЦенаЗакупки");
	
	// Индексируем колонку для моментального поиска внутри цикла
	ТЗВБазе.Индексы.Добавить("НомерСтроки");
	
	// 4. Проверяем каждую строку
	Для Каждого СтрТекущая Из ТЗТекущие Цикл
		
		СтрВБазе = ТЗВБазе.Найти(СтрТекущая.НомерСтроки, "НомерСтроки");
		
		// Если пользователь удалил строку в середине и добавил новую в конец,
		// общее количество совпадет, но номера строк разъедутся. Отлавливаем это:
		Если СтрВБазе = Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		
		// Главная проверка: изменилась ли сама цена
		Если СтрТекущая.ЦенаЗакупки <> СтрВБазе.ЦенаЗакупки ИЛИ СтрТекущая.Номенклатура <> СтрВБазе.Номенклатура Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	// Если код дошел сюда, значит ни состав строк, ни цены не менялись
	Возврат Ложь;	

КонецФункции 

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ОбщегоНазначенияСервер.ЗаполнитьРеквизитыДокументаПоУмолчанию(ЭтотОбъект);
	Валюта = ПараметрыСеанса.БазоваяВалюта;

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ИнвойсЗакупки") Тогда
		 ЗаполнитьНаОснованииИнвойсаЗакупки(ДанныеЗаполнения)
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") И ТипЗнч(ДанныеЗаполнения.ДокументОснование) = Тип("ДокументСсылка.ИнвойсЗакупки") Тогда  
		 ЗаполнитьНаОснованииИнвойсаЗакупки(ДанныеЗаполнения.ДокументОснование, ДанныеЗаполнения.ВидОперации)
	Иначе	
	КонецЕсли; 
	
	КурсУстановленВручную = Истина;
	
КонецПроцедуры

Процедура ЗаполнитьНаОснованииИнвойсаЗакупки(ДанныеЗаполнения, ЗаполнениеВидОперации=Неопределено)
	
	ДокументОснование				= ДанныеЗаполнения.Ссылка; 
	ВидОперации						= ?(ЗаполнениеВидОперации=Неопределено, Перечисления.ВидыОперацииИнвойс.Товар, ЗаполнениеВидОперации);
