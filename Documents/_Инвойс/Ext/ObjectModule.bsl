Процедура ПроверкаВозможностиПроведения(Отказ)

	

КонецПроцедуры
		   
Процедура ОбработкаПроведения(Отказ, Режим)
	
	ВалютаДоллар = ПараметрыСеанса.БазоваяВалюта;
	
	// Проверка: разрешен только один проведенный инвойс с товарами
	Если ЗначениеЗаполнено(ДокументОснование) Тогда
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |	_Инвойс.Ссылка КАК Инвойс
		             |ИЗ
		             |	Документ._Инвойс КАК _Инвойс
		             |ГДЕ
		             |	_Инвойс.Проведен
		             |	И _Инвойс.Ссылка <> &Ссылка
		             |	И _Инвойс.ДокументОснование = &ДокументОснование
		             |	И _Инвойс.ВидОперации = &ВидОперации";
	    Запр.УстановитьПараметр("ДокументОснование", ДокументОснование);
	    Запр.УстановитьПараметр("ВидОперации", ВидОперации);
	    Запр.УстановитьПараметр("Ссылка", Ссылка);
		Выборка = Запр.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			Сообщить(СтрШаблон(НСтр("ru = 'Уже есть инвойс (%1), созданный на основании текущего документа!'; en = 'There is already an invoice (%1) created based on the current document!'"), ВидОперации), СтатусСообщения.ОченьВажное);
			Отказ = Истина;	 
		КонецЕсли;
	КонецЕсли;
	
	// Проверка: затраты
	
	ЗапрЗатраты = Новый Запрос;
	ЗапрЗатраты.УстановитьПараметр("Ссылка", Ссылка);
	ЗапрЗатраты.Текст = "ВЫБРАТЬ
	                    |	ДвижениеДенегИнвойсы.Ссылка.Статья КАК Затрата,
	                    |	ДвижениеДенегИнвойсы.Ссылка КАК Документ,
	                    |	СУММА(ДвижениеДенегИнвойсы.Сумма) КАК Сумма,
	                    |	ДвижениеДенегИнвойсы.Ссылка.Валюта КАК Валюта
	                    |ИЗ
	                    |	Документ.ДвижениеДенег.Инвойсы КАК ДвижениеДенегИнвойсы
	                    |ГДЕ
	                    |	ДвижениеДенегИнвойсы.Инвойс = &Ссылка
	                    |	И ДвижениеДенегИнвойсы.Ссылка.Проведен
	            		|	И ДвижениеДенегИнвойсы.Ссылка.ВидДвиженияДенег = Значение(Перечисление.ВидДвиженияДенег.Логистика)
	                    |
	                    |СГРУППИРОВАТЬ ПО
	                    |	ДвижениеДенегИнвойсы.Ссылка.Статья,
	                    |	ДвижениеДенегИнвойсы.Ссылка,
	                    |	ДвижениеДенегИнвойсы.Ссылка.Валюта";
    РезультатЗапросаЗатраты = ЗапрЗатраты.Выполнить();      
	Если РезультатЗапросаЗатраты.Пустой() Тогда
		лЕстьЗатратыДвиженийДенег = Ложь;
	Иначе
	    лЕстьЗатратыДвиженийДенег = Истина;
	КонецЕсли;
	
	// Проверка: вес
	
	ЗапрТовары = Новый Запрос;
	ЗапрТовары.УстановитьПараметр("Ссылка", Ссылка);
	ЗапрТовары.Текст = "ВЫБРАТЬ
	                   |	ТЧ_Товары.Номенклатура КАК Номенклатура,
	                   |	ТЧ_Товары.Количество КАК Количество,
	                   |	ТЧ_Товары.Номенклатура.Вес КАК ВесНоменклатуры,
	                   |	ТЧ_Товары.Количество * ТЧ_Товары.Номенклатура.Вес КАК Вес,
	                   |	ТЧ_Товары.НомерСтроки КАК НомерСтроки
	                   |ИЗ
	                   |	Документ._Инвойс.ВКД_Товары КАК ТЧ_Товары
	                   |ГДЕ
	                   |	ТЧ_Товары.Ссылка = &Ссылка
	                   |	И ТЧ_Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)";
	ВыгрузкаТовары = ЗапрТовары.Выполнить().Выгрузить();
	Ошибки = Новый СписокЗначений;
	Для каждого СтрокаТЧ Из ВыгрузкаТовары Цикл
		Если СтрокаТЧ.ВесНоменклатуры = 0 Тогда
			Ошибки.Добавить(СтрокаТЧ.НомерСтроки);
		КонецЕсли;
	КонецЦикла;   
	лОбщийВес = ВыгрузкаТовары.Итог("Вес");
	Если лОбщийВес = 0 И (лЕстьЗатратыДвиженийДенег ИЛИ СуммаЗатрат > 0) Тогда
		//Отказ = Истина;
		//Сообщить("Общий вес нулевой! Распределение затрат невозможно");
		Сообщить("Вес товара не заполнен. Если будете распределять затраты на этот инвойс, не забудьте внести вес в карточке номенклатуры");
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	// РН ВзаиморасчетыСПоставщиками  
	
	Движения._ВзаиморасчетыСПоставщиками.Записывать = Истина;
	Движение			 = Движения._ВзаиморасчетыСПоставщиками.Добавить();
	Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
	Движение.Период		 = Дата;
	Движение.Контрагент	 = Контрагент;
	Движение.Инвойс		 = Ссылка;
	Движение.СуммаОплаты = Сумма;
	Если ЗначениеЗаполнено(ДокументОснование) И Курс = 1 Тогда
		Движение.Валюта	 = ДокументОснование.Валюта;
	Иначе	
		Движение.Валюта	 = Валюта;
	КонецЕсли;
	
	// РН ВКД_ОприходованиеНоменклатуры Приход  
	
	Движения.ВКД_ОприходованиеНоменклатуры.Записывать = Истина;
	Движения.ВКД_ОприходованиеНоменклатуры.Очистить();  
	Если Поставки.Количество() = 0 Тогда   
		
		// РН ОприходованиеНоменклатуры (одна поставка):
		
		Для Каждого ТекСтрокаВКД_Товары Из ВКД_Товары Цикл
			Если ТекСтрокаВКД_Товары.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
				Продолжить;	
			КонецЕсли;
			Движение = Движения.ВКД_ОприходованиеНоменклатуры.Добавить();
			Движение.ВидДвижения 	= ВидДвиженияНакопления.Приход;
			Движение.Период 		= Дата;
			Движение.Документ 		= Ссылка;
			Движение.Номенклатура 	= ТекСтрокаВКД_Товары.Номенклатура; 
			Движение.Поставка		= 0;
			Движение.СуммаЗакупки 	= ТекСтрокаВКД_Товары.СуммаЗакупки; // в долларах  			
			Движение.Количество 	= ТекСтрокаВКД_Товары.Количество;
			Движение.СуммаСоСкидкой = ТекСтрокаВКД_Товары.СуммаЗакупкиСоСкидкой;
			Движение.ЦенаЗакупки 	= ТекСтрокаВКД_Товары.ЦенаЗакупки;  // в долларах
			Движение.ЦенаСоСкидкой 	= ТекСтрокаВКД_Товары.ЦенаСоСкидкой;
		КонецЦикла;
		
	Иначе
	   	// © Primus1C  05.10.2023  НАЧАЛО ►
		
		// РН ОприходованиеНоменклатуры (несколько поставок):
		
		Для каждого ТекПоставка Из Поставки Цикл
			Если ТекПоставка.Количество = 0 Тогда
				Продолжить;	
			КонецЕсли;
			Если ТекПоставка.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
				Продолжить;	
			КонецЕсли;
			Движение = Движения.ВКД_ОприходованиеНоменклатуры.Добавить();
			Движение.ВидДвижения 	= ВидДвиженияНакопления.Приход;
			Движение.Период 		= Дата;
			Движение.Документ 		= Ссылка;
			Движение.Номенклатура 	= ТекПоставка.Номенклатура;
			Движение.Поставка		= ТекПоставка.Поставка;
			Движение.Количество 	= ТекПоставка.Количество; 
			//Если ЗначениеЗаполнено(ДокументОснование) И ДокументОснование.Валюта = ВалютаДоллар Тогда
				Движение.СуммаЗакупки 	= ТекПоставка.Сумма;
				Движение.ЦенаЗакупки 	= ТекПоставка.Сумма / ТекПоставка.Количество;
			//Иначе
			//	Движение.СуммаЗакупки 	= ТекПоставка.Сумма / Курс ;
			//	Движение.ЦенаЗакупки 	= Движение.СуммаЗакупки / ТекПоставка.Количество;
			//КонецЕсли;
		КонецЦикла; 
		
		// сторнируем корректировки инвойсов 
		// (потому что движения будут регистрироваться не по Инвойсы+Корректировки, а по ТЧ Поставки тек.документа)
		ЗапрОприх = Новый Запрос;
		ЗапрОприх.Текст = "ВЫБРАТЬ
		                  |	ВКД_ОприходованиеНоменклатуры.Номенклатура,
		                  |	ВКД_ОприходованиеНоменклатуры.Поставка,
		                  |	-СУММА(ВКД_ОприходованиеНоменклатуры.Количество) КАК Количество,
		                  |	-СУММА(ВКД_ОприходованиеНоменклатуры.СуммаЗакупки) КАК СуммаЗакупки,
		                  |	-СУММА(ВКД_ОприходованиеНоменклатуры.СуммаСоСкидкой) КАК СуммаСоСкидкой,
		                  |	ИСТИНА КАК ЭтоСторно
		                  |ИЗ
		                  |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ВКД_ОприходованиеНоменклатуры
		                  |ГДЕ
		                  |	ВКД_ОприходованиеНоменклатуры.Регистратор ССЫЛКА Документ.КорректировкаИнвойса
		                  |	И ВКД_ОприходованиеНоменклатуры.Документ = &Инвойс
		                  |
		                  |СГРУППИРОВАТЬ ПО
		                  |	ВКД_ОприходованиеНоменклатуры.Номенклатура,
		                  |	ВКД_ОприходованиеНоменклатуры.Поставка";
		ЗапрОприх.УстановитьПараметр("Инвойс", Ссылка);
		ВыгрузкаОприх = ЗапрОприх.Выполнить().Выгрузить();
		
		Движения.ВКД_ОприходованиеНоменклатуры.Записывать = Истина;
		//Движения.ВКД_ОприходованиеНоменклатуры.Очистить();

		Для каждого СтрокаОприх Из ВыгрузкаОприх Цикл
			Движение = Движения.ВКД_ОприходованиеНоменклатуры.Добавить();
			ЗаполнитьЗначенияСвойств(Движение, СтрокаОприх);
		   	Движение.Период = Дата;
			Движение.Документ = Ссылка;
		КонецЦикла;  
		
		//// РН СкорректированныеИнвойсы (1):
		//
		//// сторнируем корректировки инвойсов 
		//// (потому что движения будут регистрироваться не по Инвойсы+Корректировки, а по ТЧ Поставки тек.документа)
		//ЗапрСторно = Новый Запрос;
		//ЗапрСторно.Текст = "ВЫБРАТЬ
		//                   |	СкорректированныеИнвойсы.Номенклатура,
		//                   |	СкорректированныеИнвойсы.НомерСтрокиИнвойса,
		//                   |	СкорректированныеИнвойсы.ТипСтроки,
		//                   |	-СУММА(СкорректированныеИнвойсы.Количество) КАК Количество,
		//                   |	-СУММА(СкорректированныеИнвойсы.Сумма) КАК Сумма
		//                   |ИЗ
		//                   |	РегистрНакопления.СкорректированныеИнвойсы КАК СкорректированныеИнвойсы
		//                   |ГДЕ
		//                   |	СкорректированныеИнвойсы.Инвойс = &Инвойс
		//                   |	И СкорректированныеИнвойсы.Регистратор ССЫЛКА Документ.КорректировкаИнвойса
		//                   |
		//                   |СГРУППИРОВАТЬ ПО
		//                   |	СкорректированныеИнвойсы.Номенклатура,
		//                   |	СкорректированныеИнвойсы.НомерСтрокиИнвойса,
		//                   |	СкорректированныеИнвойсы.ТипСтроки";
		//ЗапрСторно.УстановитьПараметр("Инвойс", Ссылка);
		//ВыгрузкаСторно = ЗапрСторно.Выполнить().Выгрузить();

		//Движения.СкорректированныеИнвойсы.Записывать = Истина;
		//Движения.СкорректированныеИнвойсы.Очистить();

		//Для каждого СтрокаСторно Из ВыгрузкаСторно Цикл
		//	Движение = Движения.СкорректированныеИнвойсы.Добавить();
		//	ЗаполнитьЗначенияСвойств(Движение, СтрокаСторно);
		//   	Движение.Период = Дата;
		//	Движение.Инвойс = Ссылка;
		//КонецЦикла;  
		
		// © Primus1C  ОКОНЧАНИЕ ◄ 
		
	КонецЕсли;
	
	// © Primus1C  25.06.2023  НАЧАЛО ► 
	
	// РН СкорректированныеИнвойсы (2):
	
	лТолькоУслуги = Истина;
	Движения.СкорректированныеИнвойсы.Записывать = Истина;
	//Движения.СкорректированныеИнвойсы.Очистить();
	Для Каждого ТекСтрокаВКД_Товары Из ВКД_Товары Цикл
		Движение = Движения.СкорректированныеИнвойсы.Добавить(); 
		Движение.Период				= Дата;
        Движение.Инвойс				= Ссылка;
		Движение.Номенклатура		= ТекСтрокаВКД_Товары.Номенклатура;
		Движение.ТипСтроки			= Перечисления.ТипыСтрокИнвойса.ВходитВИнвойс;
		Движение.Количество			= ТекСтрокаВКД_Товары.Количество;
		Движение.Сумма				= ТекСтрокаВКД_Товары.СуммаЗакупки;
		//Движение.НомерСтрокиИнвойса	= ТекСтрокаВКД_Товары.НомерСтроки;
		Движение.НомерСтрокиИнвойса	= ТекСтрокаВКД_Товары.ИдСтроки;
		Если ТекСтрокаВКД_Товары.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
			лТолькоУслуги = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	// РН ОтправкаИнвойсов:
	
	Движения.ОтправкаИнвойсов.Очистить(); 
	Движения.ОтправкаИнвойсов.Записывать = Истина;
		
	Если НЕ лТолькоУслуги Тогда
		
		Если Поставки.Количество() = 0 Тогда   // кол-во и сумму НЕ вносим в РН, поскольку их могут изменить КорректировкиИнвойсов
		
			Движение = Движения.ОтправкаИнвойсов.Добавить(); 
			Движение.Период				= Дата;
			Движение.Инвойс 			= Ссылка;
			//Движение.Количество			= ВКД_Товары.Итог("Количество");
			//Движение.Сумма     			= ВКД_Товары.Итог("СуммаЗакупки");
		    Движение.Поставка			= 0; 
			Движение.ОжидаемыеПоставки 	= 1;
			
		Иначе // кол-во и сумму вносим в РН, т.к. КорректировкиИнвойсов уже учтены при распределении по поставкам 
		
			Запр = Новый Запрос; 
			Запр.УстановитьПараметр("Ссылка", Ссылка);
			Запр.Текст = "ВЫБРАТЬ
			             |	СУММА(ИнвойсПоставки.Количество) КАК Количество,
			             |	СУММА(ИнвойсПоставки.Сумма) КАК Сумма,
			             |	ИнвойсПоставки.Поставка КАК Поставка,
			             |	1 КАК ОжидаемыеПоставки
			             |ИЗ
			             |	Документ._Инвойс.Поставки КАК ИнвойсПоставки
			             |ГДЕ
			             |	ИнвойсПоставки.Ссылка = &Ссылка
			             |
			             |СГРУППИРОВАТЬ ПО
			             |	ИнвойсПоставки.Поставка
			             |
			             |УПОРЯДОЧИТЬ ПО
			             |	Поставка";
			Выборка = Запр.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				Движение = Движения.ОтправкаИнвойсов.Добавить(); 
				Движение.Период	= Дата;
				Движение.Инвойс = Ссылка;
				ЗаполнитьЗначенияСвойств(Движение, Выборка);	
			КонецЦикла;
		
		КонецЕсли;
	
	КонецЕсли;

	//ОбщегоНазначенияСервер.ЗаписатьСостояниеИнвойса(Ссылка); 
	
	
	// РН PасчетыПоИнвойсам

	Движения.РасчетыПоИнвойсам.Записывать = Истина;	 
	Если Контрагент.ПривязыватьИнвойсы Тогда
		Движение				= Движения.РасчетыПоИнвойсам.Добавить();
		Движение.ВидДвижения 	= ВидДвиженияНакопления.Приход; 
		Движение.Период		 	= Дата;
		Движение.Инвойс			= Ссылка;  
		Движение.Контрагент		= Контрагент;
		Движение.Сумма			= СуммаВВалютеИнвойса; 
        Движение.СуммаОплаты	= ВКД_Товары.Итог("СуммаЗакупки");
		Движение.Валюта			= РаботаСИнвойсами.ВалютаИнвойса(Ссылка);
		Движение.Курс			= Курс;
	КонецЕсли;
	
	// РС Затраты
	
	НаборЗаписей = Движения.Затраты;

	//ЗапрЗатраты = Новый Запрос;
	//ЗапрЗатраты.УстановитьПараметр("Ссылка", Ссылка);
	//ЗапрЗатраты.Текст = "ВЫБРАТЬ
	//                    |	ДвижениеДенегИнвойсы.Затрата КАК Затрата,
