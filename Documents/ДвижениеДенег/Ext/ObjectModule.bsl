				Движение.ДолгПоставщику = 0;
				Движение.ПредоплатаПоставщику = 0;
				Движение.Чем = Ссылка;
				ЕстьДолги = Истина;
			КонецЦикла; 
			
			Предоплата = Сумма - СуммаПривязано;
