				МассивИнвойсов.Добавить(Выборка.Инвойс);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// 2.3. Сохраняем объединенный массив в кэш объекта (он доживет до проведения)
	ЭтотОбъект.ДополнительныеСвойства.Вставить("ИнвойсыДляЗаписиСтатусов", МассивИнвойсов);
	
	// © Primus1C  ОКОНЧАНИЕ ◄

	//Если глЗапретЗаписиПоДате(Ссылка) Тогда Отказ = Истина; Возврат; КонецЕсли;
	
	глЗаписатьОбщиеРеквизиты(ЭтотОбъект);

	Если НЕ ЗначениеЗаполнено(ПриходРасход) Тогда ПриходРасход = Перечисления.ПриходРасход.Приход КонецЕсли;
