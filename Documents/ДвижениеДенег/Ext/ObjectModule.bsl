			КонецЕсли;
			ЕстьДеньги = Истина;   
		// © Primus1C  01.11.2024  НАЧАЛО ►
		ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Инвестиции Тогда
			Если Сумма > 0 Тогда
				Движение = Движения.Инвестиции.ДобавитьПриход(); 
				ДвижениеД = Движения.Деньги.ДобавитьПриход();
				лСумма = Сумма;
			Иначе
				Движение = Движения.Инвестиции.ДобавитьРасход();
				ДвижениеД = Движения.Деньги.ДобавитьРасход();
				лСумма = - Сумма;
			КонецЕсли;
			Движение.Период 	= Дата;
			Движение.Контрагент = Контрагент;
			Движение.Валюта 	= Валюта;
			Движение.Сумма 		= лСумма; 
			Движения.Инвестиции.Записывать = Истина;   
			
			ДвижениеД.Период 	= Дата;
			ДвижениеД.Фирма 	= Фирма;
			ДвижениеД.Касса 	= ДСчет;
			ДвижениеД.Валюта 	= Валюта;
			ДвижениеД.Остаток 	= лСумма;
			ЕстьДеньги = Истина;
		ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Биржа Тогда
			Если Сумма > 0 Тогда
				Движение = Движения.Биржа.ДобавитьПриход(); 
				ДвижениеД = Движения.Деньги.ДобавитьПриход();
				лСумма = Сумма;
			Иначе
				Движение = Движения.Биржа.ДобавитьРасход();
				ДвижениеД = Движения.Деньги.ДобавитьРасход();
				лСумма = - Сумма;
			КонецЕсли;
			Движение.Период 	= Дата;
			Движение.Статья 	= Статья;
			Движение.Валюта 	= Валюта;
			Движение.Сумма 		= лСумма; 
			Движения.Биржа.Записывать = Истина;   
			
			ДвижениеД.Период 	= Дата;
			ДвижениеД.Фирма 	= Фирма;
			ДвижениеД.Касса 	= ДСчет;
			ДвижениеД.Валюта 	= Валюта;
			ДвижениеД.Остаток 	= лСумма;
			ЕстьДеньги = Истина;   
		ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Логистика Тогда  
			Движение = Движения.Деньги.ДобавитьРасход();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Касса = ДСчет;
			Движение.Валюта = Валюта;
			Движение.Остаток = Сумма;
			ЕстьДеньги = Истина;   
		// © Primus1C  ОКОНЧАНИЕ ◄	
		КонецЕсли;
		
		//2015.11.26
		//универсально, независимо от типа, проводим КР, если они есть
		Если СуммаКР <> 0 Тогда
			Движение = Движения.РасходыДоходы.Добавить();
			Движение.Период 	= Дата;
			Движение.Фирма 		= Фирма;
			Движение.Статья 	= ?(СуммаКР < 0, Справочники.Статьи.РасходОтКР, Справочники.Статьи.ДоходОтКР);
			//здесь вид после
			Движение.Вид 		= Движение.Статья.ВидСтатьи;
			Движение.Валюта 	= Валюта;
			Движение.Сумма 		= гоАбс(СуммаКР);
			ЕстьРасходыДоходы = Истина;
		КонецЕсли; 

	Иначе // НЕ Окончательно

		Движение = Движения.НезакрытыеДокументы.ДобавитьПриход();
		Движение.Период 		= Дата;
		Движение.Фирма 			= Фирма;
		Движение.Контрагент 	= Контрагент;
		Движение.ВидДокумента 	= Перечисления.ВидДокумента.ДвижениеДенег;
		Движение.Количество 	= 1;
		ЕстьНезакрытые 			= ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.Инвестиции 
									И ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.ВводОстатков
									И ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.Биржа;

	КонецЕсли; 
	
	Движения.Долги.Записывать 				= ЕстьДолги;
	Движения.Деньги.Записывать 				= ЕстьДеньги;
	Движения.НезакрытыеДокументы.Записывать = ЕстьНезакрытые ;
	Движения.РасходыДоходы.Записывать 		= ЕстьРасходыДоходы;
	Движения.Подотчет.Записывать 			= ЕстьПодотчет;
	Движения.Зарплата.Записывать 			= ЕстьЗарплата;   
	
	// © Primus1C  10.11.2024  НАЧАЛО ► 
	
	// РН ПАРТИИ ВАЛЮТ
	
    Движения.ПартииВалюты.Записывать = Истина;
	
	Если Окончательно Тогда
		ЗапрОстаткиПартий = Новый Запрос;
		ЗапрОстаткиПартий.Текст = "ВЫБРАТЬ
				             |	ПартииВалютыОстатки.СуммаОстаток КАК Сумма,
				             |	ПартииВалютыОстатки.СуммаВБазовойВалютеОстаток КАК СуммаВБазовойВалюте
				             |ИЗ
				             |	РегистрНакопления.ПартииВалюты.Остатки(
				             |			&Дата,
				             |			Валюта = &Валюта
				             |				И Касса = &Касса) КАК ПартииВалютыОстатки";
		
		Если ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ВводОстатков 
			И Валюта.ВестиПартионныйУчет 
			И ВестиПартУчет(ДСчет) Тогда
			//
			Если Сумма > 0 Тогда
				лСуммаОстатка = Сумма;	
			Иначе
			    лСуммаОстатка = ОстатокКассы();
			КонецЕсли;	
			Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
			Движение.Период					= Дата;
			Движение.Касса 					= ДСчет;
			Движение.Валюта 				= Валюта;
			Движение.Сумма					= лСуммаОстатка;
			Движение.СуммаВБазовойВалюте	= лСуммаОстатка / СубДКурс; 
		
		ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ОбменВалюты 
			И СубДВалюта.ВестиПартионныйУчет 
			И ВестиПартУчет(СубДСчет) Тогда
			// приход только при покупке валюты (обмен)
			Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
			Движение.Период					= Дата;
			Движение.Касса 					= СубДСчет;
			Движение.Валюта 				= СубДВалюта;
			Движение.Сумма					= СубДСумма;
			Движение.СуммаВБазовойВалюте	= Сумма; 
			
		ИначеЕсли ПриходРасход = Перечисления.ПриходРасход.Расход
				И ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.Перемещение
				И СубДВалюта.ВестиПартионныйУчет 
				И ВестиПартУчет(ДСчет) Тогда  
			// оплата поставщику
			ЗапрОстаткиПартий.УстановитьПараметр("Дата", 	МоментВремени());
			ЗапрОстаткиПартий.УстановитьПараметр("Валюта", 	Валюта);
			ЗапрОстаткиПартий.УстановитьПараметр("Касса", 	ДСчет);
			Выборка = ЗапрОстаткиПартий.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				Если Выборка.Сумма <> 0 Тогда
					к = Сумма / Выборка.Сумма;
					Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
					Движение.Период					= Дата;
					Движение.Касса 					= ДСчет;
					Движение.Валюта 				= СубДВалюта;
					Движение.Сумма					= Сумма;
					Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Перемещение
			И Валюта.ВестиПартионныйУчет
			И ВестиПартУчет(ДСчет)
			И ВестиПартУчет(СубДСчет) Тогда
			// перемещение                      
			ЗапрОстаткиПартий.УстановитьПараметр("Дата", 	МоментВремени());
			ЗапрОстаткиПартий.УстановитьПараметр("Валюта", 	Валюта);
			ЗапрОстаткиПартий.УстановитьПараметр("Касса", 	ДСчет);
			Выборка = ЗапрОстаткиПартий.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				Если Выборка.Сумма <> 0 Тогда
					к = Сумма / Выборка.Сумма;
					Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
					Движение.Период					= Дата;
					Движение.Касса 					= ДСчет;
					Движение.Валюта 				= Валюта;
					Движение.Сумма					= Сумма;
					Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
					Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
					Движение.Период					= Дата;
					Движение.Касса 					= СубДСчет;
					Движение.Валюта 				= Валюта;
					Движение.Сумма					= Сумма;
					Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ПриходРасход = Перечисления.ПриходРасход.Расход 
			И Валюта.ВестиПартионныйУчет 
			И ВестиПартУчет(ДСчет) Тогда 
			//
				ЗапрОстаткиПартий.УстановитьПараметр("Дата", 	МоментВремени());
				ЗапрОстаткиПартий.УстановитьПараметр("Валюта", 	Валюта);
				ЗапрОстаткиПартий.УстановитьПараметр("Касса", 	ДСчет);
				Выборка = ЗапрОстаткиПартий.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда 
					Если Выборка.Сумма <> 0 Тогда
						к = Сумма / Выборка.Сумма;
						Движение = Движения.ПартииВалюты.ДобавитьРасход(); 
						Движение.Период					= Дата;
						Движение.Касса 					= ДСчет;
						Движение.Валюта 				= Валюта;
						Движение.Сумма					= Сумма;
						Движение.СуммаВБазовойВалюте	= Выборка.СуммаВБазовойВалюте * к; 
					КонецЕсли;
				КонецЕсли; 

		ИначеЕсли ПриходРасход = Перечисления.ПриходРасход.Приход 
			И Валюта.ВестиПартионныйУчет 
			И ВестиПартУчет(ДСчет)
			И Статья = Справочники.Статьи.ДоходОтКР Тогда
				Движение = Движения.ПартииВалюты.ДобавитьПриход(); 
				Движение.Период					= Дата;
				Движение.Касса 					= ДСчет;
				Движение.Валюта 				= Валюта;
				Движение.Сумма					= Сумма;
		КонецЕсли;
	
	КонецЕсли;

	// статусы инвойсов	
	Если ДополнительныеСвойства.Свойство("ИнвойсыДляЗаписиСтатусов") Тогда
		МассивИнвойсов = ДополнительныеСвойства.ИнвойсыДляЗаписиСтатусов;
		Если МассивИнвойсов <> Неопределено И МассивИнвойсов.Количество() > 0 Тогда
			РассчитатьИЗаписатьСтатусыИнвойсов(МассивИнвойсов);
		КонецЕсли;
	КонецЕсли;
	
    // Последовательность
	лВалюта = Неопределено;
	лКасса = Неопределено;
	Если Валюта.ВестиПартионныйУчет Тогда
		лВалюта = Валюта;
	КонецЕсли;
	Если СубДВалюта.ВестиПартионныйУчет Тогда
		лВалюта = СубДВалюта;
	КонецЕсли;
	Если ВестиПартУчет(ДСчет) Тогда
		лКасса = ДСчет;
	КонецЕсли;
	Если ВестиПартУчет(СубДСчет) Тогда
		лКасса = СубДСчет;
	КонецЕсли;
	
	НаборПоследовательности = Последовательности.ПартииВалют.СоздатьНаборЗаписей();
	НаборПоследовательности.Отбор.Регистратор.Установить(Ссылка); 
	
	Если ЗначениеЗаполнено(лВалюта) И ЗначениеЗаполнено(лКасса) Тогда
		Запись = НаборПоследовательности.Добавить();
		Запись.Регистратор = Ссылка; // Для последовательности это поле обязательно
		Запись.Период      = Дата;   // Для последовательности это поле обязательно
		// Заполняем измерения
		Запись.Касса  = лКасса;
		Запись.Валюта = лВалюта;
	КонецЕсли;
	
	// Метод Записать() внутри транзакции проведения отработает:
	// - Если условие выше выполнилось, он перезапишет старую регистрацию на новую.
	// - Если условие НЕ выполнилось (набор остался пустым), метод сотрет старую запись 
	//   этого документа из последовательности, корректно сняв его с учета.
	НаборПоследовательности.Записать();

	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	//Если гоАдминистратор() Тогда Возврат КонецЕсли; 
	
	Если Окончательно Тогда 
		ПроведениеДокументов.СообщитьОбОшибке("Отмена проведения невозможна! Документ закрыт {Окончательно}!", Ссылка, Отказ);
	КонецЕсли;
	
	Если Привязки.Количество() <> 0 Тогда 
		ПроведениеДокументов.СообщитьОбОшибке("Отмена проведения невозможна! Документ не пустой!", Ссылка, Отказ);
	КонецЕсли;
	
	// статусы инвойсов	
	Если ДополнительныеСвойства.Свойство("ИнвойсыДляЗаписиСтатусов") Тогда
		МассивИнвойсов = ДополнительныеСвойства.ИнвойсыДляЗаписиСтатусов;
		Если МассивИнвойсов <> Неопределено И МассивИнвойсов.Количество() > 0 Тогда
			РассчитатьИЗаписатьСтатусыИнвойсов(МассивИнвойсов);
		КонецЕсли;
	КонецЕсли;   

КонецПроцедуры

