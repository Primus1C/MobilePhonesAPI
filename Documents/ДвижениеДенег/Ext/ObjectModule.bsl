				КонецЦикла;
			КонецЕсли; 
			
			// РН РасчетыПоИнвойсам
			Движения.РасчетыПоИнвойсам.Записывать = Истина; 
			Если Контрагент.ПривязыватьИнвойсы Тогда
				// 1. привязанные инвойсы    
				Для каждого СтрокаТЧ Из Инвойсы Цикл 
					Если СтрокаТЧ.Сумма = 0 Тогда
					    Продолжить;
					КонецЕсли;
					Движение = Движения.РасчетыПоИнвойсам.Добавить();
