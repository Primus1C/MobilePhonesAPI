	// © Primus1C  11.03.2024  НАЧАЛО ►
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ДвижениеДенег") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения, , "Номер,Дата");
		Сумма 			= - Сумма;
	Иначе
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	Фирма 				= гоФирма();
	Привязки.Очистить();
	СуммаПривязано 		= 0;
	
	Валюта 				= Фирма.Валюта;
	ДСчет 				= ПараметрыСеанса.ДСчет;
	
	ПриходРасход 		= Перечисления.ПриходРасход.Приход;
	ВидДвиженияДенег 	= Перечисления.ВидДвиженияДенег.Покупатели;   
	
	// © Primus1C  11.03.2024  НАЧАЛО ►
	КонецЕсли;     
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	КемСоздан 		= гоПользователь(); 
	Создан 			= ТекущаяДатаСеанса(); 
	Окончательно 	= Ложь;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ЕстьДеньги 			= Ложь;
	ЕстьДолги 			= Ложь;
	ЕстьНезакрытые 		= Ложь;
	ЕстьРасходыДоходы 	= Ложь;
	ЕстьПодотчет 		= Истина;
