	Если ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.Логистика И ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.Поставщики Тогда  
    	Инвойсы.Очистить();
	КонецЕсли;	
	СуммаПривязаноИнвойсов = Инвойсы.Итог("Сумма");
	
	Если ВзаиморасчетыПоИнвойсам() Тогда
	    // есть сумма КР, внесена вручную
	Иначе	
		//2015.11.26
		//изначально суммы КР у нас нет
		СуммаКР = 0;
	КонецЕсли;
	
	Если ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.ВводОстатков Тогда
		ПроверитьЗаполн(Сумма, Ошибки, "Не заполнена сумма");
	КонецЕсли;
	
	Если ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Покупатели Тогда
		ПриходРасход = Перечисления.ПриходРасход.Приход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Контрагент, Ошибки, "Не заполнен покупатель");
		КонецЕсли; 
		Корреспонденция = "покуп: " + Контрагент;
		
		//2015.11.26
		//можно ли полностью копировать схему из поставщика по КР?
		//надо пробовать
		//не годится, нужно МЕНЯТЬ ЗНАК
		Для Каждого Стр Из Привязки Цикл
			//2015.11.26
			правильнаяСумма = омСервер.ПересчетЗн(Стр.Сумма2, Стр.Валюта2, Валюта, Фирма, Дата, 2);
			//вот тут отнимаем наоборот
			Если правильнаяСумма <> Стр.Сумма1 Тогда гоПлюс(СуммаКР, Стр.Сумма1 - правильнаяСумма) КонецЕсли;
		КонецЦикла; 
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Поставщики Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Контрагент, Ошибки, "Не заполнен поставщик");
		КонецЕсли; 
		Корреспонденция = "пост: " + Контрагент;
		
		Если НЕ ВзаиморасчетыПоИнвойсам() Тогда
			//2015.11.26
			//здесь тоже возникают КР, но только в привязках
			Для Каждого Стр Из Привязки Цикл
				//2015.11.26
				//мы закрываем долг поставщику в какой-то валюте, по какому-то курсу
				//значит, можем пересчитать его обратно по текущему курсу
				//разница накапливается
				//а вот имеет ли значение, закрываем мы предоплату или нет?
				//надо попробовать
				//пусть в прошлом месяце мы сделали предоплату в долларах 100 долларов
				//прошло время, он нам их возвращает рублями по 65, хотя сейчас курс 64 - возникает положительная разница
				правильнаяСумма = омСервер.ПересчетЗн(Стр.Сумма2, Стр.Валюта2, Валюта, Фирма, Дата, 2);
				Если правильнаяСумма <> Стр.Сумма1 Тогда гоПлюс(СуммаКР, правильнаяСумма - Стр.Сумма1) КонецЕсли; 
			КонецЦикла;    
		КонецЕсли;
	
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Перемещение Тогда 
		// © Primus1C  14.04.2026  НАЧАЛО ►
		Если Валюта.ВестиПартионныйУчет Тогда
			Если (НЕ ВестиПартУчет(ДСчет)) И ВестиПартУчет(СубДСчет) Тогда
				Ошибки.Добавить("Перемещение валюты с партионным учетом запрещено: в кассе ОТКУДА нет парт.учета, а в кассе КУДА есть парт.учет валюты!"); 
		    КонецЕсли;
		КонецЕсли;
		// © Primus1C  ОКОНЧАНИЕ ◄
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(СубДСчет, Ошибки, "Не заполнена касса КУДА");
		КонецЕсли; 
		Корреспонденция = "в: " + СубДСчет;
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ОбменВалюты Тогда 
		Контрагент = Справочники.Контрагенты.ПустаяСсылка();
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(СубДСчет, Ошибки, "Не заполнена касса КУДА");
			ПроверитьЗаполн(СубДВалюта, Ошибки, "Не заполнено В КАКУЮ валюту");
			ПроверитьЗаполн(СубДСумма, Ошибки, "Не рассчитана сумма обмена");
		КонецЕсли;
		Корреспонденция = "обмен " + СубДВалюта + " в: " + СубДСчет;
		
		// © Primus1C  24.05.2025  НАЧАЛО ►
		
		// закомментировал 
		
		////2015.11.26
		////вот первый вариант, когда может возникнуть КР
		////нужно посчитать, какая бы сумма обмена была бы, если бы курс был текущий?
		//правильнаяСумма = омСервер.ПересчетЗн(СубДСумма, СубДВалюта, Валюта, Фирма, Дата, 2);
		//Если правильнаяСумма <> Сумма Тогда
		//	//но эта разница получается в валюте обмена!!!
		//	//правильно ли это?
		//	//нужно что-то другое
		//	//надо думать
		//	//мы купили 100 долларов за 6500 рублей, а курс 64, т.е. мы потеряли 100 рублей
		//	//нужно наоборот, посчитать, за сколько мы могли бы купить, если бы по правильному курсу
		//	//вот теперь это в валюте документа и составляет 100 рублей, выведем ее на экран
		//	
		//	СуммаКР = правильнаяСумма - Сумма;
		//	
		//КонецЕсли;       
		
		Документы.ДвижениеДенег.УстановитьКурсовуюРазницу(ЭтотОбъект, Истина);
		
		// © Primus1C  ОКОНЧАНИЕ ◄
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Расходы Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Статья, Ошибки, "Не заполнена статья расходов");
			Если Статья.ВидСтатьи <> Перечисления.ДоходРасход.Расход Тогда 
				Ошибки.Добавить("Это не статья расходов!"); 
			КонецЕсли;
		КонецЕсли; 
		Корреспонденция = "расх: " + Статья;
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Доходы Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Приход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Статья, Ошибки, "Не заполнена статья доходов");
			Если Статья.ВидСтатьи <> Перечисления.ДоходРасход.Доход Тогда  
				Ошибки.Добавить("Это не статья доходов!");
			КонецЕсли;
		КонецЕсли; 
		Корреспонденция = "дох: " + Статья;
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Подотчет Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Сотрудник, Ошибки, "Не заполнен сотрудник (подотчетное лицо)");
		КонецЕсли; 
		Корреспонденция = "подотч: " + Сотрудник;
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Зарплата Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Расход;
		Если Окончательно Тогда  
			ПроверитьЗаполн(Сотрудник, Ошибки, "Не заполнен сотрудник");
			ПроверитьЗаполн(МесяцЗП, Ошибки, "Не заполнен месяц начисления зарплаты");
		КонецЕсли; 
		Корреспонденция = "зарпл: " + Сотрудник + "/" + Формат(МесяцЗП, "ДФ=MM.yyyy");
		
	ИначеЕсли ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ВводОстатков Тогда  
		ПриходРасход = Перечисления.ПриходРасход.Приход; 
		Если Валюта.ВестиПартионныйУчет И ДСчет.ВестиПартионныйУчет И ДСчет.НачалоПартионногоУчета >= Дата Тогда
			Корреспонденция = "ввод остатков (партии валют)";    
		Иначе
			Корреспонденция = "ввод остатков";    
		КонецЕсли;
	КонецЕсли; 
	
	Если Ошибки.Количество() > 0 Тогда
		Для каждого Ош Из Ошибки Цикл  
			ПроведениеДокументов.СообщитьОбОшибке(Ош.Значение, Ссылка, Отказ);
		КонецЦикла;
		Возврат;
	КонецЕсли;
	
	// Средний курс Начало
	
	Если ВидДвиженияДенег <> Перечисления.ВидДвиженияДенег.ОбменВалюты Тогда
		РассчитыватьСреднийКурс = Ложь;
	КонецЕсли;
	
	Если РассчитыватьСреднийКурс И Окончательно Тогда 
		
		БылПроведенРасчетСрКурса = Ложь;
		МассивПересчетаСрКурсов = Новый Массив;   
	
		// Узнаем состояние документа в базе данных ДО текущих изменений пользователя
		Если НЕ ЭтоНовый() Тогда
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
			Запрос.УстановитьПараметр("ВалютаДоллар", ПараметрыСеанса.БазоваяВалюта);
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Док.Проведен
				|		И Док.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.ОбменВалюты)
				|		И Док.РассчитыватьСреднийКурс
				|		И Док.Окончательно
				|		И (Док.Валюта = &ВалютаДоллар
				|			ИЛИ Док.СубДВалюта = &ВалютаДоллар) КАК БылПроведенРасчетСрКурса,
				|	ВЫБОР
				|		КОГДА Док.Валюта = &ВалютаДоллар
				|			ТОГДА Док.СубДВалюта
				|		ИНАЧЕ Док.Валюта
				|	КОНЕЦ КАК ВалютаОбмена,
				|	ВЫБОР
				|		КОГДА Док.Валюта = &ВалютаДоллар
				|			ТОГДА ""Покупка""
				|		ИНАЧЕ ""Продажа""
				|	КОНЕЦ КАК ПокупкаПродажа,
				|	Док.Дата КАК Дата
				|ИЗ
				|	Документ.ДвижениеДенег КАК Док
				|ГДЕ
				|	Док.Ссылка = &Ссылка";
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				БылПроведенРасчетСрКурса = Выборка.БылПроведенРасчетСрКурса;
				Если БылПроведенРасчетСрКурса Тогда
					МассивПересчетаСрКурсов.Добавить(Новый Структура("Валюта,Дата,ПокупкаПродажа", Выборка.ВалютаОбмена, НачалоДня(Выборка.Дата), Выборка.ПокупкаПродажа));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Состояние документа "в памяти" (то, что пользователь пытается записать) 
		//Если ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ОбменВалюты И РассчитыватьСреднийКурс И НЕ Окончательно Тогда  // ошибочное - НЕ ?
		Если ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.ОбменВалюты И РассчитыватьСреднийКурс И Окончательно Тогда
			Если Валюта = ПараметрыСеанса.БазоваяВалюта Тогда
				лВалютаОбмена = СубДВалюта;  
				лПокупкаПродажа = "Покупка";
			Иначе
				лВалютаОбмена = Валюта;
				лПокупкаПродажа = "Продажа";
			КонецЕсли;
			Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				МассивПересчетаСрКурсов.Добавить(Новый Структура("Валюта,Дата,ПокупкаПродажа", лВалютаОбмена, НачалоДня(Дата), лПокупкаПродажа));
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				// При отмене проведения пересчет нужен, только если мы отменяем именно "Обмен"
				Если БылПроведенРасчетСрКурса Тогда
					МассивПересчетаСрКурсов.Добавить(Новый Структура("Валюта,Дата,ПокупкаПродажа", лВалютаОбмена, НачалоДня(Дата), лПокупкаПродажа));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Прячем в дополнительные свойства объекта
		Если МассивПересчетаСрКурсов.Количество() > 1 Тогда
			// не допустим дубли
			Если МассивПересчетаСрКурсов[0].Дата = МассивПересчетаСрКурсов[1].Дата 
				И МассивПересчетаСрКурсов[0].Валюта = МассивПересчетаСрКурсов[1].Валюта 
				И МассивПересчетаСрКурсов[0].ПокупкаПродажа = МассивПересчетаСрКурсов[1].ПокупкаПродажа Тогда
				МассивПересчетаСрКурсов.Удалить(1);
			КонецЕсли;
		КонецЕсли;
		
		ДополнительныеСвойства.Вставить("МассивПересчетаСрКурсов", МассивПересчетаСрКурсов);	
		
	КонецЕсли; 

	// Средний курс Окончание
	
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);	
	ПересчитатьИтоги(); 
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)  
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	// Средний курс Начало
	
	Если ДополнительныеСвойства.Свойство("МассивПересчетаСрКурсов") Тогда
		
		// Здесь вызываем процедуру расчета и записи в независимый Регистр Сведений.
		// База данных в этот момент находится в идеальном (уже обновленном) состоянии.
		Для каждого Эл Из ДополнительныеСвойства.МассивПересчетаСрКурсов Цикл
			РассчитатьИЗаписатьСреднийКурс(Эл.Дата, Эл.Валюта, Эл.ПокупкаПродажа); 
		КонецЦикла;
		
	КонецЕсли; 
	
	// Средний курс Окончание
	
	// Статус оплаты инвойсов
	Для каждого СтрокаТЧ Из Инвойсы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.Инвойс) Тогда
			Состояние = РаботаСИнвойсами.СостояниеОплатыИнвойса(СтрокаТЧ.Инвойс, Ссылка, ДополнительныеСвойства.РежимЗаписи = РежимЗаписиДокумента.Проведение);
	        РаботаСИнвойсами.ЗаписатьСтатусыИнвойса(СтрокаТЧ.Инвойс,,,,Состояние.СтатусОплатыАвто, Состояние.СуммаОплаты, Состояние.ДатаОплаты, Состояние.Курс, Ссылка);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Фирма = гоФирма();
	КемСоздан = гоПользователь(); 
	Создан = ТекущаяДата(); 
	Окончательно = Ложь;
