Процедура РассчитатьИЗаписатьСтатусыИнвойсов(МассивИнвойсов)
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Инвойсы", МассивИнвойсов);
	Запр.УстановитьПараметр("Ссылка", Ссылка);   
	Запр.Текст = "ВЫБРАТЬ
	             |	ЕСТЬNULL(Долги.СуммаОстаток, 0) КАК ДолгПоРегистру,
	             |	ЕСТЬNULL(ТЧ.Сумма, 0) КАК СуммаОплатыТЧ,
	             |	АктуальныеИнвойсы.Ссылка.ДокументОснование.Сумма КАК СуммаИнвойса,
	             |	АктуальныеИнвойсы.Ссылка КАК Инвойс
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		_Инвойс.Ссылка КАК Ссылка
	             |	ИЗ
	             |		Документ._Инвойс КАК _Инвойс
	             |	ГДЕ
	             |		_Инвойс.Ссылка В(&Инвойсы)) КАК АктуальныеИнвойсы,
	             |	(ВЫБРАТЬ
	             |		ДвижениеДенегИнвойсы.Инвойс КАК Инвойс,
	             |		ДвижениеДенегИнвойсы.Сумма КАК Сумма
	             |	ИЗ
	             |		Документ.ДвижениеДенег.Инвойсы КАК ДвижениеДенегИнвойсы
	             |	ГДЕ
	             |		ДвижениеДенегИнвойсы.Ссылка = &Ссылка) КАК ТЧ,
	             |	(ВЫБРАТЬ
	             |		РасчетыПоИнвойсамОстатки.Инвойс КАК Инвойс,
	             |		СУММА(РасчетыПоИнвойсамОстатки.СуммаОстаток) КАК СуммаОстаток
	             |	ИЗ
	             |		РегистрНакопления.РасчетыПоИнвойсам.Остатки(, Инвойс В (&Инвойсы)) КАК РасчетыПоИнвойсамОстатки
	             |	
	             |	СГРУППИРОВАТЬ ПО
	             |		РасчетыПоИнвойсамОстатки.Инвойс) КАК Долги";
	Запр.Текст = "ВЫБРАТЬ
	|	ЕСТЬNULL(Долги.СуммаОстаток, 0) КАК ДолгПоРегистру,
	|	ЕСТЬNULL(ТЧ.Сумма, 0) КАК СуммаОплатыТЧ,
	|	АктуальныеИнвойсы.Ссылка.ДокументОснование.Сумма КАК СуммаИнвойса,
	|	АктуальныеИнвойсы.Ссылка КАК Инвойс
	|ИЗ
	|	(ВЫБРАТЬ
	|		_Инвойс.Ссылка КАК Ссылка
	|	ИЗ
	|		Документ._Инвойс КАК _Инвойс
	|	ГДЕ
	|		_Инвойс.Ссылка В(&Инвойсы)) КАК АктуальныеИнвойсы
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДвижениеДенегИнвойсы.Инвойс КАК Инвойс,
	|			СУММА(ДвижениеДенегИнвойсы.Сумма) КАК Сумма
	|		ИЗ
	|			Документ.ДвижениеДенег.Инвойсы КАК ДвижениеДенегИнвойсы
	|		ГДЕ
	|			ДвижениеДенегИнвойсы.Ссылка = &Ссылка
	|			И ДвижениеДенегИнвойсы.Инвойс В(&Инвойсы)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДвижениеДенегИнвойсы.Инвойс) КАК ТЧ
	|		ПО АктуальныеИнвойсы.Ссылка = ТЧ.Инвойс
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ТаблицаОстатков.Инвойс КАК Инвойс,
	|			СУММА(ТаблицаОстатков.СуммаОстаток) КАК СуммаОстаток
	|		ИЗ
	|			(ВЫБРАТЬ
	|				РасчетыПоИнвойсамОстатки.Инвойс КАК Инвойс,
	|				РасчетыПоИнвойсамОстатки.СуммаОстаток КАК СуммаОстаток
	|			ИЗ
	|				РегистрНакопления.РасчетыПоИнвойсам.Остатки(, Инвойс В (&Инвойсы)) КАК РасчетыПоИнвойсамОстатки
	|			
	|			ОБЪЕДИНИТЬ ВСЕ
	|			
	|			ВЫБРАТЬ
	|				РасчетыПоИнвойсамДвижения.Инвойс,
	|				ВЫБОР
	|					КОГДА РасчетыПоИнвойсамДвижения.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|						ТОГДА -РасчетыПоИнвойсамДвижения.Сумма
	|					ИНАЧЕ РасчетыПоИнвойсамДвижения.Сумма
	|				КОНЕЦ
	|			ИЗ
	|				РегистрНакопления.РасчетыПоИнвойсам КАК РасчетыПоИнвойсамДвижения
	|			ГДЕ
	|				РасчетыПоИнвойсамДвижения.Регистратор = &Ссылка
	|				И РасчетыПоИнвойсамДвижения.Инвойс В(&Инвойсы)
	|				И РасчетыПоИнвойсамДвижения.Активность = ИСТИНА) КАК ТаблицаОстатков
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ТаблицаОстатков.Инвойс) КАК Долги
	|		ПО АктуальныеИнвойсы.Ссылка = Долги.Инвойс" ;
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Выборка.ДолгПоРегистру = Выборка.СуммаОплатыТЧ Тогда
		 	СтатусОплатыАвто = Перечисления.Долги.Полностью;
		ИначеЕсли Выборка.ДолгПоРегистру - Выборка.СуммаОплатыТЧ = Выборка.СуммаИнвойса Тогда
		 	СтатусОплатыАвто = Перечисления.Долги.Неоплачено;
		Иначе
		 	СтатусОплатыАвто = Перечисления.Долги.Частично;
		КонецЕсли;
		РаботаСИнвойсами.ЗаписатьСтатусыИнвойса(Выборка.Инвойс, , , , 
												СтатусОплатыАвто, Выборка.СуммаОплатыТЧ, , , Выборка.Инвойс);
	КонецЦикла;

КонецПроцедуры

Процедура РассчитатьИЗаписатьСреднийКурс(ДатаЗаписи, Знач ВалютаЗаписи, ПокупкаПродажа)
	
	// вторым подзапросом добавляем текущий документ  
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", 	Ссылка);
	Запр.УстановитьПараметр("Фирма", 	Фирма);
	Запр.УстановитьПараметр("Валюта", 	ВалютаЗаписи);
	Запр.УстановитьПараметр("Доллар", 	омСервер.ПолучитьВалюту("USD"));
	Запр.УстановитьПараметр("Рубль", 	омСервер.ПолучитьВалюту("руб"));
	//Запр.УстановитьПараметр("СубДВалюта", ПараметрыСеанса.БазоваяВалюта);
	Запр.УстановитьПараметр("ДатаНач", 	ДатаЗаписи);
	Запр.УстановитьПараметр("ДатаКон", 	КонецДня(ДатаЗаписи));
	Запр.УстановитьПараметр("ЭтоПокупка", ПокупкаПродажа = "Покупка");
	Запр.Текст = "ВЫБРАТЬ
	             |	ЕСТЬNULL(СУММА(Свод.СубДСумма), 0) КАК СубДСумма,
	             |	ЕСТЬNULL(СУММА(Свод.Сумма), 0) КАК Сумма
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		ДвижениеДенег.СубДСумма КАК СубДСумма,
	             |		ДвижениеДенег.Сумма КАК Сумма
	             |	ИЗ
	             |		Документ.ДвижениеДенег КАК ДвижениеДенег
	             |	ГДЕ
	             |		ДвижениеДенег.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.ОбменВалюты)
	             |		И ДвижениеДенег.РассчитыватьСреднийКурс
	             |		И ДвижениеДенег.Окончательно
	             |		И ДвижениеДенег.Проведен
	             |		И ДвижениеДенег.Дата МЕЖДУ &ДатаНач И &ДатаКон
	             |		И ДвижениеДенег.Фирма = &Фирма 

				 //|		И ВЫБОР
				 //|				КОГДА &Валюта = &Доллар
				 //|					ТОГДА ДвижениеДенег.Валюта = &Рубль
				 //|							ИЛИ ДвижениеДенег.СубДВалюта = &Рубль
				 //|				КОГДА &ЭтоПокупка
				 //|					ТОГДА ДвижениеДенег.СубДВалюта = &Валюта
				 //|				ИНАЧЕ ДвижениеДенег.Валюта = &Валюта
				 //|			КОНЕЦ  
				 
				|		И ВЫБОР КОГДА &ЭтоПокупка
				|				ТОГДА ДвижениеДенег.СубДВалюта = &Валюта
				|				ИНАЧЕ ДвижениеДенег.Валюта = &Валюта
				|		КОНЕЦ
                |       И ДвижениеДенег.Ссылка <> &Ссылка
				
				 |	
	             |	ОБЪЕДИНИТЬ ВСЕ
	             |	
	             |	ВЫБРАТЬ
	             |		ДвижениеДенег.СубДСумма,
	             |		ДвижениеДенег.Сумма
	             |	ИЗ
	             |		Документ.ДвижениеДенег КАК ДвижениеДенег
	             |	ГДЕ
	             |		ДвижениеДенег.Ссылка = &Ссылка
	             //|		И ДвижениеДенег.Проведен
	             |		И ДвижениеДенег.Окончательно
				 |		И ДвижениеДенег.РассчитыватьСреднийКурс) КАК Свод";
	Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		//Если ВалютаЗаписи.ОбратныйКурс ИЛИ ПокупкаПродажа = "Покупка" Тогда
		Если ПокупкаПродажа = "Покупка" Тогда
			СумДелимое = Выборка.Сумма;
			СумДелитель = Выборка.СубДСумма; 
		Иначе	
			СумДелимое = Выборка.СубДСумма;
			СумДелитель = Выборка.Сумма;
		КонецЕсли;  
		Если ВалютаЗаписи.ОбратныйКурс ИЛИ ВалютаЗаписи = ПараметрыСеанса.Валюта Тогда // обратный курс, или покупка долларов за рубли
			тмп = СумДелимое;
			СумДелимое = СумДелитель;	
		    СумДелитель = тмп;
		КонецЕсли;
		Если СумДелитель = 0 Тогда
			Возврат;
		КонецЕсли;
		СреднийКурс = СумДелимое / СумДелитель;
		
		Если ВалютаЗаписи = ПараметрыСеанса.Валюта Тогда    
			// курс рубля пишем в доллар
			ВалютаЗаписи = ПараметрыСеанса.БазоваяВалюта;
		КонецЕсли;
		
		// Приводим дату к началу дня, так как периодичность регистра - День
		ПериодДень = НачалоДня(Дата);
		
		// Создаем менеджер для работы с конкретной записью
		МенеджерЗаписи = РегистрыСведений.КурсыВалют.СоздатьМенеджерЗаписи();
		
		// Устанавливаем ключевые поля (Период + Измерения) для поиска нужной записи
		МенеджерЗаписи.Период = ПериодДень;
		МенеджерЗаписи.Фирма  = Фирма;
		МенеджерЗаписи.Валюта = ВалютаЗаписи;
		
		// Читаем текущую запись из базы данных.
		// Метод Прочитать() возвращает Истина, если запись найдена.
		// Если запись найдена, ее ресурсы загрузятся в МенеджерЗаписи (мы их не потеряем).
		МенеджерЗаписи.Прочитать();
		
		// Заполняем ключевые поля (они могли очиститься, если Прочитать() вернул Ложь)
		МенеджерЗаписи.Период = ПериодДень;
		МенеджерЗаписи.Фирма  = Фирма;
		МенеджерЗаписи.Валюта = ВалютаЗаписи;
		
		// Устанавливаем новое значение ресурса 
		Если ПокупкаПродажа = "Покупка" Тогда
			МенеджерЗаписи.КурсЗакупкиСредний = СреднийКурс;
		Иначе
			МенеджерЗаписи.КурсПродажиСредний = СреднийКурс;
		КонецЕсли;
		
		// Записываем изменения в базу данных
		МенеджерЗаписи.Записать();	
		
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьЗаполн(ЗначениеДляПроверки, СписокОшибок, Ошибка)

	Если НЕ ЗначениеЗаполнено(ЗначениеДляПроверки) Тогда
		СписокОшибок.Добавить(Ошибка + "!");
	КонецЕсли;	

КонецПроцедуры

Функция ВестиПартУчет(Счет)

	Возврат Счет.ВестиПартионныйУчет И Дата >= Счет.НачалоПартионногоУчета;	

КонецФункции

Функция ОстатокКассы()
	
	Фильтр = Новый Структура("Фирма,Касса,Валюта", ДСчет.Владелец, ДСчет, Валюта);
	Табл = РегистрыНакопления.Деньги.Остатки(МоментВремени(), Фильтр, , "Остаток");
    Если Табл.Количество() = 0 Тогда
	 	Возврат 0;
	Иначе
		Возврат Табл[0].Остаток;
	КонецЕсли;    
	
КонецФункции	

Функция ВзаиморасчетыПоИнвойсам()

	Возврат (ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Поставщики) И Контрагент.ПривязыватьИнвойсы;

КонецФункции 
