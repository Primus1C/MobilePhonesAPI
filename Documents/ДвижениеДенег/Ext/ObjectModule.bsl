				//	Движение.СуммаОплаты = Сумма + СуммаКР;
				//Иначе
					Движение.СуммаОплаты = Сумма;
				//КонецЕсли;
				Движение.Валюта		 = Валюта;  
			Иначе
				Для Каждого Стр Из Привязки Цикл   
					Если ТипЗнч(Стр.Док2) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
						лИнвойс = Стр.Док2.ВКД_Инвойс;
					Иначе	
					    лИнвойс = Неопределено;
					КонецЕсли;
					Движение			 = Движения._ВзаиморасчетыСПоставщиками.Добавить();
