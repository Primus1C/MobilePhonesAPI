&НаКлиенте
// Устанавливает сумму привязки автоматически
//
Процедура ИнвойсыПередНачаломИзменения(Элемент, Отказ)
	
	// для редактирования доступно только поле "Привязано"
	Если Элемент.ТекущийЭлемент.Имя <> "ИнвойсыПривязано" Тогда
		Возврат;
	КонецЕсли;

	ТекДанные = Элемент.ТекущиеДанные;
	
	Если ТекДанные.Состояние = ПредопределенноеЗначение("Перечисление.Долги.Полностью") Тогда 
		Сообщить("" + текДанные.Инвойс + " оплачен полностью!");
		//Отказ = Истина;
		//Возврат;
	КонецЕсли;
	
	СуммаДоРедактирования = ТекДанные.Привязано;
	Если СуммаНеПривязано > 0 Тогда  // если есть что привязать, сделаем это автоматически
		лМожноПривязать = СуммаДоРедактирования + Мин(ТекДанные.ОстатокДолга, СуммаНеПривязано);  
		ТекДанные.Привязано		= лМожноПривязать;
		//ТекДанные.ОстатокДолга	= ТекДанные.ОстатокДолга - ТекДанные.Привязано;  
	 	ТекДанные.ОстатокДолга = ТекДанные.Сумма / Курс - ТекДанные.Привязано;	
		//СуммаПривязано 			= СуммаПривязано + лМожноПривязать;
		//СуммаНеПривязано 		= СуммаНеПривязано - лМожноПривязать;
		//ОбновитьИтоги();
		СуммаПривязано = Инвойсы.Итог("Привязано");
		СуммаНеПривязано = СуммаОбщая - СуммаПривязано;
		ОбновитьИтоги();  
		
	КонецЕсли; 
	
КонецПроцедуры
 
&НаКлиенте
Процедура ИнвойсыПриИзменении(Элемент)
	
	// для редактирования доступно только поле "Привязано"
	Если Элемент.ТекущийЭлемент.Имя <> "ИнвойсыПривязано" Тогда
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элемент.ТекущиеДанные; 
	Если ТекДанные.Привязано > СуммаДоРедактирования Тогда
		лМожноПривязать = Мин(ТекДанные.Привязано - СуммаДоРедактирования, СуммаНеПривязано); 
		ТекДанные.Привязано = СуммаДоРедактирования + лМожноПривязать;
	КонецЕсли;
	
	ТекДанные.ОстатокДолга = ТекДанные.Сумма / Курс - ТекДанные.Привязано;
	
	СуммаПривязано = Инвойсы.Итог("Привязано");
	СуммаНеПривязано = СуммаОбщая - СуммаПривязано;
	ОбновитьИтоги();  
  	
КонецПроцедуры

&НаКлиенте
Процедура ИнвойсыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	Если Поле.Имя = "ИнвойсыИнвойс" Тогда                                        
		СтандартнаяОбработка = Ложь;
		ОткрытьЗначение(Элемент.ТекущиеДанные.Инвойс); 
	КонецЕсли;  

КонецПроцедуры

#КонецОбласти 


&НаКлиенте
Процедура ОбновитьИтоги()
	
	ЦвОстатка = ?(СуммаНеПривязано > 0, "ЧИСЛО_ЦВ2", "ЧИСЛО_ЦВКРАСНЫЙ_ТЕКСТ");

	СтруктураИтогов = Новый Структура;
	Стр = СтрШаблон("<p>%1: %2 %3 %4 %5 %3</p>", 
						омСервер.Фрмт(НСтр("ru = 'Еще можно привязать'; en = 'You can also bind'"), "НАДПИСЬ_Ж"), 
					    омСервер.Фрмт(СуммаНеПривязано, ЦвОстатка),
					    омСервер.Фрмт(Валюта, "НАДПИСЬ_ЦВ2"),
	                    омСервер.Фрмт(НСтр("ru = 'из'; en = 'of'"), "НАДПИСЬ_Ж"),
					    омСервер.Фрмт(СуммаОбщая, "ЧИСЛО_ЦВ2")
						);
	СтруктураИтогов.Вставить("Итоги", Стр); 

	Элементы.ДекорацияИтого.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураИтогов.Итоги));
	
	Элементы.СохранитьВыбор.КнопкаПоУмолчанию = СуммаНеПривязано = 0;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьВыбор(Команда)
	
	ТребуетсяПометкаНеПересчитыватьПриход = Ложь;
	МассивИ = Новый Массив;  
	
	Для Каждого строкаВ из Инвойсы Цикл
		Если строкаВ.Привязано > 0 Тогда 
			МассивИ.Добавить(строкаВ);  
			Если строкаВ.ЕстьПриходТовара И НЕ строкаВ.НеПересчитыватьПриходТовара Тогда
				ТребуетсяПометкаНеПересчитыватьПриход = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;  
	
	//Если ТребуетсяПометкаНеПересчитыватьПриход Тогда
	//	Если НЕ клВопрос("Есть инвойс(ы), по которым получен товар.
	//					|Цены этих приходных накладных будут пересчитаны.
	//					|Вы уверены, что
	//					|пометка 'НЕ ПЕРЕСЧИТЫВАТЬ ПРИХОД' не нужна?") Тогда
	//		Возврат;
	//	КонецЕсли;
	//КонецЕсли;
	//
	//ЭтаФорма.Закрыть(МассивИ);
    Если ТребуетсяПометкаНеПересчитыватьПриход Тогда
		клВопрос(Новый ОписаниеОповещения("СохранитьВыборПослеПодтверждения", ЭтотОбъект, МассивИ),
			"Есть инвойс(ы), по которым получен товар.
			|Цены этих приходных накладных будут пересчитаны.
			|Вы уверены, что
			|пометка 'НЕ ПЕРЕСЧИТЫВАТЬ ПРИХОД' не нужна?");
	Иначе
		ЭтаФорма.Закрыть(МассивИ);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СохранитьВыборПослеПодтверждения(Результат, МассивИ) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	ЭтаФорма.Закрыть(МассивИ);
КонецПроцедуры


&НаКлиенте
Процедура СвязанныеДокументы(Команда)

	ОткрытьФорму("ОбщаяФорма.ФормаСтруктурыПодчиненности", Новый Структура("ДокументСсылка", Элементы.Инвойсы.ТекущиеДанные.Инвойс), , Истина, );

КонецПроцедуры


&НаКлиенте                              
Процедура ТолькоНеоплаченные(Команда)

	ТолькоНеОплаченные = НЕ ТолькоНеОплаченные;
	Элементы.ФормаТолькоНеоплаченные.Пометка = ТолькоНеОплаченные;
	
	Если ТолькоНеОплаченные Тогда
		Отбор = Новый Структура("Неоплачено", Истина);
		Элементы.Инвойсы.ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);	
	Иначе
		Элементы.Инвойсы.ОтборСтрок = Неопределено;		
	КонецЕсли; 
	
КонецПроцедуры

