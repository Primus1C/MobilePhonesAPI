#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Курс 	= Параметры.Курс;
	Валюта 	= Параметры.Валюта; 
	Вал 	= Валюта.Символ; 
	
	//Элементы.ИнвойсыИнвойсСумма.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Сумма'; en = 'Сумма'"), Вал); 
	Элементы.ИнвойсыПривязано.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Привязано'; en = 'Привязано'"), Вал); 
	Элементы.ИнвойсыОстатокДолга.Заголовок = СтрШаблон("%1 (%2)", НСтр("ru = 'Остаток долга'; en = 'Остаток долга'"), Вал); 
	Если Параметры.Дата <> Дата(1,1,1) Тогда
		Дата = Параметры.Дата;  
		лДата = Дата;    
	ИначеЕсли ЗначениеЗаполнено(Параметры.Документ.Ссылка) Тогда
		Дата = Параметры.Документ.Ссылка.МоментВремени();  
		лДата = Параметры.Документ.Ссылка.МоментВремени().Дата;
	Иначе
		Дата = ТекущаяДатаСеанса();
		лДата = Дата;
	КонецЕсли;
	//Заголовок = СтрШаблон("%1: %2 %3", Параметры.Контрагент, НСтр("ru = 'оплата (привязка) инвойсов на'; en = 'payment (binding) of invoices at'"), лДата);
	Заголовок = СтрШаблон("%1: %2", Параметры.Контрагент, НСтр("ru = 'оплата (привязка) инвойсов'; en = 'payment (binding) of invoices'"));
	
	//СуммаОбщая = Параметры.Документ.Сумма - Параметры.Документ.СуммаПривязаноИнвойсов;
	СуммаОбщая 			= Параметры.Документ.Сумма;
	СуммаПривязано 		= Параметры.Документ.СуммаПривязаноИнвойсов;
	СуммаНеПривязано 	= Макс(0, СуммаОбщая - СуммаПривязано);
	
	глПокраситьВалютыТЗ(ЭтаФорма, "ИнвойсыИнвойсВалюта", "Инвойсы.Инвойс.ДокументОснование.Валюта");  
	
	Запрос = Новый Запрос;     
	// значения формы док-та
	Запрос.УстановитьПараметр("Контрагент", 	Параметры.Контрагент);
	Запрос.УстановитьПараметр("ДвижениеДенег",	Параметры.Документ.Ссылка);
	Запрос.УстановитьПараметр("Проведен",		Параметры.Документ.Ссылка.Проведен);
	Запрос.УстановитьПараметр("ТЧ", 			Параметры.ИнвойсыТЧ.Выгрузить());  
	Запрос.УстановитьПараметр("Курс", 			Курс);
	Запрос.УстановитьПараметр("Валюта", 		Валюта);
	// значения ссылки док-та
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДатаСеанса()));
	
	Запрос.Текст = "ВЫБРАТЬ
		|	тч.Инвойс КАК Инвойс,
		|	тч.Сумма КАК Сумма,
		|	тч.СуммаОплаты КАК СуммаОплаты,
		|	тч.СуммаКР КАК СуммаКР,
		|	тч.НеПересчитыватьПриходТовара КАК НеПересчитыватьПриходТовара
		|ПОМЕСТИТЬ ТЧ
		|ИЗ
		|	&тч КАК тч
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Взаиморасчеты.Инвойс КАК Инвойс,
		|	Взаиморасчеты.Инвойс.СуммаВВалютеИнвойса КАК Сумма,
		|	Взаиморасчеты.СуммаКР КАК СуммаКР,
		|	Взаиморасчеты.Инвойс.Валюта КАК Валюта,
		|	Взаиморасчеты.Долг / ВЫБОР
		|		КОГДА Взаиморасчеты.Инвойс.ДокументОснование.Валюта = &Валюта
		|			ТОГДА 1
		|		ИНАЧЕ &Курс
		|	КОНЕЦ КАК ОстатокДолга,
		|	ВЫБОР
		|		КОГДА Взаиморасчеты.Инвойс.ДокументОснование.Валюта = &Валюта
		|			ТОГДА 1
		|		ИНАЧЕ &Курс
		|	КОНЕЦ КАК Курс,
		|	Взаиморасчеты.Долг > 0 КАК Неоплачено,
		|	Взаиморасчеты.Привязано КАК Привязано,
		|	Взаиморасчеты.НеПересчитыватьПриходТовара КАК НеПересчитыватьПриходТовара,
		|	СостоянияИнвойсов.СтатусОплатыАвто КАК Состояние,
		|	ЕСТЬNULL(ПоступленияТоваров.ЕстьПриходТовара, ЛОЖЬ) КАК ЕстьПриходТовара
		|ИЗ
		|	(ВЫБРАТЬ
		|		Свод.Инвойс КАК Инвойс,
		|		СУММА(Свод.Сумма) КАК Долг,
		|		СУММА(Свод.СуммаОплаты) КАК Привязано,
		|		СУММА(Свод.СуммаКР) КАК СуммаКР,
		|		ЕСТЬNULL(МАКСИМУМ(Свод.НеПересчитыватьПриходТовара), ЛОЖЬ) КАК НеПересчитыватьПриходТовара
		|	ИЗ
		|		(ВЫБРАТЬ
		|			""Данные из формы документа"" КАК Источник,
		|			ТЧ.Инвойс КАК Инвойс,
		|			-ТЧ.Сумма КАК Сумма,
		|			ТЧ.СуммаОплаты КАК СуммаОплаты,
		|			ТЧ.СуммаКР КАК СуммаКР,
		|			ТЧ.НеПересчитыватьПриходТовара КАК НеПересчитыватьПриходТовара
		|		ИЗ
		|			ТЧ КАК ТЧ
		|		
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ
		|			""Данные из документа, записанного в БД"",
		|			ИнвойсыДокумента.Инвойс,
		|			ИнвойсыДокумента.Сумма,
		|			0,
		|			ИнвойсыДокумента.СуммаКР,
		|			NULL
		|		ИЗ
		|			Документ.ДвижениеДенег.Инвойсы КАК ИнвойсыДокумента
		|		ГДЕ
		|			ИнвойсыДокумента.Ссылка = &ДвижениеДенег
		|		
		|		ОБЪЕДИНИТЬ ВСЕ
		|		
		|		ВЫБРАТЬ
		|			""Данные из РН РасчетыПоИнвойсам, не на дату, а все; включают движения тек.док-та"",
		|			РасчетыПоИнвойсам.Инвойс,
		|			РасчетыПоИнвойсам.СуммаОстаток,
		|			0,
		|			0,
		|			NULL
		|		ИЗ
		|			РегистрНакопления.РасчетыПоИнвойсам.Остатки(, Контрагент = &Контрагент) КАК РасчетыПоИнвойсам) КАК Свод
		|	
		|	СГРУППИРОВАТЬ ПО
		|		Свод.Инвойс) КАК Взаиморасчеты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
		|		ПО Взаиморасчеты.Инвойс = СостоянияИнвойсов.Инвойс
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ОприходованиеНоменклатуры.Документ КАК Инвойс,
		|			СУММА(ОприходованиеНоменклатуры.КоличествоРасход) > 0 КАК ЕстьПриходТовара
		|		ИЗ
		|			РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Обороты(, &Дата, , ) КАК ОприходованиеНоменклатуры
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ОприходованиеНоменклатуры.Документ) КАК ПоступленияТоваров
		|		ПО Взаиморасчеты.Инвойс = ПоступленияТоваров.Инвойс";
	Выгрузка = Запрос.Выполнить().Выгрузить();
	Инвойсы.Загрузить(Выгрузка); 
	
	масИнвойсыДокумента = Параметры.ИнвойсыТЧ.Выгрузить().ВыгрузитьКолонку("Инвойс"); 
	Если масИнвойсыДокумента.ВГраница() > -1 Тогда
		НайдСтроки = Инвойсы.НайтиСтроки(Новый Структура("Инвойс", масИнвойсыДокумента[0])); 
		Если НайдСтроки.Количество() > 0 Тогда
			НайдСтрока = НайдСтроки[0];
			НайдСтрока.ОстатокДолга = НайдСтрока.ОстатокДолга - Параметры.СуммаКР;
		КонецЕсли;
	КонецЕсли;
	ВыбранныеИнвойсы.ЗагрузитьЗначения(масИнвойсыДокумента);
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()

	// ВыбранныеИнвойсы
	
	ЭлементОформления = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", Метаданные.ЭлементыСтиля.ЦветФонаСтрокиИсключаемойИзВыбора.Значение);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,, Истина)); 
	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Инвойсы.Инвойс"); 
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
	ЭлементОтбора.ПравоеЗначение = ВыбранныеИнвойсы;
	ЭлементОтбора.Использование  = Истина;
	ОформляемоеПоле = ЭлементОформления.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ИнвойсыИнвойс"); 
	ОформляемоеПоле.Использование = Истина;
	
	// Состояние (статусы)

	Запр = Новый Запрос; 
	Запр.Текст = "ВЫБРАТЬ
	             |	ЦветаОформления.Значение КАК Цвет,
	             |	ЦветаОформления.Настройка.ИмяПредопределенныхДанных КАК Статус
	             |ИЗ
	             |	РегистрСведений.ЦветаОформления КАК ЦветаОформления
	             |ГДЕ
	             |	ЦветаОформления.Настройка.Родитель = &ГруппаНастроек
	             |	И ЦветаОформления.Значение <> """"";
	Запр.УстановитьПараметр("ГруппаНастроек", ПланыВидовХарактеристик.ЦветаОформления.СтатусыПривязкиИнвойсов);
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	
		ЭлементОформления = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", гоЦветРГБ(Выборка.Цвет));
		ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("Инвойсы.Состояние");
		ЭлементОтбора.ВидСравнения  	= ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение 	= Перечисления.Долги[СтрЗаменить(Выборка.Статус,"Инв_","")];
		ЭлементОтбора.Использование 	= Истина;
		
		ОформляемоеПоле = ЭлементОформления.Поля.Элементы.Добавить();
		ОформляемоеПоле.Поле 			= Новый ПолеКомпоновкиДанных("ИнвойсыСостояние");
		ОформляемоеПоле.Использование 	= Истина;
	
	КонецЦикла;
	
КонецПроцедуры

