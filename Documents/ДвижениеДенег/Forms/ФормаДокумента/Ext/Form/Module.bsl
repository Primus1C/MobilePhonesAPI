&НаКлиенте
Процедура ПривязатьИнвойсыЗавершение(Рез, ДопПараметры) Экспорт
	Если НЕ ТипЗнч(Рез) = Тип("Массив") Тогда Возврат КонецЕсли; 
	// Получили данные:
	//		Привязано - в валюте инвойса
	//		ОстатокДолга - в валюте инвойса
	
	Для Каждого Эл Из Рез Цикл 
		НайдСтроки = Объект.Инвойсы.НайтиСтроки(Новый Структура("Инвойс", Эл.Инвойс)); 
		Если НайдСтроки.Количество() = 0 Тогда
			СтрокаТЧ = Объект.Инвойсы.Добавить();
			СтрокаТЧ.Инвойс = Эл.Инвойс;
		Иначе
			СтрокаТЧ = НайдСтроки[0];
		КонецЕсли;
		СтрокаТЧ.СуммаОплаты 				= Эл.Привязано;
		СтрокаТЧ.Сумма 						= Эл.Привязано * эл.Курс;
		СтрокаТЧ.Долг 						= Эл.ОстатокДолга; 
		СтрокаТЧ.НеПересчитыватьПриходТовара = Эл.НеПересчитыватьПриходТовара;
		//Если Эл.Сумма = Эл.Остаток Тогда
		//	СтрокаТЧ.Состояние = ПредопределенноеЗначение("Перечисление.Долги.НеЗакрыто");
		//ИначеЕсли СтрокаТЧ.Долг = 0 Тогда
		//	СтрокаТЧ.Состояние = ПредопределенноеЗначение("Перечисление.Долги.Полностью");
		//ИначеЕсли СтрокаТЧ.Долг > 0 Тогда
		//	СтрокаТЧ.Состояние = ПредопределенноеЗначение("Перечисление.Долги.Частично");
		//КонецЕсли;
		СтрокаТЧ.Состояние = РаботаСИнвойсами.СостояниеДолга(СтрокаТЧ.СуммаОплаты, гоРеквизит(СтрокаТЧ.Инвойс, "СуммаВВалютеИнвойса"));
		СтрокаТЧ.СтатусПроведения = ОбщегоНазначенияСервер.СтатусПроведения(СтрокаТЧ.Инвойс);
		
	КонецЦикла;
	
	Объект.СуммаПривязаноИнвойсов = Объект.Инвойсы.Итог("Сумма");
    МоиИтоги();
	Модифицированность = Истина;
	
КонецПроцедуры


