&НаКлиенте
Процедура УстановитьВидимостьДоступность(ОбработатьВидДД = Ложь)
	
	НетСтрок = Объект.Привязки.Количество() = 0;
	ЕстьСтроки = НЕ НетСтрок;
	
	Закрыто = Объект.Окончательно;	
	НеЗакрыто = НЕ Закрыто;
	
	//2015.11.20
	этоПоставщики 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Поставщики"));
	этоПокупатели 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Покупатели"));
	этоРасходы 					= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Расходы"));
	этоДоходы 					= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Доходы"));
	этоПеремещение 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Перемещение"));
	этоОбменВалюты 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.ОбменВалюты"));
	этоПодотчет 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Подотчет"));
	этоЗарплата 				= (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Зарплата")); 
	этоИнвестиции 				= Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Инвестиции");
	этоБиржа 					= Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Биржа");
	этоЛогистика 				= Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Логистика"); 
	этоПоставщикиПоИнвойсам 	= Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.Поставщики") И ВзаиморасчетыПоИнвойсам(Объект.Контрагент); 
	//этоПеремещениеСПартионнымУчетом = этоПеремещение 
	//									И омСервер.ПолучитьРеквизит(Объект.ДСчет,"ВестиПартионныйУчет") 
	//									И омСервер.ПолучитьРеквизит(Объект.СубДСчет,"ВестиПартионныйУчет") 
	//									И омСервер.ПолучитьРеквизит(Объект.Валюта,"ВестиПартионныйУчет");
	//2016.01.31
	этоВводОстатков = (Объект.ВидДвиженияДенег = гоПеречисление("ВидДвиженияДенег.ВводОстатков"));
	
	//2015.11.21
	Если ОбработатьВидДД Тогда
		//получается, что приход может бытть достаточно редко
		//2016.01.31 + ИЛИ этоВводОстатков
		Объект.ПриходРасход = ?(этоПокупатели ИЛИ этоДоходы ИЛИ этоВводОстатков ИЛИ этоИнвестиции ИЛИ ЭтоБиржа, 
								гоПеречисление("ПриходРасход.Приход"), 
								гоПеречисление("ПриходРасход.Расход"));
	КонецЕсли; 
	
	//2015.11.20
	//ну и так далее подобные ситуации
	Элементы.Статья.Видимость = этоРасходы ИЛИ этоДоходы ИЛИ этоБиржа ИЛИ этоЛогистика;
	Элементы.ГруппаСубДСчет.Видимость = этоПеремещение ИЛИ этоОбменВалюты;
	Элементы.ГруппаПривязки.Видимость = этоПоставщики ИЛИ этоПокупатели ИЛИ этоЛогистика;
	//2015.11.21
	Элементы.СубДВалюта.Видимость 				= этоОбменВалюты;
	Элементы.СубДКурс.Видимость 				= этоОбменВалюты; 
	УстановитьВидимостьКурсаОплатыИнвойсов();
	Элементы.СубДОбратный.Видимость 			= этоОбменВалюты;
	Элементы.СубДСумма.Видимость 				= этоОбменВалюты;
	//Элементы.РассчитыватьСреднийКурс.Видимость 	= этоОбменВалюты ИЛИ этоПеремещениеСПартионнымУчетом;
	Элементы.РассчитыватьСреднийКурс.Видимость 	= этоОбменВалюты;
	Элементы.Сотрудник.Видимость 				= этоПодотчет ИЛИ этоЗарплата;
	Элементы.МесяцЗП.Видимость 					= этоЗарплата;
	//2015.11.22
	Элементы.ГруппаКонтрагент.Видимость 	= этоПоставщики ИЛИ этоПокупатели ИЛИ этоДоходы ИЛИ этоРасходы ИЛИ этоИнвестиции;  
	//2015.11.23
	Элементы.ГрИтогиОстатки.Видимость 		= этоПоставщики ИЛИ этоПокупатели;
	
	Элементы.ГруппаЛогистика.Видимость 		= этоЛогистика;
	
	//2015.12.08
	Если НЕ гоМенеджер() Тогда  
		//Элементы.ФормаОтчетОборотыПодотчетаОборотыЛица.Видимость = этоПодотчет ИЛИ этоЗарплата;   
		//Если Элементы.Найти("ФормаОтчетОборотыЗарплатыОборотыСотрудника") <> Неопределено Тогда
		//	Элементы.ФормаОтчетОборотыЗарплатыОборотыСотрудника.Видимость = этоПодотчет ИЛИ этоЗарплата;
		//КонецЕсли;
	КонецЕсли; 
	Элементы.ФормаОтчетДолгиДолги.Видимость = этоПоставщики ИЛИ этоПокупатели ИЛИ этоДоходы ИЛИ этоРасходы;
	
	//2015.11.20
	//наоброт, привязывать можно только когда проведено
	Элементы.ПривязкиПривязать.Доступность = Закрыто;
	Элементы.ПривязкиОчиститьПривязки.Доступность = Закрыто;
	
	//2015.12.08 попробуем только по закрыто
	Элементы.Дата.ТолькоПросмотр = Закрыто;		//Объект.Проведен ИЛИ 
	
	Элементы.Сумма.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Валюта.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Контрагент.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	
	//2015.11.21
	//получается, что никогда не нужно будет это задавать, все происходит автоматические
	Элементы.ПриходРасход.ТолькоПросмотр = Истина;	//ЕстьСтроки ИЛИ Закрыто;
	Элементы.ВидДвиженияДенег.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	
	//2015.11.21
	Элементы.Статья.ТолькоПросмотр 		= Закрыто;
	Элементы.Сотрудник.ТолькоПросмотр 	= Закрыто;
	Элементы.МесяцЗП.ТолькоПросмотр 	= Закрыто;
	Элементы.СубДСчет.ТолькоПросмотр 	= Закрыто;
	Элементы.СубДВалюта.ТолькоПросмотр 	= Закрыто;
	Элементы.СубДКурс.ТолькоПросмотр 	= Закрыто;  
	Элементы.РассчитыватьСреднийКурс.ТолькоПросмотр = Закрыто;
	//Элементы.СубДОбратный.ТолькоПросмотр = Закрыто;
	//2015.11.22 а это зачем открывать, пусть сумму ровняют курсом
	//Элементы.СубДСумма.ТолькоПросмотр = Закрыто;
	
	Элементы.Установить.Доступность = НеЗакрыто;
	Элементы.Снять.Доступность = Закрыто;      
	
	// © Primus1C  08.11.2023  НАЧАЛО ►
	Элементы.ГруппаКР.Видимость 				= этоОбменВалюты ИЛИ этоПоставщикиПоИнвойсам;
	//Элементы.СуммаКР.ТолькоПросмотр				= НЕ этоПоставщикиПоИнвойсам;
	Элементы.ПроцентИнвестиций.Видимость 		= этоИнвестиции;    
	Элементы.ГруппаНакладные.Видимость 			= НЕ этоЛогистика; 
	Элементы.ГруппаИнвойсы.Видимость 			= этоЛогистика ИЛИ этоПоставщикиПоИнвойсам; 
	Элементы.Затрата.Видимость 					= этоЛогистика;
	Элементы.ГруппаЛогистика.ТолькоПросмотр 	= Закрыто; 
	Элементы.Инвойсы.ТолькоПросмотр 			= Закрыто; 
	Элементы.Затрата.ТолькоПросмотр 			= Закрыто;
	
	Элементы.ГруппаОплатаИнвойсов.ТолькоПросмотр= Закрыто;
	Элементы.ГруппаСреднийКурс.Видимость 		= этоПоставщикиПоИнвойсам 
													И омСервер.ПолучитьРеквизит(Объект.Валюта,"ВестиПартионныйУчет")
													И омСервер.ПолучитьРеквизит(Объект.ДСчет,"ВестиПартионныйУчет");
	Элементы.ИнвойсыДолг.Видимость 				= этоПоставщикиПоИнвойсам;
	Элементы.ИнвойсыСостояние.Видимость 		= этоПоставщикиПоИнвойсам; 
	Элементы.ИнвойсыГруппаПривязка.Видимость	= этоПоставщикиПоИнвойсам;
	
	Если омСервер.ЕстьРоль("Разработка") Тогда
		Элементы.ИнвойсыСумма.ТолькоПросмотр = Ложь; 
		Элементы.ИнвойсыСумма.Доступность = Истина;
		Элементы.ИнвойсыСуммаОплаты.ТолькоПросмотр = Ложь;
		Элементы.ИнвойсыСуммаОплаты.Доступность = Истина;
		Элементы.ИнвойсыСумма.ТолькоПросмотр = Ложь;
		Элементы.ИнвойсыСумма.Доступность = Истина;
	КонецЕсли;                         
	
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

