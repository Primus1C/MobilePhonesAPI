&НаКлиенте
Процедура ОтобразитьИконкуПартионногоУчета(СчетСсылка, Декорация)
	
	лПартУчет = ВестиПартионныйУчет(СчетСсылка);
	Если лПартУчет.ВестиПартионныйУчет Тогда
		Декорация.Видимость = Истина;	
	    Декорация.Подсказка = "Партионный учет ведется";
		Если лПартУчет.Дата <> Дата(1,1,1) Тогда
			Декорация.Подсказка = Декорация.Подсказка + " с " + Формат(лПартУчет.Дата, "ДФ=dd.MM.yyyy");
		КонецЕсли;
	Иначе
		Декорация.Видимость = Ложь;	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ВестиПартионныйУчет(Счет)
	
	Если ЗначениеЗаполнено(Счет) Тогда
		Если Счет.ВестиПартионныйУчет Тогда
			Если Счет.НачалоПартионногоУчета <= Объект.Дата Тогда
				Возврат Новый Структура("ВестиПартионныйУчет, Дата", Истина, Счет.НачалоПартионногоУчета);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	     
	Возврат Новый Структура("ВестиПартионныйУчет", Ложь);

КонецФункции	
	
&НаКлиенте
Процедура ПересчитатьСуммуСКонтролемКурса(ПоКурсуПользователя = Ложь)
	
	ТекстОшибки = "";
	ПересчитатьСумму(ПоКурсуПользователя, ТекстОшибки);	
	Если ТекстОшибки <> "" Тогда
		Сооб = Новый СообщениеПользователю;		
	    Сооб.Поле = "Объект.СуммаКР";
		Сооб.Текст = ТекстОшибки;
		Сооб.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗаголовокЗакладкиИнвойсы()

	Если этоПоставщикиПоИнвойсам Тогда
		Если Объект.Инвойсы.Количество() = 0 Тогда
			Элементы.ГруппаИнвойсы.Заголовок = "Инвойсы (требуется заполнить)";
			Элементы.ГруппаИнвойсы.Картинка = БиблиотекаКартинок.ВниманиеКрасный;
		Иначе
			Элементы.ГруппаИнвойсы.Заголовок = "Инвойсы";
			Элементы.ГруппаИнвойсы.Картинка = Новый Картинка;
		КонецЕсли;		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РаспределитьЗатраты()
	
	Если ЭтоЛогистика Тогда
		ТЧ = Объект.Инвойсы;
		Если ТЧ.Количество() > 0 Тогда
			Для каждого СтрокаТЧ Из ТЧ Цикл
				СтрокаТЧ.Сумма = Объект.Сумма / ТЧ.Количество();
			КонецЦикла;	 
			Ост = Объект.Сумма - ТЧ.Итог("Сумма");
			Если Ост <> 0 Тогда
				ТЧ[ТЧ.Количество()-1].Сумма = ТЧ[ТЧ.Количество()-1].Сумма + Ост;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	УстановитьЗаголовокЗакладкиИнвойсы();

КонецПроцедуры

