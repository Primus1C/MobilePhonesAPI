&НаКлиенте
Процедура ОтобразитьДолгиИнвойсов()
	
	Если этоПоставщики И гоРеквизит(Объект.Контрагент, "ПривязыватьИнвойсы") Тогда  
		Долги = ОбщегоНазначенияСервер.ДолгиПоставщикуПоИнвойсам(Объект.Контрагент, Объект.Дата);
		
		Долг = "";
		Для каждого эл Из Долги.ПоВалютам Цикл  
			Если Эл.Сумма <> 0 Тогда
				Долг = Долг + Формат(эл.Сумма, "ЧДЦ=2") + " " + эл.Валюта + " ";
			КонецЕсли;
		КонецЦикла;
		Если Долг = "" Тогда
			Долг = НСтр("ru = 'Долг по инвойсам: 0.00'; en = 'Долг по инвойсам: 0.00'")
		Иначе
			Долг = НСтр("ru = 'Долг по инвойсам: '; en = 'Долг по инвойсам: '") + Долг;
		КонецЕсли;
		
        Для каждого эл Из Долги.ПоИнвойсам Цикл
			НайдСтроки = Объект.Инвойсы.НайтиСтроки(Новый Структура("Инвойс",эл.Инвойс)); 
			Если НайдСтроки.Количество() > 0 Тогда
				НайдСтроки[0].Долг = эл.Сумма; 
				НайдСтроки[0].Состояние = эл.СтатусОплатыАвто;
			КонецЕсли;
		КонецЦикла;   
		
		Элементы.Долг.Видимость = Истина;	
	ИначеЕсли этоПокупатели Тогда	
		Элементы.Долг.Видимость = Ложь;	
	Иначе
		Элементы.Долг.Видимость = Ложь;	
	КонецЕсли;
	
	
	
	
	//ДолгиИнвойсов = ДолгиИнвойсов();	

КонецПроцедуры

