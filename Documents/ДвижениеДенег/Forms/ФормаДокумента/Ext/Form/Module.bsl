&НаКлиенте
Процедура Установить(Команда)
	Если Объект.Окончательно Тогда Возврат КонецЕсли;
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	
	//2015.11.22 
	//Отказ = "";
	Если Объект.Сумма = 0 И НЕ ЭтоВВодОстатков Тогда клОшибка("Не введена сумма!"); Возврат; КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.Валюта) Тогда клОшибка("Не выбрана валюта!"); Возврат; КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ВидДвиженияДенег) Тогда клОшибка("Не выбран вид операции!"); Возврат; КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.ПриходРасход) Тогда клОшибка("Не выбран тип операции!"); Возврат; КонецЕсли;
	
	Если этоПокупатели Тогда
		Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда клОшибка("Не заполнен покупатель!"); Возврат; КонецЕсли;
	ИначеЕсли этоПоставщики Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда клОшибка("Не заполнен поставщик!"); Возврат; КонецЕсли;
	ИначеЕсли этоПеремещение Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.СубДСчет) Тогда клОшибка("Не заполнена касса КУДА!"); Возврат; КонецЕсли;
	ИначеЕсли этоОбменВалюты Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.СубДСчет) Тогда клОшибка("Не заполнена касса КУДА!"); Возврат; КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.СубДВалюта) Тогда клОшибка("Не заполнено В КАКУЮ валюту!"); Возврат; КонецЕсли;
		Если Объект.СубДСумма = 0 Тогда клОшибка("Не посчитана сумма обмена!"); Возврат; КонецЕсли;
	ИначеЕсли этоРасходы Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.Статья) Тогда клОшибка("Не заполнена статья расходов!"); Возврат; КонецЕсли;
		Если гоРеквизит(Объект.Статья, "ВидСтатьи") <> гоПеречисление("ДоходРасход.Расход") Тогда клОшибка("Это не статья расходов!"); Возврат; КонецЕсли;
	ИначеЕсли этоДоходы Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.Статья) Тогда клОшибка("Не заполнена статья доходов!"); Возврат; КонецЕсли;
		Если гоРеквизит(Объект.Статья, "ВидСтатьи") <> гоПеречисление("ДоходРасход.Доход") Тогда клОшибка("Это не статья доходов!"); Возврат; КонецЕсли;
	ИначеЕсли этоПодотчет Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.Сотрудник) Тогда клОшибка("Не заполнен сотрудник (подотчетное лицо)!"); Возврат; КонецЕсли;
	ИначеЕсли этоЗарплата Тогда  
		Если НЕ ЗначениеЗаполнено(Объект.Сотрудник) Тогда клОшибка("Не заполнен сотрудник!"); Возврат; КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.МесяцЗП) Тогда клОшибка("Не заполнен месяц начисления зарплаты!"); Возврат; КонецЕсли;
	//2016.01.31	
	ИначеЕсли этоВводОстатков Тогда  
		
	КонецЕсли; 
	
	//Если клНетДа(НСтр("ru = 'Установить флаг <Окончательно>?'; en = 'Set flag <Finaly>?'")) Тогда Возврат КонецЕсли;
	//
	//Объект.Окончательно = Истина;
	//МояЗаписать(Ложь);
	//
	//Если Объект.ВидДвиженияДенег = ПредопределенноеЗначение("Перечисление.ВидДвиженияДенег.ОбменВалюты") Тогда
	//	доп = СтрШаблон(", в %1 %2, курс %3, КР %4",
	//	               Формат(Объект.СубДСумма,"ЧДЦ=2"),
	//				   Объект.СубДВалюта,
	//                   Объект.СубдКурс,
	//				   Формат(Объект.СуммаКР,"ЧДЦ=2"));
	//Иначе
	//	доп = "";	
	//КонецЕсли;
	//гоЗаписьЖурналаРегистрации(СтрШаблон("Установили (%1, сумма %2 %3%4, (%5))", 
	//									Объект.ВидДвиженияДенег, 
	//									Формат(Объект.Сумма,"ЧДЦ=2"), 
	//									Объект.Валюта,
	//									доп,
	//									СокрЛП(Объект.Корреспонденция)),
	//							ИмяДокумента, 
	//							"Установка {Окончательно}", 
	//							Объект.Ссылка, 2);
	клНетДа(Новый ОписаниеОповещения("УстановитьПослеПодтверждения", ЭтотОбъект), НСтр("ru = 'Установить флаг <Окончательно>?'; en = 'Set flag <Finaly>?'"));
КонецПроцедуры
 
&НаКлиенте
Процедура УстановитьПослеПодтверждения(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Объект.Окончательно = Истина;
	МояЗаписать(Ложь);
	
	Если Объект.ВидДвиженияДенег = ПредопределенноеЗначение("Перечисление.ВидДвиженияДенег.ОбменВалюты") Тогда
		доп = СтрШаблон(", в %1 %2, курс %3, КР %4",
		               Формат(Объект.СубДСумма,"ЧДЦ=2"),
					   Объект.СубДВалюта,
	                   Объект.СубдКурс,
					   Формат(Объект.СуммаКР,"ЧДЦ=2"));
	Иначе
		доп = "";	
	КонецЕсли;
	гоЗаписьЖурналаРегистрации(СтрШаблон("Установили (%1, сумма %2 %3%4, (%5))", 
										Объект.ВидДвиженияДенег, 
										Формат(Объект.Сумма,"ЧДЦ=2"), 
										Объект.Валюта,
										доп,
										СокрЛП(Объект.Корреспонденция)),
								ИмяДокумента, 
								"Установка {Окончательно}", 
								Объект.Ссылка, 2);
КонецПроцедуры

