Процедура СредневзвешКурсНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ФормаОтчета = ПолучитьФорму("Отчет.СреднийКурс.Форма");
	
	ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Дата", Объект.Дата);
	ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Валюта", Объект.Валюта);
	
	//ФормаОтчета.Элементы.ФормаВарианты.Видимость = Ложь;
	ФормаОтчета.Открыть();
	ФормаОтчета.СкомпоноватьРезультат();  

КонецПроцедуры



