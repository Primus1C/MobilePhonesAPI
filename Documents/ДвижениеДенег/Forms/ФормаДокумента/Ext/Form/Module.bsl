	//Если НЕ ПоКурсуПользователя Тогда
	//	Объект.СубДКурс =	новСубДКурс;
	//КонецЕсли;
	//
	//
	//Возврат;
	
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	
	Если (Объект.СубДКурс = 0) ИЛИ (Объект.СубДКурс = 1) Тогда
		Кур1 = омСервер.Курс(Объект.Валюта, 	Объект.Фирма, Объект.Дата);
		Кур2 = омСервер.Курс(Объект.СубДВалюта, Объект.Фирма, Объект.Дата);
		
		Если Кур1 = 1 Тогда
			Объект.СубДКурс = Кур2;
			Объект.СубДОбратный = 0;
		ИначеЕсли Кур2 = 1 Тогда
			Объект.СубДКурс = Кур1;
			Объект.СубДОбратный = 1;
		Иначе
			Если Кур1 < Кур2 Тогда
