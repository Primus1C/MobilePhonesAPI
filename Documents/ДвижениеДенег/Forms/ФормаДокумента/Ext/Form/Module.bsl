	Если Объект.Валюта = Объект.СубДВалюта Тогда
		лКурс = 1;	  
		
	ИначеЕсли Объект.Валюта	= БазоваяВалютаФирмы Тогда 
		лКурс = омСервер.Курс(Объект.СубДВалюта, Объект.Фирма, Объект.Дата); 
		Объект.СубДОбратный = Истина;   
		
	ИначеЕсли Объект.СубДВалюта	= БазоваяВалютаФирмы Тогда
		лКурс = омСервер.Курс(Объект.Валюта, Объект.Фирма, Объект.Дата); 
		Объект.СубДОбратный = Ложь;   

	ИначеЕсли Объект.СубДВалюта.БазоваяВалюта = Объект.Валюта Тогда // пересчет в базовую валюту
		лКурс = омСервер.Курс(Объект.СубДВалюта, Объект.Фирма, Объект.Дата); 
		Объект.СубДОбратный = НЕ Объект.СубДВалюта.ОбратныйКурс;     
		
	ИначеЕсли Объект.Валюта.БазоваяВалюта = Объект.СубДВалюта Тогда //
		лКурс = омСервер.Курс(Объект.Валюта, Объект.Фирма, Объект.Дата);
		Объект.СубДОбратный = Объект.Валюта.ОбратныйКурс; 
		
	Иначе // кросс-курс
		Кур1 = омСервер.Курс(Объект.Валюта, 	Объект.Фирма, Объект.Дата);
		Кур2 = омСервер.Курс(Объект.СубДВалюта, Объект.Фирма, Объект.Дата);
		Если Кур1 < Кур2 Тогда
			лКурс = Окр(Кур2 / Кур1, 5);
			Объект.СубДОбратный = Ложь;
		Иначе
			лКурс = Окр(Кур1 / Кур2, 5);
			Объект.СубДОбратный = Истина;
		КонецЕсли;    
			
			
	КонецЕсли;    
	
	лКурсЭталон = лКурс;
	Если ПоКурсуПользователя Тогда 
		лКурс = Объект.СубДКурс; 
	Иначе	
		Объект.СубДКурс = лКурс;
	КонецЕсли;
	
	Если Объект.СубДОбратный Тогда
		Объект.СубДСумма = Окр(Объект.Сумма / лКурс, 2);
		СуммаЭталон = Окр(Объект.СубДСумма * лКурсЭталон, 2);
	Иначе
		Объект.СубДСумма = Окр(Объект.Сумма * лКурс, 2);
		СуммаЭталон = Окр(Объект.СубДСумма / лКурсЭталон, 2);
	КонецЕсли;
	
	Объект.СуммаКР = СуммаЭталон - Объект.Сумма;

    ВОЗВРАТ;
	
	
	
	
	//Кур1 = омСервер.Курс(Объект.Валюта, 	Объект.Фирма, Объект.Дата);
	//Кур2 = омСервер.Курс(Объект.СубДВалюта, Объект.Фирма, Объект.Дата);
	//
