	//
	//Объект.Окончательно = Ложь;
	//МояЗаписать(Ложь);
	//
	//гоЗаписьЖурналаРегистрации("Сняли", ИмяДокумента, "Снятие {Окончательно}", Объект.Ссылка, 2);
	клНетДа(Новый ОписаниеОповещения("СнятьПослеПодтверждения", ЭтотОбъект), "Снять флаг <Окончательно>?");

