	//		Объект.СубДОбратный = Ложь;
	//		новСубДКурс 		= Кур2;
	//		Объект.СубДСумма 	= Окр(Объект.Сумма * Кур2, 2);
	//	Иначе
	//		Объект.СубДОбратный = Истина; 
	//		новСубДКурс 		= Кур1;
	//		Объект.СубДСумма 	= Окр(Объект.Сумма * Кур1, 2);
	//	КонецЕсли;
	//ИначеЕсли Объект.Валюта.БазоваяВалюта = Объект.СубДВалюта Тогда
	//	Если Объект.Валюта.ОбратныйКурс Тогда
	//		Объект.СубДОбратный = Истина;
	//		новСубДКурс 		= Кур1;
	//		Объект.СубДСумма 	= Окр(Объект.Сумма / Кур1, 2);
	//	Иначе
	//		Объект.СубДОбратный = Ложь; 
	//		новСубДКурс 		= Кур2;
	//		Объект.СубДСумма 	= Окр(Объект.Сумма / Кур2, 2);
	//	КонецЕсли;
	//Иначе
	//	Сообщить(СтрШаблон("В обмене должна присутствовать валюта %1 или %2!", ВалютаДол, ВалютаРуб));
	//	Возврат;
	//КонецЕсли; 
