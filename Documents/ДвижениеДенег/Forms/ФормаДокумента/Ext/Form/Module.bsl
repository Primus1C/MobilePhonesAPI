&НаКлиенте
Процедура УстановитьВидимостьКурсаОплатыИнвойсов()

	Если этоПоставщикиПоИнвойсам И ЗначениеЗаполнено(Объект.Валюта) Тогда 
		масВалют = ДругиеВалютыИвойсовКонтрагента(); 
		Если масВалют.Количество() = 0 Тогда
			Элементы.ГруппаОплатаИнвойсов.Видимость = Ложь; 
		Иначе
			Элементы.ГруппаОплатаИнвойсов.Видимость = Истина;
			лВалюты = омСервер.Фрмт(СтрШаблон("%1 / %2", Объект.СубДВалюта, Объект.Валюта), "НАДПИСЬ_ЦВ2");   
			//+
			ЕстьВалютаВИнвойсах = Ложь;
			Для каждого СтрокаТЧ Из Объект.Инвойсы Цикл
			    Если РаботаСИнвойсами.ВалютаИнвойса(СтрокаТЧ.Инвойс) = Объект.Валюта Тогда
					ЕстьВалютаВИнвойсах = Истина; Прервать;
				КонецЕсли;
			КонецЦикла; 
			Если ЕстьВалютаВИнвойсах Тогда
				лВалюты = лВалюты + омСервер.Фрмт(" (курс не используется в привязках инвойсов)", "НАДПИСЬ_ЦВ3");
			КонецЕсли;
			//-
			Элементы.ДекорацияВалютаИнвойсов.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(лВалюты));
		КонецЕсли; 
	ИначеЕсли этоВводОстатков И гоРеквизит(Объект.Валюта, "ВестиПартионныйУчет") Тогда
		лВалюты = омСервер.Фрмт(СтрШаблон("%1 / %2", Объект.Валюта, ВалютаДол), "НАДПИСЬ_ЦВ2"); 
		Элементы.ДекорацияВалютаИнвойсов.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(лВалюты));
		Элементы.ГруппаОплатаИнвойсов.Видимость = Истина;
	Иначе	
		Элементы.ГруппаОплатаИнвойсов.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ИнвойсыСуммаОплаты.Заголовок = СтрШаблон("Сумма (%1)", гоРеквизит(Объект.Валюта, "Символ"));

КонецПроцедуры

&НаСервере
// Возвращает массив валют из инвойсов закупки контрагента, отличающиеся от валюты текущего док-та
//
Функция ДругиеВалютыИвойсовКонтрагента()

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запр.УстановитьПараметр("Валюта", Объект.Валюта);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ИнвойсЗакупки.Валюта КАК Валюта
	             |ИЗ
	             |	Документ.ИнвойсЗакупки КАК ИнвойсЗакупки
	             |ГДЕ
	             |	ИнвойсЗакупки.Проведен
	             |	И ИнвойсЗакупки.Контрагент = &Контрагент
	             |	И ИнвойсЗакупки.Валюта <> &Валюта";  
	Возврат Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);

КонецФункции 

