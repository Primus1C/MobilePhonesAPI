&НаСервере
Процедура РассчитатьСредневзвешенныйКурс()

	Если Объект.Валюта.ВестиПартионныйУчет 
		И Объект.ДСчет.ВестиПартионныйУчет И Объект.Дата >= Объект.ДСчет.НачалоПартионногоУчета
		И Объект.ВидДвиженияДенег = Перечисления.ВидДвиженияДенег.Поставщики Тогда
		
	  	СрКурс = РаботаСВалютой.СредневзвешенныйКурс(Объект.Валюта, Объект.ДСчет, ?(ЗначениеЗаполнено(Объект.Ссылка), Объект.Ссылка.МоментВремени(), Объект.Дата));

	Иначе                   
		
		СрКурс = 0;

	КонецЕсли;
	
	СредневзвешКурс = СтрШаблон("%1 %2 / %3", Формат(СрКурс,"ЧДЦ=5"), Объект.Валюта.Код, Объект.Валюта.БазоваяВалюта.Код); 

	ФмтСреднийКурс = СтрШаблон("%1 %2 %3 / %4 %5",
							омСервер.Фрмт("Средн.курс:", "НАДПИСЬ_ЦВ2"),
							?(СрКурс = 0, омСервер.Фрмт("не введен", "КРАСНЫЙ_ТЕКСТ"), ""),
							омСервер.Фрмт(Объект.Валюта.Код, "НАДПИСЬ_ЦВ2"),
							омСервер.Фрмт(Объект.Валюта.БазоваяВалюта.Код, "НАДПИСЬ_ЦВ2"), 
							?(СрКурс = 0, омСервер.Фрмт("НЕ ВВЕДЕН", "КРАСНЫЙ_ТЕКСТ"), ""),
							);
	Элементы.ДекорацияСредневзвешКурс.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(ФмтСреднийКурс)); 
	
КонецПроцедуры

