	ЭтаФорма.ОтчетКурсыРезультатОтчета.Очистить();
	
	// Вызываем стандартный метод формирования отчета.
	// Так как реквизит формы имеет тип "ОтчетОбъект", 
	// у него есть доступ ко всем процедурам модуля объекта отчета.
	
	ОтчетОбъект = РеквизитФормыВЗначение("ОтчетКурсы");
	
	////////	ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Дата", Объект.Дата);
	////////ОбщегоНазначенияКлиент.УстановитьПараметрВФормеОтчета(ФормаОтчета, "Валюта", Объект.Валюта);

	// Если у вас переопределена ПриКомпоновкеРезультата, 
	// вызываем её вручную или через стандартный механизм:
	ОтчетОбъект.СкомпоноватьРезультат(ЭтаФорма.ОтчетКурсыРезультатОтчета, ЭтаФорма.ОтчетКурсы.ДанныеРасшифровки);
	
	// Если нужно сохранить данные расшифровки для работы двойного клика:
	ПоместитьВоВременноеХранилище(ЭтаФорма.ОтчетКурсы.ДанныеРасшифровки, ЭтаФорма.ДанныеРасшифровки);
	
КонецПроцедуры

