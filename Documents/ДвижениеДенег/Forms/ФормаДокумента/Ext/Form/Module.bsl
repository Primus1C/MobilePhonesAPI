&НаКлиенте
Процедура Привязать(Команда)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли;
	Если гоПЗ(Объект.Контрагент) Тогда Возврат КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда Возврат КонецЕсли; 
	
	локСумма = Объект.Сумма;
	Если локСумма = 0 Тогда Возврат КонецЕсли; 
	
	МояЗаписать(Ложь);
	
	Если НЕ Объект.Проведен Тогда клОшибка("Документ не проведен!"); Возврат; КонецЕсли; 
	
	Пар = Новый Структура("Док, Привязки, ТолькоПривязки", Объект.Ссылка, Объект.Привязки, 0);
	
	ОткрытьФорму("Обработка.ПривязкаДолгов.Форма.Форма", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("ПривязатьЗавершение", ЭтотОбъект));
КонецПроцедуры

&НаКлиенте
Процедура ПривязатьЗавершение(Рез, ДопПараметры) Экспорт
	Если Рез = Неопределено Тогда Возврат КонецЕсли; 
	
	//2015.11.27
	СохМасПривязки = клПривязкиВМассив(Объект);
	
	ЗаполнитьПривязки(Рез.ПривязкиСтрока);
	
	МояЗаписать(Ложь);
	
	//2015.11.27
	клОповеститьПривязки(Объект, СохМасПривязки);
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПривязки(Команда)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли;
	Если гоПЗ(Объект.Контрагент) Тогда Возврат КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда Возврат КонецЕсли; 
	Если Объект.Сумма = 0 Тогда Возврат КонецЕсли; 
	
	Если Объект.Привязки.Количество() = 0 Тогда Возврат КонецЕсли; 
	
	МояЗаписать(Ложь);
	
	Если НЕ Объект.Проведен Тогда клОшибка("Документ не проведен!"); Возврат; КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("ОчиститьПривязкиЗавершение", ЭтотОбъект), "Очистить все привязки (удалить строки)?", , Истина);
КонецПроцедуры

