			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Докум.Ссылка КАК Ссылка,
	Докум.ПометкаУдаления КАК ПометкаУдаления,
	Докум.Номер КАК Номер,
	Докум.Дата КАК Дата,
	Докум.Проведен КАК Проведен,
	Докум.Контрагент КАК Контрагент,
	Докум.Сумма КАК Сумма,
	Докум.ДСчет КАК ДСчет,
	Докум.ПриходРасход КАК ПриходРасход,
	Докум.Валюта КАК Валюта,
	Докум.Строк КАК Строк,
	Докум.СуммаПривязано КАК СуммаПривязано,
	Докум.ВидДвиженияДенег КАК ВидДвиженияДенег,
	Докум.КемСоздан КАК КемСоздан,
	Докум.Создан КАК Создан,
	Докум.КемСохранен КАК КемСохранен,
	Докум.Сохранен КАК Сохранен,
	Докум.Фирма КАК Фирма,
	Докум.СубДСчет КАК СубДСчет,
	Докум.Статья КАК Статья,
	Докум.Примечание КАК Примечание,
	ВЫБОР
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.ОбменВалюты)
			ТОГДА Докум.СубДКурс
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.ВводОстатков)
			ТОГДА Докум.СубДКурс
		ИНАЧЕ 0
	КОНЕЦ КАК Курс,
	ВЫБОР
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Логистика)
			ТОГДА Докум.Статья
		ИНАЧЕ Докум.Корреспонденция
	КОНЕЦ КАК Корреспонденция,
	Докум.Окончательно КАК Окончательно,
	//Докум.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Покупатели)
			ТОГДА ЕСТЬNULL(Рег.ПредоплатаПокупателяОстаток, 0)
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Поставщики)
			ТОГДА ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК Предоплата,
	ВЫБОР
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Покупатели)
			ТОГДА ВЫБОР
					КОГДА Докум.Окончательно
							И Докум.Сумма &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ПредоплатаПокупателяОстаток, 0) &lt;&gt; 0
									ТОГДА ВЫБОР
											КОГДА ЕСТЬNULL(Рег.ПредоплатаПокупателяОстаток, 0) &lt;&gt; Докум.Сумма
												ТОГДА ЗНАЧЕНИЕ(Перечисление.Предоплаты.Частично)
											ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Неоплачено)
										КОНЕЦ
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Полностью)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.НеЗакрыто)
				КОНЕЦ
		КОГДА Докум.ВидДвиженияДенег = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенег.Поставщики)
			ТОГДА ВЫБОР
					КОГДА Докум.Окончательно
							И Докум.Сумма &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) &lt;&gt; 0
									ТОГДА ВЫБОР
											КОГДА ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) &lt;&gt; Докум.Сумма
												ТОГДА ЗНАЧЕНИЕ(Перечисление.Предоплаты.Частично)
											ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Неоплачено)
										КОНЕЦ
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Полностью)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.НеЗакрыто)
				КОНЕЦ
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Пусто)
	КОНЕЦ КАК Состояние
ИЗ
	Документ.ДвижениеДенег КАК Докум
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки КАК Рег
		ПО Докум.Ссылка = Рег.Док</QueryText>
