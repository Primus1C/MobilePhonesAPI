&НаКлиенте
Процедура ОбновитьОстатки(Команда)
	
	Если СпиКас.Количество() <> 0 И СпиКас.НайтиПоЗначению(ФильтрДСчет) = Неопределено Тогда 
		ОстаткиПоСчету = "?";
		Элементы.ДекорацияОстаткиПоСчету.Заголовок = "?";
	Иначе		
		СтруктураОстатков = СтруктураОстатков(ФильтрДСчет); 
		ОстаткиПоСчету = СтруктураОстатков.Строка;
		Элементы.ДекорацияОстаткиПоСчету.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураОстатков.ФмтСтрока)); 
	КонецЕсли;  
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктураОстатков(Касса) 
	
	Если гоПЗ(Касса) Тогда 
		Результат = "?"; 
		ФмтРезультат = "?"; 
	Иначе	
		Результат = ""; 
		ФмтРезультат = ""; 
		Фильтр = Новый Структура("Фирма,Касса", Касса.Владелец, Касса);
		Табл = РегистрыНакопления.Деньги.Остатки(, Фильтр, "Валюта", "Остаток");
		Если Табл.Количество() > 0 Тогда 
			Для Каждого стрТабл Из Табл Цикл  
				Граница = Последовательности.ПартииВалют.ПолучитьГраницу(Новый Структура("Касса,Валюта", Касса, стрТабл.Валюта));		
				Если ЗначениеЗаполнено(Граница) Тогда
					СтрГраница = " (" + Граница.Дата + ")";
				Иначе	
					СтрГраница = "";
				КонецЕсли;
				гоРезСоо(Результат, гоСуммаЗнВал(стрТабл.Остаток, стрТабл.Валюта, 2) + СтрГраница, ",   ");  
				ФмтРезультат = СтрШаблон("%1%2 %3%4",
							?(ЗначениеЗаполнено(ФмтРезультат), ФмтРезультат + ",&#160;", ФмтРезультат),
							омСервер.Фрмт(стрТабл.Остаток, "ЧИСЛО_ЦВ2"), 
							омСервер.Фрмт(стрТабл.Валюта, "НАДПИСЬ_ЦВ2"),
							омСервер.Фрмт(?(ЗначениеЗаполнено(Граница), СтрШаблон(" (%1)", Формат(Граница.Дата,"ДЛФ=D")) ,""), "НАДПИСЬ_ЦВ1")
							);

			КонецЦикла; 
		КонецЕсли;  
	КонецЕсли; 
	
	Возврат Новый Структура("Строка,ФмтСтрока", Результат, ФмтРезультат);    
	
КонецФункции


#Область ОтчетПартииВалют

&НаКлиенте
Процедура ОтчетПартииВалюты(Команда)

	// 1. Указываем имя отчета 
    ИмяОтчета = "Отчет.ПартииВалют";
    
    // 2. Получаем схему компоновки данных отчета (чтобы знать структуру настроек)
    // Делаем это через серверный вызов, так как Схема доступна только на сервере
    НастройкиСКД = ПолучитьНастройкиПоУмолчанию(ИмяОтчета);
    
    // 3. Формируем пользовательские настройки (именно они видны на форме отчета)
    ПользовательскиеНастройки = НастройкиСКД.ПользовательскиеНастройки;
    
 	// --- ЗАПОЛНЯЕМ ПАРАМЕТРЫ (Даты, Периоды, Флажки из запроса) ---
    УстановитьЗначениеПараметраСКД(НастройкиСКД.Настройки, ПользовательскиеНастройки, "Валюта", Элементы.Список.ТекущиеДанные.Валюта);
    УстановитьЗначениеПараметраСКД(НастройкиСКД.Настройки, ПользовательскиеНастройки, "Касса", ФильтрДСчет);
	
	//// 4. Устанавливаем нужный отбор (например, по Контрагенту)
	//// ИмяПоля должно точно совпадать с именем поля в запросе СКД
	//УстановитьЗначениеОтбора(НастройкиСКД.Настройки, ПользовательскиеНастройки, "Валюта", Элементы.Список.ТекущиеДанные.Валюта);
	//УстановитьЗначениеОтбора(НастройкиСКД.Настройки, ПользовательскиеНастройки, "Касса", ФильтрДСчет);
    
    // 5. Упаковываем настройки в параметры открытия формы
    ПараметрыОткрытия = Новый Структура;
    ПараметрыОткрытия.Вставить("ПользовательскиеНастройки", ПользовательскиеНастройки);
    
    // ВАЖНО: Ключ 'СформироватьПриОткрытии' дает команду платформе 
    // не просто открыть форму, но и сразу нажать кнопку "Сформировать"
    ПараметрыОткрытия.Вставить("СформироватьПриОткрытии", Истина);
    
    // 6. Открываем форму отчета
    ОткрытьФорму(ИмяОтчета + ".Форма", ПараметрыОткрытия, ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНастройкиПоУмолчанию(ИмяОтчета)
    
    // Создаем "пустой" отчет, чтобы вытащить из него схему
    ОтчетОбъект = Отчеты[СтрЗаменить(ИмяОтчета, "Отчет.", "")].Создать();
    
    Результат = Новый Структура;
    Результат.Вставить("Настройки", ОтчетОбъект.КомпоновщикНастроек.Настройки);
    Результат.Вставить("ПользовательскиеНастройки", ОтчетОбъект.КомпоновщикНастроек.ПользовательскиеНастройки);
    
    Возврат Результат;
    
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьЗначениеОтбора(Настройки, ПользовательскиеНастройки, ИмяПоля, Значение)
    
    ПолеКомпоновки = Новый ПолеКомпоновкиДанных(ИмяПоля);
    
    // 1. Ищем этот отбор в ОСНОВНЫХ настройках отчета
    // (он там должен быть добавлен разработчиком, пусть даже с пустой галкой)
    ЭлементОтбора = Неопределено;
    Для Каждого Элемент Из Настройки.Отбор.Элементы Цикл
        Если ТипЗнч(Элемент) = Тип("ЭлементОтбораКомпоновкиДанных") 
           И Элемент.ЛевоеЗначение = ПолеКомпоновки Тогда
            ЭлементОтбора = Элемент;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Если ЭлементОтбора = Неопределено Тогда
        // Если отбора нет вообще, создаем его (но он не появится в "быстрых", 
        // если не был заранее выведен туда в конфигураторе)
        ЭлементОтбора = Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
        ЭлементОтбора.ЛевоеЗначение = ПолеКомпоновки;
    КонецЕсли;
    
    // 2. Ищем СВЯЗАННЫЙ отбор в ПОЛЬЗОВАТЕЛЬСКИХ настройках (те, что на форме)
    // Связь идет по уникальному идентификатору (ИдентификаторПользовательскойНастройки)
    Идентификатор = ЭлементОтбора.ИдентификаторПользовательскойНастройки;
    
    ЭлементПользовательский = ПользовательскиеНастройки.Элементы.Найти(Идентификатор);
    
    Если ЭлементПользовательский <> Неопределено Тогда
        // Если отбор выведен в шапку (быстрые отборы), заполняем его там
        ЭлементПользовательский.ПравоеЗначение = Значение;
        ЭлементПользовательский.Использование  = Истина;
        ЭлементПользовательский.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
    Иначе
        // Если отбор скрыт глубоко в настройках
        ЭлементОтбора.ПравоеЗначение = Значение;
        ЭлементОтбора.Использование  = Истина;
        ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
    КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьЗначениеПараметраСКД(Настройки, ПользовательскиеНастройки, ИмяПараметра, Значение)
    
    // Создаем специальный объект для поиска параметра
    ПараметрКомпоновки = Новый ПараметрКомпоновкиДанных(ИмяПараметра);
    
    // 1. Ищем параметр в ОСНОВНЫХ настройках отчета
    ЭлементПараметра = Настройки.ПараметрыДанных.Элементы.Найти(ПараметрКомпоновки);
    
    Если ЭлементПараметра = Неопределено Тогда
        // Такого параметра нет в схеме вообще
        Возврат; 
    КонецЕсли;
    
    // 2. Ищем связанный параметр в ПОЛЬЗОВАТЕЛЬСКИХ настройках (на форме)
    Идентификатор = ЭлементПараметра.ИдентификаторПользовательскойНастройки;
    
    ЭлементПользовательский = ПользовательскиеНастройки.Элементы.Найти(Идентификатор);
    
    Если ЭлементПользовательский <> Неопределено Тогда
        // Заполняем на форме (в быстрых настройках)
        ЭлементПользовательский.Значение = Значение;
        ЭлементПользовательский.Использование = Истина;
    Иначе
        // Если параметр не выведен пользователю, заполняем его скрыто
        ЭлементПараметра.Значение = Значение;
        ЭлементПараметра.Использование = Истина;
    КонецЕсли;

КонецПроцедуры

