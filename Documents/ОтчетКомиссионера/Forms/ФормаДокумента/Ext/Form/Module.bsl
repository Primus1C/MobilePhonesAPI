#Область ДействияЭлементовФормы

&НаКлиенте
Процедура ИзБуфераОбмена(Команда)

	//Если ЭтаФорма.ТолькоПросмотр ИЛИ Объект.Окончательно Тогда
	//	Возврат;
	//КонецЕсли;
	//
	//МоиИтоги();
	
	Ошибки = Новый СписокЗначений;  
	Если НЕ ЗначениеЗаполнено(Объект.СкладКомиссии) Тогда
		Ошибки.Добавить("Не выбран склад комиссии");
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Ошибки.Добавить("Не выбран контрагент");
	КонецЕсли; 
	Если Ошибки.Количество() > 0  Тогда
		Для каждого ош Из Ошибки Цикл
		    Сообщить(ош.Значение);
		КонецЦикла;
		Возврат;
	КонецЕсли;
	
	РаботаСоСканеромШК.ПолучитьИМЕИИзБуфера(Новый ОписаниеОповещения("ИзБуфераОбменаПослеПолученияБуфера", ЭтотОбъект));

КонецПроцедуры

&НаКлиенте
Процедура ИзБуфераОбменаПослеПолученияБуфера(Буф, ДопПараметры) Экспорт

	//если уже есть такой товар, зачем искать цену
	ЕстЦен = 0;
	Если Объект.Товары.Количество() <> 0 Тогда
		//Мас = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
		//Если Мас.Количество() <> 0 Тогда ЕстЦен = Мас[0].ЦенаПродажи КонецЕсли;
	КонецЕсли; 
	
	НСтр = СтрЧислоСтрок(Буф);
	Для Н = 1 По НСтр Цикл
		СС = "";
		С = СтрПолучитьСтроку(Буф, Н);
		Пока (СС = "") И (С <> "") Цикл
			СС = гоСледПолеТаб(С);
		КонецЦикла; 
		НовСтрокаТЧ = Объект.Товары.Добавить();
		СведенияПартии = СведенияПартии(СС);
		Если ЗначениеЗаполнено(СведенияПартии) Тогда
		   ЗаполнитьЗначенияСвойств(НовСтрокаТЧ, СведенияПартии);
		Иначе
			НовСтрокаТЧ.Серия = СС;	
		КонецЕсли;
	КонецЦикла;  

КонецПроцедуры

&НаСервере
Функция СведенияПартии(Серия)
	
	ТаблицаПартий =	Комиссия.ОстаткиПартийНаКомиссии(Серия, Объект.Дата, Объект.Фирма, Объект.СкладКомиссии); 
	Если ТаблицаПартий.Количество() = 0 Тогда 
		Возврат Неопределено;
	Иначе
		СведенияПартии = Новый Структура("Серия,Номенклатура,Партия,Количество");
		ЗаполнитьЗначенияСвойств(СведенияПартии, ТаблицаПартий[0]);
		Возврат СведенияПартии;
	КонецЕсли;	

КонецФункции 

&НаКлиенте
