			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Дно");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьМакета);
	
	ИначеЕсли ВариантПечатнойФормы = "Вес" Тогда

		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьМакета);

		Запрос.Текст = ТекстЗапросаТовары + "ВЫБРАТЬ различные
		                                    |	ТЗ.Номенклатура КАК Номенклатура,
		                                    |	ТЗ.Номенклатура.Вес КАК Вес,
		                                    |	СУММА(ТЗ.Количество) КАК Количество,
		                                    |	СУММА(ТЗ.Количество) * ТЗ.Номенклатура.Вес КАК ИтВес
		                                    |ИЗ
		                                    |	ТЗ КАК ТЗ
		                                    |
		                                    |СГРУППИРОВАТЬ ПО
		                                    |	ТЗ.Номенклатура,
		                                    |	ТЗ.Номенклатура.Вес
		                                    |
		                                    |УПОРЯДОЧИТЬ ПО
		                                    |	Номенклатура.Наименование";
		Выборка = Запрос.Выполнить().Выбрать();
		ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
		Пока Выборка.Следующий() Цикл
			ОбластьСтрока.Параметры.Заполнить(Выборка);
			ТабДокумент.Вывести(ОбластьСтрока);
		КонецЦикла; 
		
	ИначеЕсли ВариантПечатнойФормы = "ЗатратыПоГруппам" Тогда
		
		Запрос.УстановитьПараметр("Пусто", Справочники.ГруппыПодбораНоменклатуры.ПустаяСсылка());
		Запрос.УстановитьПараметр("НетГруппыПодбора", НСтр("ru = '<группа подбора не определена>'; en = '<selection group not defined>'"));
		Запрос.Текст = ТекстЗапросаТовары + "ВЫБРАТЬ  
			|	ВЫБОР
			|		КОГДА ТЗ.Номенклатура.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		Иначе &НетГруппыПодбора
			|	КОНЕЦ КАК ТоварнаяГруппа,
			|	ТЗ.Инвойс КАК Инвойс,
			|	ТЗ.Номенклатура КАК Номенклатура,  
			//+
			|	ТЗ.Номенклатура.Вес КАК ВесЕд, 
			//-
			|	СУММА(ТЗ.Количество) КАК Количество,
			|	СУММА(ТЗ.Сумма) КАК Сумма,   
			|	СУММА(ТЗ.Сумма/ТЗ.Количество) КАК Цена
			//|	СРЕДНЕЕ(ТЗ.Сумма / ТЗ.Количество) КАК Цена
			|ПОМЕСТИТЬ тзОтправки
			|ИЗ
			|	ТЗ КАК ТЗ
			|
			|СГРУППИРОВАТЬ ПО
			|	ТЗ.Инвойс,
			|	ВЫБОР
			|		КОГДА ТЗ.Номенклатура.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		КОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора <> &Пусто
			|			ТОГДА ТЗ.Номенклатура.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.ГруппаПодбора
			|		Иначе &НетГруппыПодбора
			|	КОНЕЦ,
			|	ТЗ.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	тзОтправки.ТоварнаяГруппа КАК ТоварнаяГруппа,
			|	тзОтправки.Инвойс КАК Инвойс,
			|	тзОтправки.Номенклатура КАК Номенклатура,  
			|	тзОтправки.ВесЕд КАК ВесЕд,    
			|	тзОтправки.Количество КАК Количество,
			|	тзОтправки.Сумма КАК Сумма,
			|	тзОтправки.Цена КАК Цена,
			|	ОтправкаРаспределениеЗатрат.Количество КАК КоличествоЗатрат,
			//|	ОтправкаРаспределениеЗатрат.Цена КАК ЦенаЗатрат,
			|	ОтправкаРаспределениеЗатрат.Цена КАК ЦенаЗатрат,
			|	ОтправкаРаспределениеЗатрат.Вес КАК Вес,
			//|   ОтправкаРаспределениеЗатрат.Сумма * тзОтправки.Количество/ОтправкаРаспределениеЗатрат.Количество КАК СуммаЗатрат
			|   (ОтправкаРаспределениеЗатрат.Сумма + ОтправкаРаспределениеЗатрат.СуммаAWB + ОтправкаРаспределениеЗатрат.СуммаИнвойс)* тзОтправки.Количество/ОтправкаРаспределениеЗатрат.Количество КАК СуммаЗатрат
			|ИЗ
			|	тзОтправки КАК тзОтправки
			|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			|							ОтправкаРаспрЗатрат.Номенклатура КАК Номенклатура,
			|							среднее(ОтправкаРаспрЗатрат.Количество) КАК Количество,
			|							СУММА(ОтправкаРаспрЗатрат.Цена) КАК Цена,
			|							среднее(ОтправкаРаспрЗатрат.Вес) КАК Вес,
			|							СУММА(ОтправкаРаспрЗатрат.Сумма) КАК Сумма,
			|							СУММА(ОтправкаРаспрЗатрат.СуммаAWB) КАК СуммаAWB,
			|							СУММА(ОтправкаРаспрЗатрат.СуммаИнвойс) КАК СуммаИнвойс
			|						ИЗ
			|							Документ.ОтправкаПеремещений.РаспределениеЗатрат КАК ОтправкаРаспрЗатрат
			|						ГДЕ
			|							ОтправкаРаспрЗатрат.Ссылка = &Ссылка
			|						СГРУППИРОВАТЬ ПО
			|							ОтправкаРаспрЗатрат.Номенклатура) КАК ОтправкаРаспределениеЗатрат
			|		ПО тзОтправки.Номенклатура = ОтправкаРаспределениеЗатрат.Номенклатура
			|ИТОГИ
			|	СУММА(Количество),
			|	СУММА(Сумма),
			//|	СРЕДНЕЕ(Цена),
			|	СУММА(Цена),
			|	СУММА(КоличествоЗатрат),
			|	СРЕДНЕЕ(ЦенаЗатрат),
			|	СУММА(Вес),    
			|	СРЕДНЕЕ(ВесЕд),
			|	СУММА(СуммаЗатрат)
			|ПО
			|	ОБЩИЕ,
			|	Инвойс,
			|	ТоварнаяГруппа,
			|	Номенклатура"; 
		
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка);
		
		//+
		ВыборкаИтог = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);  
		ВыборкаИтог.Следующий();
		ОбластьДно = Макет.ПолучитьОбласть("Дно");
        ОбластьДно.Параметры.Заполнить(ВыборкаИтог);
		//-
		
		ТабДокумент.НачатьАвтогруппировкуСтрок();
		//Инв = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Инвойс");
		Инв = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока Инв.Следующий() Цикл
			ОбластьМакета = Макет.ПолучитьОбласть("Инвойс");
			ОбластьМакета.Параметры.Заполнить(Инв);
			ТабДокумент.Вывести(ОбластьМакета, 1);
			Грп = Инв.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Грп.Следующий() Цикл
				ОбластьМакета = Макет.ПолучитьОбласть("Группа");
				ОбластьМакета.Параметры.Заполнить(Грп);
				ТабДокумент.Вывести(ОбластьМакета, 2);
				Ном = Грп.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Ном.Следующий() Цикл
					
					ОбластьМакета = Макет.ПолучитьОбласть("Строка");
					ОбластьМакета.Параметры.Заполнить(Ном);
					//ОбластьМакета.Рисунки.D1.Картинка = 
					ТабДокумент.Вывести(ОбластьМакета, 3);
					
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		ТабДокумент.ЗакончитьАвтогруппировкуСтрок();

		//ОбластьДно.Параметры.Заполнить(Шапка);  
		//ОбластьДно.Параметры.Сумма = Итоги.Сумма;
		//ОбластьДно.Параметры.Количество = Итоги.Количество;
		ТабДокумент.Вывести(ОбластьДно);
		
	КонецЕсли;

КонецПроцедуры	

Процедура ВыбратьЭлементыВИерархии(ВыборкаСИерархией, Макет, ТабДокумент) 
	
	Пока ВыборкаСИерархией.Следующий() Цикл   
		
		Уровень = ВыборкаСИерархией.Номенклатура.Уровень();
		Если ВыборкаСИерархией.ТипЗаписи() = ТипЗаписиЗапроса.ИтогПоИерархии Тогда  
			
			ОбластьМакета = Макет.ПолучитьОбласть("Группа");
			ОбластьМакета.Параметры.Заполнить(ВыборкаСИерархией);
			ТабДокумент.Вывести(ОбластьМакета, Уровень);
			
			ВыбратьЭлементыВИерархии (ВыборкаСИерархией.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией, "Номенклатура"), Макет, ТабДокумент);
			
		ИначеЕсли ВыборкаСИерархией.ТипЗаписи() = ТипЗаписиЗапроса. ДетальнаяЗапись Тогда

			ОбластьМакета =  Макет.ПолучитьОбласть("Строка");
			ОбластьМакета.Параметры.Заполнить(ВыборкаСИерархией); 
			ТабДокумент.Вывести(ОбластьМакета, Уровень);
			
		КонецЕсли; 
		
	КонецЦикла;    
	
КонецПроцедуры