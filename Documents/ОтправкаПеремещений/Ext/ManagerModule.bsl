// Возвращает доступные варианты печати документа
//
// Вовращаемое значение:
//  Струткура, каждая строка которой соответствует одному из вариантов печати
//  
Функция ПолучитьСтруктуруПечатныхФорм() Экспорт

	Возврат Новый Структура("Отправка, ПакингЛист, Отгрузки, Вес, Прибытие, ЗатратыПоГруппам", 
							НСтр("ru='Отправка';en='Shipment'"), 
							НСтр("ru='Пакинг лист';en='Packing list'"), 
							НСтр("ru='Отгрузки';en='Shipments'"),
							НСтр("ru='Контроль веса';en='Weight'"), 
							НСтр("ru='Прибытие';en='Arrival'"),
							НСтр("ru='Затраты по товарным группам';en='Costs by product group'")
							);		

КонецФункции 

Процедура ПечатьДокумента(ДокСсылка, ВариантПечатнойФормы, ТабДокумент, Параметры = 0) Экспорт
	
	Если НЕ (РольДоступна("Администратор") ИЛИ 
			РольДоступна("Логистика") ИЛИ 
			РольДоступна("Бухгалтерия") ИЛИ 
			РольДоступна("Менеджер") ИЛИ 
			РольДоступна("МетреонПолный") ИЛИ 
			РольДоступна("МетреонЛогистика") ИЛИ
			РольДоступна("ПросмотрДокументаОтправка")) Тогда 
		Сообщить(НСтр("ru = 'Недостаточно прав!'; en = 'Not enough rights!'"));
		Возврат;
	КонецЕсли;
	
	СкрытьЦены = (РольДоступна("Менеджер") ИЛИ РольДоступна("ПросмотрДокументаОтправка"))
				И НЕ РольДоступна("ВидимостьНаценки")
				И НЕ РольДоступна("Администратор");
	
	ТабДокумент.Очистить();
	Макет = Документы.ОтправкаПеремещений.ПолучитьМакет(ВариантПечатнойФормы);
	
	ЗапросШ = Новый Запрос;
	ЗапросШ.УстановитьПараметр("Ссылка", ДокСсылка);
	ЗапросШ.УстановитьПараметр("ПредставлениеДокумента",  ОбщегоНазначения.ПредставлениеДокументаДляПечати(ДокСсылка, ПолучитьСтруктуруПечатныхФорм()[ВариантПечатнойФормы]));
	ЗапросШ.Текст = "ВЫБРАТЬ
	               |	Отправка.Номер,
	               |	Отправка.Дата,
	               |	Отправка.НомерОтгрузки,
	               |	Отправка.Перевозчик,
	               |	Отправка.Вес,
	               |	Отправка.Мест,
	               |	Отправка.Количество,
	               |	Отправка.ТипПеревозки,
	               |	Отправка.ДатаПоступленияПлан,
	               |	Отправка.ДатаПоступленияФакт,
	               |	Отправка.СкладОтправитель,
	               |	ВЫРАЗИТЬ(Отправка.Примечание КАК СТРОКА(1000)) КАК Примечание,
	               |	&ПредставлениеДокумента КАК ПредставлениеДокумента
	               |ИЗ
	               |	Документ.ОтправкаПеремещений КАК Отправка
	               |ГДЕ
	               |	Отправка.Ссылка = &Ссылка";
	Шапка = ЗапросШ.Выполнить().Выбрать();
	Шапка.Следующий();
	
	ТекстЗапросаТовары = "ВЫБРАТЬ
	                     |	Свод.Номенклатура КАК Номенклатура,
	                     |	Свод.Инвойс КАК Инвойс,
	                     |	Свод.НомерИнвойса КАК НомерИнвойса,
	                     |	Свод.Поставщик КАК Поставщик,
	                     |	Свод.Псевдоним КАК Псевдоним,
	                     |	Свод.Количество КАК Количество,
	                     |	Свод.Сумма КАК Сумма
	                     |ПОМЕСТИТЬ ТЗ
	                     |ИЗ
	                     |	(ВЫБРАТЬ
	                     |		ПеремещениеТовары.Номенклатура КАК Номенклатура,
	                     |		ПеремещениеТовары.Партия.Док.ВКД_Инвойс КАК Инвойс,
	                     |		ПеремещениеТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойса,
	                     |		ПеремещениеТовары.Партия.Док.ВКД_Инвойс.Контрагент КАК Поставщик,
	                     |		ПеремещениеТовары.Партия.Док.ВКД_Инвойс.Контрагент.Псевдоним КАК Псевдоним,
	                     |		ПеремещениеТовары.Количество КАК Количество,
	                     |		ВЫБОР
	                     |			КОГДА &СкрытьЦены
	                     |				ТОГДА 0
	                     |			ИНАЧЕ ПеремещениеТовары.СуммаЗакупки
	                     |		КОНЕЦ КАК Сумма
	                     |	ИЗ
	                     |		Документ.Перемещение.Товары КАК ПеремещениеТовары
	                     |	ГДЕ
	                     |		ПеремещениеТовары.Ссылка В
	                     |				(ВЫБРАТЬ
	                     |					ТЧ.ТоварныйДокумент
	                     |				ИЗ
	                     |					Документ.ОтправкаПеремещений.ТоварныеДокументы КАК ТЧ
	                     |				ГДЕ
	                     |					ТЧ.Ссылка = &Ссылка)
	                     |	
	                     |	ОБЪЕДИНИТЬ ВСЕ
	                     |	
	                     |	ВЫБРАТЬ
	                     |		РНТовары.Номенклатура,
	                     |		РНТовары.Партия.Док.ВКД_Инвойс,
	                     |		РНТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика,
	                     |		РНТовары.Партия.Док.ВКД_Инвойс.Контрагент,
	                     |		РНТовары.Партия.Док.ВКД_Инвойс.Контрагент.Псевдоним,
	                     |		РНТовары.Количество,
	                     |		ВЫБОР
	                     |			КОГДА &СкрытьЦены
	                     |				ТОГДА 0
	                     |			ИНАЧЕ РНТовары.СуммаЗакупки
	                     |		КОНЕЦ
	                     |	ИЗ
	                     |		Документ.РасходнаяНакладная.Товары КАК РНТовары
	                     |	ГДЕ
	                     |		РНТовары.Ссылка В
	                     |				(ВЫБРАТЬ
	                     |					ТЧ.ТоварныйДокумент
	                     |				ИЗ
	                     |					Документ.ОтправкаПеремещений.ТоварныеДокументы КАК ТЧ
	                     |				ГДЕ
	                     |					ТЧ.Ссылка = &Ссылка)) КАК Свод";
	ТекстЗапросаТовары = ТекстЗапросаТовары + "; ";
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	Запрос.УстановитьПараметр("СкрытьЦены", СкрытьЦены);
	
	Если ВариантПечатнойФормы = "Отправка" Тогда

		Запрос.Текст = ТекстЗапросаТовары + "ВЫБРАТЬ
		               |	ТЗ.Номенклатура КАК Номенклатура,  
					   |	ТЗ.Номенклатура.Вес КАК Вес,
		               |	СУММА(ТЗ.Количество) КАК Количество,
		               |	СУММА(ТЗ.Сумма) КАК Сумма,
		               |	среднее(ТЗ.Сумма / ТЗ.Количество) КАК Цена,
 						|	СУММА(ТЗ.Количество) * ТЗ.Номенклатура.Вес / 1000 КАК ИтВес
 						|ИЗ ТЗ      
					   |
					   |  Сгруппировать по ТЗ.Номенклатура,
					   |  ТЗ.Номенклатура.Вес
					   |
		               |УПОРЯДОЧИТЬ ПО
		               |	ТЗ.Номенклатура.Наименование
		               |ИТОГИ
		               |	СУММА(Количество),
		               |	СУММА(Сумма), 
					   |	Среднее(Цена),
					   |	Среднее(Вес), 
					   |	Сумма(ИтВес)
		               |ПО Общие,
		               |	Номенклатура ИЕРАРХИЯ"; 
		
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка);

		Итоги = Запрос.Выполнить().Выбрать();
		Итоги.Следующий();

		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(Шапка);  
		ОбластьДно.Параметры.Сумма 		= Итоги.Сумма;
		ОбластьДно.Параметры.Количество = Итоги.Количество;
		ОбластьДно.Параметры.ИтВес 		= Итоги.ИтВес;

		Итоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией, "Номенклатура");
		ТабДокумент.НачатьАвтогруппировкуСтрок();
		ВыбратьЭлементыВИерархии(Итоги, Макет, ТабДокумент); 
		ТабДокумент.ЗакончитьАвтогруппировкуСтрок();

		ТабДокумент.Вывести(ОбластьДно);
		
	ИначеЕсли ВариантПечатнойФормы = "Прибытие" Тогда	

		Запрос.Текст = ТекстЗапросаТовары + "ВЫБРАТЬ
						|	ВЫБОР
						|		КОГДА СостоянияИнвойсов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыИнвойса.Прибыл)
						|			ТОГДА ИСТИНА
						|		ИНАЧЕ ЛОЖЬ
						|	КОНЕЦ КАК Прибыл,
						|	ТЗ.Номенклатура КАК Номенклатура,
						|	СУММА(ТЗ.Количество) КАК Количество,
						|	СУММА(ТЗ.Сумма) КАК Сумма,
						|	СРЕДНЕЕ(ТЗ.Сумма / ТЗ.Количество) КАК Цена
						|ИЗ
						|	ТЗ КАК ТЗ
						|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
						|		ПО ТЗ.Инвойс = СостоянияИнвойсов.Инвойс
						|
						|СГРУППИРОВАТЬ ПО
						|	ВЫБОР
						|		КОГДА СостоянияИнвойсов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыИнвойса.Прибыл)
						|			ТОГДА ИСТИНА
						|		ИНАЧЕ ЛОЖЬ
						|	КОНЕЦ,
						|	ТЗ.Номенклатура
						|УПОРЯДОЧИТЬ ПО
						|	ТЗ.Номенклатура.Наименование
						|ИТОГИ
						|	СУММА(Количество),
						|	СУММА(Сумма),
						|	СРЕДНЕЕ(Цена)
						|ПО
						|	ОБЩИЕ,
						|	Прибыл,
						|	Номенклатура ИЕРАРХИЯ";  
		
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка);
		
		ОбластьСтатус = Макет.ПолучитьОбласть("Статус");

		ВыборкаИт = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВыборкаИт.Следующий();   
		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(ВыборкаИт);
		
		ВыборкаС = ВыборкаИт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			//ТабДокумент.НачатьАвтогруппировкуСтрок();
		Пока ВыборкаС.Следующий() Цикл  

			ОбластьСтатус.Параметры.Заполнить(ВыборкаС);
			ОбластьСтатус.Параметры.Статус = ?(ВыборкаС.Прибыл, "Прибыл", "НЕ прибыл");
			ТабДокумент.Вывести(ОбластьСтатус);   
			
			т = ВыборкаС.Выбрать();
			ТабДокумент.НачатьАвтогруппировкуСтрок();
			ВыбратьЭлементыВИерархии(т, Макет, ТабДокумент); 
			ТабДокумент.ЗакончитьАвтогруппировкуСтрок();   

		КонецЦикла;	
		//	ТабДокумент.ЗакончитьАвтогруппировкуСтрок();
		
		ТабДокумент.Вывести(ОбластьДно);
		
	ИначеЕсли ВариантПечатнойФормы = "ПакингЛист" Тогда	

		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка); 
		ТабДокумент.Вывести(ОбластьМакета);
		
		Запрос.Текст = ТекстЗапросаТовары +
					"ВЫБРАТЬ
					|	Свод.Инвойс КАК Инвойс,
					|	Свод.Инвойс.Валюта.Символ КАК Валюта,
					|	Свод.НомерИнвойса,
					|	Свод.Поставщик,
					|	Свод.Псевдоним,
					|	Свод.Номенклатура КАК Товар,
					|	Свод.Количество КАК Количество,
					|	Свод.Сумма КАК Сумма,
					|	Свод.Сумма / Свод.Количество КАК Цена
					|ИЗ ТЗ КАК Свод
					|ИТОГИ
					|	СУММА(Количество),
					|	СУММА(Сумма)
					|ПО
					|	ОБЩИЕ,
					|	Инвойс,
					|	Товар
					|АВТОУПОРЯДОЧИВАНИЕ";
		
		РезультатЗапроса = Запрос.Выполнить();
		Выгрузка = РезультатЗапроса.Выгрузить();
		ВыборкаИт = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВыборкаИт.Следующий();   
		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(ВыборкаИт);
					   
		ОбластьИнвойс 	= Макет.ПолучитьОбласть("Инвойс");
		ОбластьТовар 	= Макет.ПолучитьОбласть("Товар");
		//ОбластьИтог 	= Макет.ПолучитьОбласть("Итог");
		
		ВыборкаИ = ВыборкаИт.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаИ.Следующий() Цикл    
			ОбластьИнвойс.Параметры.Заполнить(ВыборкаИ);
			ВыборкаТ = ВыборкаИ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаТ.Следующий() Цикл 
				//ОбластьТовар.Параметры.Заполнить(ВыборкаТ);
				//ТабДокумент.Вывести(ОбластьТовар);
				выб = ВыборкаТ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока Выб.Следующий() Цикл   
					ОбластьИнвойс.Параметры.Инвойс			= Выб.Инвойс;
					ОбластьИнвойс.Параметры.НомерИнвойса    = Выб.НомерИнвойса;
					ОбластьИнвойс.Параметры.Поставщик       = Выб.Поставщик;
					ОбластьИнвойс.Параметры.Псевдоним       = Выб.Псевдоним;
					ОбластьИнвойс.Параметры.Валюта       	= Выб.Валюта;
				КонецЦикла;
			КонецЦикла;
			ТабДокумент.Вывести(ОбластьИнвойс);   
			
			ВыборкаТ = ВыборкаИ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаТ.Следующий() Цикл 
				ОбластьТовар.Параметры.Заполнить(ВыборкаТ);
				ОбластьТовар.Параметры.Цена       			= ОбластьТовар.Параметры.Сумма / ОбластьТовар.Параметры.Количество;
				ТабДокумент.Вывести(ОбластьТовар);
			КонецЦикла;

		КонецЦикла;	

		//ТабДокумент.Вывести(ОбластьИтог);

		ТабДокумент.Вывести(ОбластьДно);
		
	ИначеЕсли ВариантПечатнойФормы = "Отгрузки" Тогда	
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьМакета);

		Запрос.Текст = ТекстЗапросаТовары + 
						"ВЫБРАТЬ
						|	ТЗ.Инвойс,
						|	ТЗ.Поставщик,
						|	ТЗ.НомерИнвойса КАК НомерИнвойса,
						|	ТЗ.ДатаЗакупки,
						|	СУММА(ТЗ.Количество) КАК Количество,
						|	СУММА(ТЗ.Сумма) КАК Сумма,
						|	ТЗ.Валюта КАК Символ
						|ИЗ
						|	ТЗ КАК ТЗ
						|
						|СГРУППИРОВАТЬ ПО
						|	ТЗ.Инвойс,
						|	ТЗ.Поставщик,
						|	ТЗ.НомерИнвойса,
						|	ТЗ.ДатаЗакупки,
						|	ТЗ.Валюта
						|
						|УПОРЯДОЧИТЬ ПО
						|	НомерИнвойса
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ
						|	СУММА(ТЗ.Количество) КАК Количество,
						|	СУММА(ТЗ.Сумма) КАК Сумма,
						|	ТЗ.Валюта КАК Валюта
						|ИЗ
						|	ТЗ КАК ТЗ
						|
						|СГРУППИРОВАТЬ ПО
						|	ТЗ.Валюта"; 
		Пакет =  Запрос.ВыполнитьПакет();
        ВыборкаИ = Пакет[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
		Пока ВыборкаИ.Следующий() Цикл 
			ОбластьСтрока.Параметры.Заполнить(ВыборкаИ);  
			ОбластьСтрока.Параметры.ДатаОтгрузки = Шапка.ДатаПоступленияПлан;
			ТабДокумент.Вывести(ОбластьСтрока);
		КонецЦикла;
		
		Выгрузка = Пакет[2].Выгрузить();
		ОбластьМакета = Макет.ПолучитьОбласть("Итог"); 
		Если Выгрузка.Количество() > 1 Тогда
			Для каждого СтрокаИт Из Выгрузка Цикл
				ОбластьМакета.Параметры.Заполнить(СтрокаИт); 
				ТабДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
			ОбластьМакета.Параметры.Валюта 		= НСтр("ru = 'ВСЕГО'; en = 'TOTAL'");
			ОбластьМакета.Параметры.Сумма 		= "";
			ОбластьМакета.Параметры.Символ 		= "";
			ОбластьМакета.Параметры.Количество 	= Выгрузка.Итог("Количество");
			ТабДокумент.Вывести(ОбластьМакета);
		Иначе
			ОбластьМакета.Параметры.Заполнить(Выгрузка[0]);
