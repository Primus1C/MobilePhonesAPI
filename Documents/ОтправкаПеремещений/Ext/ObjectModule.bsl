Процедура ОбработкаПроведения(Отказ, Режим)
	
	ПроверкаЗаполнения(Отказ);
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;
	
	// РС Затраты    

	ВалютаДоллар = ПараметрыСеанса.БазоваяВалюта;
    Фирма = ПараметрыСеанса.Фирма;

	НаборЗаписей = Движения.Затраты;    

	Если Окончательно Тогда
	
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		             |	Свод.Номенклатура КАК Номенклатура,
		             |	Свод.Партия КАК Партия,
		             |	РаспрЗатрат.Затрата КАК Затрата,
		             //|	РаспрЗатрат.Количество КАК Количество,
		             |	РаспрЗатрат.Цена КАК Цена
		             |ИЗ
		             |	(ВЫБРАТЬ
		             |		ПеремещениеТовары.Номенклатура КАК Номенклатура,
		             |		ПеремещениеТовары.Партия КАК Партия
		             |	ИЗ
		             |		Документ.Перемещение.Товары КАК ПеремещениеТовары
		             |	ГДЕ
		             |		ПеремещениеТовары.Ссылка В
		             |				(ВЫБРАТЬ
		             |					ТЧ.ТоварныйДокумент
		             |				ИЗ
		             |					Документ.ОтправкаПеремещений.ТоварныеДокументы КАК ТЧ
		             |				ГДЕ
		             |					ТЧ.Ссылка = &Ссылка)
		             |		И ПеремещениеТовары.Номенклатура В
		             |				(ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |					ТЧ.Номенклатура
		             |				ИЗ
		             |					Документ.ОтправкаПеремещений.РаспределениеЗатрат КАК ТЧ
		             |				ГДЕ
		             |					ТЧ.Ссылка = &Ссылка)
		             |	
		             |	ОБЪЕДИНИТЬ
		             |	
		             |	ВЫБРАТЬ
		             |		РНТовары.Номенклатура,
		             |		РНТовары.Партия
		             |	ИЗ
		             |		Документ.РасходнаяНакладная.Товары КАК РНТовары
		             |	ГДЕ
		             |		РНТовары.Ссылка В
		             |				(ВЫБРАТЬ
		             |					ТЧ.ТоварныйДокумент
		             |				ИЗ
		             |					Документ.ОтправкаПеремещений.ТоварныеДокументы КАК ТЧ
		             |				ГДЕ
		             |					ТЧ.Ссылка = &Ссылка)
		             |		И РНТовары.Номенклатура В
		             |				(ВЫБРАТЬ РАЗЛИЧНЫЕ
		             |					ТЧ.Номенклатура
		             |				ИЗ
		             |					Документ.ОтправкаПеремещений.РаспределениеЗатрат КАК ТЧ
		             |				ГДЕ
		             |					ТЧ.Ссылка = &Ссылка)) КАК Свод
		             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		             |			ОтправкаПеремещенийРаспределениеЗатрат.Номенклатура КАК Номенклатура,
		             |			ОтправкаПеремещенийРаспределениеЗатрат.Затрата КАК Затрата,
		             //|			СУММА(ОтправкаПеремещенийРаспределениеЗатрат.Количество) КАК Количество,
		             |			СУММА(ОтправкаПеремещенийРаспределениеЗатрат.Цена) КАК Цена
		             |		ИЗ
		             |			Документ.ОтправкаПеремещений.РаспределениеЗатрат КАК ОтправкаПеремещенийРаспределениеЗатрат
		             |		ГДЕ
		             |			ОтправкаПеремещенийРаспределениеЗатрат.Ссылка = &Ссылка
		             |		
		             |		СГРУППИРОВАТЬ ПО
		             |			ОтправкаПеремещенийРаспределениеЗатрат.Номенклатура,
		             |			ОтправкаПеремещенийРаспределениеЗатрат.Затрата) КАК РаспрЗатрат
		             |		ПО Свод.Номенклатура = РаспрЗатрат.Номенклатура";
		Запр.УстановитьПараметр("Ссылка", Ссылка);
		
		РезультатЗапроса = Запр.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			
			НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
			НаборЗаписей.Записать(Истина);
			
		Иначе	
			
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				НовЗапись = НаборЗаписей.Добавить(); 
				НовЗапись.Период		= Дата;
				НовЗапись.Источник 		= Ссылка;
				НовЗапись.Номенклатура 	= Выборка.Номенклатура;	
			 	НовЗапись.Затрата		= Выборка.Затрата;
				НовЗапись.Партия 		= Выборка.Партия; 
				//НовЗапись.Количество	= Выборка.Количество;
				НовЗапись.Сумма 		= Выборка.Цена;
				НовЗапись.Валюта 		= ВалютаЗатрат;  
				НовЗапись.Зарегистрировано = ТекущаяДата();
			    НовЗапись.СуммаВБазВалюте  = РаботаСВалютой.Пересчитать2025(Выборка.Цена, ВалютаЗатрат, ВалютаДоллар, Фирма, Дата); 
			КонецЦикла;
			НаборЗаписей.Записать(Истина);
			
		КонецЕсли;
		
	Иначе   
		
		НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
		НаборЗаписей.Записать(Истина);
		
	КонецЕсли;
	
КонецПроцедуры

