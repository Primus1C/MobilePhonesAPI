Функция ИнвойсыТекущейПроведеннойОтправки()

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Регистратор", Ссылка);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ОтправкаИнвойсов.Инвойс КАК Инвойс,
	             |	СостоянияИнвойсов.Статус КАК Статус,
	             |	ВЫБОР
	             |		КОГДА ПредыдущиеОтправки.Инвойс ЕСТЬ NULL
	             |			ТОГДА ЛОЖЬ
	             |		ИНАЧЕ ИСТИНА
	             |	КОНЕЦ КАК БылиОтправки
	             |ИЗ
	             |	РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
	             |		ПО ОтправкаИнвойсов.Инвойс = СостоянияИнвойсов.Инвойс
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ОтправкаИнвойсов.Инвойс КАК Инвойс,
	             |			МИНИМУМ(ОтправкаИнвойсов.Поставка) КАК Поставка
	             |		ИЗ
	             |			РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |		ГДЕ
	             |			ОтправкаИнвойсов.Регистратор ССЫЛКА Документ.Отправка
	             |			И ОтправкаИнвойсов.Регистратор <> &Регистратор
	             |		
	             |		СГРУППИРОВАТЬ ПО
	             |			ОтправкаИнвойсов.Инвойс) КАК ПредыдущиеОтправки
	             |		ПО ОтправкаИнвойсов.Инвойс = ПредыдущиеОтправки.Инвойс
	             |			И ОтправкаИнвойсов.Поставка = ПредыдущиеОтправки.Поставка
	             |ГДЕ
	             |	ОтправкаИнвойсов.Регистратор = &Регистратор";
    Выгрузка = Запр.Выполнить().Выгрузить();
	Возврат Выгрузка;

КонецФункции 

Функция ИнвойсыУдаленныеИзОтправки()

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Регистратор", Ссылка);
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ОтправкаИнвойсов.Инвойс КАК Инвойс,
	             |	СостоянияИнвойсов.Статус КАК Статус,
	             |	ВЫБОР
	             |		КОГДА ПредыдущиеОтправки.Инвойс ЕСТЬ NULL
	             |			ТОГДА ЛОЖЬ
	             |		ИНАЧЕ ИСТИНА
	             |	КОНЕЦ КАК БылиОтправки
	             |ИЗ
	             |	РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
	             |		ПО ОтправкаИнвойсов.Инвойс = СостоянияИнвойсов.Инвойс
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ОтправкаИнвойсов.Инвойс КАК Инвойс,
	             |			МИНИМУМ(ОтправкаИнвойсов.Поставка) КАК Поставка
	             |		ИЗ
	             |			РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |		ГДЕ
	             |			ОтправкаИнвойсов.Регистратор ССЫЛКА Документ.Отправка
	             |			И ОтправкаИнвойсов.Регистратор <> &Регистратор
	             |		
	             |		СГРУППИРОВАТЬ ПО
	             |			ОтправкаИнвойсов.Инвойс) КАК ПредыдущиеОтправки
	             |		ПО ОтправкаИнвойсов.Инвойс = ПредыдущиеОтправки.Инвойс
	             |			И ОтправкаИнвойсов.Поставка = ПредыдущиеОтправки.Поставка
	             |ГДЕ
	             |	ОтправкаИнвойсов.Регистратор = &Регистратор
	             |	И НЕ ОтправкаИнвойсов.Инвойс В
	             |				(ВЫБРАТЬ
	             |					ТЧ.Инвойс
	             |				ИЗ
	             |					Документ.Отправка.Инвойсы КАК ТЧ
	             |				ГДЕ
	             |					ТЧ.Ссылка = &Регистратор)";
    Выгрузка = Запр.Выполнить().Выгрузить();
	Возврат Выгрузка;

