Функция ПредыдущиеСтатусыИнвойсов(Инвойсы) 
	
	Результат = Новый Соответствие;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Инвойсы", Инвойсы);
	Запр.Текст = "ВЫБРАТЬ
	             |	Инвойсы.Инвойс,
	             |	ВЫБОР
	             |		КОГДА ЕСТЬNULL(ОтправкиОприход.Оприходование, 0) = 0
	             |			ТОГДА ЛОЖЬ
	             |		ИНАЧЕ ИСТИНА
	             |	КОНЕЦ КАК ЕстьОприходование,
	             |	ВЫБОР
	             |		КОГДА ЕСТЬNULL(ОтправкиОприход.Отправки, 0) = 0
	             |			ТОГДА ЛОЖЬ
	             |		ИНАЧЕ ИСТИНА
	             |	КОНЕЦ КАК ЕстьОтправка,
	             |	СостоянияИнвойсов.Статус КАК Статус
	             |ИЗ
	             |	(ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |		Инвойсы.Ссылка КАК Инвойс
	             |	ИЗ
	             |		Документ._Инвойс КАК Инвойсы
	             |	ГДЕ
	             |		Инвойсы.Ссылка В(&Инвойсы)) КАК Инвойсы
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ВКД_ОприходованиеНоменклатурыОстатки.Документ КАК Инвойс,
	             |			СУММА(ВКД_ОприходованиеНоменклатурыОстатки.КоличествоОстаток) КАК Оприходование,
	             |			0 КАК Отправки
	             |		ИЗ
	             |			РегистрНакопления.ВКД_ОприходованиеНоменклатуры.Остатки КАК ВКД_ОприходованиеНоменклатурыОстатки
	             |		ГДЕ
	             |			ВКД_ОприходованиеНоменклатурыОстатки.Документ В(&Инвойсы)
	             |		
	             |		СГРУППИРОВАТЬ ПО
	             |			ВКД_ОприходованиеНоменклатурыОстатки.Документ
	             |		
	             |		ОБЪЕДИНИТЬ
	             |		
	             |		ВЫБРАТЬ
	             |			ОтправкаИнвойсов.Инвойс,
	             |			0,
	             |			СУММА(ОтправкаИнвойсов.ОжидаемыеПоставки)
	             |		ИЗ
	             |			РегистрНакопления.ОтправкаИнвойсов КАК ОтправкаИнвойсов
	             |		ГДЕ
	             |			ОтправкаИнвойсов.ОжидаемыеПоставки < 0
	             |		
	             |		СГРУППИРОВАТЬ ПО
	             |			ОтправкаИнвойсов.Инвойс) КАК ОтправкиОприход
	             |		ПО (ОтправкиОприход.Инвойс = Инвойсы.Инвойс)
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнвойсов КАК СостоянияИнвойсов
	             |		ПО Инвойсы.Инвойс = СостоянияИнвойсов.Инвойс";
     Выборка = Запр.Выполнить().Выбрать();
	 Пока Выборка.Следующий() Цикл
	 	Результат.Вставить(Выборка.Инвойс, 
							Новый Структура("Статус, ЕстьОприходование, ЕстьОтправка",
											Выборка.Статус, Выборка.ЕстьОприходование, Выборка.ЕстьОтправка));
	 КонецЦикла;  
	 Возврат Результат; 
	 
КонецФункции 

