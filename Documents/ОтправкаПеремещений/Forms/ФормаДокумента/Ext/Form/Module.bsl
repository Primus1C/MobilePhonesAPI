&НаКлиенте
Процедура ВхожденияНоменклатуры(Команда) 

	Данные = Элементы.Дерево.ТекущиеДанные; 
	Если Данные <> Неопределено Тогда 
		ТекстСообщения = "";
		РаспределитьЗатратыНаСервере(Данные.Номенклатура, ТекстСообщения); 
		Если ТекстСообщения <> "" Тогда 
			клПредупреждение(ТекстСообщения,, "Распред.затрат " + Данные.Номенклатура); 
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

