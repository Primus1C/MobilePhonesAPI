&НаСервере
Процедура РаспределитьЗатратыНаСервере(Номенклатура = Неопределено, ТекстСообщения = "")
	
	// 0
	
	Отказ = "";
	Для каждого СтрокаТЧ Из Объект.ТоварныеДокументы Цикл 
		Если НЕ СтрокаТЧ.ТоварныйДокумент.Проведен Тогда
			Отказ = ОбщегоНазначения.ПредставлениеДокументаДляПечати(СтрокаТЧ.ТоварныйДокумент) + ", ";
		КонецЕсли;	
	КонецЦикла;
	Если Отказ <> "" Тогда
		Отказ = Лев(Отказ, СтрДлина(Отказ) - 2);
		Сообщить(НСтр("ru = 'Распределение невозможно! Документ не проведен: '; en = 'Distribution impossible! Document not posted:'") + Отказ);
		Возврат;
	КонецЕсли; 
	Разделитель = Символы.ПС + Символы.ПС;
	
	// Партии товаров без серий 
	
	ЗапрБез = Новый Запрос;
	ЗапрБез.УстановитьПараметр("ТоварныеДокументы", Объект.ТоварныеДокументы.Выгрузить(,"ТоварныйДокумент").ВыгрузитьКолонку(0));
	ЗапрБез.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                |	Свод.Номенклатура КАК Номенклатура,
	                |	СУММА(ПНТовары.Количество) КАК Количество
	                |ИЗ
	                |	(ВЫБРАТЬ
	                |		ПеремещениеТовары.Номенклатура КАК Номенклатура,
	                |		ПеремещениеТовары.Партия КАК Партия
	                |	ИЗ
	                |		Документ.Перемещение.Товары КАК ПеремещениеТовары
	                |	ГДЕ
	                |		ПеремещениеТовары.Ссылка В(&ТоварныеДокументы)
	                |		И НЕ ПеремещениеТовары.Номенклатура.УчетПоСериям
	                |	
	                |	ОБЪЕДИНИТЬ
	                |	
	                |	ВЫБРАТЬ
	                |		РасхНаклТовары.Номенклатура,
	                |		РасхНаклТовары.Партия
	                |	ИЗ
	                |		Документ.РасходнаяНакладная.Товары КАК РасхНаклТовары
	                |	ГДЕ
	                |		РасхНаклТовары.Ссылка В(&ТоварныеДокументы)
	                |		И НЕ РасхНаклТовары.Номенклатура.УчетПоСериям) КАК Свод
	                |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная.Товары КАК ПНТовары
	                |		ПО Свод.Партия = ПНТовары.Партия
	                |			И Свод.Партия.Док = ПНТовары.Ссылка
	                |
	                |СГРУППИРОВАТЬ ПО
	                |	Свод.Номенклатура";
	ВыгрузкаБез = ЗапрБез.Выполнить().Выбрать();
	СоотвКолБезСерий = Новый Соответствие;  
	Пока ВыгрузкаБез.Следующий() Цикл
		СоотвКолБезСерий.Вставить(ВыгрузкаБез.Номенклатура, ВыгрузкаБез.Количество); 
	КонецЦикла;
	
	// 1. Затраты товарных групп
	
	Если Номенклатура = Неопределено Тогда
		Объект.РаспределениеЗатрат.Очистить();   
		Для каждого СтрокаТЧ Из Объект.Затраты Цикл
			СтрокаТЧ.Вес 	= 0;
			СтрокаТЧ.ЦенаКг = 0;
		КонецЦикла;
	КонецЕсли;
	
	// заполним вес нетто    
	
	Если Номенклатура <> Неопределено Тогда 
		ТекстСообщения = ТекстСообщения + "Вхождения товара:" + Символы.ПС;
		ЗапрИнфо = Новый Запрос;  
		ЗапрИнфо.УстановитьПараметр("ТоварныеДокументы", Объект.ТоварныеДокументы.Выгрузить(,"ТоварныйДокумент").ВыгрузитьКолонку(0));
		ЗапрИнфо.УстановитьПараметр("Номенклатура", Номенклатура);
		ЗапрИнфо.Текст = "ВЫБРАТЬ разрешенные
		                 |	ПеремещениеТовары.Номенклатура КАК Номенклатура,
		                 |	СУММА(ПеремещениеТовары.Количество) КАК Количество,
		                 |	СУММА(ПеремещениеТовары.Количество) * ПеремещениеТовары.Номенклатура.Вес / 1000 КАК Вес,
		                 |	ПеремещениеТовары.Ссылка КАК Ссылка
		                 |ИЗ
		                 |	Документ.Перемещение.Товары КАК ПеремещениеТовары
		                 |ГДЕ
		                 |	ПеремещениеТовары.Ссылка В(&ТоварныеДокументы)
		                 |	И ПеремещениеТовары.Номенклатура = &Номенклатура
		                 |
		                 |СГРУППИРОВАТЬ ПО
		                 |	ПеремещениеТовары.Номенклатура,
		                 |	ПеремещениеТовары.Ссылка,
		                 |	ПеремещениеТовары.Номенклатура.Вес
		                 |
		                 |ОБЪЕДИНИТЬ
		                 |
		                 |ВЫБРАТЬ
		                 |	РасхНаклТовары.Номенклатура,
		                 |	СУММА(РасхНаклТовары.Количество),
		                 |	СУММА(РасхНаклТовары.Количество) * РасхНаклТовары.Номенклатура.Вес / 1000,
		                 |	РасхНаклТовары.Ссылка
		                 |ИЗ
		                 |	Документ.РасходнаяНакладная.Товары КАК РасхНаклТовары
		                 |ГДЕ
		                 |	РасхНаклТовары.Ссылка В(&ТоварныеДокументы)
		                 |	И РасхНаклТовары.Номенклатура = &Номенклатура
		                 |
		                 |СГРУППИРОВАТЬ ПО
