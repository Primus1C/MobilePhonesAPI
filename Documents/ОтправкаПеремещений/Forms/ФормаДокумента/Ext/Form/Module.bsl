&НаСервере
Функция ЗаполнитьПоказателиПеремещений()
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	             |	СУММА(ПеремещениеТовары.Количество) КАК Количество,
	             |	СУММА(ПеремещениеТовары.СуммаЗакупки) КАК Сумма,
	             |	ПеремещениеТовары.Ссылка КАК Ссылка
	             |ИЗ
	             |	Документ.Перемещение.Товары КАК ПеремещениеТовары
	             |ГДЕ
	             |	ПеремещениеТовары.Ссылка В(&ТоварныеДокументы)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ПеремещениеТовары.Ссылка
	             |
	             |ОБЪЕДИНИТЬ
	             |
	             |ВЫБРАТЬ
	             |	СУММА(РасходнаяТовары.Количество),
	             |	СУММА(РасходнаяТовары.СуммаЗакупки),
	             |	РасходнаяТовары.Ссылка
	             |ИЗ
	             |	Документ.РасходнаяНакладная.Товары КАК РасходнаяТовары
	             |ГДЕ
	             |	РасходнаяТовары.Ссылка В(&ТоварныеДокументы)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	РасходнаяТовары.Ссылка";
	Запр.УстановитьПараметр("ТоварныеДокументы", Объект.ТоварныеДокументы.Выгрузить(,"ТоварныйДокумент").ВыгрузитьКолонку(0)); 
	Соотв = Новый Соответствие;
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Соотв.Вставить(Выборка.Ссылка, Новый Структура("Количество,Сумма", Выборка.Количество, Выборка.Сумма));
	КонецЦикла;
	Для каждого СтрокаТЧ Из Объект.ТоварныеДокументы Цикл
		Если ЗначениеЗаполнено(СтрокаТЧ.ТоварныйДокумент) И Соотв.Получить(СтрокаТЧ.ТоварныйДокумент) <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, Соотв.Получить(СтрокаТЧ.ТоварныйДокумент));
		КонецЕсли; 
		СтрокаТЧ.СтатусПроведения = ОбщегоНазначенияСервер.СтатусПроведения(СтрокаТЧ.ТоварныйДокумент);
	КонецЦикла;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьСписокВыбораПоставок(СтрокаТЧ)

	КвоПоставок = КэшДанных.ТоварныеДокументы[СтрокаТЧ.Инвойс].КоличествоПоставокВИнвойсе;
	Если КвоПоставок = 0 Тогда
		//	//Поле.СписокВыбора.Добавить(0, "инвойс полностью");
	Иначе  
		ПолеПоставка = Элементы.ТоварныеДокументы.ПодчиненныеЭлементы.ИнвойсыПоставка;
		ПолеПоставка.СписокВыбора.Очистить();
		Для Инд = 1 По КвоПоставок Цикл     
			КвоВПоставке = КэшДанных.ТоварныеДокументы[СтрокаТЧ.Инвойс].ПоставкиИнвойсов[Инд].Количество;
			ПолеПоставка.СписокВыбора.Добавить(Инд, СтрШаблон(НСтр("ru = '%1 (из %2), кол-во %3'; en = '%1 (of %2), quantity %3'"), Инд, КвоПоставок, КвоВПоставке));
		КонецЦикла;
		Элементы.ТоварныеДокументы.ТекущиеДанные.Поставка = 1;
	КонецЕсли;

КонецПроцедуры

