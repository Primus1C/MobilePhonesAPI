&НаСервере
Функция ДокументыТЧ()
	
	Спис = Новый СписокЗначений;
	Для каждого СтрокаТЧ Из Объект.ТоварныеДокументы Цикл
		Спис.Добавить(СтрШаблон("%1##", СтрокаТЧ.ТоварныйДокумент.Номер));
	КонецЦикла;
	Возврат Спис;

