#Область Дерево

&НаСервере
Процедура ЗаполнитьДеревоЗначенийНаСервере()
	
	Дер = РеквизитФормыВЗначение("Дерево");
	Дер.Строки.Очистить(); 
	
	ТГПеревозчика = НоменклатураТоварныхГруппПеревозчика(Объект.Перевозчик);

	// 1
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ТЗ.Номенклатура КАК Номенклатура,
	             |	ТЗ.Затрата КАК Затрата,
	             |	ТЗ.Количество КАК Количество,
	             |	ТЗ.Цена КАК Цена,
	             |	ТЗ.Вес КАК Вес,
	             |	ТЗ.Сумма КАК Сумма
	             |ПОМЕСТИТЬ ТЗ
	             |ИЗ
	             |	&ТЧ КАК ТЗ
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	ДляТЧРаспрЗатрат.Номенклатура КАК Номенклатура,
	             |	ДляТЧРаспрЗатрат.Затрата КАК Затрата,
	             |	ДляТЧРаспрЗатрат.Количество КАК Количество,
	             |	ДляТЧРаспрЗатрат.Цена КАК Цена,
	             |	ДляТЧРаспрЗатрат.Вес КАК Вес,
	             |	ДляТЧРаспрЗатрат.Сумма КАК Сумма
	             |ИЗ
	             |	ТЗ КАК ДляТЧРаспрЗатрат
	             |ИТОГИ
	             |	СРЕДНЕЕ(Количество),
	             |	СУММА(Цена),
	             |	СРЕДНЕЕ(Вес),
	             |	СУММА(Сумма)
	             |ПО
	             |	Номенклатура,
	             |	Затрата";
	Запр.УстановитьПараметр("ТЧ", Объект.РаспределениеЗатрат.Выгрузить());
  	ВыборкаН = Запр.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаН.Следующий() Цикл 
		СтрокаН = Дер.Строки.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаН, ВыборкаН); 
		СтрокаН.ТоварнаяГруппаПеревозчика = ТГПеревозчика.Получить(СтрокаН.Номенклатура);
		ВыборкаЗ = ВыборкаН.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаЗ.Следующий() Цикл
			СтрокаЗ = СтрокаН.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗ, ВыборкаЗ, "Номенклатура,Затрата,Сумма");  
		КонецЦикла;
	КонецЦикла;
	
	// 2
	
	Для каждого СтрокаЗатратДоп Из Объект.ЗатратыДоп Цикл
		НайдСтроки = Дер.Строки.НайтиСтроки(Новый Структура("Номенклатура", СтрокаЗатратДоп.Номенклатура));	
		Если НайдСтроки.Количество() > 0 Тогда
			НайдСтрока = НайдСтроки[0];  
			Если СтрокаЗатратДоп.Вид = Перечисления.РегистраторыЗатрат.ОтправкаAWB Тогда
				НайдСтрока.ЦенаAWB = СтрокаЗатратДоп.Цена;
				НайдСтрока.СуммаAWB	= СтрокаЗатратДоп.Цена * НайдСтрока.Количество;
			ИначеЕсли СтрокаЗатратДоп.Вид = Перечисления.РегистраторыЗатрат.Инвойс Тогда
				НайдСтрока.ЦенаИнвойс = СтрокаЗатратДоп.Цена;
				НайдСтрока.СуммаИнвойс 	= СтрокаЗатратДоп.Цена * НайдСтрока.Количество;
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
	Для каждого СтрокаТЧ Из Дер.Строки Цикл
		СтрокаТЧ.ЦенаИтог = СтрокаТЧ.Цена + СтрокаТЧ.ЦенаAWB + СтрокаТЧ.ЦенаИнвойс;	
		СтрокаТЧ.ПометкаУдаления = СтрокаТЧ.Номенклатура.ПометкаУдаления;
	КонецЦикла;
	
	// 3
	
	ЗначениеВРеквизитФормы(Дер, "Дерево");
	
	Элементы.ДеревоНоменклатура.ТекстПодвала	= Дер.Строки.Количество();  
	Элементы.ДеревоКоличество.ТекстПодвала 		= Дер.Строки.Итог("Количество");
	Элементы.ДеревоСумма.ТекстПодвала 			= Формат(Дер.Строки.Итог("Сумма"), "ЧДЦ=4");
	Элементы.ДеревоВес.ТекстПодвала 			= Формат(Дер.Строки.Итог("Вес"), "ЧДЦ=3");
	
КонецПроцедуры

