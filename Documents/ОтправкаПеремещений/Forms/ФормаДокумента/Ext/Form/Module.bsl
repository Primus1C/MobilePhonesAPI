&НаСервере
Функция ИнфоЗатрат(Номенклатура)
	
	Мас = Новый Массив;
	Запр = Новый Запрос;	
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.УстановитьПараметр("Номенклатура", Номенклатура);
    Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
                 |	ОприходНоменклатуры.Документ КАК Документ,
                 |	СУММА(ОприходНоменклатуры.Количество) КАК Количество,
                 |	СУММА(ОприходНоменклатуры.Количество * ОприходНоменклатуры.Номенклатура.Вес) / 1000 КАК Вес,
                 |	ОприходНоменклатуры.Поставка
                 |ИЗ
                 |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ОприходНоменклатуры
                 |ГДЕ
                 |	(ОприходНоменклатуры.Документ, ОприходНоменклатуры.Поставка) В
                 |			(ВЫБРАТЬ
                 |				ИнвойсыОтправки.Инвойс,
                 |				ИнвойсыОтправки.Поставка
                 |			ИЗ
                 |				Документ.Отправка.Инвойсы КАК ИнвойсыОтправки
                 |			ГДЕ
                 |				ИнвойсыОтправки.Ссылка = &Ссылка)
                 |	И ОприходНоменклатуры.Номенклатура = &Номенклатура
                 |
                 |СГРУППИРОВАТЬ ПО
                 |	ОприходНоменклатуры.Документ,
                 |	ОприходНоменклатуры.Поставка
                 |
                 |УПОРЯДОЧИТЬ ПО
                 |	ОприходНоменклатуры.Документ.Дата" ;
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Мас.Добавить(Новый Структура("Инвойс,Поставка,Количество,Вес", Выборка.Документ, Выборка.Поставка, Выборка.Количество, Выборка.Вес));	
	КонецЦикла;	
	Возврат Мас;
	
КонецФункции

