&НаСервереБезКонтекста
Функция НоменклатураТоварныхГруппПеревозчика(Перевозчик)
	
	Соотв = Новый Соответствие;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Перевозчик", Перевозчик);
	Запр.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
				 |	ТоварныеГруппыПеревозчиковТовары.Номенклатура КАК ГруппаНоменклатуры,
	             |	ТоварныеГруппыПеревозчиковТовары.Ссылка КАК ТоварнаяГруппаПеревозчика
	             |ИЗ
	             |	Справочник.ТоварныеГруппыПеревозчиков.Товары КАК ТоварныеГруппыПеревозчиковТовары
	             |ГДЕ
	             |	ТоварныеГруппыПеревозчиковТовары.Ссылка.Владелец = &Перевозчик
	             |	И НЕ ТоварныеГруппыПеревозчиковТовары.Ссылка.ПометкаУдаления"; 
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗапрН = Новый Запрос;   
		ЗапрН.УстановитьПараметр("Группа", Выборка.ГруппаНоменклатуры);
		ЗапрН.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		              |	Номенклатура.Ссылка КАК Ссылка
		              |ИЗ
		              |	Справочник.Номенклатура КАК Номенклатура
		              |ГДЕ
		              |	Номенклатура.Ссылка В ИЕРАРХИИ(&Группа)
		              |	И НЕ Номенклатура.ЭтоГруппа";
		ВыборкаН = ЗапрН.Выполнить().Выбрать(); 
		Пока ВыборкаН.Следующий() Цикл
			Соотв.Вставить(ВыборкаН.Ссылка, Выборка.ТоварнаяГруппаПеревозчика);
		КонецЦикла;
	КонецЦикла;             
	
	Возврат Соотв;
	
