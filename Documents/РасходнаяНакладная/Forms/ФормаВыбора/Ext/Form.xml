				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Докум.Ссылка КАК Ссылка,
	Докум.ПометкаУдаления КАК ПометкаУдаления,
	Докум.Номер КАК Номер,
	Докум.Дата КАК Дата,
	Докум.Проведен КАК Проведен,
	Докум.Контрагент КАК Контрагент,
	Докум.Сумма КАК Сумма,
	Докум.СуммаЗакупки КАК СуммаЗакупки,
	Докум.стрПроцент КАК стрПроцент,
	Докум.Валюта КАК Валюта,
	Докум.Строк КАК Строк,
	Докум.СуммаПривязано КАК СуммаПривязано,
	Докум.Склад КАК Склад,
	Докум.КемСоздан КАК КемСоздан,
	Докум.Создан КАК Создан,
	Докум.КемСохранен КАК КемСохранен,
	Докум.Сохранен КАК Сохранен,
	Докум.Фирма КАК Фирма,
	выразить (Докум.Примечание как строка(100)) КАК Примечание,
	Докум.Окончательно КАК Окончательно,
	Докум.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;= 0
			ТОГДА ""
		КОГДА Докум.СрокОплаты = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ТОГДА "?"
		ИНАЧЕ РАЗНОСТЬДАТ(&amp;ТекущаяДата, Докум.СрокОплаты, ДЕНЬ)
	КОНЕЦ КАК Оплатить,
	ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) КАК Долг,
	ВЫБОР
		КОГДА Докум.Окончательно
				И Докум.Сумма &gt; 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;&gt; Докум.Сумма
									ТОГДА ЗНАЧЕНИЕ(Перечисление.Долги.Частично)
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Неоплачено)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.Полностью)
				КОНЕЦ
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Долги.НеЗакрыто)
	КОНЕЦ КАК Состояние,
	Докум.ПроцентПлюс КАК ПроцентПлюс,
	Докум.ПроцентМинус КАК ПроцентМинус,
	Докум.Количество КАК Количество
ИЗ
	Документ.РасходнаяНакладная КАК Докум
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки КАК Рег
		ПО Докум.Ссылка = Рег.Док
ГДЕ
	ВЫБОР
			КОГДА &amp;Граница = НЕОПРЕДЕЛЕНО
				ТОГДА ИСТИНА
			ИНАЧЕ Докум.Дата &gt; &amp;Граница
		КОНЕЦ</QueryText>
