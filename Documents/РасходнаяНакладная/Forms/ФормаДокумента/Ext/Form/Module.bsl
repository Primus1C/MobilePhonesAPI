&НаСервере  
// Возвращает соответствие Серия -> Значения реквизитов партий, имеющихся на остатке
//
Функция СведенияПартий(МассивСерий)
	
	МассивВРег = Новый Массив;
	МассивНРег = Новый Массив;
	Для каждого Эл Из МассивСерий Цикл
		МассивВРег.Добавить(Врег(Эл));
		МассивНРег.Добавить(Нрег(Эл));
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Рег.Партия КАК Партия,
	               |	Рег.ОстатокОстаток КАК Остаток,
	               |	Рег.Партия.Серия КАК Серия,
	               |	Рег.Номенклатура КАК Номенклатура,
	               |	Рег.Партия.ЦенаЗакупки КАК ЦенаЗакупки,
	               |	Рег.Партия.Валюта КАК Валюта
	               |ИЗ
	               |	РегистрНакопления.ОстаткиТовара.Остатки КАК Рег
	               |ГДЕ
	               |	Рег.Фирма = &Фирма
	               |	И Рег.Склад = &Склад
	               |	И Рег.ОстатокОстаток >= 1
	               |	И (Рег.Партия.Серия В (&Серии)
	               |			ИЛИ Рег.Партия.Серия В (&СерииНРег)
	               |			ИЛИ Рег.Партия.Серия В (&СерииВРег))";
	Запрос.УстановитьПараметр("Серии",  	МассивСерий);
	Запрос.УстановитьПараметр("СерииНРег",  МассивВРег);
	Запрос.УстановитьПараметр("СерииВРег",  МассивНРег);
	Запрос.УстановитьПараметр("Склад",  	Объект.Склад);
	Запрос.УстановитьПараметр("Фирма",  	Объект.Фирма);
	Выборка = Запрос.Выполнить().Выбрать(); 
	СоотвПартий = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СведенияПартии = Новый Структура("Партия,Номенклатура,Остаток,ЦенаЗакупки,Валюта", 
										Выборка.Партия, Выборка.Номенклатура, Выборка.Остаток, Выборка.ЦенаЗакупки, Выборка.Валюта);
		Серия = СокрЛП(Выборка.Серия);								
		СоотвПартий.Вставить(Серия, СведенияПартии);
		СоотвПартий.Вставить(ВРег(Серия), СведенияПартии);
		СоотвПартий.Вставить(НРег(Серия), СведенияПартии);
	КонецЦикла;
	Возврат СоотвПартий;

КонецФункции 

&НаСервереБезКонтекста
Функция ПредставлениеНаценки(стрПроцент)
	
	Если ЗначениеЗаполнено(стрПроцент) Тогда
		Если стрПроцент = "У" Тогда
			Возврат "У";	
		ИначеЕсли Лев(стрПроцент,1) = "-" Тогда
			Возврат стрПроцент;  
		Иначе
			Возврат "%";
		КонецЕсли;
	Иначе
		Возврат "";	
	КонецЕсли;      
	
