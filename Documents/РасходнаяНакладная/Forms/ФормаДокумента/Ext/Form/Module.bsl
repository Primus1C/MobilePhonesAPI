&НаКлиенте
Процедура ВставитьСтрокиИзБуфераЗавершение(Результат, Параметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	О = "";
	ИДИ = ВставитьСтрокиИзБуфераСервер(Параметры.БуфДок, Параметры.БуфСтр, Параметры.НовЦен, О);
	клЕстьОшибка(О);
	Если ИДИ = -1 Тогда Возврат КонецЕсли;
	
	МояЗаписать(Ложь);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
КонецПроцедуры

&НаСервере
Функция ВставитьСтрокиИзБуфераСервер(БуфДок, БуфСтр, ОбщЦен, О)
	Рез = -1;
	БуфКол = БуфСтр.Количество();
	
	Для Каждого Стр Из БуфДок.Товары Цикл
		Если БуфКол <> 0 Тогда
			Если БуфСтр.Найти(Стр.НомерСтроки) = Неопределено Тогда Продолжить КонецЕсли; КонецЕсли; 
			
		//в строке у нас партия и возможно, цена, если не задана одна общая
		НовКол = Стр.Количество;
		НовПар = Стр.Партия;
		НовНом = НовПар.Владелец;
		
		//2016.12.14
		Если гоРеквизит(НовНом, "ЗапретОтгрузки") Тогда Сообщить(гоИмя(НовПар) + " - включен запрет отгрузки, строка пропускается!"); Продолжить; КонецЕсли;
		
		НовСер = Стр.Серия;
		Если ОбщЦен = 0 Тогда 
			НовЦен = омСервер.ПересчетЗн(НовПар.ЦенаЗакупки, НовПар.Валюта, Объект.Валюта, Объект.Фирма, Объект.Дата, ЧислоЗнаковЦена);
		Иначе 
			НовЦен = ОбщЦен;
		КонецЕсли; 
		
		ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
		Если ОстПар < НовКол Тогда Сообщить(гоИмя(НовПар) + " - остаток партии " + ОстПар + " меньше указанного количества " + НовКол + "!" + гоРС() +
											?(ОстПар = 0, "Строка пропускается", "Количество исправлено") + "!"); 
			Если ОстПар = 0 Тогда 
				Продолжить; 
			Иначе 
				НовКол = ОстПар;
			КонецЕсли; 
		КонецЕсли; 
			
		НовСтр = Объект.Товары.Добавить();
		
		НовСтр.Номенклатура = НовНом;
		НовСтр.Партия = НовПар;
		НовСтр.Количество = НовКол;
		НовСтр.ЦенаПродажи = НовЦен;
		
		Рез = НовСтр.ПолучитьИдентификатор();
		
		гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦена) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Вставка из буфера", Объект.Ссылка, 2);
	КонецЦикла; 
	
	Возврат Рез;
КонецФункции

&НаКлиенте
Функция ЕстьЕще(ТекИДИ, ТекНом)
	Рез = Новый Массив;
	
	Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", ТекНом));
	Если НЕ (Нашли.Количество() = 0) Тогда
		Для Каждого Стр Из Нашли Цикл
			Если Стр.ПолучитьИдентификатор() = ТекИДИ Тогда Продолжить КонецЕсли;
			Рез.Добавить(Стр);
		КонецЦикла; 
	КонецЕсли;

	Возврат Рез;
КонецФункции

&НаКлиенте
Процедура МоеРедактирование(Кол)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	
	//2016.05.24
	//Усл = гоРеквизит(Стр.Номенклатура, "Услуги");
	Усл = гоРеквизит(Стр.Номенклатура, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга");
	
	Если гоЭто("ЦенаПродажи", Кол) Тогда
		БылЦен = Стр.ЦенаПродажи;
		
		Если Кол = "ЦенаПродажи" Тогда
			НовЦен = БылЦен;
			ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаЦены", ЭтотОбъект, Новый Структура("ИДИ,БылЦен", ИДИ, БылЦен)), НовЦен, "Цена", 19, ЧислоЗнаковЦена);
			Возврат;
		КонецЕсли;
	ИначеЕсли Кол = "ДляПечати" Тогда
		БылСтр = СокрЛП(Стр.ДляПечати);
		НовСтр = БылСтр;
		
		ПоказатьВводСтроки(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаДляПечати", ЭтотОбъект, Новый Структура("ИДИ,БылСтр", ИДИ, БылСтр)), НовСтр, НСтр("ru = 'Для печати'; en = 'For print'"), 100, Ложь);
	//2017.01.17	
	ИначеЕсли Кол = "ДатаВозврата" Тогда
		//2017.01.18
		//услуги не трогаем
		Если Усл Тогда Возврат КонецЕсли;
		Зна = Стр[Кол];
		Был = Зна;
		Если НЕ ЗначениеЗаполнено(Зна) Тогда Зна = гоТекущаяДата() КонецЕсли;
		ПоказатьВводДаты(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаДатыВозврата", ЭтотОбъект, Новый Структура("ИДИ,Был,Кол", ИДИ, Был, Кол)), Зна, "Дата возврата:", ЧастиДаты.Дата);
	ИначеЕсли Кол = "Количество" Тогда
		//2017.01.17
		Если ЗначениеЗаполнено(Стр.ДатаВозврата) Тогда клОшибка("Уже введена дата возврата!"); Возврат; КонецЕсли;
		
		БылКол = Стр.Количество;
		НовКол = БылКол;
		
		ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаКоличества", ЭтотОбъект, Новый Структура("ИДИ,БылКол,Усл", ИДИ, БылКол, Усл)), НовКол, НСтр("ru = 'Введите количество'; en = 'Input quantity'"), 14, ЧислоЗнаковКоличество);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаЦены(НовЦен, Параметры) Экспорт
	Если НовЦен = Неопределено Тогда Возврат КонецЕсли;
	Если НовЦен = Параметры.БылЦен Тогда Возврат КонецЕсли; 
	
	ИДИ = Параметры.ИДИ;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	БылЦен = Параметры.БылЦен;
	Доба = "";
	
	Стр.ЦенаПродажи = НовЦен;
	
	Колич =	Стр.Количество;
	Номен =	Стр.Номенклатура;
	
	МояЗаписать(Ложь);
	гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(БылЦен, ЧислоЗнаковЦена) + "->" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦена) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование цены" + Доба, Объект.Ссылка, 2);
	
	Нашли = ЕстьЕще(ИДИ, Номен);
	Если НЕ (Нашли.Количество() = 0) Тогда
		клДаНет(Новый ОписаниеОповещения("МоеРедактированиеПослеПодтвержденияОстальных", ЭтотОбъект, Новый Структура("Нашли,НовЦен,Доба", Нашли, НовЦен, Доба)),
			НСтр("ru = 'В документе есть еще такая же номенклатура! Проставить новую цену и на нее тоже?'; en = 'The document also contains the same nomenclature! Set a new price on it too?'"));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеПодтвержденияОстальных(Результат, Параметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	НовЦен = Параметры.НовЦен;
	Доба = Параметры.Доба;
	
	Для Каждого Стр Из Параметры.Нашли Цикл
		БылЦен = Стр.ЦенаПродажи;
		Если БылЦен = НовЦен Тогда Продолжить КонецЕсли; 
		
		Стр.ЦенаПродажи = НовЦен;
		
		Колич =	Стр.Количество;
		Номен =	Стр.Номенклатура;
		гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(БылЦен, ЧислоЗнаковЦена) + "->" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦена) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование цены" + Доба, Объект.Ссылка, 2);
	КонецЦикла;
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаДляПечати(НовСтр, Параметры) Экспорт
	Если НовСтр = Неопределено Тогда Возврат КонецЕсли;
	Если СокрЛП(НовСтр) = Параметры.БылСтр Тогда Возврат КонецЕсли; 
	
	Стр = Объект.Товары.НайтиПоИдентификатору(Параметры.ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	Стр.ДляПечати = НовСтр;
	МояЗаписать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаДатыВозврата(Зна, Параметры) Экспорт
	Если Зна = Неопределено Тогда Возврат КонецЕсли;
	Был = Параметры.Был;
	Если Был = Зна Тогда Возврат КонецЕсли;
	
	ИДИ = Параметры.ИДИ;
	Кол = Параметры.Кол;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	//2017.01.18
	//если снимаем дату возврата, то нужно убедиться, что есть остаток, может, его переместили
	Если НЕ ЗначениеЗаполнено(Зна) Тогда
		ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, Стр.Партия);
		Если Стр.Количество > ОстПар Тогда клОшибка("Не хватит остатка " + Строка(Стр.Количество - ОстПар) + " для " + гоИмя(Стр.Партия) + "!"); Возврат; КонецЕсли;
	КонецЕсли;
	Стр[Кол] = Зна;
	МояЗаписать(Ложь);
	Номен = Стр.Номенклатура;
	СЦена = Стр.ЦенаПродажи;
	гоЗаписьЖурналаРегистрации(гоДата2(Был) + "->" + гоДата2(Зна) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦена) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента, "Редактирование даты возврата", Номен, 2);
	гоЗаписьЖурналаРегистрации(гоДата2(Был) + "->" + гоДата2(Зна) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦена) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование даты возврата", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаКоличества(НовКол, Параметры) Экспорт
	Если НовКол = Неопределено Тогда Возврат КонецЕсли;
	
	ИДИ = Параметры.ИДИ;
	БылКол = Параметры.БылКол;
	Усл = Параметры.Усл;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	//2016.05.24
	//не нужно проверять услуги на остаток
	Если НЕ Усл Тогда  
		ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, Стр.Партия);
		Если Объект.Проведен Тогда ОстПар = ОстПар + БылКол КонецЕсли;
		
		Если НовКол > ОстПар Тогда 
			клОшибка("Не хватило остатка " + Строка(НовКол - ОстПар) + " для " + гоИмя(Стр.Партия) + ", исправлено на " + ОстПар + "!");
			НовКол = ОстПар;
		КонецЕсли;
	КонецЕсли; 
	Если НовКол = Стр.Количество Тогда Возврат КонецЕсли;
	
	Стр.Количество = НовКол;
	
	МояЗаписать(Ложь);
	
	Колич = НовКол;
	Номен = Стр.Номенклатура;
	СЦена = Стр.ЦенаПродажи;
	
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦена) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента, "Редактирование количества", Номен, 2);
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦена) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование количества", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура МоеУдаление()
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда 
		Если гоАдминистратор() Тогда 
			Сообщить("Под ответственность Администратора!");
		Иначе 
			Возврат;
		КонецЕсли; 
	КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("МоеУдалениеЗавершение", ЭтотОбъект, ИДИ),
		НСтр("ru = 'Удалить строку?'; en = 'Delete line?'"));
КонецПроцедуры

&НаКлиенте
Процедура МоеУдалениеЗавершение(Результат, ИДИ) Экспорт 
	
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Удаляем = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Удаляем = Неопределено Тогда клОшибка("Странно, не нашли текущую строку!"); Возврат; КонецЕсли; 
	
	Объект.Товары.Удалить(Удаляем);
	
	гоЗаписьЖурналаРегистрации(СтрШаблон("%1|%2|%3",
	                           		Строка(Удаляем.Количество),
							   		гоСуммаЗн(Удаляем.ЦенаПродажи, ЧислоЗнаковЦена),
							   		гоИмя(Удаляем.Номенклатура, Ложь)),
							   ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удаление строки", Объект.Ссылка, 2);

	//партия сама пометится на удаление при записи
	МояЗаписать(Ложь); 
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Если гоПЗ(Объект.Контрагент) Тогда Возврат КонецЕсли;
	Если омСервер.ЕстьНезакрытыеДокументы(Объект.Контрагент, Объект.Ссылка) Тогда 
		клВнимание(НСтр("ru = 'ВНИМАНИЕ! Есть незакрытые документы!!!'; en = 'ATTENTION! There are unclosed documents!!!'")) 
	КонецЕсли; 
	// © Primus1C  13.11.2024  НАЧАЛО ►
	ОтобразитьДолгИРазрешения();
	// © Primus1C  ОКОНЧАНИЕ ◄
КонецПроцедуры

&НаКлиенте
Процедура Установить(Команда)
	Если Объект.Окончательно Тогда Возврат КонецЕсли;
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Товары.Количество() = 0 Тогда 
		клНамекнуть(ИмяДокумента, НСтр("ru = 'Документ пуст!'; en = 'The document is empty!'"), БиблиотекаКартинок.ПоискДанных);
		Возврат;
	КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("УстановитьПослеПодтверждения", ЭтотОбъект), НСтр("ru = 'Установить флаг <Окончательно>?'; en = 'Set flag <Finaly>?'"));
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПослеПодтверждения(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	//2016.01.31
	Если Объект.счеКонсигнация = 0 Тогда 
		//тут все обыденно
		Объект.Окончательно = Истина;
		МояЗаписать(Ложь);
		УстановитьЗавершение();
	Иначе 
		//2016.02.02
		//проверяем валюты на совпадение временно, ставим запрет, если не та валюта
		//Сч = 0;  
		Сч = Новый СписокЗначений;
		Для Каждого Стр Из Объект.Товары Цикл
			ПарВал = гоРеквизит(Стр.Партия, "Валюта");
			Если ПарВал = Объект.Валюта Тогда Продолжить КонецЕсли;
			//гоПлюс(Сч);  
			Сч.Добавить(Стр.номерСтроки);
		КонецЦикла; 
		//Если Сч <> 0 Тогда клОшибка("В документе есть К-партии: " + Сч + ", оприходованные в другой валюте!" + гоРС() + 
		//							"Установка {Окончательно} запрещена!"); Возврат; КонецЕсли;
		Если Сч.Количество()> 0 Тогда клОшибка("В документе есть К-партии: строка (строки) " + Сч + ", оприходованные в другой валюте! 
												|Установка {Окончательно} запрещена!"); Возврат; КонецЕсли;
		
		клНетДа(Новый ОписаниеОповещения("УстановитьПослеПодтвержденияКонсигнации", ЭтотОбъект), СтрШаблон(
				НСтр("ru = 'Есть строки с К-партиями: %1!%2В их приходах будут установлены ТЕКУЩИЕ цены продажи по текущему курсу, долг поставщику УВЕЛИЧИТСЯ!!!%2 Все равно продолжать?'; 
				|en = 'There are lines with K-parties: %1!%2In their parishes, CURRENT selling prices will be set at the current rate, the debt to the supplier will INCREASE!!!%2 Should we continue anyway?'"), 
				Объект.счеКонсигнация, гоРС()));
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПослеПодтвержденияКонсигнации(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	//ставим все в транзакции на сервере, чтобы иметь возможность все отменить
	О = "";
	М = Новый Массив;
	УстановитьСервер(О, Ложь, М);
	Если клЕстьОшибка(О) Тогда Возврат КонецЕсли;
	
	//тут вручную обновим все
	УстановитьВидимостьДоступность();
	МоиОстатки();
	МоиИтоги();
	
	клОповеститьОбИзмененииМассив(М);
	
	УстановитьЗавершение();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗавершение()
	гоЗаписьЖурналаРегистрации(СтрШаблон("Установили. Строк %1, сумма %2",Объект.Товары.Количество(),Формат(Объект.Сумма,"ЧДЦ=2")), ИмяДокумента, "Установка {Окончательно}", Объект.Ссылка, 2);
КонецПроцедуры

&НаСервере
Процедура УстановитьСервер(О, Снятие = Ложь, М)
	
	НачатьТранзакцию();
	
	Попытка
	
		// © Primus1C  26.04.2026  НАЧАЛО ►
		// (рефакторинг оригинального кода)
		
		// установка в справочнике Партии цен закупки товаров консигнации 
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		             |	ТЧТовары.Партия КАК Партия,
		             |	ТЧТовары.Партия.Док КАК ДокументПартии,
		             |	ТЧТовары.Партия.Валюта КАК Валюта,
		             |	ТЧТовары.ЦенаПродажи КАК ЦенаПродажи,
		             |	ТЧТовары.Партия.Док.Проведен КАК ДокументПартииПроведен
		             |ИЗ
		             |	Документ.РасходнаяНакладная.Товары КАК ТЧТовары
		             |ГДЕ
		             |	ТЧТовары.Ссылка = &Ссылка
		             |	И ТЧТовары.Партия.Консигнация";
		Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
		РезультатЗапроса = Запр.Выполнить();
		Если НЕ РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка Цикл
				ПартияОбъект = Выборка.Партия.ПолучитьОбъект();
				Если Снятие Тогда 
					ПартияОбъект.ЦенаЗакупки = 0;
				Иначе 
					ПартияОбъект.ЦенаЗакупки = омСервер.ПересчетЗн(Выборка.ЦенаПродажи, Объект.Валюта, Выборка.Валюта, Объект.Фирма, Объект.Дата, Объект.Фирма.ЧислоЗнаковЦенаЗакупки);
				КонецЕсли; 
				ПартияОбъект.Записать();
				М.Добавить(Выборка.Партия);
			КонецЦикла;
		КонецЕсли;
