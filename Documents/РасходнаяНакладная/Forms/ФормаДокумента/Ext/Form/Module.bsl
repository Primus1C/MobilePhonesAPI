	// © Primus1C  13.11.2025  НАЧАЛО ►  
	
	// массив нужен чтобы сохранить порядок серий
	мас = Новый Массив;
	Для Н = 1 По КвоСтрок Цикл
		НовСер = "";
		С = СтрПолучитьСтроку(Буф, Н);
		Пока (НовСер = "") И (С <> "") Цикл
			НовСер = гоСледПолеТаб(С);
		КонецЦикла;	
		серия = СокрЛП(НовСер);
		Если серия = "" Тогда
			Продолжить;		
		Иначе
			мас.Добавить(серия);
		КонецЕсли;
	КонецЦикла;

	СоотвПартий = СведенияПартий(мас);
	
