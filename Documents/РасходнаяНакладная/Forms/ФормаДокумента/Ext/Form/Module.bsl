&НаСервере
Функция ПартииСерии(Серия)
	
	спис = Новый СписокЗначений;
	запр = Новый Запрос;  
	запр.УстановитьПараметр("Серия", Серия);
	запр.Текст = "ВЫБРАТЬ
	             |	Партии.Ссылка КАК Партия,
	             |	Партии.ПометкаУдаления КАК ПометкаУдаления,
	             |	Партии.ЦенаЗакупки КАК ЦенаЗакупки,
	             |	Партии.Валюта КАК Валюта
	             |ИЗ
	             |	Справочник.Партии КАК Партии
	             |ГДЕ
	             |	Партии.Серия = &Серия";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		спис.Добавить(Новый Структура("Партия,Удален,ЦенаЗакупки,Валюта", 
										Выборка.Партия, 
										Выборка.ПометкаУдаления,  
										омСервер.ПересчетЗн(Выборка.ЦенаЗакупки, Выборка.Валюта, Объект.Валюта, Объект.Фирма, Объект.Дата, 4),
										Выборка.Валюта
										));
	КонецЦикла;
	Возврат Спис;
	
КонецФункции // ПартииСерии()

