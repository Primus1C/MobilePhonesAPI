	ТекДанные = Элементы.Товары.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;  
	
	Цены = ОбщегоНазначенияСервер.СоставЗатрат(Элементы.Товары.ТекущиеДанные.Партия, ЭтаФорма.Объект.Ссылка, Истина); 
	НоваяЦена = Цены.СуммаВал + Элементы.Товары.ТекущиеДанные.ЦенаЗакупки;
	Если ТекДанные.ВКД_ЦенаСЗатратами = Окр(НоваяЦена, 4) Тогда
		клВнимание(СтрШаблон("Цена с затратами составляет %1
							|(обновление не требуется)", 
							Формат(НоваяЦена,"ЧДЦ=5"))
					,, "Цена с затратами");
	Иначе	
		клДаНет(Новый ОписаниеОповещения("ОбновитьЦенуСЗатратамиЗавершение", ЭтотОбъект, Новый Структура("ТекДанные,НоваяЦена", ТекДанные, НоваяЦена)),
			СтрШаблон("Цена с затратами составляет %1. Установить это значение?", Формат(НоваяЦена,"ЧДЦ=5")), Ложь);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЦенуСЗатратамиЗавершение(Результат, Параметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	ТекДанные = Параметры.ТекДанные;
	НоваяЦена = Параметры.НоваяЦена;
	
	ТекДанные.ВКД_ЦенаСЗатратами = НоваяЦена;   
	ТекДанные.стрПроцент = гоПроцент0(ТекДанные.СуммаПродажи, ТекДанные.ВКД_ЦенаСЗатратами * ТекДанные.Количество);   
	Модифицированность = Истина;
КонецПроцедуры


#Область ПодключаемаяПечать
	
&НаКлиенте
Процедура ВыполнитьПодключеннуюПечать(Команда)
	
	ВариантПечатнойФормы = СтрЗаменить(Команда.Имя, "ПодключеннаяПечать_", "");   
	ТабДок = ПечатнаяФорма(ВариантПечатнойФормы);
	ПараметрыПечати = Новый Структура("Таб, Имя, НеДляПечати", ТабДок, гоИмя(Объект.Ссылка, Ложь), Ложь);
	ОткрытьФорму("ОбщаяФорма.ПечатьБезЗащиты", ПараметрыПечати, , Истина); 
		
КонецПроцедуры  

&НаСервере
Функция ПечатнаяФорма(ВариантПечатнойФормы)

	ТабДок = Новый ТабличныйДокумент;
	Документы.РасходнаяНакладная.ПечатьДокумента(Объект.Ссылка, ВариантПечатнойФормы, ТабДок);
	Возврат ТабДок;
	
КонецФункции 

#КонецОбласти


&НаКлиенте
Процедура УстановитьКолво(Команда) 
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		СтрокаТЧ.Количество = 1;
	КонецЦикла;
    Объект.Дата = Дата(2026,02,12);
	Записать();
	
КонецПроцедуры

