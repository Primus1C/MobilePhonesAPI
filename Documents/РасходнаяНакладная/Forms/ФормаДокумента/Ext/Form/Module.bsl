#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;
	
	Если гоНПЗ(Параметры.ЗначениеКопирования) Тогда Сообщить(НСтр("ru = 'Копирование расходных накладных запрещено!'; en = 'Copying sales invoices is prohibited!'")); Отказ = Истина; Возврат; КонецЕсли; 
	
	РежимЗаписиПроведение = Новый Структура ("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	//2016.09.12
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если гоПользователь().НеВидетьЧужиеНакладные Тогда
			Если гоПользователь() <> Объект.КемСоздан Тогда Отказ = Истина; Возврат; КонецЕсли; КонецЕсли; КонецЕсли; 
	
	Избранный = гоИзбранный(Объект.Ссылка);
	
	ЧислоЗнаковКоличество = Объект.Фирма.ЧислоЗнаковКоличество;
	//ЧислоЗнаковЦена = Объект.Фирма.ЧислоЗнаковЦена;
	ЧислоЗнаковЦена = 4;
	
	Элементы.ТоварыКоличество.Формат 					= "ЧДЦ=" + ЧислоЗнаковКоличество;
	Элементы.ТоварыЦенаПродажи.Формат 					= "ЧДЦ=" + ЧислоЗнаковЦена;
	Элементы.ТоварыНоменклатураРодитель.Видимость 		= Объект.Фирма.ВыводитьГруппа;
	Элементы.ТоварыНоменклатураПроизводитель.Видимость 	= Объект.Фирма.ВыводитьПроизводитель;
	Элементы.ТоварыСерия.Видимость 						= Объект.Фирма.ВыводитьСерия;
	Элементы.ТоварыПартияСрокГодности.Видимость 		= Объект.Фирма.ВыводитьСрокГодности;
	
	//Элементы.ТоварыУдалитьВсе.Видимость = Истина;
	
	//Попытка
	//	Элементы.ФормаИзменитьФорму.Видимость = Ложь;
	//Исключение
	//КонецПопытки; 
	
	//2015.12.08
	//Элементы.ТоварыстрПроцент.Видимость 				= ВКД_ПроверитьДоступностьРоли();
	
	//2016.03.25
	Элементы.РучнойШК.Видимость 						= гоПользователь().КлавиатурныйСканерШК;
	
	//2017.03.24
	Мас = ОбщегоНазначенияПовтИсп.МассивДоступныхСкладов();
	Если Мас.Количество() <> 0 Тогда
	Если Мас.Найти(Объект.Склад) = Неопределено Тогда Отказ = Истина; Возврат; КонецЕсли; КонецЕсли; 

	// © Primus1C  29.07.2023  НАЧАЛО ►  
	
	Режим = ОбщегоНазначенияПовтИсп.ВидимостьНаценки();
	Элементы.ТоварыЦенаЗакупки.Видимость	= Режим;
	Элементы.ТоварыстрПроцент.Видимость		= Режим;
	Элементы.ТоварыПроцент.Видимость		= НЕ Режим;

	ЗаполнитьКэшДанных();
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка._Инвойс") Тогда
			Если Объект.ДокументОснование.Проформа = Перечисления.ВидыИнвойса.Инвойс Тогда
				ТолькоПросмотр = Истина;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 
	Элементы.Валюта.БыстрыйВыбор = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("БыстрыйВыборВалют"); 
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И НЕ ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		Объект.Валюта 	= ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("Валюта");
		Объект.Склад 	= ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("Склад");
	КонецЕсли;    
	
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		СтрокаТЧ.Процент = ПредставлениеНаценки(СтрокаТЧ.стрПроцент);
	КонецЦикла;

	СтруктураПечатныхФорм = Документы.РасходнаяНакладная.ПолучитьСтруктуруПечатныхФорм();  
	ПараметрыРазмещения = Новый Структура("Форма, ЭтоФормаОбъекта, КоманднаяПанель", ЭтаФорма, Истина, Неопределено);
	ОбщегоНазначенияСервер.ПодключитьКомандыПечати(ПараметрыРазмещения, СтруктураПечатныхФорм);   

	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	клФормаДокументаПриОткрытии(ЭтаФорма, Объект);
	
	ТолПро = ЭтаФорма.ТолькоПросмотр;
	
	ЕстьОплата = Ложь;
	//2016.08.26
	//этоЧужой = Ложь;
	Если НЕ Объект.Ссылка.Пустая() Тогда 
		ЕстьОплата = омСервер.ЕстьОплатаДокумента(Объект.Ссылка); 
		//2016.08.26
		//этоЧужой = гоЧужойДокумент(Объект.КемСоздан);
	КонецЕсли; 
	
	//2016.08.26 + ИЛИ этоЧужой
	Если Избранный ИЛИ ЕстьОплата ИЛИ (Объект.СуммаПривязано <> 0) 
		//ИЛИ этоЧужой 
		Тогда ТолПро = Истина КонецЕсли;
	
	ЭтаФорма.ТолькоПросмотр = ТолПро;
	
	стрПросмотр = клПросмотр(ЭтаФорма, Избранный, Объект.Ссылка);
	
	УстановитьВидимостьДоступность();
	МоиИтоги();
	
	РаботаСоСканеромШК.СканерШКПодключить(); 

	// © Primus1C  27.12.2023  НАЧАЛО ►  
	ОтобразитьЦветВалюты();
	ОтобразитьДолгИРазрешения();	
	// © Primus1C  ОКОНЧАНИЕ ◄
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)

	клФормаДокументаПередЗаписью(Объект, Отказ);

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)

	УстановитьВидимостьДоступность();
	МоиОстатки();
	МоиИтоги();  

	// © Primus1C  06.07.2023  НАЧАЛО ►
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента);
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПеречитатьДанныеФормыДокумента" Тогда
		Модифицированность = Истина;
		Прочитать();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура МоиИтоги()
	
	// © Primus1C  02.12.2023  НАЧАЛО ►
	//стрИтого = "";
	//стрОплата = "";
	//омСервер.МоиИтоги(Объект, стрИтого, стрОплата); 
	СтруктураИтогов = омСервер.МоиИтогиФорматированные(Объект);
	Элементы.ДекорацияИтого.Заголовок = Новый ФорматированнаяСтрока(ОбщегоНазначенияСервер.ТекстHTMLВФорматированнуюСтроку(СтруктураИтогов.Итоги));
	стрОплата = СтруктураИтогов.Оплата;
	// © Primus1C  ОКОНЧАНИЕ ◄ 
	
КонецПроцедуры

&НаКлиенте
Процедура МоиОстатки()
	стрОстатки = "?";
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	стрОстатки = омСервер.МоиОстатки(Объект.Ссылка, Стр.Номенклатура, Стр.Партия);
КонецПроцедуры

&НаКлиенте
Процедура МояЗаписать(ПроверятьМодифицированность = Истина)
	УстановитьВидимостьДоступность();
	
	Если ПроверятьМодифицированность Тогда
		Если НЕ Модифицированность Тогда Возврат КонецЕсли; КонецЕсли; 
		
	Записать(РежимЗаписиПроведение);
	МоиОстатки();
	МоиИтоги();   
		
	// © Primus1C  19.01.2025  НАЧАЛО ►
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		СтрокаТЧ.Процент = ПредставлениеНаценки(СтрокаТЧ.стрПроцент);
	КонецЦикла;
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	ЕстьСтроки = Объект.Товары.Количество() > 0;
	
	Закрыто = Объект.Окончательно;	
	НеЗакрыто = НЕ Закрыто;
	
	//2015.12.08 попробуем только по закрыто
	Элементы.Дата.ТолькоПросмотр = Закрыто;		//Объект.Проведен ИЛИ
	Элементы.Склад.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Валюта.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Установить.Доступность = НеЗакрыто;
	Элементы.Снять.Доступность = Закрыто;
	
	//2015.12.12
	Элементы.Контрагент.ТолькоПросмотр = Закрыто;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриАктивизацииСтроки(Элемент)
	МоиОстатки();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	МоеДобавление();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
	МоеРедактирование(СтрЗаменить(Элемент.ТекущийЭлемент.Имя, "Товары", ""));
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалением(Элемент, Отказ)
	Отказ = Истина;
	МоеУдаление();
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавление()  
	
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Отказ = "";
	Если гоПЗ(Объект.Склад) Тогда Отказ = НСтр("ru = 'Не задан склад!'; en = 'Warehouse not specified!'"); КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда Отказ = Отказ + Символы.ПС + НСтр("ru = 'Не задана валюта!'; en = 'Currency not specified!'"); КонецЕсли; 
	Если Отказ <> "" Тогда
		клОшибка(Отказ);
		Возврат;
	КонецЕсли;
	
	Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли;  // если док-т вообще не записан
	
	Попытка
		НовНом = Элементы.Товары.ТекущиеДанные.Номенклатура;
		НовПар = Элементы.Товары.ТекущиеДанные.Партия;
	Исключение 
		НовНом = гоПустой("Номенклатура");
		НовПар = гоПустой("Партии");
	КонецПопытки;
	
	МоеДобавлениеШаг(НовНом);
	
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеШаг(НовНом)
	//гоУстановитьПараметрСеанса("Склад", Объект.Склад);
	ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораНоменклатуры", ЭтотОбъект), НовНом, НСтр("ru = 'Выберите номенклатуру'; en = 'Select good'"));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораНоменклатуры(НовНом, ДопПараметры) Экспорт
	Если НовНом = Неопределено Тогда Возврат КонецЕсли; 
	
	//2016.12.14
	Если гоРеквизит(НовНом, "ЗапретОтгрузки") Тогда 
		клОшибка(НСтр("ru = 'Включен запрет отгрузки, выберите другую номенклатуру!'; en = 'Shipment prohibition is enabled, select another good!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	//УчетПоСериям = гоРеквизит(НовНом, "УчетПоСериям");
	//та пусть добавляют что хотят, мы будем партию проверять
	//Если НЕ УчетПоСериям Тогда
	//	Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
	//	Если НЕ (Нашли.Количество() = 0) Тогда клВнимание(гоИмя(НовНом) + ": уже есть в документе!" + гоРС() + "Возможно, нужно просто отредактировать количество!!!") КонецЕсли;
	//КонецЕсли; 
	
	//2015.11.18
	//ну а что тут делать в ручном? просто выбирать партии, наверное, не списывать же их по ФИФО?
	//у нас такого вообще то и нет, хотя когда-то делали
	
	//2016.05.24
	//Усл = гоРеквизит(НовНом, "Услуги");
	//Если Усл Тогда 
	Если гоРеквизит(НовНом, "ТипНоменклатуры") = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда 
		Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
		Если Нашли.Количество() > 0 Тогда 
			клОшибка(СтрШаблон("%1: %2!%3%4!!!", 
								гоИмя(НовНом),
								НСтр("ru = 'уже есть в документе'; en = 'is already in the document'"),
								Символы.ПС,
								НСтр("ru = 'Используйте редактирование количества'; en = 'Use quantity editing'"))); 
			МоеДобавлениеШаг(НовНом); 
			Возврат; 
		КонецЕсли;
		НовЦен = 0;
		ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеДобавлениеПослеВводаСуммыУслуги", ЭтотОбъект, НовНом), НовЦен, НСтр("ru = 'Сумма услуги (количество будет 1)'; en = 'Amount of service (quantity will be 1)'"), 19, ЧислоЗнаковЦена);
	Иначе 
		гоУстановитьПараметрСеанса("Склад", Объект.Склад);
		гоУстановитьПараметрСеанса("Номенклатура", НовНом);
		ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораПартии", ЭтотОбъект, НовНом), НовПар, НСтр("ru = 'Выберите партию'; en = 'Select batch'"));
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВводаСуммыУслуги(НовЦен, НовНом) Экспорт
	Если НовЦен = Неопределено Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	Если НовЦен = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введена сумма услуги!'; en = 'Sum is not inputed!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	клСохранитьИзменения(Новый ОписаниеОповещения("МоеДобавлениеПослеПодтвержденияУслуги", ЭтотОбъект, 
		Новый Структура("НовНом,НовПар,НовКол,НовЦен", НовНом, 0, 1, НовЦен)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеПодтвержденияУслуги(Результат, Параметры) Экспорт
	Если НЕ Результат Тогда 
		МоеДобавлениеШаг(Параметры.НовНом); 
		Возврат; 
	КонецЕсли; 
	
	МоеДобавлениеЗавершить(Параметры.НовНом, Параметры.НовПар, Параметры.НовКол, Параметры.НовЦен);
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораПартии(НовПар, НовНом) Экспорт
	Если НовПар = Неопределено Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	//тут работает выбор нормально, получим остаток партии, вдруг выбрали без остатка
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если ОстПар <= 0 Тогда 
		клОшибка(НСтр("ru = 'Нет остатка у выбранной партии!'; en = 'The selected batch has no balance!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Партия", НовПар));
	Если Нашли.Количество() > 0 Тогда 
		клОшибка(СтрШаблон(НСтр("ru = '%1: уже есть в документе!%2Используйте редактирование количества!!!'; en = '%1: already in the document!%2Use quantity editing!!!'"), гоИмя(НовПар), гоРС()));
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	 //ВКД++
	//НовЦен = омСервер.ПересчетЗн(гоРеквизит(НовПар, "ЦенаЗакупки"), гоРеквизит(НовПар, "Валюта"), Объект.Валюта, Объект.Фирма, Объект.Дата, ЧислоЗнаковЦена);
	ЦенаСоСкидкой = гоРеквизит(НовПар, 	"ВКД_ЦенаСоСкидкой");
	ЦенаЗакупки = гоРеквизит(НовПар, 	"ЦенаЗакупки");
	
	Сумма = ?(ЦенаСоСкидкой = 0, ЦенаЗакупки, ЦенаСоСкидкой ) + ЗатратыПартии(НовПар);
	
	// © Primus1C  27.04.2026  НАЧАЛО ►
	//НовЦен = омСервер.ПересчетЗн(Сумма, гоРеквизит(НовПар, "Валюта"), Объект.Валюта, Объект.Фирма, Объект.Дата, ЧислоЗнаковЦена);			
	ЦенаСЗатратами = РаботаСВалютой.Пересчитать2025(Сумма, гоРеквизит(НовПар, "Валюта"), Объект.Валюта, Объект.Фирма, Объект.Дата);			
	// © Primus1C  ОКОНЧАНИЕ ◄
	//ВКД--
		 
	Пар = Новый Структура;
	Пар.Вставить("Фирма", Объект.Фирма);
	Пар.Вставить("Номенклатура", НовНом);
	Пар.Вставить("Валюта", Объект.Валюта);
	Пар.Вставить("Количество", ОстПар);
	Пар.Вставить("Цена", ЦенаСЗатратами);
	Пар.Вставить("ЦенаЗакупки", ЦенаСЗатратами);
	Пар.Вставить("Склад", Объект.Склад);
	Пар.Вставить("Партия", НовПар);
	
	ОткрытьФорму("ОбщаяФорма.ВводСтрокиРН", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("МоеДобавлениеПослеВводаСтроки", ЭтотОбъект, Новый Структура("НовНом,НовПар", НовНом, НовПар)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВводаСтроки(Пар, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	
	Если гоПЗ(Пар) Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	НовЦен = Пар.Цена;
	Если НовЦен = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введена цена продажи!'; en = 'Selling price not entered!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	НовКол = Пар.Количество;
	Если НовКол = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введено количество!'; en = 'Quantity not entered!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	клСохранитьИзменения(Новый ОписаниеОповещения("МоеДобавлениеПослеПодтвержденияПартии", ЭтотОбъект, 
		Новый Структура("НовНом,НовПар,НовКол,НовЦен", НовНом, НовПар, НовКол, НовЦен)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеПодтвержденияПартии(Результат, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	НовКол = Параметры.НовКол;
	НовЦен = Параметры.НовЦен;
	
	Если НЕ Результат Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если НовКол > ОстПар Тогда 
		клОшибка(СтрШаблон(НСтр("ru = 'Не хватило остатка %1 для %2, исправлено на %3!'; en = 'There was not enough balance %1 for %2, corrected for %3!'"), Строка(НовКол - ОстПар), гоИмя(НовПар), ОстПар));
		НовКол = ОстПар;
	КонецЕсли;
	
	МоеДобавлениеЗавершить(НовНом, НовПар, НовКол, НовЦен);
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеЗавершить(НовНом, НовПар, НовКол, НовЦен)
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНом;
	НовСтр.Партия = НовПар;
	НовСтр.Количество = НовКол;
	НовСтр.ЦенаПродажи = НовЦен;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоСуммаЗн(НовЦен, ЧислоЗнаковЦена) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	МоеДобавлениеШаг(НовНом);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗатратыПартии(Партия)

	ВсеЗатраты = Документы.РасходнаяНакладная.ЗатратыПартий(Партия);	
	Результат = 0;  
	сум = ВсеЗатраты.ЗатратыПартии.Получить(Партия); 
	Если сум <> Неопределено Тогда
		Результат = Результат + сум;
	КонецЕсли;
	сум = ВсеЗатраты.ЗатратыПартииИнвойсов.Получить(Партия); 
	Если сум <> Неопределено Тогда
		Результат = Результат + сум;
	КонецЕсли;
	Возврат Результат;
	
КонецФункции 

&НаКлиенте
Процедура ЛюбаяСерия(НовСер, СтатьНаРучной = Ложь, ЦенаУжеТут = -1)
//2016.03.25 + СтатьНаРучной = Ложь
//2016.04.07 + ЦенаУжеТут = -1

	ШК = СокрЛП(НовСер);
	Если ШК = "" Тогда Возврат КонецЕсли; 

	//2016.04.07
	Если НЕ (ЦенаУжеТут = -1) Тогда  
		//придется все продублировать
		Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
		Если Объект.Окончательно Тогда Возврат КонецЕсли; 
		
		МоиИтоги();
		Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
		
		Если гоПЗ(Объект.Склад) Тогда клОшибка(НСтр("ru = 'Не задан склад!'; en = 'Warehouse not specified!'")); Возврат; КонецЕсли; 
		Если гоПЗ(Объект.Валюта) Тогда клОшибка(НСтр("ru = 'Не задана валюта!'; en = 'Currency not specified!'")); Возврат; КонецЕсли; 
		
		Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли; 
	КонецЕсли; 
	
	//по идее, нужно найти товар с такой серией и передать его в добавление строки, зачем изобретать велосипед?
	СпиПар = омСервер.ПартииПоСерииОстатки(ШК, Объект.Фирма, Объект.Склад);
	
	Ско = СпиПар.Количество();
	Если Ско = 0 Тогда
		Сигнал();
		клОшибка(СтрШаблон("%1: %2 %3", 
							омСервер.Фрмт(НСтр("ru = 'Нет остатков по серии'; en = 'There are no remaining goods for the series!'"), "НАДПИСЬ_ЦВ1"), 
							омСервер.Фрмт(ШК, "НАДПИСЬ_ЦВ2"),
							омСервер.Фрмт("!", "НАДПИСЬ_ЦВ1")));
		Возврат;
	ИначеЕсли Ско > 1 Тогда
		Сигнал();
		СпиПар.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("ЛюбаяСерияПослеВыбораПартии", ЭтотОбъект, Новый Структура("ШК,СтатьНаРучной,ЦенаУжеТут", ШК, СтатьНаРучной, ЦенаУжеТут)),
			НСтр("ru = 'Найдено несколько партий с такой серией, выберите:'; en = 'Several batches with this series have been found, please select:'"));
		Возврат;
	КонецЕсли; 
	
	ЛюбаяСерияПродолжение(СпиПар[0].Значение, ШК, СтатьНаРучной, ЦенаУжеТут);
КонецПроцедуры

