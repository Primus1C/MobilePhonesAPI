&НаКлиенте
Процедура Снять(Команда)
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли; 
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("СнятьПослеПодтверждения", ЭтотОбъект), НСтр("ru = 'Снять флаг <Окончательно>?'; en = 'Unset flag <Finaly>?'"));
КонецПроцедуры

&НаКлиенте
Процедура СнятьПослеПодтверждения(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	//2016.01.31
	Если Объект.счеКонсигнация = 0 Тогда 
		//тут все обыденно
		Объект.Окончательно = Ложь;
		МояЗаписать(Ложь);
		СнятьЗавершение();
	Иначе 
		клНетДа(Новый ОписаниеОповещения("СнятьПослеПодтвержденияКонсигнации", ЭтотОбъект), СтрШаблон(
				НСтр("ru = 'Есть строки с К-партиями: %1!%2В их приходах будут возвращены НУЛЕВЫЕ цены, долг поставщику уменьшится и может стать ОТРИЦАТЕЛЬНЫМ!!!%2 Все равно продолжать?'; 
				|en = 'There are lines with K-parties: %1!%2ZERO prices will be returned to their receipts, the debt to the supplier will decrease and may become NEGATIVE!!!%2 Should we continue anyway?'"), 
				Объект.счеКонсигнация, гоРС()));
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура СнятьПослеПодтвержденияКонсигнации(Результат, ДопПараметры) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	//ставим все в транзакции на сервере, чтобы иметь возможность все отменить
	О = "";
	М = Новый Массив;
	УстановитьСервер(О, Истина, М);
	Если клЕстьОшибка(О) Тогда Возврат КонецЕсли;
	
	//тут вручную обновим все
	УстановитьВидимостьДоступность();
	МоиОстатки();
	МоиИтоги();
	
	клОповеститьОбИзмененииМассив(М);
	
	СнятьЗавершение();
КонецПроцедуры

