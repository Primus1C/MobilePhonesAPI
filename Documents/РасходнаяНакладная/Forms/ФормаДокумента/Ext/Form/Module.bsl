	БуфДок = Параметры.БуфДок;
	БуфСтр = Параметры.БуфСтр;
	БуфКол = БуфСтр.Количество();
	
	клНетДа(Новый ОписаниеОповещения("ВставитьСтрокиИзБуфераЗавершение", ЭтотОбъект, Новый Структура("БуфДок,БуфСтр,НовЦен", БуфДок, БуфСтр, НовЦен)),
		"Вставить из " + гоИмя(БуфДок) + " " + ?(БуфКол = 0, "все строки", " выделенные строки (" + БуфКол + ")") + "?");
