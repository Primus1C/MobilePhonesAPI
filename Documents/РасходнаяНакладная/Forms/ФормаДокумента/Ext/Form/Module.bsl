&НаКлиенте
Процедура ЛюбаяСерияПродолжение(ТекПар, ШК, СтатьНаРучной, ЦенаУжеТут)
	Если ТекПар = 0 Тогда Возврат КонецЕсли; 
	
	НовКол = 1;
	//НовЦен = омСервер.ПересчетЗн(гоРеквизит(ТекПар, "ЦенаЗакупки"), гоРеквизит(ТекПар, "Валюта"), Объект.Валюта, Объект.Фирма, Объект.Дата, ЧислоЗнаковЦена);	//вот вопрос!!!
	НовЦен = РаботаСВалютой.Пересчитать2025(гоРеквизит(ТекПар, "ЦенаЗакупки"), гоРеквизит(ТекПар, "Валюта"), Объект.Валюта, Объект.Фирма, Объект.Дата);
	НовНом = гоРеквизит(ТекПар, "Владелец");
	
	//2016.12.14
	Если гоРеквизит(НовНом, "ЗапретОтгрузки") Тогда клОшибка(НСтр("ru = 'Включен запрет отгрузки, выберите другую номенклатуру!'; en = 'Shipment prohibition is enabled, select another good!'")); Возврат; КонецЕсли;
	
	//2016.04.23
	//если уже есть такой товар, зачем искать цену
	ЕстЦен = 0;
	Если Объект.Товары.Количество() > 0 Тогда
		Мас = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", НовНом));
		Если Мас.Количество() > 0 Тогда ЕстЦен = Мас[0].ЦенаПродажи КонецЕсли;
	КонецЕсли; 

	//2016.04.23
	Если ЕстЦен <> 0 Тогда 
		НовЦен = ЕстЦен;
	Иначе 
		//2016.04.07
		Если НЕ (ЦенаУжеТут = -1) Тогда  
			Если НЕ (ЦенаУжеТут = 0) Тогда  
				НовЦен = ЦенаУжеТут;
			КонецЕсли; 
		Иначе
			ПоказатьВводЧисла(Новый ОписаниеОповещения("ЛюбаяСерияПослеВводаЦены", ЭтотОбъект, Новый Структура("ТекПар,ШК,НовНом,НовКол,СтатьНаРучной", ТекПар, ШК, НовНом, НовКол, СтатьНаРучной)),
				НовЦен, НСтр("ru = 'Цена (подставлена закупка по курсу)'; en = 'Price (purchase is set at the exchange rate)'"), 19, ЧислоЗнаковЦена);
			Возврат;
		КонецЕсли; 
	КонецЕсли;
	
	ЛюбаяСерияЗавершить(ТекПар, ШК, НовНом, НовКол, НовЦен, СтатьНаРучной);
КонецПроцедуры

&НаКлиенте
