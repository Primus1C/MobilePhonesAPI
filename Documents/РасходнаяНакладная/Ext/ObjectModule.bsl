		КонецЕсли; 
		
		//2017.01.17
		Если ЗначениеЗаполнено(Стр.ДатаВозврата) Тогда 
			Стр.СуммаЗакупки = 0;
		Иначе 
			Стр.СуммаЗакупки = Стр.ЦенаЗакупки * Стр.Количество;
		КонецЕсли;
		
		////ВКД++
		////Стр.стрПроцент = гоПроцент0(Стр.СуммаПродажи, Стр.СуммаЗакупки);
		//Если Стр.ВКД_ЦенаСЗатратами = 0 Тогда
		//	Стр.стрПроцент = гоПроцент0(Стр.СуммаПродажи, Стр.СуммаЗакупки);
		//Иначе
		//	//Вставка ВИКОД
		//	//Автор: Белеля Т, 07.04.2023, Задача:000017307
		//	//Стр.стрПроцент = гоПроцент0(Стр.СуммаПродажи, Стр.ВКД_ЦенаСЗатратами); 
		//	Стр.стрПроцент = гоПроцент0(Стр.СуммаПродажи, Стр.ВКД_ЦенаСЗатратами*Стр.Количество);
		//    //окончание вставки
		//КонецЕсли;
		////ВКД--
		
		//2016.01.31
		Стр.счКонсигнация = ?(Стр.Партия.Консигнация, 1, 0);
		//2016.05.24
		Стр.СуммаУслуг = 0;
		
	Иначе 
		
		//2016.05.24
		Стр.Серия = "";
		Стр.ЦенаЗакупки = 0;
		Стр.стрПроцент = "У";
		Стр.счКонсигнация = 0;
		Стр.СуммаУслуг = Стр.СуммаПродажи;
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ПересчитатьИтоги()

	Сумма = Товары.Итог("СуммаПродажи");

	СуммаЗакупки = Товары.Итог("СуммаЗакупки");
	
	//ВКД++
	ВКД_СуммаСоСкидкой = Товары.Итог("ВКД_ЦенаСоСкидкой");

	//Вставка ВИКОД
	//Автор: Белеля Т, 07.04.2023, Задача:000017307
	//ВКД_СуммаСЗатратами = Товары.Итог("ВКД_ЦенаСЗатратами");   
	лВКД_СуммаСЗатратами = 0;
	Для каждого стр из Товары цикл
		лВКД_СуммаСЗатратами = лВКД_СуммаСЗатратами + стр.ВКД_ЦенаСЗатратами * стр.Количество;   
	КонецЦикла;
	//окончание вставки
	ВКД_СуммаСЗатратами = лВКД_СуммаСЗатратами;
	
	//ВКД--
	
	//2016.05.24
	СуммаУслуг = Товары.Итог("СуммаУслуг");
	
	//ВКД++
	//стрПроцент = гоПроцент0(Сумма - СуммаУслуг, СуммаЗакупки);
	Если ВКД_СуммаСЗатратами = 0 Тогда
	  стрПроцент = гоПроцент0(Сумма - СуммаУслуг, СуммаЗакупки);
    Иначе 
	  стрПроцент = гоПроцент0(Сумма - СуммаУслуг, ВКД_СуммаСЗатратами);
    КонецЕсли;
	//ВКД--
	
	Строк = Товары.Количество();
	СуммаПривязано = Привязки.Итог("Сумма1");
	//2016.01.31
	счеКонсигнация = Товары.Итог("счКонсигнация");  
	
КонецПроцедуры

