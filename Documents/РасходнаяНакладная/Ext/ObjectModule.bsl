		////////-
		Стр.стрПроцент = гоПроцент0(Стр.СуммаПродажи, Стр.ВКД_ЦенаСЗатратами * Стр.Количество);
		
		// © Primus1C  ОКОНЧАНИЕ ◄
		
		//2016.01.31
		СтрПартияЦенаЗакупки = Стр.Партия.ЦенаЗакупки;
		Если (СтрПартияЦенаЗакупки = 0) И (Стр.Партия.Консигнация) Тогда
			Стр.ЦенаЗакупки = Стр.ЦенаПродажи;
		//Иначе 
