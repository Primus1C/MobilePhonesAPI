	                     |	ТЧТовары.Ссылка.Фирма КАК Фирма,
	                     |	ТЧТовары.Номенклатура КАК Номенклатура,
	                     |	ТЧТовары.Серия КАК Серия,
	                     |	ТЧТовары.Партия КАК Партия,
	                     |	ТЧТовары.Партия.ЦенаЗакупкиВБазВалюте КАК ЦенаЗакупкиВБазВалюте,
	                     |	ТЧТовары.Партия.Док КАК ДокументПартии,
	                     |	ТЧТовары.Партия.Контрагент КАК Поставщик,
	                     |	ТЧТовары.ДатаВозврата КАК ДатаВозврата,
	                     |	ТЧТовары.Количество КАК Количество,
	                     |	ТЧТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар) КАК ЭтоТовар,
	                     |	ТЧТовары.ВКД_ЦенаСЗатратами КАК ВКД_ЦенаСЗатратами,
	                     |	ТЧТовары.СуммаПродажи КАК СуммаПродажи,
	                     |	ТЧТовары.СуммаЗакупки КАК СуммаЗакупки
	                     |ИЗ
	                     |	Документ.РасходнаяНакладная.Товары КАК ТЧТовары
	                     |ГДЕ
	                     |	ТЧТовары.Ссылка = &Ссылка
	                     |	И ТЧТовары.Количество <> 0"; 
	Стр = ЗапросТовары.Выполнить().Выбрать();
	
	//Для Каждого Стр Из Товары Цикл  
	Пока Стр.Следующий() Цикл
		
		//Если Стр.Количество = 0 Тогда Продолжить КонецЕсли; 
		//2016.05.24
		//услуги не проводим по остаткам
		Если НЕ ЗначениеЗаполнено(Стр.Партия) Тогда Продолжить КонецЕсли;
		
		Если Стр.ЭтоТовар Тогда
			Движение = Движения.ОстаткиТовара.ДобавитьРасход();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Склад = Склад;
			Движение.Номенклатура = Стр.Номенклатура;
			Движение.Партия = Стр.Партия;
			Движение.Остаток = Стр.Количество;
			Движение.Резерв = 0;
			ЕстьОстатки = Истина;
		КонецЕсли;
		
		//2017.01.18
		Если ЗначениеЗаполнено(Стр.ДатаВозврата) И Стр.ЭтоТовар Тогда
			//тут же возвращаем все, например, с минусом
			Движение = Движения.ОстаткиТовара.ДобавитьРасход();
			Движение.Период = Стр.ДатаВозврата;
			Движение.Фирма = Фирма;
			Движение.Склад = Склад;
			Движение.Номенклатура = Стр.Номенклатура;
			Движение.Партия = Стр.Партия;
			Движение.Остаток = - Стр.Количество;
			Движение.Резерв = 0;
			ЕстьОстатки = Истина;
		Иначе
			//все остальное: резервы и специальный регистр продаж - только если нет возврата
			Если НЕ Окончательно И Стр.ЭтоТовар Тогда
				Движение = Движения.ОстаткиТовара.ДобавитьПриход();
				Движение.Период = Дата;
				Движение.Фирма = Фирма;
				Движение.Склад = Склад;
				Движение.Номенклатура = Стр.Номенклатура;
				Движение.Партия = Стр.Партия;
				Движение.Остаток = 0;
				Движение.Резерв = Стр.Количество;
				ЕстьОстатки = Истина;
				
				////2015.12.08
				//Движение = Движения.РезервыТовара.ДобавитьПриход();
				//Движение.Период = Дата;
				//Движение.Фирма = Фирма;
				//Движение.Склад = Склад;
				//Движение.Номенклатура = Стр.Номенклатура;
				//Движение.Партия = Стр.Партия;
				//Движение.Док = Ссылка;
				//Движение.Остаток = Стр.Количество;
				//ЕстьРезервы = Истина;
			Иначе
				//2015.12.11
				Движение = Движения.Продажи.Добавить();
				Движение.Период = Дата;
				Движение.Фирма = Фирма;
				Движение.Валюта = Валюта;
				Движение.Покупатель = Контрагент;
				Движение.Номенклатура = Стр.Номенклатура;
				Движение.Количество = Стр.Количество;
				Движение.Сумма = Стр.СуммаПродажи; 
				Движение.Склад = Склад;
				//ВКД Кононов А.М. 05.02.20
				//Движение.Наценка = Стр.СуммаПродажи - Стр.СуммаЗакупки;
				Движение.Наценка = Стр.СуммаПродажи - (Стр.ВКД_ЦенаСЗатратами * Стр.Количество);
				//..     
				// © Primus1C  09.03.2025  НАЧАЛО ► 
				Движение.Партия = Стр.Партия;
				////Если Валюта <> ВалютаРубль Тогда
				////	Движение.НаценкаВалютная = Стр.СуммаПродажи - Стр.СуммаЗакупки;
				////КонецЕсли;      
				СуммаВБазВалюте = РаботаСВалютой.Пересчитать2025(Стр.СуммаПродажи, Валюта, ВалютаДоллар, Фирма, Дата);
				Движение.СуммаВБазВалюте = СуммаВБазВалюте;
				//Движение.НаценкаВБазВалюте = СуммаВБазВалюте - Стр.Количество * Стр.ЦенаЗакупкиВБазВалюте;
				Движение.НаценкаВБазВалюте = РаботаСВалютой.Пересчитать2025(Движение.Наценка, Валюта, ВалютаДоллар, Фирма, Дата);
				// © Primus1C  ОКОНЧАНИЕ ◄
				Движение.Поставщик = Стр.Поставщик;
				//2016.04.07
				//Движение.ДокументПрихода = Стр.Партия.Док;
				Движение.ДокументПрихода = Стр.ДокументПартии;
				//2016.09.12
				Движение.Автор = КемСоздан;
				ЕстьПродажи = Истина;
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;

	Если Окончательно Тогда
		
		//2015.11.21
		//появился регистр доходов
		
		//ВКД Кононов А.М. 05.02.20
		//локСумма = Сумма - СуммаЗакупки - СуммаУслуг;
		СуммаСЗатратами = 0;
		Для Каждого Стр Из Товары Цикл
			СуммаСЗатратами = СуммаСЗатратами + (Стр.Количество * Стр.ВКД_ЦенаСЗатратами);
		КонецЦикла;
		локСумма = Товары.Итог("СуммаПродажи") - СуммаСЗатратами - СуммаУслуг;
		//..
		
		// © Primus1C  04.12.2025  НАЧАЛО ►
		Запр = Новый Запрос;
		Запр.Текст = "ВЫБРАТЬ
		             |	СУММА(РНТовары.СуммаПродажи - РНТовары.Количество * РНТовары.ВКД_ЦенаСЗатратами) КАК СуммаСЗатратами,
		             |	РНТовары.Партия.Док.ВКД_Инвойс.ДокументОснование.СкладОтправитель.Статья КАК Статья
		             |ИЗ
		             |	Документ.РасходнаяНакладная.Товары КАК РНТовары
		             |ГДЕ
		             |	РНТовары.Ссылка = &Ссылка
		             |	И РНТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		             |
		             |СГРУППИРОВАТЬ ПО
		             |	РНТовары.Партия.Док.ВКД_Инвойс.ДокументОснование.СкладОтправитель.Статья";
		Запр.УстановитьПараметр("Ссылка", Ссылка);
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл  
			Если ЗначениеЗаполнено(Выборка.Статья) Тогда
				лСтатья = Выборка.Статья	
			Иначе
			    лСтатья = Справочники.Статьи.ДоходОтПродажи;
			КонецЕсли;
			//Сообщить(СтрШаблон("%1: %2", лСтатья, Выборка.СуммаСЗатратами)); 
			Движение = Движения.РасходыДоходы.Добавить();
			Движение.Период 	= Дата;
			Движение.Фирма 		= Фирма;
			Движение.Вид 		= Перечисления.ДоходРасход.Доход;
			Движение.Статья 	= лСтатья;
			Движение.Валюта 	= Валюта;
			Движение.Сумма 		= Выборка.СуммаСЗатратами;
			ЕстьРасходыДоходы 	= Истина;
		КонецЦикла;
		
		// © Primus1C  ОКОНЧАНИЕ ◄
		
		//Если локСумма <> 0 Тогда
		//	Движение = Движения.РасходыДоходы.Добавить();
		//	Движение.Период = Дата;
		//	Движение.Фирма = Фирма;
		//	Движение.Вид = Перечисления.ДоходРасход.Доход;
		//	Движение.Статья = Справочники.Статьи.ДоходОтПродажи;
		//	Движение.Валюта = Валюта;
		//	//2016.05.24
		//	//исключаем услуги именно из доходов
		//	Движение.Сумма = локСумма;
		//	ЕстьРасходыДоходы = Истина;
		//КонецЕсли; 
		
		//2016.05.29
		//договорились, что проводим услуги отдельной статьей
		Если СуммаУслуг <> 0 Тогда  
			Движение = Движения.РасходыДоходы.Добавить();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Вид = Перечисления.ДоходРасход.Доход;
			Движение.Статья = Справочники.Статьи.ДоходОтУслуг;
			Движение.Валюта = Валюта;
			Движение.Сумма = СуммаУслуг;
			ЕстьРасходыДоходы = Истина;
		КонецЕсли;
		
		Движение = Движения.Долги.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Фирма = Фирма;
		Движение.Док = Ссылка;
		Движение.Валюта = Валюта;
		Движение.Контрагент = Контрагент;
		Движение.ДолгПокупателя = Сумма;
		Движение.ПредоплатаПокупателя = 0;
		Движение.ДолгПоставщику = 0;
		Движение.ПредоплатаПоставщику = 0;
		Движение.Чем = 0;
		ЕстьДолги = Истина;
		
		Для Каждого Стр Из Привязки Цикл
			Движение = Движения.Долги.ДобавитьРасход();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Док = Стр.Док2;
			Движение.Валюта = Стр.Валюта2;
			Движение.Контрагент = Контрагент;
			Движение.ДолгПокупателя = 0;
			Движение.ПредоплатаПокупателя = ?(Стр.ЭтоПредоплата, Стр.Сумма2, 0);
			Движение.ДолгПоставщику = ?(Стр.ЭтоПредоплата, 0, Стр.Сумма2);
			Движение.ПредоплатаПоставщику = 0;
			Движение.Чем = Ссылка;
			ЕстьДолги = Истина;
			
			Движение = Движения.Долги.ДобавитьРасход();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Док = Ссылка;
			Движение.Валюта = Валюта;
			Движение.Контрагент = Контрагент;
			Движение.ДолгПокупателя = Стр.Сумма1;
			Движение.ПредоплатаПокупателя = 0;
			Движение.ДолгПоставщику = 0;
			Движение.ПредоплатаПоставщику = 0;
			Движение.Чем = Стр.Док2;
			ЕстьДолги = Истина;
		КонецЦикла; 
		
		//2015.11.27
		//универсально, независимо от типа, проводим КР, если они есть
		Если СуммаКР <> 0 Тогда
			Движение = Движения.РасходыДоходы.Добавить();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Статья = ?(СуммаКР < 0, Справочники.Статьи.РасходОтКР, Справочники.Статьи.ДоходОтКР);
			//здесь вид после статьи
			Движение.Вид = Движение.Статья.ВидСтатьи;
			Движение.Валюта = Валюта;
			Движение.Сумма = гоАбс(СуммаКР);
			ЕстьРасходыДоходы = Истина;
		КонецЕсли; 
		
	Иначе // НЕ Окончательно
		
		Движение = Движения.НезакрытыеДокументы.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Фирма = Фирма;
		Движение.Контрагент = Контрагент;
		Движение.ВидДокумента = Перечисления.ВидДокумента.РасходнаяНакладная;
		Движение.Количество = 1;
		ЕстьНезакрытые = Истина; 
		
	КонецЕсли; 
	
	// © Primus1C  22.07.2026  НАЧАЛО ►
	
	// РН РезервыТовара  
	
	Движения.РезервыТовара.Записывать = Истина;
	
	Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ИнвойсПродажи") И ДокументОснование.РезервироватьТовар Тогда
	
		Запр = Новый Запрос;
		Запр.УстановитьПараметр("Ссылка", Ссылка);
		Запр.Текст = "ВЫБРАТЬ
		             |	ТЧТовары.Номенклатура КАК Номенклатура,
		             |	СУММА(ТЧТовары.Количество) КАК Количество
		             |ИЗ
		             |	Документ.РасходнаяНакладная.Товары КАК ТЧТовары
		             |ГДЕ
		             |	ТЧТовары.Ссылка = &Ссылка
		             |	И ТЧТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		             |
		             |СГРУППИРОВАТЬ ПО
		             |	ТЧТовары.Номенклатура";
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Движение = Движения.РезервыТовара.Добавить();
			Движение.ВидДвижения 	= ВидДвиженияНакопления.Расход;
			Движение.Период 		= Дата;
			Движение.Номенклатура 	= Выборка.Номенклатура;
			Движение.Заказ 			= ДокументОснование;   
			Движение.Склад          = Склад;
			Движение.Фирма          = Фирма;
			Движение.Количество 	= Выборка.Количество;
		КонецЦикла;
		
	КонецЕсли;
	
	// © Primus1C  ОКОНЧАНИЕ ◄

	Движения.Долги.Записывать = ЕстьДолги;
	Движения.ОстаткиТовара.Записывать = ЕстьОстатки;
	Движения.НезакрытыеДокументы.Записывать = ЕстьНезакрытые;
	Движения.РасходыДоходы.Записывать = ЕстьРасходыДоходы;
	//2015.12.08
	//Движения.РезервыТовара.Записывать = ЕстьРезервы;
	//2015.12.11
	Движения.Продажи.Записывать = ЕстьПродажи; 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	Если гоАдминистратор() Тогда 
		УстановитьСтатус(Перечисления.СтатусыИнвойсаПродажи.ГотовКОтгрузке);
		Возврат; 
	КонецЕсли; 
	
	Если Окончательно Тогда Сообщить(НСтр("ru = 'Отмена проведения невозможна! Документ закрыт {Окончательно}!'; en = 'Unposted is not possible! The document is closed <Finally>!'")); Отказ = Истина; КонецЕсли;
	
	Если Товары.Количество() <> 0 Тогда Сообщить(НСтр("ru = 'Отмена проведения невозможна! Документ не пустой!'; en = 'Unposted is not possible! The document is not empty!'")); Отказ = Истина; КонецЕсли;
	
	//	Если НачалоДня(Дата) < гоТекущаяДата() Тогда
	//		Сообщить("Только Избранный!"); Отказ = Истина; Возврат; КонецЕсли;   

	УстановитьСтатус(Перечисления.СтатусыИнвойсаПродажи.ГотовКОтгрузке);
	
КонецПроцедуры

Процедура УстановитьСтатус(Статус)

	Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ИнвойсПродажи") Тогда                
		КемИзменено = Неопределено;
		РаботаСИнвойсами.ЗаписатьСтатусИнвойсаПродажи(ДокументОснование, Статус, Ссылка, КемИзменено);
	КонецЕсли;

КонецПроцедуры

