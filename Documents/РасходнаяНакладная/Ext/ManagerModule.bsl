Процедура ПечатьДокумента_(Тек, Поз, Таб, ПоАлфавиту) Экспорт
	Таб.Очистить();
	
	М = Документы.РасходнаяНакладная.ПолучитьМакет("Печать");
	С = Новый Структура;
	гоВставитьКучу(С, "Загол, ИмяПокупателя1, ИмяПокупателя2, ИмяПокупателя3, ИмяПоставщика1, ИмяПоставщика2, ИмяПоставщика3, ИмяПоставщика4, ИмяПоставщика5, ИмяПоставщика6");
	гоВставитьКучу(С, "ИмяСклада, ДопНомера, НомерПП, лНоменклатура, лЕИ, лКоличество, лЦена, лСумма, сКоличество, сБезНДС, сНДС, сСумма, ссСкидка, сСкидка, СтрСНДС,Задолженность");
	гоВставитьКучу(С, "лБезНДС, лНДС, лСкидка, лВалюта, сВалюта, лОплата");
	//2016.04.07
	гоВставитьКучу(С, "лСерия");
	
	С.Загол = "Расходная накладная № " + Тек.Номер + " от " + гоДата(Тек.Дата);
	С.ИмяСклада = СокрЛП(Тек.Склад);
	С.ИмяПоставщика1 = "";
	С.ИмяПоставщика2 = "";
	С.ИмяПоставщика3 = "";
	С.ИмяПоставщика4 = "";
	С.ИмяПоставщика5 = "";
	С.ИмяПоставщика6 = "";
	С.ИмяПокупателя1 = "";
	С.ИмяПокупателя2 = "";
	С.ИмяПокупателя3 = "";

	Если гоНПЗ(Тек.Фирма) Тогда
		С.ИмяПоставщика1 = СокрЛП(Тек.Фирма.ПолнНаименование);
	КонецЕсли;
	
	ДляПечати = СокрЛП(Тек.ДляПечати);
	
	Если ДляПечати = "" Тогда 
		Если гоНПЗ(Тек.Контрагент) Тогда
			С.ИмяПокупателя1 = СокрЛП(Тек.Контрагент.ПолнНаименование);
			Если С.ИмяПокупателя1 = "" Тогда С.ИмяПокупателя1 = СокрЛП(Тек.Контрагент.Наименование) КонецЕсли;
			С.ИмяПокупателя2 = СокрЛП(Тек.Контрагент.Телефоны);
			С.ИмяПокупателя3 = СокрЛП(Тек.Контрагент.Адрес);
		КонецЕсли;
	Иначе 
		С.ИмяПокупателя1 = ДляПечати;
	КонецЕсли; 
	
	Фикс = 4;
	ВывестиСекцию(Таб, М, "ШапкаП1", С); гоПлюс(Фикс);
	Если С.ИмяПоставщика2 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП2", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика3 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП3", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика4 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП4", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика5 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП5", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПоставщика6 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаП6", С); гоПлюс(Фикс); КонецЕсли;
	ВывестиСекцию(Таб, М, "ШапкаК1", С); гоПлюс(Фикс);
	Если С.ИмяПокупателя2 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаК2", С); гоПлюс(Фикс); КонецЕсли;
	Если С.ИмяПокупателя3 <> "" Тогда ВывестиСекцию(Таб, М, "ШапкаК3", С); гоПлюс(Фикс); КонецЕсли;
	
	ВывестиСекцию(Таб, М, "Шапка", С);
	
	Табл = Тек.Товары.Выгрузить();
	// © Primus1C  11.12.2025  НАЧАЛО ►
	Запр = Новый Запрос; 
	Запр.УстановитьПараметр("Ссылка", Тек);
	Запр.Текст = "ВЫБРАТЬ
	             |	РНТовары.Номенклатура КАК Номенклатура,
	             |	РНТовары.Серия КАК Серия,
	             |	РНТовары.ЦенаЗакупки КАК ЦенаЗакупки,
	             |	РНТовары.Количество КАК Количество,
	             |	РНТовары.СуммаЗакупки КАК СуммаЗакупки,
	             |	РНТовары.ДляПечати КАК ДляПечати,
	             |	РНТовары.ЦенаПродажи КАК ЦенаПродажи,
	             |	РНТовары.СуммаПродажи КАК СуммаПродажи,
	             |	РНТовары.стрПроцент КАК стрПроцент,
	             |	РНТовары.счКонсигнация КАК счКонсигнация,
	             |	РНТовары.СуммаУслуг КАК СуммаУслуг,
	             |	РНТовары.ДатаВозврата КАК ДатаВозврата,
	             |	РНТовары.ВКД_ЦенаСоСкидкой КАК ВКД_ЦенаСоСкидкой,
	             |	РНТовары.ВКД_ЦенаСЗатратами КАК ВКД_ЦенаСЗатратами,
	             |	РНТовары.Партия КАК Партия,
	             |	РНТовары.НомерСтроки КАК НомерСтроки
	             |ИЗ
	             |	Документ.РасходнаяНакладная.Товары КАК РНТовары
	             |ГДЕ
	             |	РНТовары.Ссылка = &Ссылка";
	Если ПоАлфавиту Тогда
		Запр.Текст = Запр.Текст + " УПОРЯДОЧИТЬ ПО РНТовары.Номенклатура.Наименование";	
	КонецЕсли;
	Табл = Запр.Выполнить().Выгрузить();
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	//2016.04.07
	Если Поз = 2 Тогда 
		Сабл = Табл.Скопировать();
		Сабл.Свернуть("Номенклатура, ДляПечати, ЦенаПродажи, Серия", "Количество, СуммаЗакупки");
		Сабл.Сортировать("Номенклатура ВОЗР, ДляПечати ВОЗР, ЦенаПродажи ВОЗР, Серия ВОЗР");
		Сабл.Индексы.Добавить("Номенклатура, ДляПечати, ЦенаПродажи");
	КонецЕсли; 
	
	Табл.Свернуть("Номенклатура, ДляПечати, ЦенаПродажи", "Количество, СуммаПродажи");
	
	С.лВалюта = СокрЛП(Тек.Валюта);
	
	ЧислоЗнаковЦена = Тек.Фирма.ЧислоЗнаковЦена;
	
	НомерПП = 0;
	Для Каждого _Табл Из Табл Цикл
		гоПлюс(НомерПП);
		
		ДляПечати = СокрЛП(_Табл.ДляПечати);
		Если ДляПечати = "" Тогда 
			С.лНоменклатура = гоИмя(_Табл.Номенклатура, Ложь);
		Иначе 
			С.лНоменклатура = ДляПечати;
		КонецЕсли; 
		
		С.НомерПП = НомерПП;
		С.лЕИ = "шт.";	//СокрЛП(_Табл.Номенклатура.ЕИ);
		С.лКоличество = _Табл.Количество;
		
		С.лЦена = гоСуммаЗн(_Табл.ЦенаПродажи, ЧислоЗнаковЦена);
		С.лСумма = гоЦена2(_Табл.СуммаПродажи);
		
		ВывестиСекцию(Таб, М, "Строка", С);
		
		//2016.04.07
		Если Поз = 2 Тогда
			Мас = Сабл.НайтиСтроки(Новый Структура("Номенклатура, ДляПечати, ЦенаПродажи", _Табл.Номенклатура, _Табл.ДляПечати, _Табл.ЦенаПродажи));
			Для Каждого _Сабл Из Мас Цикл
				С.лСерия = _Сабл.Серия;
				С.лКоличество = _Сабл.Количество;
				ВывестиСекцию(Таб, М, "СтрокаС", С);
			КонецЦикла; 
		КонецЕсли; 
	КонецЦикла;
	
	С.сКоличество = Табл.Итог("Количество");
	С.сВалюта = С.лВалюта;
	
	лСумПро = Тек.Сумма;
	чСумма = 0;
	чСумма = лСумПро;
	С.сСумма = гоЦена2(чСумма);
	С.сБезНДС = гоЦена2(чСумма);
	С.сНДС = гоЦена2(0);
	С.СтрСНДС = гоСуммаПрописьюВал(чСумма, Тек.Валюта);	// + гоРС() + "Без НДС.";
	
	//+++++++++++++18.11.2019
	//-----------------------
	//+++++++++++++++++++++++
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДолгиОстатки.Валюта,
	               |	ДолгиОстатки.ПокупательОстаток
	               |ИЗ
	               |	РегистрНакопления.Долги.Остатки(
	               |			,
	               |			Контрагент = &Контрагент
	               |				И Фирма = &Фирма) КАК ДолгиОстатки";
	Запрос.УстановитьПараметр("Контрагент",Тек.Контрагент);
	Запрос.УстановитьПараметр("Фирма",Тек.Фирма);
	Выборка = ЗАпрос.Выполнить().Выбрать();
	СтрокаЗадолженность = "Задолженность : ";
	Пока Выборка.Следующий() Цикл
		 СтрокаЗадолженность = СтрокаЗадолженность+ " 
		 | "+ Выборка.ПокупательОстаток + " " + Выборка.Валюта+ ";";	
	 КонецЦикла;
	 С.Задолженность = СтрокаЗадолженность;
	//+++++++++++++++++++++++
	//-----------------------
	//+++++++++++++18.11.2019

	ВывестиСекцию(Таб, М, "Подвал", С);
	
	//глПараметрыСтраницы(Таб, 1);
	//глПовторятьПриПечатиСтроки(Таб, Фикс, Фикс);
КонецПроцедуры

// © Primus1C  06.10.2025  НАЧАЛО ►

#Область Печать
	
Процедура ВывестиСекцию(Таб, Макет, Область, Параметры, Уровень=Неопределено) 
	Ш = Макет.ПолучитьОбласть(Область); 
	Ш.Параметры.Заполнить(Параметры);  
	Если Уровень=Неопределено Тогда
		Таб.Вывести(Ш);
	Иначе
		Таб.Вывести(Ш, Уровень);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	
	СПФ = Новый Структура("БезСерий, ПоСериям, БезСерийПоАлфавиту, ПоСериямПоАлфавиту",  
							НСтр("ru='Расходная накладная (без серий)';en='Sales invoice (no series)'"), 
							НСтр("ru='Расходная накладная (по сериям)';en='Sales invoice (with series)'"),		
							НСтр("ru='Расходная накладная (без серий), алфавитный порядок';en='Sales invoice (no series), alphabetical order'"), 
							НСтр("ru='Расходная накладная (по сериям), алфавитный порядок';en='Sales invoice (with series), alphabetical order'")		
							);		
	Если РольДоступна("Администратор") ИЛИ РольДоступна("Логистика") ИЛИ РольДоступна("Бухгалтерия") ИЛИ РольДоступна("ИнвойсТоварный") ИЛИ РольДоступна("ИнвойсЗакупки") Тогда
		СПФ.Вставить("ПоИнвойсам", НСтр("ru='Расходная накладная (по инвойсам)';en='Sales invoice (invoices)'"));		
		СПФ.Вставить("ПоИнвойсамЗаДень", НСтр("ru='Расходные за день (по инвойсам)';en='Daily sales invoices'"));		
	КонецЕсли;						
							
	Возврат СПФ;						
							
КонецФункции 

Процедура ПечатьДокумента(ДокСсылка, ВариантПечатнойФормы, ТабДокумент, Параметры = 0) Экспорт
	
	Если ВариантПечатнойФормы = "БезСерий" ИЛИ ВариантПечатнойФормы = "ПоСериям" ИЛИ
		ВариантПечатнойФормы = "БезСерийПоАлфавиту" ИЛИ ВариантПечатнойФормы = "ПоСериямПоАлфавиту" Тогда
		
		Если ВариантПечатнойФормы = "БезСерий" ИЛИ ВариантПечатнойФормы = "БезСерийПоАлфавиту" Тогда
			поз = 1;
		Иначе
			поз = 2;
		КонецЕсли;
		ПечатьДокумента_(ДокСсылка, Поз, ТабДокумент, СтрНайти(ВариантПечатнойФормы, "ПоАлфавиту")>0);
		
	Иначе
		
		ТабДокумент.Очистить();  
		Макет = Документы.РасходнаяНакладная.ПолучитьМакет(ВариантПечатнойФормы);
		
		ЗапрШ = Новый Запрос;
		ЗапрШ.УстановитьПараметр("Ссылка", ДокСсылка);
		ЗапрШ.УстановитьПараметр("ПредставлениеДокумента",  ОбщегоНазначения.ПредставлениеДокументаДляПечати(ДокСсылка, ));
		ЗапрШ.Текст = "ВЫБРАТЬ
	             |	Накладная.Номер КАК Номер,
	             |	Накладная.Дата КАК Дата,
	             |	Накладная.Контрагент КАК Контрагент,
	             |	Накладная.Сумма КАК Сумма,
	             |	Накладная.Валюта КАК Валюта,
	             |	Накладная.Склад КАК Склад,
	             |	Накладная.Количество КАК Количество,
	             |	ВЫРАЗИТЬ(Накладная.Примечание КАК СТРОКА(1000)) КАК Примечание,
	             |	&ПредставлениеДокумента КАК ПредставлениеДокумента 
	             |ИЗ
	             |	Документ.РасходнаяНакладная КАК Накладная
	             |ГДЕ
	             |	Накладная.Ссылка = &Ссылка";   
		ОбщегоНазначенияСервер.УстановитьПредставлениеКонтрагентаВЗапросе(ЗапрШ.Текст, "Накладная.Контрагент");	
		Шапка = ЗапрШ.Выполнить().Выбрать();
		Шапка.Следующий(); 
		ВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка); 
	
		ЗапрИ = Новый Запрос;
		ЗапрИ.Текст = "ВЫБРАТЬ
		              |	РНТовары.Номенклатура КАК Номенклатура,
		              |	РНТовары.Партия.Док.ВКД_Инвойс КАК Инвойс,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Контрагент КАК Поставщик,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.ВКД_ДатаИнвойсаПоставщика КАК ДатаИнвойса,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойсаПоставщика,
		              |	СУММА(РНТовары.Количество) КАК Количество,
		              |	ИнвТовары.Количество КАК КоличествоИнвойс,
		              |	РНТовары.Ссылка.Контрагент КАК Покупатель,
		              |	РНТовары.Ссылка.Валюта КАК Валюта,
		              |	ИнвИтог.Количество КАК ИтКоличествоИнвойс
		              |ИЗ
		              |	Документ.РасходнаяНакладная.Товары КАК РНТовары
		              |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		              |			ИнвойсТовары.Ссылка КАК Ссылка,
		              |			ИнвойсТовары.Номенклатура КАК Номенклатура,
		              |			СУММА(ИнвойсТовары.Количество) КАК Количество
		              |		ИЗ
		              |			Документ._Инвойс.ВКД_Товары КАК ИнвойсТовары
		              |		
		              |		СГРУППИРОВАТЬ ПО
		              |			ИнвойсТовары.Ссылка,
		              |			ИнвойсТовары.Номенклатура) КАК ИнвТовары
		              |		ПО РНТовары.Партия.Док.ВКД_Инвойс = ИнвТовары.Ссылка
		              |			И РНТовары.Номенклатура = ИнвТовары.Номенклатура
		              |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		              |			СУММА(_ИнвойсВКД_Товары.Количество) КАК Количество,
		              |			_ИнвойсВКД_Товары.Ссылка КАК Ссылка
		              |		ИЗ
		              |			Документ._Инвойс.ВКД_Товары КАК _ИнвойсВКД_Товары
		              |		
		              |		СГРУППИРОВАТЬ ПО
		              |			_ИнвойсВКД_Товары.Ссылка) КАК ИнвИтог
		              |		ПО РНТовары.Партия.Док.ВКД_Инвойс = ИнвИтог.Ссылка
		              |ГДЕ
		              |	РНТовары.Ссылка.Склад = &Склад
		              |	И ВЫБОР
		              |			КОГДА &ЗаДень
		              |				ТОГДА РНТовары.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
		              |			ИНАЧЕ РНТовары.Ссылка = &Ссылка
		              |		КОНЕЦ
		              |
		              |СГРУППИРОВАТЬ ПО
		              |	РНТовары.Номенклатура,
		              |	РНТовары.Партия.Док.ВКД_Инвойс,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Контрагент,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Дата,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика,
		              |	ИнвТовары.Количество,
		              |	РНТовары.Ссылка.Контрагент,
		              |	РНТовары.Ссылка.Валюта,
		              |	ИнвИтог.Количество
		              |
		              |УПОРЯДОЧИТЬ ПО
		              |	Поставщик,
		              |	НомерИнвойсаПоставщика,
		              |	Номенклатура
		              |АВТОУПОРЯДОЧИВАНИЕ";
		ОбщегоНазначенияСервер.УстановитьПредставлениеКонтрагентаВЗапросе(ЗапрИ.Текст, "РНТовары.Партия.Док.ВКД_Инвойс.Контрагент");	
		ЗапрИ.УстановитьПараметр("Ссылка", ДокСсылка);
		ЗапрИ.УстановитьПараметр("Склад", ДокСсылка.Склад);
		ЗапрИ.УстановитьПараметр("Дата", ДокСсылка.Дата);
		ЗапрИ.УстановитьПараметр("ЗаДень", ВариантПечатнойФормы = "ПоИнвойсамЗаДень");
		
		ИтКоличество = 0; 
		Ном = 0;
		ВыборкаИ = ЗапрИ.Выполнить().Выбрать();
		Пока ВыборкаИ.Следующий() Цикл     
			ИтКоличество = ИтКоличество + ВыборкаИ.Количество;  
			Ном = Ном + 1;
			//ОбластьДно.Параметры.Ном = Ном;
			ВывестиСекцию(ТабДокумент, Макет, "Строка", ВыборкаИ); 
		КонецЦикла;
		
		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(Шапка);
		ОбластьДно.Параметры.ИтКоличество = ИтКоличество;
		//ОбластьДно.Параметры.СуммаПрописью = гоСуммаПрописьюВал(Шапка.Сумма, Шапка.Валюта);
		ТабДокумент.Вывести(ОбластьДно);
	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

