//
Функция ЗатратыПартий(МассивПартий) Экспорт

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Партии", МассивПартий);
	Запр.Текст = "ВЫБРАТЬ
	             |	Затраты.Партия КАК Партия,
	             |	СУММА(Затраты.Сумма) КАК Сумма
	             |ИЗ
	             |	РегистрСведений.Затраты КАК Затраты
	             |ГДЕ
	             |	Затраты.Партия В(&Партии)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	Затраты.Партия
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	Свод.Партия КАК Партия,
	             |	СУММА(Свод.Сумма) КАК Сумма
	             |ИЗ
	             |	(ВЫБРАТЬ
	             |		Партии.Ссылка КАК Партия,
	             |		Партии.Владелец КАК Номенклатура,
	             |		Партии.Док.ВКД_Инвойс КАК Инвойс,
	             |		Партии.Док.Поставка КАК Поставка,
	             |		ЗатратыИнв.Сумма КАК Сумма
	             |	ИЗ
	             |		Справочник.Партии КАК Партии
	             |			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |				Затраты.Сумма КАК Сумма,
	             |				Затраты.Номенклатура КАК Номенклатура,
	             |				Затраты.Инвойс КАК Инвойс,
	             |				Затраты.Поставка КАК Поставка
	             |			ИЗ
	             |				РегистрСведений.Затраты КАК Затраты
	             |			ГДЕ
	             |				(Затраты.Номенклатура, Затраты.Инвойс, Затраты.Поставка, Затраты.Партия) В
	             |						(ВЫБРАТЬ
	             |							П.Владелец,
	             |							П.Док.ВКД_Инвойс,
	             |							П.Док.Поставка,
	             |							ЗНАЧЕНИЕ(Справочник.Партии.ПустаяСсылка)
	             |						ИЗ
	             |							Справочник.Партии КАК П
	             |						ГДЕ
	             |							П.Ссылка В (&Партии))) КАК ЗатратыИнв
	             |			ПО Партии.Владелец = ЗатратыИнв.Номенклатура
	             |				И Партии.Док.ВКД_Инвойс = ЗатратыИнв.Инвойс
	             |				И Партии.Док.Поставка = ЗатратыИнв.Поставка
	             |	ГДЕ
	             |		Партии.Ссылка В(&Партии)) КАК Свод
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	Свод.Партия";
	Пакет = Запр.ВыполнитьПакет();
	ВыборкаПартии = Пакет[0].Выбрать();  
	СоотвЗатратыПартии = Новый Соответствие;
	Пока ВыборкаПартии.Следующий() Цикл
		СоотвЗатратыПартии.Вставить(ВыборкаПартии.Партия, ВыборкаПартии.Сумма);		
	КонецЦикла;
	ВыборкаПартииИнв = Пакет[1].Выбрать(); 
	СоотвПартииИнв = Новый Соответствие;
	Пока ВыборкаПартииИнв.Следующий() Цикл
		СоотвПартииИнв.Вставить(ВыборкаПартииИнв.Партия, ВыборкаПартииИнв.Сумма);		
	КонецЦикла;
	
	Возврат Новый Структура("ЗатратыПартии, ЗатратыПартииИнвойсов", СоотвЗатратыПартии, СоотвПартииИнв);
	
КонецФункции 

