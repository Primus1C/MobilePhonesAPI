&НаКлиенте
Процедура МоеДобавлениеШаг(НовНом, НовПар)
	гоУстановитьПараметрСеанса("Склад", Объект.Склад);
	ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораНоменклатуры", ЭтотОбъект, НовПар), НовНом, НСтр("ru = 'Выберите номенклатуру'; en = 'Select the good'"));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораНоменклатуры(НовНом, НовПар) Экспорт
	Если НовНом = Неопределено Тогда Возврат КонецЕсли; 
	
	гоУстановитьПараметрСеанса("Склад", Объект.Склад);
	гоУстановитьПараметрСеанса("Номенклатура", НовНом);
	
	//2015.12.20
	Если гоРеквизит(Объект.Фирма, "ПроверятьВалютуЗакупкиВПеремещении") Тогда  
		гоУстановитьПараметрСеанса("ВалютаВыбора", Объект.Валюта);
	КонецЕсли; 
	
	ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораПартии", ЭтотОбъект, НовНом), НовПар, НСтр("ru = 'Выберите партию'; en = 'Select batch'"));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораПартии(НовПар, НовНом) Экспорт
	Если НовПар = Неопределено Тогда 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли; 
	
	//тут работает выбор нормально, получим остаток партии, вдруг выбрали без остатка
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если ОстПар <= 0 Тогда 
		клОшибка(НСтр("ru = 'Нет остатка у выбранной партии!'; en = 'The selected batch has no balance!'")); 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли; 
	
	Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Партия", НовПар));
	Если НЕ (Нашли.Количество() = 0) Тогда 
		клОшибка(гоИмя(НовПар) + ": уже есть в документе!" + гоРС() + "Используйте редактирование количества!!!"); 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли;
	
	Пар = Новый Структура;
	Пар.Вставить("Фирма", Объект.Фирма);
	Пар.Вставить("Номенклатура", НовНом);
	Пар.Вставить("Количество", ОстПар);
	Пар.Вставить("Склад", Объект.Склад);
	Пар.Вставить("Партия", НовПар);
	
	ОткрытьФорму("ОбщаяФорма.ВводСтрокиПМ", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("МоеДобавлениеПослеВводаСтроки", ЭтотОбъект, Новый Структура("НовНом,НовПар", НовНом, НовПар)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВводаСтроки(Пар, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	
	Если гоПЗ(Пар) Тогда 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли; 
	
	НовКол = Пар.Количество;
	Если НовКол = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введено количество!'; en = 'Quantity is not specified!'")); 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли;
	
	клСохранитьИзменения(Новый ОписаниеОповещения("МоеДобавлениеПослеПодтверждения", ЭтотОбъект, Новый Структура("НовНом,НовПар,НовКол", НовНом, НовПар, НовКол)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеПодтверждения(Результат, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	
	Если НЕ Результат Тогда 
		МоеДобавлениеШаг(НовНом, НовПар); 
		Возврат; 
	КонецЕсли; 
	
	НовКол = Параметры.НовКол;
	
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если НовКол > ОстПар Тогда 
		клОшибка("Не хватило остатка " + Строка(НовКол - ОстПар) + " для " + гоИмя(НовПар) + ", исправлено на " + ОстПар + "!");
		НовКол = ОстПар;
	КонецЕсли;
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНом;
	НовСтр.Партия = НовПар;
	НовСтр.Количество = НовКол;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	МоеДобавлениеШаг(НовНом, НовПар);
КонецПроцедуры



&НаКлиенте
Процедура ЛюбаяСерия(ШК, СтатьНаРучной = Ложь)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги(Объект.Товары.Количество()-1);
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если гоПЗ(Объект.Склад) Тогда клОшибка("Не задан склад ОТКУДА!"); Возврат; КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда клОшибка("Не задана валюта!"); Возврат; КонецЕсли; 
	
	Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли; 
	
	//по идее, нужно найти товар с такой серией и передать его в добавление строки, зачем изобретать велосипед?
	СпиПар = омСервер.ПартииПоСерииОстатки(ШК, Объект.Фирма, Объект.Склад);
	
	Ско = СпиПар.Количество();
	ТекПар = 0;
	Если Ско  = 0 Тогда
		Сигнал();
		клОшибка("Нет остатков по серии: " + ШК + "!");
		Возврат;
	ИначеЕсли Ско > 1 Тогда
		Сигнал();
		Эле = СпиПар.ВыбратьЭлемент("Найдено несколько партий с такой серией, выберите:");
		Если Эле = Неопределено Тогда Возврат КонецЕсли;
		ТекПар = Эле.Значение;
	Иначе
		ТекПар = СпиПар[0].Значение;
	КонецЕсли; 
	Если ТекПар = 0 Тогда Возврат КонецЕсли; 
	
	//2015.12.25
	Если гоРеквизит(Объект.Фирма, "ПроверятьВалютуЗакупкиВПеремещении") Тогда  
		НовВал = гоРеквизит(ТекПар, "Валюта");
		Если НовВал <> Объект.Валюта Тогда клОшибка("Не та валюта: " + гоИмя(НовВал) + "!"); Возврат; КонецЕсли;
	КонецЕсли; 
	
	НовКол = 1;
	НовНом = гоРеквизит(ТекПар, "Владелец");
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНом;
	НовСтр.Партия = ТекПар;
	НовСтр.Количество = НовКол;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(ШК + "|" + Строка(НовКол) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	Если СтатьНаРучной Тогда 
		РучнойШК = "";
		ПодключитьОбработчикОжидания("МоеОжидание", 0.1, Истина);
	КонецЕсли;  
	
КонецПроцедуры

