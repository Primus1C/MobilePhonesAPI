&НаКлиенте
Процедура МоеРедактированиеПослеВводаКоличества(НовКол, Параметры) Экспорт
	Если НовКол = Неопределено Тогда Возврат КонецЕсли;
	
	ИДИ = Параметры.ИДИ;
	БылКол = Параметры.БылКол;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, Стр.Партия);
	Если Объект.Проведен Тогда ОстПар = ОстПар + БылКол КонецЕсли;
	
	Если НовКол > ОстПар Тогда 
		клОшибка("Не хватило остатка " + Строка(НовКол - ОстПар) + " для " + гоИмя(Стр.Партия) + ", исправлено на " + ОстПар + "!");
		НовКол = ОстПар;
	КонецЕсли;
	Если НовКол = Стр.Количество Тогда Возврат КонецЕсли;
	
	Стр.Количество = НовКол;
	
	МояЗаписать(Ложь);
	
	Колич = НовКол;
	Номен = Стр.Номенклатура;
	
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента, "Редактирование количества", Номен, 2);
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование количества", Объект.Ссылка, 2);
КонецПроцедуры


