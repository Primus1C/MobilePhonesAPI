&НаСервере
Процедура ОтобразитьЦеныСЗатратами(НомерСтроки = Неопределено)
	
	//Соотв = Новый Соответствие;
	//Запр = Новый Запрос;
	//Запр.Текст = "ВЫБРАТЬ
	//             |	РаспрЗатрат.Номенклатура КАК Номенклатура,
	//             |	РаспрЗатрат.Количество КАК Количество,
	//             |	РаспрЗатрат.Цена КАК Цена,
	//             |	РаспрЗатрат.Сумма КАК Сумма,
	//             |	РаспрЗатрат.СуммаAWB КАК СуммаAWB,
	//             |	РаспрЗатрат.СуммаПеремещений КАК СуммаПеремещений
	//             |ИЗ
	//             |	Документ.ОтправкаПеремещений.РаспределениеЗатрат КАК РаспрЗатрат
	//             |ГДЕ
	//             |	РаспрЗатрат.Ссылка В
	//             |			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	//             |				ОтправкаПеремещенийПеремещения.Ссылка КАК Ссылка
	//             |			ИЗ
	//             |				Документ.ОтправкаПеремещений.Перемещения КАК ОтправкаПеремещенийПеремещения
	//             |			ГДЕ
	//             |				ОтправкаПеремещенийПеремещения.Перемещение.Проведен
	//             |				И ОтправкаПеремещенийПеремещения.Перемещение = &Ссылка)";
	//Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	//Выборка = Запр.Выполнить().Выбрать();
	//Пока Выборка.Следующий() Цикл
	//	Соотв.Вставить(Выборка.Номенклатура, Выборка.Сумма / Выборка.Количество);
	//КонецЦикла;
	//Для каждого СтрокаТЧ Из Объект.Товары Цикл   
	//	Затр = Соотв.Получить(СтрокаТЧ.Номенклатура);
	//	Если Затр = Неопределено Тогда
	//		Затр = 0;	
	//	КонецЕсли;
	//	СтрокаТЧ.ЦенаСЗатратами = СтрокаТЧ.ЦенаЗакупки + Затр;
	//КонецЦикла;

	СоотвЗатрат = Новый Соответствие;
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	РНТовары.Партия КАК Партия,
	             |	ЗатратыПартий.Сумма КАК Сумма
	             |ИЗ
	             |	Документ.Перемещение.Товары КАК РНТовары
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			Затраты.Партия КАК Партия,
	             |			СУММА(Затраты.Сумма) КАК Сумма
	             |		ИЗ
	             |			РегистрСведений.Затраты КАК Затраты
	             |		
	             |		СГРУППИРОВАТЬ ПО
	             |			Затраты.Партия) КАК ЗатратыПартий
	             |		ПО РНТовары.Партия = ЗатратыПартий.Партия
	             |ГДЕ
	             |	РНТовары.Ссылка = &Ссылка";
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);  

	Если НомерСтроки = Неопределено Тогда
		
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СоотвЗатрат.Вставить(Выборка.Партия, Выборка.Сумма);		
		КонецЦикла;
		
		Для каждого СтрокаТЧ Из Объект.Товары Цикл   
			Затр = СоотвЗатрат.Получить(СтрокаТЧ.Номенклатура);
			Если Затр = Неопределено Тогда
				Затр = 0;	
			КонецЕсли;
			СтрокаТЧ.ЦенаСЗатратами = СтрокаТЧ.ЦенаЗакупки + Затр;
			СтрокаТЧ.СуммаСЗатратами = СтрокаТЧ.ЦенаСЗатратами * СтрокаТЧ.Количество;
		КонецЦикла; 
		
	Иначе
		
		Запр.Текст = "ВЫБРАТЬ
		             |	Затраты.Партия КАК Партия,
		             |	СУММА(Затраты.Сумма) КАК Сумма
		             |ИЗ
		             |	РегистрСведений.Затраты КАК Затраты
		             |ГДЕ
		             |	Затраты.Партия = &Партия
		             |
		             |СГРУППИРОВАТЬ ПО
		             |	Затраты.Партия";
		
		Попытка
		
		СтрокаТЧ = Объект.Товары[НомерСтроки];
		Запр.УстановитьПараметр("Партия", СтрокаТЧ.Партия);  
	
		Выборка = Запр.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			СтрокаТЧ.ЦенаСЗатратами = СтрокаТЧ.ЦенаЗакупки + Выборка.Сумма;
			СтрокаТЧ.СуммаСЗатратами = СтрокаТЧ.ЦенаСЗатратами * СтрокаТЧ.Количество;
		КонецЦикла;
		
		Исключение
		КонецПопытки; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МоиОстатки()
	стрОстатки = "?";
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	стрОстатки = омСервер.МоиОстатки(Объект.Ссылка, Стр.Номенклатура, Стр.Партия) + гоРС() + омСервер.МоиОстатки(Объект.Ссылка, Стр.Номенклатура, Стр.Партия, Истина);
КонецПроцедуры

&НаКлиенте
Процедура МояЗаписать(ПроверятьМодифицированность = Истина)
	УстановитьВидимостьДоступность();
	
	Если ПроверятьМодифицированность Тогда
		Если НЕ Модифицированность Тогда Возврат КонецЕсли; КонецЕсли; 
		
	Записать(РежимЗаписиПроведение);
	//МоиОстатки();
	МоиИтоги();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	НетСтрок = Объект.Товары.Количество() = 0;
	ЕстьСтроки = НЕ НетСтрок;
	
	Закрыто = Объект.Окончательно;	
	НеЗакрыто = НЕ Закрыто;
	
	Элементы.Дата.ТолькоПросмотр = Закрыто;		//Объект.Проведен ИЛИ
	Элементы.Склад.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Куда.ТолькоПросмотр = Закрыто;
	Элементы.Валюта.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Установить.Доступность = НеЗакрыто;
	Элементы.Снять.Доступность = Закрыто;
КонецПроцедуры


