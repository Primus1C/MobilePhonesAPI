	Объект.Окончательно = Истина;
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации("Установили", ИмяДокумента, "Установка {Окончательно}", Объект.Ссылка, 2);
КонецПроцедуры

&НаКлиенте
Процедура Снять(Команда)
	Если НЕ Объект.Окончательно Тогда Возврат КонецЕсли; 
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Сч = 0;
	Для Каждого Стр Из Объект.Товары Цикл
		Если гоПЗ(Стр.Номенклатура) ИЛИ гоПЗ(Стр.Партия) ИЛИ (Стр.Количество = 0) Тогда Продолжить КонецЕсли;
		
		Ост = омСервер.ОстатокПартии(Объект.Фирма, Объект.Куда, Стр.Партия);
		Если Ост >= Стр.Количество Тогда Продолжить КонецЕсли;
		
		//Сообщить("На складе КУДА будет отрицательный остаток (" + Строка(Ост - Стр.Количество) + ") для " + гоИмя(Стр.Партия)); 
		Сообщить(СтрШаблон(НСтр("ru = 'На складе КУДА будет отрицательный остаток (%1) для %2'; en = 'There will be a negative balance of %2 in the warehouse (%!) '"), Строка(Ост - Стр.Количество), гоИмя(Стр.Партия)));
		гоПлюс(Сч);
	КонецЦикла;
	
	Если Сч <> 0 Тогда клОшибка(СтрШаблон(НСтр("ru = 'Остатки станут отрицательными %1!'; en = 'The balances will become negative %1!'"), гоИмя(Сч))); Возврат; КонецЕсли;
	
	клНетДа(Новый ОписаниеОповещения("СнятьПослеПодтверждения", ЭтотОбъект), НСтр("ru = 'Снять флаг {Окончательно}?'; en = 'Unset flag <Finaly>?'"));
КонецПроцедуры

