КонецПроцедуры

Процедура ПечатьДокумента_(Тек, Поз, Таб, Параметры = 0) Экспорт
	
	Таб.Очистить();
	
	М = Документы.Перемещение.ПолучитьМакет("Печать");
	С = Новый Структура;
	гоВставитьКучу(С, "Загол, ИмяПокупателя1, ИмяПоставщика1");
	гоВставитьКучу(С, "ДопНомера, НомерПП, лНоменклатура, лЕИ, лКоличество, лЦена, лСумма, сКоличество, СтрСНДС");
	гоВставитьКучу(С, "лВалюта");
	
	С.Загол = стрШаблон(НСтр("ru = 'Перемещение № %1 от %2'; en = 'Transfer № %1 (%2)'"), Тек.Номер, гоДата(Тек.Дата));
	С.ИмяПоставщика1 = "";
	С.ИмяПокупателя1 = "";

	Если гоНПЗ(Тек.Склад) Тогда
		С.ИмяПоставщика1 = СокрЛП(Тек.Склад);
	КонецЕсли;
	
	Если гоНПЗ(Тек.Куда) Тогда
		С.ИмяПокупателя1 = СокрЛП(Тек.Куда);
	КонецЕсли;
	
	Фикс = 4;
	ВывестиСекцию(Таб, М, "ШапкаП1", С); гоПлюс(Фикс);
	ВывестиСекцию(Таб, М, "ШапкаК1", С); гоПлюс(Фикс);
	
	ВывестиСекцию(Таб, М, "Шапка", С);
	
	Табл = Тек.Товары.Выгрузить();
	Табл.Свернуть("Номенклатура, ЦенаЗакупки", "Количество, СуммаЗакупки");
	
	С.лВалюта = СокрЛП(Тек.Валюта);
	
	ЧислоЗнаковЦена = Тек.Фирма.ЧислоЗнаковЦенаЗакупки;
	
	НомерПП = 0;
	Для Каждого _Табл Из Табл Цикл
		гоПлюс(НомерПП);
		
		С.лНоменклатура = гоИмя(_Табл.Номенклатура, Ложь);
		С.НомерПП = НомерПП;
		С.лЕИ = НСтр("ru = 'шт.'; en = 'pc.'");
		С.лКоличество = _Табл.Количество;
		С.лЦена = гоСуммаЗн(_Табл.ЦенаЗакупки, ЧислоЗнаковЦена);
		С.лСумма = гоЦена2(_Табл.СуммаЗакупки);
		
		ВывестиСекцию(Таб, М, "Строка", С);
	КонецЦикла;
	
	С.лКоличество = Табл.Итог("Количество");
	С.лСумма = гоЦена2(Тек.Сумма);
	С.СтрСНДС = гоСуммаПрописьюВал(Тек.Сумма, Тек.Валюта);
		
	ВывестиСекцию(Таб, М, "Подвал", С);
	
	глПараметрыСтраницы(Таб, 1);
	глПовторятьПриПечатиСтроки(Таб, Фикс, Фикс);
КонецПроцедуры

Процедура ВывестиСекцию(Таб, Макет, Область, Параметры, Уровень=Неопределено) 
	Ш = Макет.ПолучитьОбласть(Область); 
	Ш.Параметры.Заполнить(Параметры);  
	Если Уровень=Неопределено Тогда
		Таб.Вывести(Ш);
	Иначе
		Таб.Вывести(Ш, Уровень);
	КонецЕсли;
КонецПроцедуры

