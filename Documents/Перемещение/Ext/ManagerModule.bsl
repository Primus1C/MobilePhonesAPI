Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	
	СПФ = Новый Структура("БезСерий",  
							НСтр("ru='Перемещение';en='Transfer'") 
							//НСтр("ru='Перемещение (по сериям)';en='Transfer (with series)'")		
							);		
	//Если РольДоступна("Администратор") ИЛИ РольДоступна("Логистика") ИЛИ РольДоступна("Бухгалтерия") ИЛИ РольДоступна("ИнвойсТоварный") ИЛИ РольДоступна("ИнвойсЗакупки") Тогда
		СПФ.Вставить("ПоИнвойсам", НСтр("ru='Перемещение (по инвойсам)';en='Transfer (invoices)'"));		
		СПФ.Вставить("ПоИнвойсамЗаДень", НСтр("ru='Перемещения за день (по инвойсам)';en='Daily transfer (invoices)'"));		
	//КонецЕсли;						
							
	Возврат СПФ;						
							
КонецФункции 

Процедура ПечатьДокумента(ДокСсылка, ВариантПечатнойФормы, ТабДокумент, Параметры = 0) Экспорт
	
	Если ВариантПечатнойФормы = "БезСерий" ИЛИ ВариантПечатнойФормы = "ПоСериям" Тогда
		
		Если ВариантПечатнойФормы = "БезСерий" Тогда
			поз = 1;
		Иначе
			поз = 2;
		КонецЕсли;
		ПечатьДокумента_(ДокСсылка, Поз, ТабДокумент);
		
	Иначе
		
		ТабДокумент.Очистить();  
		Макет = Документы.РасходнаяНакладная.ПолучитьМакет(ВариантПечатнойФормы);
		
		ЗапрШ = Новый Запрос;
		ЗапрШ.УстановитьПараметр("Ссылка", ДокСсылка);
		ЗапрШ.УстановитьПараметр("ПредставлениеДокумента",  ОбщегоНазначения.ПредставлениеДокументаДляПечати(ДокСсылка, ));
		ЗапрШ.Текст = "ВЫБРАТЬ
	             |	Накладная.Номер КАК Номер,
	             |	Накладная.Дата КАК Дата,
	             |	Накладная.Контрагент КАК Контрагент,
	             |	Накладная.Сумма КАК Сумма,
	             |	Накладная.Валюта КАК Валюта,
	             |	Накладная.Склад КАК Склад,      
				 |	Накладная.Куда КАК Куда,
	             |	Накладная.Количество КАК Количество,
	             |	ВЫРАЗИТЬ(Накладная.Примечание КАК СТРОКА(1000)) КАК Примечание,
	             |	&ПредставлениеДокумента КАК ПредставлениеДокумента 
	             |ИЗ
	             |	Документ.Перемещение КАК Накладная
	             |ГДЕ
	             |	Накладная.Ссылка = &Ссылка";   
		//ОбщегоНазначенияСервер.УстановитьПредставлениеКонтрагентаВЗапросе(ЗапрШ.Текст, "Накладная.Контрагент");	
		Шапка = ЗапрШ.Выполнить().Выбрать();
		Шапка.Следующий(); 
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка); 
	
		ЗапрИ = Новый Запрос;
		ЗапрИ.Текст = "ВЫБРАТЬ
		              |	РНТовары.Номенклатура КАК Номенклатура,
		              |	РНТовары.Партия.Док.ВКД_Инвойс КАК Инвойс,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Контрагент КАК Поставщик,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Дата КАК ДатаИнвойса,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойсаПоставщика,
		              |	СУММА(РНТовары.Количество) КАК Количество,
		              |	ИнвТовары.Количество КАК КоличествоИнвойс,
		              |	РНТовары.Ссылка.Контрагент КАК Покупатель,
		              |	РНТовары.Ссылка.Валюта КАК Валюта,
		              |	ИнвИтог.Количество КАК ИтКоличествоИнвойс
		              |ИЗ
		              |	Документ.Перемещение.Товары КАК РНТовары
		              |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		              |			ИнвойсТовары.Ссылка КАК Ссылка,
		              |			ИнвойсТовары.Номенклатура КАК Номенклатура,
		              |			СУММА(ИнвойсТовары.Количество) КАК Количество
		              |		ИЗ
		              |			Документ._Инвойс.ВКД_Товары КАК ИнвойсТовары
		              |		
		              |		СГРУППИРОВАТЬ ПО
		              |			ИнвойсТовары.Ссылка,
		              |			ИнвойсТовары.Номенклатура) КАК ИнвТовары
		              |		ПО РНТовары.Партия.Док.ВКД_Инвойс = ИнвТовары.Ссылка
		              |			И РНТовары.Номенклатура = ИнвТовары.Номенклатура
		              |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		              |			СУММА(_ИнвойсВКД_Товары.Количество) КАК Количество,
		              |			_ИнвойсВКД_Товары.Ссылка КАК Ссылка
		              |		ИЗ
		              |			Документ._Инвойс.ВКД_Товары КАК _ИнвойсВКД_Товары
		              |		
		              |		СГРУППИРОВАТЬ ПО
		              |			_ИнвойсВКД_Товары.Ссылка) КАК ИнвИтог
		              |		ПО РНТовары.Партия.Док.ВКД_Инвойс = ИнвИтог.Ссылка
		              |ГДЕ
		              |	РНТовары.Ссылка.Склад = &Склад
		              |	И ВЫБОР
		              |			КОГДА &ЗаДень
		              |				ТОГДА РНТовары.Ссылка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
		              |			ИНАЧЕ РНТовары.Ссылка = &Ссылка
		              |		КОНЕЦ
		              |
		              |СГРУППИРОВАТЬ ПО
		              |	РНТовары.Номенклатура,
		              |	РНТовары.Партия.Док.ВКД_Инвойс,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Контрагент,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.Дата,
		              |	РНТовары.Партия.Док.ВКД_Инвойс.ВКД_НомерИнвойсаПоставщика,
		              |	ИнвТовары.Количество,
		              |	РНТовары.Ссылка.Контрагент,
		              |	РНТовары.Ссылка.Валюта,
		              |	ИнвИтог.Количество
		              |
		              |УПОРЯДОЧИТЬ ПО
		              |	Поставщик,
		              |	НомерИнвойсаПоставщика,
		              |	Номенклатура
		              |АВТОУПОРЯДОЧИВАНИЕ";
		ОбщегоНазначенияСервер.УстановитьПредставлениеКонтрагентаВЗапросе(ЗапрИ.Текст, "РНТовары.Партия.Док.ВКД_Инвойс.Контрагент");	
		ЗапрИ.УстановитьПараметр("Ссылка", ДокСсылка);
		ЗапрИ.УстановитьПараметр("Склад", ДокСсылка.Склад);
		ЗапрИ.УстановитьПараметр("Дата", ДокСсылка.Дата);
		ЗапрИ.УстановитьПараметр("ЗаДень", ВариантПечатнойФормы = "ПоИнвойсамЗаДень");
		
		Ном = 0;
		ИтКоличество = 0; 
		ВыборкаИ = ЗапрИ.Выполнить().Выбрать();
		Пока ВыборкаИ.Следующий() Цикл     
			ИтКоличество = ИтКоличество + ВыборкаИ.Количество;  
			Ном = Ном + 1;
			//ОбластьДно.Параметры.Ном = Ном;
			глВывестиСекцию(ТабДокумент, Макет, "Строка", ВыборкаИ); 
		КонецЦикла;
		
		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(Шапка);
		ОбластьДно.Параметры.ИтКоличество = ИтКоличество;
		//ОбластьДно.Параметры.СуммаПрописью = гоСуммаПрописьюВал(Шапка.Сумма, Шапка.Валюта);
		ТабДокумент.Вывести(ОбластьДно);
	
	КонецЕсли;

КонецПроцедуры

