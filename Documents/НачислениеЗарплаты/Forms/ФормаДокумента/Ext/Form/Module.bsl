
&НаКлиенте
Процедура ПометкиИнвертировать(Команда)
	ПометкиОбработать(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПометкиСнять(Команда)
	ПометкиОбработать(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПометкиУстановить(Команда)
	ПометкиОбработать(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ПометкиОбработать(Пометка)

	Для каждого Эл Из Этаформа.ФильтрОфис Цикл
		Если Пометка = Неопределено Тогда
			Эл.Пометка = НЕ Эл.Пометка;
		Иначе
		    Эл.Пометка = Пометка;
		КонецЕсли;
	КонецЦикла;	
    ФильтрОфисПометкаПриИзменении(Неопределено);
	 
КонецПроцедуры


#Область ДействияФормы
 
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)  
	
	ИмяДокумента = Объект.Ссылка.Метаданные().Синоним;

	Элементы.ГруппаСостояние.Видимость = ОбщегоНазначенияПовтИсп.ПолучитьЗначениеНастройки("ОтображатьСостояниеВФормеДокумента");
	ОбщегоНазначения.ОтобразитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента); 

	ВалютаРубль = омСервер.ПолучитьВалюту("руб");
	ВалютаДоллар = омСервер.ПолучитьВалюту("USD");  
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Валюта = ВалютаДоллар;
	КонецЕсли; 
	
	Для каждого СтрокаТЧ Из Объект.Список Цикл
		СтрокаТЧ.Офис = СтрокаТЧ.Сотрудник.Офис;
	КонецЦикла;
	ОбновитьФильтр();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	//клФормаДокументаПриОткрытии(ЭтаФорма, Объект);

	Месяц = Формат(Объект.Период, "ДФ='MMMM yyyy'");
	Если Год(Объект.Период) = 1 Тогда
		СформироватьСписокВыбораМесяца(Год(ТекущаяДата()));
	Иначе
		СформироватьСписокВыбораМесяца(Год(Объект.Период));
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Объект.СуммаВДолларах = Объект.Список.Итог("КВыдачеВДолларах");
	Объект.СуммаВРублях = Объект.Список.Итог("КВыдачеВРублях");

КонецПроцедуры

#КонецОбласти 


#Область ДействияЭлементовШапки

&НаКлиенте
Процедура МесяцПриИзменении(Элемент)
	Если Месяц <> "" Тогда
		Если СтрДлина(Месяц)=4 Тогда 
			СформироватьСписокВыбораМесяца(Число(Месяц));
			Объект.Период = НачалоМесяца(Дата(Число(Месяц), 1, 1));
			Месяц = Формат(Объект.Период, "ДФ='MMMM yyyy'");
		Иначе
			НомМесяца = (Найти("янвфевмарапрмайиюниюлавгсеноктноядек",Нрег(Лев(Месяц,3)))+2)/3; //получаем номер месяца
			ВыбрГод = Число(Прав(Месяц, 4));
			Объект.Период = НачалоМесяца(Дата(ВыбрГод, НомМесяца, 1));
		КонецЕсли;    
	КонецЕсли;
	
	Объект.Список.Очистить();
    Модифицированность = Истина;
КонецПроцедуры

