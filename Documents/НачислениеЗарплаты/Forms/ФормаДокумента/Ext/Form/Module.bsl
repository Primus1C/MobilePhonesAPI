&НаКлиенте
Процедура ЗаполнитьАвансы(Команда)
	ЗаполнитьАвансыНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАвансыНаСервере()
	
	// © Primus1C  23.08.2025  НАЧАЛО ► 
	АвансыРубль = Новый Соответствие;
	АвансыДоллар = Новый Соответствие;
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ВЫБОР
	             |		КОГДА ЗарплатаОбороты.Валюта = &Доллар
	             |			ТОГДА ЗарплатаОбороты.ОстатокРасход
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК АвансВДолларах,
	             |	ВЫБОР
	             |		КОГДА ЗарплатаОбороты.Валюта = &Рубль
	             |			ТОГДА ЗарплатаОбороты.ОстатокРасход
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК АвансВРублях,
	             |	ЗарплатаОбороты.Сотрудник КАК Сотрудник
	             |ИЗ
	             |	РегистрНакопления.Зарплата.Обороты(, , , МесяцЗП = &МесяцЗП) КАК ЗарплатаОбороты";
	Запр.УстановитьПараметр("Рубль", 	ВалютаРубль);
	Запр.УстановитьПараметр("Доллар", 	ВалютаДоллар);
	Запр.УстановитьПараметр("МесяцЗП", 	НачалоМесяца(Объект.Период));
    Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		АвансыРубль.Вставить(Выборка.Сотрудник, Выборка.АвансВРублях);			
		АвансыДоллар.Вставить(Выборка.Сотрудник, Выборка.АвансВДолларах);			
	КонецЦикла;
	
	Для каждого СтрокаТЧ Из Объект.Список Цикл
		СтрокаТЧ.АвансВРублях 		= АвансыРубль.Получить(СтрокаТЧ.Сотрудник);	
		СтрокаТЧ.АвансВДолларах 	= АвансыДоллар.Получить(СтрокаТЧ.Сотрудник);	
		СтрокаТЧ.КВыдачеВРублях 	= СтрокаТЧ.НачисленоВРублях - СтрокаТЧ.АвансВРублях - СтрокаТЧ.ШтрафВРублях;
		СтрокаТЧ.КВыдачеВДолларах 	= СтрокаТЧ.НачисленоВДолларах - СтрокаТЧ.АвансВДолларах - СтрокаТЧ.ШтрафВДолларах;
	КонецЦикла;
	
	Возврат;
	
	// © Primus1C  ОКОНЧАНИЕ ◄
	
	Если Не Объект.Курс = 0 Тогда	
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ТЗ.Сотрудник
		|ПОМЕСТИТЬ ВТ_Сотрудники
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДвижениеДенег.Валюта,
		|	СУММА(ДвижениеДенег.Сумма) КАК Сумма,
		|	ДвижениеДенег.Сотрудник
		|ПОМЕСТИТЬ ВТ_Документы
		|ИЗ
		|	Документ.ДвижениеДенег КАК ДвижениеДенег
		|ГДЕ
		|	ДвижениеДенег.Проведен
		|	И НЕ ДвижениеДенег.ПометкаУдаления
		|	И ДвижениеДенег.ВидДвиженияДенег = &ВидДвиженияДенег
		|	И ДвижениеДенег.МесяцЗП МЕЖДУ &НачалоПериода И &КонецПериода
		|
		|СГРУППИРОВАТЬ ПО
		|	ДвижениеДенег.Сотрудник,
		|	ДвижениеДенег.Валюта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Сотрудники.Сотрудник,
		|	ВЫБОР
		|		КОГДА ВТ_Документы.Валюта = &Рубль
		|			ТОГДА ВТ_Документы.Сумма
		|	КОНЕЦ КАК АвансВРублях,
		|	ВЫБОР
		|		КОГДА ВТ_Документы.Валюта = &Доллар
		|			ТОГДА ВТ_Документы.Сумма
		|	КОНЕЦ КАК АвансВДолларах
		|ИЗ
		|	ВТ_Сотрудники КАК ВТ_Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Документы КАК ВТ_Документы
		|		ПО ВТ_Сотрудники.Сотрудник = ВТ_Документы.Сотрудник";
		
		Запрос.УстановитьПараметр("НачалоПериода", 	НачалоМесяца(Объект.Период));
		Запрос.УстановитьПараметр("КонецПериода", 	КонецМесяца(Объект.Период));
		Запрос.УстановитьПараметр("ВидДвиженияДенег", ПредопределенноеЗначение("Перечисление.ВидДвиженияДенег.Зарплата"));
		Запрос.УстановитьПараметр("ТЗ", 			Объект.Список.Выгрузить());
		Запрос.УстановитьПараметр("Доллар", 		ВалютаДоллар);
		Запрос.УстановитьПараметр("Рубль", 			ВалютаРубль);
		ТаблицаАвансов = Запрос.Выполнить().Выгрузить();
		ТаблицаАвансов.Свернуть("Сотрудник","АвансВДолларах,АвансВРублях");
		
		Объект.Список.Загрузить(ТаблицаАвансов);
		Модифицированность = Истина;
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен курс валюты!";
		Сообщение.Сообщить();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	Сотрудники.Ссылка КАК Сотрудник,
	             |	Сотрудники.Офис КАК Офис,
	             |	ВЫБОР
	             |		КОГДА Сотрудники.Валюта = &Доллар
	             |			ТОГДА Сотрудники.Оклад
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК ОкладВДолларах,
	             |	ВЫБОР
	             |		КОГДА Сотрудники.Валюта = &Рубль
	             |			ТОГДА Сотрудники.Оклад
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК ОкладВРублях,
	             |	ВЫБОР
	             |		КОГДА Сотрудники.Валюта = &Доллар
	             |			ТОГДА Сотрудники.Оклад
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК НачисленоВДолларах,
	             |	ВЫБОР
	             |		КОГДА Сотрудники.Валюта = &Рубль
	             |			ТОГДА Сотрудники.Оклад
	             |		ИНАЧЕ 0
	             |	КОНЕЦ КАК НачисленоВРублях,
	             |	Сотрудники.Валюта КАК Валюта
	             |ИЗ
	             |	Справочник.Сотрудники КАК Сотрудники
	             |ГДЕ
	             |	НЕ Сотрудники.ПометкаУдаления
	             |	И Сотрудники.ПринятНаРаботу <> &БезДаты
	             |	И Сотрудники.ПринятНаРаботу <= &ДатаПринят
	             |	И (Сотрудники.ДатаУвольнения = &БезДаты
	             |			ИЛИ Сотрудники.ДатаУвольнения >= &ДатаУволен)";
	Запр.УстановитьПараметр("БезДаты", Дата(1,1,1));
	Запр.УстановитьПараметр("Рубль", ВалютаРубль);
	Запр.УстановитьПараметр("Доллар", ВалютаДоллар);
	Запр.УстановитьПараметр("ДатаПринят", КонецМесяца(Объект.Период));
	Запр.УстановитьПараметр("ДатаУволен", НачалоМесяца(Объект.Период));  
	Выгрузка = Запр.Выполнить().Выгрузить();
	Объект.Список.Загрузить(Выгрузка);
	ОбновитьФильтр();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьФильтр()
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ
	             |	ТЧ.Сотрудник КАК Сотрудник
	             |ПОМЕСТИТЬ ВТ
	             |ИЗ
	             |	&ТЧ КАК ТЧ
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	ВТ.Сотрудник.Офис КАК Офис
	             |ИЗ
	             |	ВТ КАК ВТ
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Офис
	             |АВТОУПОРЯДОЧИВАНИЕ";
	Запр.УстановитьПараметр("ТЧ", Объект.Список.Выгрузить());
	Выгрузка = Запр.Выполнить().Выгрузить();
	Этаформа.ФильтрОфис.ЗагрузитьЗначения(Выгрузка.ВыгрузитьКолонку(0));
	Этаформа.ФильтрОфис.ЗаполнитьПометки(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда) 
	
	Если Объект.Список.Количество() = 0 Тогда
		ЗаполнитьНаСервере();
		Модифицированность = Истина;
	Иначе	
		Режим = РежимДиалогаВопрос.ДаНет;
		Текст = "Табличная часть будет перезаполнена. Продолжить?";
		Ответ = Вопрос(Текст, Режим, 0);    
		Если Ответ = КодВозвратаДиалога.Да Тогда
			ЗаполнитьНаСервере();
			Модифицированность = Истина;
		КонецЕсли;
	КонецЕсли;  
	
	ФильтрОфисПометкаПриИзменении(Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОкладыНаСервере()
	
	Запрос = Новый Запрос;  
	Запрос.УстановитьПараметр("Ссылка", Объект.Список.Выгрузить().ВыгрузитьКолонку("Сотрудник"));
	Запрос.Текст = "ВЫБРАТЬ
	               |	Сотрудники.Ссылка КАК Сотрудник,
	               |	Сотрудники.Оклад КАК Оклад,
	               |	Сотрудники.Валюта КАК Валюта
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.Ссылка В(&Ссылка)";
    Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НайдСтроки = Объект.Список.НайтиСтроки(Новый Структура("Сотрудник", Выборка.Сотрудник)); 
		Если НайдСтроки.ВГраница() = -1 Тогда
			Продолжить;
		КонецЕсли;
		НайдСтрока = НайдСтроки[0];
	    Если Выборка.Валюта = ВалютаРубль Тогда
			НайдСтрока.ОкладВРублях = Выборка.Оклад;
		ИначеЕсли Выборка.Валюта = ВалютаДоллар Тогда
			НайдСтрока.ОкладВДолларах = Выборка.Оклад;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОклады(Команда)
	
	ЗаполнитьОкладыНаСервере(); 
	Для каждого СтрокаТЧ Из Объект.Список Цикл
		ПересчитатьСтрокуТЧ(СтрокаТЧ)
	КонецЦикла;
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ПересчитатьСтрокуТЧ(СтрокаТЧ)

	СтрокаТЧ.НачисленоВДолларах 	= СтрокаТЧ.ОкладВДолларах + СтрокаТЧ.ПремияВДолларах;
	СтрокаТЧ.КВыдачеВДолларах 		= СтрокаТЧ.НачисленоВДолларах - СтрокаТЧ.АвансВДолларах - СтрокаТЧ.ШтрафВДолларах;
	СтрокаТЧ.НачисленоВРублях 		= СтрокаТЧ.ОкладВРублях + СтрокаТЧ.ПремияВРублях;
	СтрокаТЧ.КВыдачеВРублях 		= СтрокаТЧ.НачисленоВРублях - СтрокаТЧ.АвансВРублях - СтрокаТЧ.ШтрафВРублях;

КонецПроцедуры


&НаКлиенте
Процедура СформироватьСписокВыбораМесяца(Год)
    
	Элементы.Месяц.СписокВыбора.Очистить();
	Элементы.Месяц.СписокВыбора.Добавить(Формат(Год-1, "ЧГ=0"));
	Для к = 1 По 12  Цикл
		СформДата = Дата(Год, к, 1);
		Наим = Формат(СформДата, "ДФ = ММММ_гггг");
		Наим = СтрЗаменить(Наим, "_", " ");
		Элементы.Месяц.СписокВыбора.Добавить(Наим);    
	КонецЦикла; 
	Элементы.Месяц.СписокВыбора.Добавить(Формат(Год+1, "ЧГ=0"));
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКВыдаче()
	
	Для каждого Стр ИЗ Объект.Список Цикл
		Стр.КВыдачеВДолларах = 0;
		Стр.КВыдачеВРублях = 0;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрОфисПометкаПриИзменении(Элемент)
	
	Фильтр = Новый СписокЗначений;
	Для каждого Эл Из ФильтрОфис Цикл
		Если Эл.Пометка Тогда
			Фильтр.Добавить(Эл.Значение);
		КонецЕсли;
	КонецЦикла;
	
    Для каждого СтрокаТЧ Из Объект.Список Цикл
		СтрокаТЧ.ПризнакОтбора = Фильтр.НайтиПоЗначению(СтрокаТЧ.ОФис) <> Неопределено;
	КонецЦикла;
	
	Отбор = Новый Структура;
	Отбор.Вставить("ПризнакОтбора", Истина);
	Элементы.Список.ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);
	
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступность()

	Для каждого Элемент Из Элементы Цикл 
		Тип = ТипЗнч(Элемент);
		Если Тип = Тип("ПолеФормы") ИЛИ Тип = Тип("ТаблицаФормы") Тогда
			Элемент.ТолькоПросмотр = Объект.Окончательно; 
		ИначеЕсли Тип = Тип("КнопкаФормы") И Элемент.Родитель <> Элементы.ФормаКоманднаяПанель Тогда
			Элемент.Доступность = НЕ Объект.Окончательно;
		КонецЕсли;
	КонецЦикла;	    
	Если Элементы.Найти("Снять") <> Неопределено Тогда
		Элементы.Снять.Доступность = Объект.Окончательно;
	КонецЕсли;
	Если Элементы.Найти("Установить") <> Неопределено Тогда
		Элементы.Установить.Доступность = НЕ Объект.Окончательно;
	КонецЕсли;
	Элементы.Окончательно.ТолькоПросмотр = Истина;
	
КонецПроцедуры



 