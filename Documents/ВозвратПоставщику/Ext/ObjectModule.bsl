Процедура ПересчитатьСтроку(Стр)
	Стр.Серия = Стр.Партия.Серия;
	Стр.ЦенаЗакупки = Стр.Партия.ЦенаЗакупки;
	Стр.СуммаЗакупки = Стр.ЦенаЗакупки * Стр.Количество;
КонецПроцедуры

Процедура ПересчитатьИтоги()
	Сумма = Товары.Итог("СуммаЗакупки");
	Строк = Товары.Количество();
	СуммаПривязано = Привязки.Итог("Сумма1");
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	// © Primus1C  02.04.2025  НАЧАЛО ►
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	// © Primus1C  ОКОНЧАНИЕ ◄

	Если глЗапретЗаписиПоДате(Ссылка) Тогда Отказ = Истина; Возврат; КонецЕсли;
	
	//Если НЕ ЗначениеЗаполнено(Фирма) Тогда Фирма = гоФирма() КонецЕсли; 
	//Если НЕ ЗначениеЗаполнено(КемСоздан) Тогда КемСоздан = гоПользователь() КонецЕсли; 
	//Если НЕ ЗначениеЗаполнено(Создан) Тогда Создан = ТекущаяДата() КонецЕсли; 
	//КемСохранен = гоПользователь();
	//Сохранен = ТекущаяДата();
    омСервер.ЗаписатьОбщиеРеквизиты(ЭтотОбъект);
	
	БылФлагНеПроверятьОстатки = ФлагНеПроверятьОстатки;
	Если (БылФлагНеПроверятьОстатки = 1) ИЛИ (БылФлагНеПроверятьОстатки = 9) Тогда 
		ФлагНеПроверятьОстатки = 2;
		Если БылФлагНеПроверятьОстатки = 9 Тогда Возврат КонецЕсли; 
	ИначеЕсли БылФлагНеПроверятьОстатки = 2 Тогда 
		ФлагНеПроверятьОстатки = 0;
	КонецЕсли;
	
	Для Каждого Стр Из Товары Цикл
		ПересчитатьСтроку(Стр);
	КонецЦикла;
	ПересчитатьИтоги();
	
	СуммаКР = 0;
	Для Каждого Стр Из Привязки Цикл
		правильнаяСумма = омСервер.ПересчетЗн(Стр.Сумма2, Стр.Валюта2, Валюта, Фирма, Дата, 2);
		//тут приход в кассу, считаем, как для оплаты покупателя
		Если правильнаяСумма <> Стр.Сумма1 Тогда гоПлюс(СуммаКР, Стр.Сумма1 - правильнаяСумма) КонецЕсли; 
	КонецЦикла;  
	
КонецПроцедуры

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	Префикс = глПрефиксДефис(Фирма);
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Фирма = гоФирма();
	КемСоздан = гоПользователь(); 
	Создан = ТекущаяДата(); 
	Окончательно = Ложь;
	Привязки.Очистить();
	СуммаПривязано = 0;
	
	Валюта = Фирма.Валюта;
	Склад = Фирма.Склад;
	
	//2017.03.24
	Мас = ОбщегоНазначенияПовтИсп.МассивДоступныхСкладов();
	Если Мас.Количество() <> 0 Тогда Склад = Мас[0] КонецЕсли;
КонецПроцедуры

