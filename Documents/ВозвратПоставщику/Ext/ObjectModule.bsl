КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если (ФлагНеПроверятьОстатки <> 2) И (Товары.Количество() > 0) Тогда  
		НадоЗаписать = Ложь;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "
			|ВЫБРАТЬ
			|	МИНИМУМ(ДокТовары.НомерСтроки) КАК НомерСтроки,
			|	ДокТовары.Номенклатура КАК Номенклатура,
			|	ДокТовары.Партия КАК Партия,
			|	СУММА(ДокТовары.Количество) КАК Количество
			|ПОМЕСТИТЬ ВТТовары
			|ИЗ
			|	Документ.ВозвратПоставщику.Товары КАК ДокТовары
			|ГДЕ
			|	ДокТовары.Ссылка = &Ссылка
			|СГРУППИРОВАТЬ ПО
			|	ДокТовары.Номенклатура,
			|	ДокТовары.Партия
			|ИНДЕКСИРОВАТЬ ПО
			|	Номенклатура,
			|	Партия
			|;
			|ВЫБРАТЬ
			|	ВТТовары.НомерСтроки,
			|	ВТТовары.Номенклатура,
			|	ВТТовары.Партия,
			|	ВТТовары.Количество,
			|	ЕСТЬNULL(ОстПар.ОстатокОстаток, 0) КАК Остаток
			|ИЗ
			|	ВТТовары КАК ВТТовары
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки( , Партия В
			|					(ВЫБРАТЬ
			|						Т.Партия
			|					ИЗ
			|						ВТТовары КАК Т) И Склад = &Склад И Фирма = &Фирма) КАК ОстПар
			|		ПО ВТТовары.Партия = ОстПар.Партия
			|";

		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Запрос.УстановитьПараметр("Склад", Склад);
		Запрос.УстановитьПараметр("Фирма", Фирма);
		
		Исправлений = 0;
		Первое = Истина;
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если НЕ ЗначениеЗаполнено(Выборка.Партия) Тогда Продолжить КонецЕсли; 
			
			Если Выборка.Количество <= Выборка.Остаток Тогда Продолжить КонецЕсли; 
			Если Первое Тогда Сообщить("Проведение " + Ссылка + " - не хватило остатков партий:"); Первое = Ложь; КонецЕсли; 
			
			Сообщить(гоИмя(Выборка.Партия) + ": количество = " + Выборка.Количество + " больше остатка = " + Выборка.Остаток + "! ИСПРАВЛЕНО!!!");
			
			БылоКолво = Выборка.Количество;		 	
			Колич = Выборка.Остаток;
			Номен = Выборка.Партия.Владелец;
			гоЗаписьЖурналаРегистрации(Строка(БылоКолво) + "->" + Строка(Колич) + "|" + гоИмя(Ссылка, Ложь), "Возврат поставщику", "Не хватило при проведении", Номен, 2);
			гоЗаписьЖурналаРегистрации(Строка(БылоКолво) + "->" + Строка(Колич) + "|" + гоИмя(Номен, Ложь), "Возврат поставщику", "Не хватило при проведении", Ссылка, 2);
			
			локОстаток = Выборка.Остаток;
			Если локОстаток < 0 Тогда локОстаток = 0 КонецЕсли;
			Отнять = Выборка.Количество - локОстаток;
			
			Нашли = Товары.НайтиСтроки(Новый Структура("Партия", Выборка.Партия));
			Если Нашли.Количество() = 0 Тогда Отказ = Истина; Сообщить("Странная ошибка! Вообще не нашли " + гоИмя(Выборка.Партия)); Возврат; КонецЕсли; 
			
			Для Каждого Лтр Из Нашли Цикл
				Если Лтр.Количество >= Отнять Тогда
					Лтр.Количество = Лтр.Количество - Отнять;
					Отнять = 0;
				Иначе
					Отнять = Отнять - Лтр.Количество;
					Лтр.Количество = 0;
				КонецЕсли; 
				Исправлений = Исправлений + 1;
				Если Отнять = 0 Тогда Прервать КонецЕсли; 
			КонецЦикла; 
			
			Если Отнять <> 0 Тогда Отказ = Истина; Сообщить("Странная ошибка! Не смогли уменьшить количество на " + Отнять + " для " + гоИмя(Выборка.Партия)); Возврат; КонецЕсли; 
		КонецЦикла;
		
		НадоЗаписать = НЕ (Исправлений = 0);
		Если НадоЗаписать Тогда Записать(РежимЗаписиДокумента.Запись) КонецЕсли; 
	КонецЕсли; 
	
    ЕстьОстатки = Ложь;
    ЕстьРезервы = Ложь;
	ЕстьДолги = Ложь;
	ЕстьНезакрытые = Ложь;
	ЕстьРасходыДоходы = Ложь;
	ЕстьПоставки = Ложь;
	ЕстьПлатежныйКалендарь = Ложь;
	
	Для Каждого Стр Из Товары Цикл
		Если Стр.Количество = 0 Тогда Продолжить КонецЕсли; 
		
		//+ 
		лИнвойс = Стр.Партия.Док.ВКД_Инвойс.ДокументОснование; 
		Если ЗначениеЗаполнено(лИнвойс) Тогда
			Движение = Движения.ПлатежныйКалендарьЗакупки.ДобавитьРасход();
			Движение.Период			= Дата;
			Движение.Контрагент 	= Контрагент; 
			Движение.Инвойс			= лИнвойс;
			Движение.Сумма			= Сумма;
			Движение.Валюта			= Валюта;
			Движение.ДатаОплаты		= лИнвойс.ДатаОплаты;
			Движение.ДатаПрибытия	= лИнвойс.ДатаНаСкладеОтправителя; 
			ЕстьПлатежныйКалендарь = Истина;      
		КонецЕсли;
		//-
		
		Движение = Движения.ОстаткиТовара.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Фирма = Фирма;
		Движение.Склад = Склад;
		Движение.Номенклатура = Стр.Номенклатура;
		Движение.Партия = Стр.Партия;
		Движение.Остаток = - Стр.Количество;
		Движение.Резерв = 0;
		ЕстьОстатки = Истина;
		
		Если НЕ Окончательно Тогда
			Движение = Движения.ОстаткиТовара.ДобавитьПриход();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Склад = Склад;
			Движение.Номенклатура = Стр.Номенклатура;
			Движение.Партия = Стр.Партия;
			Движение.Остаток = 0;
			Движение.Резерв = Стр.Количество;
			ЕстьОстатки = Истина;
			
			//Движение = Движения.РезервыТовара.ДобавитьПриход();
			//Движение.Период = Дата;
			//Движение.Фирма = Фирма;
			//Движение.Склад = Склад;
			//Движение.Номенклатура = Стр.Номенклатура;
			//Движение.Партия = Стр.Партия;
			//Движение.Док = Ссылка;
			//Движение.Остаток = Стр.Количество;
			//ЕстьРезервы = Истина;
		Иначе
			Движение = Движения.Поставки.Добавить();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Валюта = Валюта;
			Движение.Поставщик = Контрагент;
			Движение.Номенклатура = Стр.Номенклатура;
			Движение.Количество = - Стр.Количество;
			Движение.Сумма = - Стр.СуммаЗакупки;
			ЕстьПоставки = Истина;
		КонецЕсли; 
	КонецЦикла;

	Если Окончательно Тогда
		Для Каждого Стр Из Привязки Цикл
			Если Стр.ЭтоПредоплата Тогда
				Движение = Движения.Долги.ДобавитьПриход();
			Иначе
				Движение = Движения.Долги.ДобавитьРасход();
			КонецЕсли; 
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Док = Стр.Док2;
			Движение.Валюта = Стр.Валюта2;
			Движение.Контрагент = Контрагент;
			Движение.ДолгПокупателя = 0;
			Движение.ПредоплатаПокупателя = 0;
			Движение.ДолгПоставщику = ?(Стр.ЭтоПредоплата, 0, Стр.Сумма2);
			Движение.ПредоплатаПоставщику = ?(Стр.ЭтоПредоплата, Стр.Сумма2, 0);
			Движение.Чем = Ссылка;
			ЕстьДолги = Истина;
		КонецЦикла; 
		
		Предоплата = Сумма - СуммаПривязано;
		
		Движение = Движения.Долги.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Фирма = Фирма;
		Движение.Док = Ссылка;
		Движение.Валюта = Валюта;
		Движение.Контрагент = Контрагент;
		Движение.ДолгПокупателя = 0;
		Движение.ПредоплатаПокупателя = 0;
		Движение.ДолгПоставщику = 0;
		Движение.ПредоплатаПоставщику = Предоплата;
		Движение.Чем = 0;
		ЕстьДолги = Истина;
		
		//универсально, независимо от типа, проводим КР, если они есть
		Если СуммаКР <> 0 Тогда
			Движение = Движения.РасходыДоходы.Добавить();
			Движение.Период = Дата;
			Движение.Фирма = Фирма;
			Движение.Статья = ?(СуммаКР < 0, Справочники.Статьи.РасходОтКР, Справочники.Статьи.ДоходОтКР);
			Движение.Вид = Движение.Статья.ВидСтатьи;
			Движение.Валюта = Валюта;
			Движение.Сумма = гоАбс(СуммаКР);
			ЕстьРасходыДоходы = Истина;
		КонецЕсли; 
	Иначе
		Движение = Движения.НезакрытыеДокументы.ДобавитьПриход();
		Движение.Период = Дата;
		Движение.Фирма = Фирма;
		Движение.Контрагент = Контрагент;
		Движение.ВидДокумента = Перечисления.ВидДокумента.ВозвратПоставщику;
		Движение.Количество = 1;
		ЕстьНезакрытые = Истина;
	КонецЕсли; 
	
	Движения.Долги.Записывать = ЕстьДолги;
	Движения.ОстаткиТовара.Записывать = ЕстьОстатки;
	//Движения.РезервыТовара.Записывать = ЕстьРезервы;
	Движения.НезакрытыеДокументы.Записывать = ЕстьНезакрытые;
	Движения.РасходыДоходы.Записывать = ЕстьРасходыДоходы;
	Движения.Поставки.Записывать = ЕстьПоставки;    
	//+
	Движения.ПлатежныйКалендарьЗакупки.Записывать = ЕстьПлатежныйКалендарь;
	//-
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	Если гоАдминистратор() Тогда Возврат КонецЕсли; 
	
	Если Окончательно Тогда Сообщить("Отмена проведения невозможна! Документ закрыт {Окончательно}!"); Отказ = Истина; КонецЕсли;
	
	Если Товары.Количество() <> 0 Тогда Сообщить("Отмена проведения невозможна! Документ не пустой!"); Отказ = Истина; КонецЕсли;
	
	//Если НЕ (гоМельник() ИЛИ гоКолинко() ИЛИ гоЕстьРоль("КомуВчераСклад")) Тогда
	//	Если НачалоДня(Дата) < гоТекущаяДата() Тогда
	//		Сообщить("Только Избранный!"); Отказ = Истина; Возврат; КонецЕсли; КонецЕсли; 
КонецПроцедуры
