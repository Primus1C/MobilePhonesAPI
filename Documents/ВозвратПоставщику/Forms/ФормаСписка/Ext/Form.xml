	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Докум.Ссылка,
	Докум.ПометкаУдаления,
	Докум.Номер,
	Докум.Дата,
	Докум.Проведен,
	Докум.Контрагент,
	Докум.Сумма,
	Докум.Валюта,
	Докум.Строк,
	Докум.СуммаПривязано,
	Докум.Склад,
	Докум.КемСоздан,
	Докум.Создан,
	Докум.КемСохранен,
	Докум.Сохранен,
	Докум.Фирма,
	Докум.Примечание,
	Докум.Окончательно,
	Докум.МоментВремени,
	ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) КАК Предоплата,
	ВЫБОР
		КОГДА (Докум.Окончательно И Докум.Сумма &gt; 0)
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) &lt;&gt; 0
						ТОГДА ВЫБОР
								КОГДА ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) &lt;&gt; Докум.Сумма
									ТОГДА ЗНАЧЕНИЕ(Перечисление.Предоплаты.Частично)
								ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Неоплачено)
							КОНЕЦ
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.Полностью)
				КОНЕЦ
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.Предоплаты.НеЗакрыто)
	КОНЕЦ КАК Состояние
ИЗ
	Документ.ВозвратПоставщику КАК Докум
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки КАК Рег
		ПО Докум.Ссылка = Рег.Док	</QueryText>
				<MainTable>Document.ВозвратПоставщику</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:item xsi:type="dcsset:FilterItemComparison">
							<dcsset:left xsi:type="dcscor:Field">Фирма</dcsset:left>
							<dcsset:comparisonType>Equal</dcsset:comparisonType>
