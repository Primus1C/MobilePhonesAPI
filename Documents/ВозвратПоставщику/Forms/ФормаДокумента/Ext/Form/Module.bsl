&НаСервере
Процедура ВКД_ЗаполнитьПоСерии(Серия)
		
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	              |	ОстаткиТовараОстатки.Склад,
	              |	ОстаткиТовараОстатки.Номенклатура,
	              |	ОстаткиТовараОстатки.Партия,
	              |	ОстаткиТовараОстатки.Партия.Серия КАК Серия,
	              |	ОстаткиТовараОстатки.Партия.Контрагент КАК Поставщик,
	              |	ОстаткиТовараОстатки.Партия.Валюта КАК Валюта,
	              |	ВЫБОР
	              |		КОГДА ОстаткиТовараОстатки.Партия.ВКД_ЦенаСоСкидкой = 0
	              |			ТОГДА ОстаткиТовараОстатки.Партия.ЦенаЗакупки
	              |		ИНАЧЕ ОстаткиТовараОстатки.Партия.ВКД_ЦенаСоСкидкой
	              |	КОНЕЦ КАК ЦенаЗакупки
	              |ИЗ
	              |	РегистрНакопления.ОстаткиТовара.Остатки(, Партия.Серия = &Серия) КАК ОстаткиТовараОстатки" ;
	
	Запрос.УстановитьПараметр("Серия",Серия);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Количество() = 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не найден товар с этой серией!" ;
		Сообщение.Сообщить();
	ИначеЕсли Выборка.Количество() > 1 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Найдено несколько товаров с этой серией! Автопоиск отключен!";
        Сообщение.Сообщить();
		Объект.ВКД_АвтоматическийПоиск = Ложь;
		Возврат;
	Иначе
		Выборка.Следующий();
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Объект.Контрагент = Выборка.Поставщик;
	ИначеЕсли ЗначениеЗаполнено(Объект.Контрагент) И Объект.Контрагент <> Выборка.Поставщик Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Эта номенклатура поставлена другим поставщиком! Необходимо создать другой документ!";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
		Объект.Валюта = Выборка.Валюта;
		Объект.Склад = Выборка.Склад;
		Стр = Объект.Товары.Добавить();
		Стр.Номенклатура = Выборка.Номенклатура;
		Стр.Серия = Выборка.Серия;
		Стр.Партия = Выборка.Партия;
		Стр.ЦенаЗакупки = Выборка.ЦенаЗакупки;
		Стр.Количество = 1;
		Стр.СуммаЗакупки = Выборка.ЦенаЗакупки;	
		
	КонецЕсли;

КонецПроцедуры

