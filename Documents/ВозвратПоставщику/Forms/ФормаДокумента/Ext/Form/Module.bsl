	// © Primus1C  ОКОНЧАНИЕ ◄
КонецПроцедуры

&НаКлиенте
Процедура МоиОстатки()
	стрОстатки = "?";
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	стрОстатки = омСервер.МоиОстатки(Объект.Ссылка, Стр.Номенклатура, Стр.Партия);
КонецПроцедуры

&НаКлиенте
Процедура МояЗаписать(ПроверятьМодифицированность = Истина)
	УстановитьВидимостьДоступность();
	
	Если ПроверятьМодифицированность Тогда
		Если НЕ Модифицированность Тогда Возврат КонецЕсли; КонецЕсли; 
		
	Записать(РежимЗаписиПроведение);
	МоиОстатки();
	МоиИтоги();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	НетСтрок = Объект.Товары.Количество() = 0;
	ЕстьСтроки = НЕ НетСтрок;
	
	Закрыто = Объект.Окончательно;	
	НеЗакрыто = НЕ Закрыто;
	
	Элементы.Дата.ТолькоПросмотр = Закрыто;
	Элементы.Склад.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Валюта.ТолькоПросмотр = ЕстьСтроки ИЛИ Закрыто;
	Элементы.Установить.Доступность = НеЗакрыто;
	Элементы.Снять.Доступность = Закрыто;
	Элементы.Контрагент.ТолькоПросмотр = Закрыто ИЛИ ЕстьСтроки;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриАктивизацииСтроки(Элемент)
	МоиОстатки();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	МоеДобавление();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
	МоеРедактирование(СтрЗаменить(Элемент.ТекущийЭлемент.Имя, "Товары", ""));
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалением(Элемент, Отказ)
	Отказ = Истина;
	МоеУдаление();
КонецПроцедуры


&НаКлиенте
Процедура МоеДобавление()
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если гоПЗ(Объект.Склад) Тогда клОшибка(НСтр("ru = 'Не задан склад!'; en = 'Warehouse not specified!'")); Возврат; КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда клОшибка(НСтр("ru = 'Не задана валюта!'; en = 'Currency not specified!'")); Возврат; КонецЕсли; 
	Если гоПЗ(Объект.Контрагент) Тогда клОшибка("Не задан поставщик!"); Возврат; КонецЕсли; 
	
	Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли; 
	
	Попытка
		НовНом = Элементы.Товары.ТекущиеДанные.Номенклатура;
		НовПар = Элементы.Товары.ТекущиеДанные.Партия;
	Исключение 
		НовНом = гоПустой("Номенклатура");
		НовПар = гоПустой("Партии");
	КонецПопытки;
	
	МоеДобавлениеШаг(НовНом);
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеШаг(НовНом)
	гоУстановитьПараметрСеанса("Склад", Объект.Склад);
	ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораНоменклатуры", ЭтотОбъект), НовНом, "Выберите номенклатуру");
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораНоменклатуры(НовНом, ДопПараметры) Экспорт
	Если НовНом = Неопределено Тогда Возврат КонецЕсли; 
	
	гоУстановитьПараметрСеанса("Склад", Объект.Склад);
	гоУстановитьПараметрСеанса("Номенклатура", НовНом);
	
	гоУстановитьПараметрСеанса("ВалютаВыбора", Объект.Валюта);
	гоУстановитьПараметрСеанса("ПоставщикВыбора", Объект.Контрагент);
	
	ПоказатьВводЗначения(Новый ОписаниеОповещения("МоеДобавлениеПослеВыбораПартии", ЭтотОбъект, НовНом), НовПар, НСтр("ru = 'Выберите партию'; en = 'Select batch'"));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВыбораПартии(НовПар, НовНом) Экспорт
	Если НовПар = Неопределено Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	//тут работает выбор нормально, получим остаток партии, вдруг выбрали без остатка
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если ОстПар <= 0 Тогда 
		клОшибка("Нет остатка у выбранной партии!"); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	Нашли = Объект.Товары.НайтиСтроки(Новый Структура("Партия", НовПар));
	Если НЕ (Нашли.Количество() = 0) Тогда 
		клОшибка(гоИмя(НовПар) + ": уже есть в документе!" + гоРС() + "Используйте редактирование количества!!!"); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	Пар = Новый Структура;
	Пар.Вставить("Фирма", Объект.Фирма);
	Пар.Вставить("Номенклатура", НовНом);
	Пар.Вставить("Количество", ОстПар);
	Пар.Вставить("Склад", Объект.Склад);
	Пар.Вставить("Партия", НовПар);
	
	ОткрытьФорму("ОбщаяФорма.ВводСтрокиПМ", Пар, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("МоеДобавлениеПослеВводаСтроки", ЭтотОбъект, Новый Структура("НовНом,НовПар", НовНом, НовПар)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеВводаСтроки(Пар, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	
	Если гоПЗ(Пар) Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли; 
	
	НовКол = Пар.Количество;
	Если НовКол = 0 Тогда 
		клОшибка(НСтр("ru = 'Не введено количество!'; en = 'Quantity not entered!'")); 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	клСохранитьИзменения(Новый ОписаниеОповещения("МоеДобавлениеПослеПодтверждения", ЭтотОбъект, 
		Новый Структура("НовНом,НовПар,НовКол", НовНом, НовПар, НовКол)));
КонецПроцедуры

&НаКлиенте
Процедура МоеДобавлениеПослеПодтверждения(Результат, Параметры) Экспорт
	НовНом = Параметры.НовНом;
	НовПар = Параметры.НовПар;
	НовКол = Параметры.НовКол;
	
	Если НЕ Результат Тогда 
		МоеДобавлениеШаг(НовНом); 
		Возврат; 
	КонецЕсли;
	
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, НовПар);
	Если НовКол > ОстПар Тогда 
		клОшибка("Не хватило остатка " + Строка(НовКол - ОстПар) + " для " + гоИмя(НовПар) + ", исправлено на " + ОстПар + "!");
		НовКол = ОстПар;
	КонецЕсли;
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНом;
	НовСтр.Партия = НовПар;
	НовСтр.Количество = НовКол;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(Строка(НовКол) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
	
	МоеДобавлениеШаг(НовНом);
КонецПроцедуры


&НаКлиенте
Процедура ЛюбаяСерия(ШК)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Если гоПЗ(Объект.Склад) Тогда клОшибка("Не задан склад!"); Возврат; КонецЕсли; 
	Если гоПЗ(Объект.Валюта) Тогда клОшибка("Не задана валюта!"); Возврат; КонецЕсли; 
	Если гоПЗ(Объект.Контрагент) Тогда клОшибка("Не задан поставщик!"); Возврат; КонецЕсли; 
	
	Если гоПЗ(Объект.Ссылка) Тогда МояЗаписать(Ложь) КонецЕсли; 
	
	//по идее, нужно найти товар с такой серией и передать его в добавление строки, зачем изобретать велосипед?
	СпиПар = омСервер.ПартииПоСерииОстатки(ШК, Объект.Фирма, Объект.Склад);
	
	Ско = СпиПар.Количество();
	Если Ско  = 0 Тогда
		Сигнал();
		клОшибка("Нет остатков по серии: " + ШК + "!");
		Возврат;
	ИначеЕсли Ско > 1 Тогда
		Сигнал();
		СпиПар.ПоказатьВыборЭлемента(Новый ОписаниеОповещения("ЛюбаяСерияПослеВыбораПартии", ЭтотОбъект, ШК), 
			"Найдено несколько партий с такой серией, выберите:");
		Возврат;
	КонецЕсли; 
	
	ЛюбаяСерияПродолжение(СпиПар[0].Значение, ШК);
КонецПроцедуры

&НаКлиенте
Процедура ЛюбаяСерияПослеВыбораПартии(Эле, ШК) Экспорт
	Если Эле = Неопределено Тогда Возврат КонецЕсли;
	ЛюбаяСерияПродолжение(Эле.Значение, ШК);
КонецПроцедуры

&НаКлиенте
Процедура ЛюбаяСерияПродолжение(ТекПар, ШК)
	Если ТекПар = 0 Тогда Возврат КонецЕсли; 
	
	НовКол = 1;
	НовНом = гоРеквизит(ТекПар, "Владелец");
	
	//проверить валюту и поставщика нужно
	НовПос = гоРеквизит(ТекПар, "Контрагент");
	НовВал = гоРеквизит(ТекПар, "Валюта");
	
	Если НовПос <> Объект.Контрагент Тогда клОшибка("Не тот поставщик: " + гоИмя(НовПос) + "!"); Возврат; КонецЕсли; 
	Если НовВал <> Объект.Валюта Тогда клОшибка("Не та валюта: " + гоИмя(НовВал) + "!"); Возврат; КонецЕсли;
	
	НовСтр = Объект.Товары.Добавить();
	
	НовСтр.Номенклатура = НовНом;
	НовСтр.Партия = ТекПар;
	НовСтр.Количество = НовКол;
	
	ИДИ = НовСтр.ПолучитьИдентификатор();
	
	МояЗаписать(Ложь);
	
	гоЗаписьЖурналаРегистрации(ШК + "|" + Строка(НовКол) + "|" + гоИмя(НовНом, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Добавление строки", Объект.Ссылка, 2);
	
	Элементы.Товары.ТекущаяСтрока = ИДИ;
КонецПроцедуры


&НаКлиенте
Процедура МоеРедактирование(Кол)
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли; 
	Если Объект.Окончательно Тогда Возврат КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	
	Если Кол = "Количество" Тогда
		БылКол = Стр.Количество;
		НовКол = БылКол;
		
		ПоказатьВводЧисла(Новый ОписаниеОповещения("МоеРедактированиеПослеВводаКоличества", ЭтотОбъект, Новый Структура("ИДИ,БылКол", ИДИ, БылКол)), НовКол, "Введите количество", 14, ЧислоЗнаковКоличество);
	Иначе
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МоеРедактированиеПослеВводаКоличества(НовКол, Параметры) Экспорт
	Если НовКол = Неопределено Тогда Возврат КонецЕсли;
	
	ИДИ = Параметры.ИДИ;
	БылКол = Параметры.БылКол;
	Стр = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	ОстПар = омСервер.ОстатокПартии(Объект.Фирма, Объект.Склад, Стр.Партия);
	Если Объект.Проведен Тогда ОстПар = ОстПар + БылКол КонецЕсли;
	
	Если НовКол > ОстПар Тогда 
		клОшибка("Не хватило остатка " + Строка(НовКол - ОстПар) + " для " + гоИмя(Стр.Партия) + ", исправлено на " + ОстПар + "!");
		НовКол = ОстПар;
	КонецЕсли;
	Если НовКол = Стр.Количество Тогда Возврат КонецЕсли;
	
	Стр.Количество = НовКол;
	
	МояЗаписать(Ложь);
	
	Колич = НовКол;
	Номен = Стр.Номенклатура;
	СЦена = Стр.ЦенаЗакупки;
	
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Объект.Ссылка, Ложь), ИмяДокумента, "Редактирование количества", Номен, 2);
	гоЗаписьЖурналаРегистрации(Строка(БылКол) + "->" + Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента, "Редактирование количества", Объект.Ссылка, 2);
КонецПроцедуры


&НаКлиенте
Процедура МоеУдаление()
	Если ЭтаФорма.ТолькоПросмотр Тогда Возврат КонецЕсли;
	Если Объект.Окончательно Тогда 
		Если гоАдминистратор() Тогда 
			Сообщить("Под ответственность Администратора!");
		Иначе 
			Возврат;
		КонецЕсли; 
	КонецЕсли; 
	
	МоиИтоги();
	Если НЕ (стрОплата = "") Тогда Возврат КонецЕсли; 
	
	ИДИ = Элементы.Товары.ТекущаяСтрока;
	Стр = Элементы.Товары.ТекущиеДанные;
	Если Стр = Неопределено Тогда Возврат КонецЕсли; 
	
	клНетДа(Новый ОписаниеОповещения("МоеУдалениеЗавершение", ЭтотОбъект, ИДИ),
		"Удалить строку?");
КонецПроцедуры

&НаКлиенте
Процедура МоеУдалениеЗавершение(Результат, ИДИ) Экспорт
	Если НЕ Результат Тогда Возврат КонецЕсли;
	
	Удаляем = Объект.Товары.НайтиПоИдентификатору(ИДИ);
	Если Удаляем = Неопределено Тогда клОшибка("Странно, не нашли текущую строку!"); Возврат; КонецЕсли; 
	
	Номен = Удаляем.Номенклатура;
	СЦена = Удаляем.ЦенаЗакупки;
	Колич = Удаляем.Количество;
	
	Объект.Товары.Удалить(Удаляем);
	
	гоЗаписьЖурналаРегистрации(Строка(Колич) + "|" + гоСуммаЗн(СЦена, ЧислоЗнаковЦенаЗакупки) + "|" + гоИмя(Номен, Ложь), ИмяДокумента + ?(Объект.Окончательно, "ПослеОкончательно", ""), "Удаление строки", Объект.Ссылка, 2);
	
	//партия сама пометится на удаление при записи
	МояЗаписать(Ложь);
КонецПроцедуры


