КонецПроцедуры

&НаСервере
Процедура РаспределитьЗатратыНаСервере()
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ
	             |	ОприходНоменклатуры.Номенклатура КАК Номенклатура,
	             |	ЗНАЧЕНИЕ(Справочник.ГруппыПодбораНоменклатуры.ПустаяСсылка) КАК ТоварнаяГруппа,
	             |	СУММА(ОприходНоменклатуры.Количество) КАК Количество,
	             |	СУММА(ОприходНоменклатуры.Количество * ОприходНоменклатуры.Номенклатура.Вес) / 1000 КАК Вес
	             |ИЗ
	             |	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ОприходНоменклатуры
	             |ГДЕ
	             |	(ОприходНоменклатуры.Документ, ОприходНоменклатуры.Поставка) В
	             |			(ВЫБРАТЬ
	             |				ИнвойсыОтправки.Инвойс,
	             |				ИнвойсыОтправки.Поставка
	             |			ИЗ
	             |				Документ.ОтправкаAWB.Инвойсы КАК ИнвойсыОтправки
	             |			ГДЕ
	             |				ИнвойсыОтправки.Ссылка = &Ссылка)
	             |	И ОприходНоменклатуры.Регистратор ССЫЛКА Документ._Инвойс
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	ОприходНоменклатуры.Номенклатура
	             |АВТОУПОРЯДОЧИВАНИЕ" ;
	Выгрузка = Запр.Выполнить().Выгрузить();
	Для каждого СтрокаВыгрузки Из Выгрузка Цикл
		СтрокаВыгрузки.ТоварнаяГруппа = ТоварнаяГруппа(СтрокаВыгрузки.Номенклатура);
	КонецЦикла;
	
	тзРаспределениеЗатрат = Объект.РаспределениеЗатрат.Выгрузить();
	тзРаспределениеЗатрат.Очистить();
	тзЗатраты = Объект.Затраты.Выгрузить();
	тзЗатраты.Сортировать("ТоварнаяГруппа"); 	// чтобы сначала распределять общие
	
	// распределим по каждой затрате:
	Для каждого СтрокаЗатрат Из тзЗатраты Цикл
		
		Если ЗначениеЗаполнено(СтрокаЗатрат.ТоварнаяГруппа) Тогда
			СтрокиОднойГруппы = Выгрузка.НайтиСтроки(Новый Структура("ТоварнаяГруппа", СтрокаЗатрат.ТоварнаяГруппа));
		Иначе
			СтрокиОднойГруппы = Выгрузка;
		КонецЕсли;
		
		// распределим сумму затраты по весу
		ВесГруппы = 0;
		Для каждого СтрокаТЧ Из СтрокиОднойГруппы Цикл
			ВесГруппы = ВесГруппы + СтрокаТЧ.Вес;  
		КонецЦикла;
		   
		НайдСтроки = Объект.Затраты.НайтиСтроки(Новый Структура("Затрата,Сумма,ТоварнаяГруппа",
																СтрокаЗатрат.Затрата, СтрокаЗатрат.Сумма, СтрокаЗатрат.ТоварнаяГруппа));
		Если НайдСтроки.Количество() > 0 Тогда
			НайдСтрока = НайдСтроки[0];
			НайдСтрока.Вес = ВесГруппы; 
			//НайдСтрока.ЦенаКг = ?(НайдСтрока.Вес=0, НайдСтрока.Сумма, НайдСтрока.Сумма / НайдСтрока.Вес);
		КонецЕсли;
		
		к = ?(ВесГруппы=0, 0, СтрокаЗатрат.Сумма / ВесГруппы);
		Для каждого СтрокаГруппы Из СтрокиОднойГруппы Цикл
			//СтрокаТЧ.Сумма = СтрокаТЧ.Сумма + СтрокаТЧ.Вес * к; 
			СтрокаТЗ = тзРаспределениеЗатрат.Добавить();
			СтрокаТЗ.Номенклатура	= СтрокаГруппы.Номенклатура;
			СтрокаТЗ.Затрата        = СтрокаЗатрат.Затрата;
			СтрокаТЗ.Количество     = СтрокаГруппы.Количество;
			СтрокаТЗ.Вес            = СтрокаГруппы.Вес;
			СтрокаТЗ.Сумма          = СтрокаГруппы.Вес * к;
		КонецЦикла;
		
	КонецЦикла;	 
	
	тзРаспределениеЗатрат.Свернуть("Номенклатура,Затрата,Вес", "Количество,Сумма,Цена");
	Для каждого СтрокаТЗ Из тзРаспределениеЗатрат Цикл
		СтрокаТЗ.Цена = СтрокаТЗ.Сумма / СтрокаТЗ.Количество;
	КонецЦикла; 
	тзРаспределениеЗатрат.Сортировать("Номенклатура,Затрата");
	Объект.РаспределениеЗатрат.Загрузить(тзРаспределениеЗатрат);
	
	ЗаполнитьДеревоЗначенийНаСервере();
	ВОЗВРАТ;
	
	////////////////////////////////////

	лВыводитьСообщения = Ложь;
	
	Запр = Новый Запрос;  
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.Текст = "ВЫБРАТЬ
				|	ОприходНоменклатуры.Номенклатура,
				|	СУММА(ОприходНоменклатуры.Количество) КАК Количество,
				|	СУММА(ОприходНоменклатуры.Количество * ОприходНоменклатуры.Номенклатура.Вес) / 1000 КАК Вес
				|ИЗ
				|	РегистрНакопления.ВКД_ОприходованиеНоменклатуры КАК ОприходНоменклатуры
				|ГДЕ
				|	(ОприходНоменклатуры.Документ, ОприходНоменклатуры.Поставка) В
				|			(ВЫБРАТЬ
				|				ИнвойсыОтправки.Инвойс,
				|				ИнвойсыОтправки.Поставка
				|			ИЗ
				|				Документ.ОтправкаAWB.Инвойсы КАК ИнвойсыОтправки
				|			ГДЕ
				|				ИнвойсыОтправки.Ссылка = &Ссылка)
				|	И ОприходНоменклатуры.Регистратор ССЫЛКА Документ._Инвойс
				|
				|СГРУППИРОВАТЬ ПО
				|	ОприходНоменклатуры.Номенклатура
				|АВТОУПОРЯДОЧИВАНИЕ" ;
	Объект.РаспределениеЗатрат.Загрузить(Запр.Выполнить().Выгрузить()); 
	ОтобразитьТоварныеГруппы();

	Если Объект.РаспределениеЗатрат.Итог("Вес") = 0 Тогда
	 	Возврат;
	 КонецЕсли;
	 //К = Объект.СуммаЗатрат / Объект.РаспределениеЗатрат.Итог("Вес");
	 //Для каждого СтрокаТЧ Из Объект.РаспределениеЗатрат Цикл
	 //	СтрокаТЧ.Сумма 	= СтрокаТЧ.Вес * К;
	 //	СтрокаТЧ.Цена 	= СтрокаТЧ.Вес * К / СтрокаТЧ.Количество;
	 //КонецЦикла;
	 
	 тзЗатраты = Объект.Затраты.Выгрузить();
	 тзЗатраты.Сортировать("ТоварнаяГруппа"); 	// чтобы сначала распределять общие
	 
	 // распределим по каждой затрате:
	 Для каждого СтрокаЗатрат Из тзЗатраты Цикл
		 
		 Если лВыводитьСообщения Тогда
			Сообщить(СтрШаблон("Стр.%1. Распределение группы <%2> (сумма %3):", СтрокаЗатрат.НомерСтроки, СтрокаЗатрат.ТоварнаяГруппа, Формат(СтрокаЗатрат.Сумма,"ЧДЦ=2")));			 
		 КонецЕсли;   
		 
		 Если ЗначениеЗаполнено(СтрокаЗатрат.ТоварнаяГруппа) Тогда
			 СтрокиОднойГруппы = Объект.РаспределениеЗатрат.НайтиСтроки(Новый Структура("ТоварнаяГруппа", СтрокаЗатрат.ТоварнаяГруппа));
		 Иначе
			 СтрокиОднойГруппы = Объект.РаспределениеЗатрат;
		 КонецЕсли;
		 
		 // распределим сумму затраты по весу
		 ВесГруппы 	= 0;
		 Для каждого СтрокаТЧ Из СтрокиОднойГруппы Цикл
			 ВесГруппы 	= ВесГруппы + СтрокаТЧ.Вес;  
		 КонецЦикла;
			 //+  
			 НайдСтроки = Объект.Затраты.НайтиСтроки(Новый Структура("Затрата,Сумма,ТоварнаяГруппа",СтрокаЗатрат.Затрата,СтрокаЗатрат.Сумма,СтрокаЗатрат.ТоварнаяГруппа));
			 Если НайдСтроки.Количество() > 0 Тогда
				 НайдСтрока = НайдСтроки[0];
				 НайдСтрока.Вес = ВесГруппы; 
				 //НайдСтрока.ЦенаКг = ?(НайдСтрока.Вес=0, НайдСтрока.Сумма, НайдСтрока.Сумма / НайдСтрока.Вес);
			 КонецЕсли;
			 //-
		 к = ?(ВесГруппы=0, 0, СтрокаЗатрат.Сумма / ВесГруппы);
		 Для каждого СтрокаТЧ Из СтрокиОднойГруппы Цикл
			 СтрокаТЧ.Сумма = СтрокаТЧ.Сумма + СтрокаТЧ.Вес * к;
			 Если лВыводитьСообщения Тогда
				 Сообщить(СтрШаблон("   стр.%1 '%2': +%3", СтрокаТЧ.НомерСтроки, СтрокаТЧ.Номенклатура, Формат(СтрокаТЧ.Вес * к, "ЧДЦ=5")));			 
			 КонецЕсли;   
		 КонецЦикла;
		 
	 КонецЦикла;                               
	 
	 Для каждого СтрокаТЧ Из Объект.РаспределениеЗатрат Цикл
	 	СтрокаТЧ.Цена = СтрокаТЧ.Сумма / СтрокаТЧ.Количество;
	 КонецЦикла;
	 
	 Для каждого СтрокаТЧ Из Объект.Затраты Цикл
	 	Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ТоварнаяГруппа) Тогда
			СтрокаТЧ.Вес = 0;
		КонецЕсли;
	 КонецЦикла;

КонецПроцедуры

