&НаКлиенте
Процедура ИнвойсыПриАктивизацииЯчейки(Элемент)
		 
	Поле = Элемент.ТекущийЭлемент; 
	Если Поле.Имя = "ИнвойсыПоставка" Тогда
	
		Поле.СписокВыбора.Очистить();
		КвоПоставок = КэшДанных.Инвойсы[Элемент.ТекущиеДанные.Инвойс].КоличествоПоставокВИнвойсе;
		Если КвоПоставок = 0 Тогда
			//Поле.СписокВыбора.Добавить(0, "инвойс полностью");
		Иначе
			Для Инд = 1 По КвоПоставок Цикл   
				КвоВПоставке = КэшДанных.Инвойсы[Элемент.ТекущиеДанные.Инвойс].ПоставкиИнвойсов[Инд].Количество;
				Поле.СписокВыбора.Добавить(Инд, СтрШаблон(НСтр("ru = '%1 (из %2), кол-во %3'; en = '%1 (of %2), quantity %3'"), Инд, КвоПоставок, КвоВПоставке));
			КонецЦикла;
			//Элемент.ТекущиеДанные.Поставка = 1;
		КонецЕсли;	
	
	КонецЕсли; 

КонецПроцедуры

