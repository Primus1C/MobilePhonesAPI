&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Объект.Количество = Объект.Инвойсы.Итог("Количество");

	// проверка дублей строк
	Ошибки = Новый Соответствие;
	Для каждого СтрокаТЧ Из Объект.Инвойсы Цикл
		НайдСтроки = Объект.Инвойсы.НайтиСтроки(Новый Структура("Инвойс,Поставка", СтрокаТЧ.Инвойс, СтрокаТЧ.Поставка));
		Если НайдСтроки.ВГраница() > 0 Тогда  
			Стр = "";
			Для Инд = 0 По НайдСтроки.ВГраница() Цикл
				Стр = Стр + НайдСтроки[Инд].НомерСтроки + ", ";
			КонецЦикла;
			Ошибки.Вставить(СтрокаТЧ.Инвойс, Стр);
		КонецЕсли;	
	КонецЦикла;
	Если Ошибки.Количество() > 0 Тогда
		ТекстОшибки = НСтр("ru = 'Найдены дубли в строках: '; en = 'Duplicates found in the lines: '") + Символы.ПС;
		Для каждого Ош Из Ошибки Цикл
			ТекстОшибки = СтрШаблон(НСтр("ru = '%1 %2 - строки %3%4'; en = '%1 %2 - lines %3%4'"), ТекстОшибки, Ош.Ключ, Ош.Значение, Символы.ПС);
		КонецЦикла;
		ТекстОшибки = Лев(ТекстОшибки, СтрДлина(ТекстОшибки)-3);	
		Сообщить(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

