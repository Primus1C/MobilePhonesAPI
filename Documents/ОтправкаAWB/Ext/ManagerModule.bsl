// Возвращает доступные варианты печати документа
//
// Вовращаемое значение:
//  Струткура, каждая строка которой соответствует одному из вариантов печати
//  
Функция ПолучитьСтруктуруПечатныхФорм() Экспорт

	Возврат Новый Структура("Отправка,ПоИнвойсам", 
							НСтр("ru='Отправка';en='Shipment'"),
							НСтр("ru='По инвойсам';en='Invoises'")
							);		

КонецФункции 

Процедура ПечатьДокумента(ДокСсылка, ВариантПечатнойФормы, ТабДокумент, Параметры = 0) Экспорт
	
	Если НЕ (РольДоступна("Администратор") ИЛИ 
			РольДоступна("Логистика") ИЛИ 
			РольДоступна("Бухгалтерия") ИЛИ 
			РольДоступна("Менеджер") ИЛИ 
			РольДоступна("МетреонПолный") ИЛИ 
			РольДоступна("МетреонЛогистика") ИЛИ
			РольДоступна("ПросмотрДокументаОтправка") ИЛИ 
			РольДоступна("ПриходованиеВводомНаОсновании")) Тогда 
		Сообщить(НСтр("ru = 'Недостаточно прав!'; en = 'Not enough rights!'"));
		Возврат;
	КонецЕсли;
	
	СкрытьЦены = (РольДоступна("Менеджер") ИЛИ РольДоступна("ПросмотрДокументаОтправка"))
				И НЕ РольДоступна("ВидимостьНаценки")
				И НЕ РольДоступна("Администратор");

	ТабДокумент.Очистить();
	Макет = Документы.ОтправкаAWB.ПолучитьМакет(ВариантПечатнойФормы);
	
	ЗапросШ = Новый Запрос;
	ЗапросШ.УстановитьПараметр("Ссылка", ДокСсылка);
	ЗапросШ.УстановитьПараметр("ПредставлениеДокумента",  ОбщегоНазначения.ПредставлениеДокументаДляПечати(ДокСсылка, ПолучитьСтруктуруПечатныхФорм()[ВариантПечатнойФормы]));
	ЗапросШ.Текст = "ВЫБРАТЬ
	                |	Отправка.Номер КАК Номер,
	                |	Отправка.Дата КАК Дата,
	                |	Отправка.AWB КАК AWB,
	                |	Отправка.Перевозчик КАК Перевозчик,
	                |	Отправка.СкладОтправитель КАК СкладОтправитель,
	                |	Отправка.СкладПолучатель КАК СкладПолучатель,
	                |	ВЫРАЗИТЬ(Отправка.Примечание КАК СТРОКА(1000)) КАК Примечание,
	                |	&ПредставлениеДокумента КАК ПредставлениеДокумента,
	                |	Отправка.Количество КАК Количество
	                |ИЗ
	                |	Документ.ОтправкаAWB КАК Отправка
	                |ГДЕ
	                |	Отправка.Ссылка = &Ссылка";
	Шапка = ЗапросШ.Выполнить().Выбрать();
	Шапка.Следующий();
	
	ТекстЗапросаТовары = "ВЫБРАТЬ
	                     |	Свод.Инвойс КАК Инвойс,
	                     |	Свод.Поставка КАК Поставка,
	                     |	Свод.Валюта КАК Валюта,
	                     |	Свод.НомерИнвойса КАК НомерИнвойса,
	                     |	Свод.Поставщик КАК Поставщик,
	                     |	Свод.Псевдоним КАК Псевдоним,
	                     |	Свод.ДатаЗакупки КАК ДатаЗакупки,
	                     |	Свод.Номенклатура КАК Номенклатура,
	                     |	Свод.Количество КАК Количество,
	                     |	ВЫБОР
	                     |		КОГДА &СкрытьЦены
	                     |			ТОГДА 0
	                     |		ИНАЧЕ Свод.Сумма
	                     |	КОНЕЦ КАК Сумма
	                     |ПОМЕСТИТЬ ТЗ
	                     |ИЗ
	                     |	(ВЫБРАТЬ
	                     |		ОтправкаИнвойсы.Инвойс КАК Инвойс,
	                     |		ОтправкаИнвойсы.Поставка КАК Поставка,
	                     |		ОтправкаИнвойсы.Инвойс.Валюта.Символ КАК Валюта,
	                     |		ОтправкаИнвойсы.Инвойс.ВКД_НомерИнвойсаПоставщика КАК НомерИнвойса,
	                     |		ОтправкаИнвойсы.Инвойс.Контрагент КАК Поставщик,
	                     |		ОтправкаИнвойсы.Инвойс.Контрагент.Псевдоним КАК Псевдоним,
	                     |		ОтправкаИнвойсы.Инвойс.ВКД_ДатаИнвойсаПоставщика КАК ДатаЗакупки,
	                     |		ПоставкиИнвойса.Номенклатура КАК Номенклатура,
	                     |		ПоставкиИнвойса.Количество КАК Количество,
	                     |		ПоставкиИнвойса.Сумма КАК Сумма,
	                     |		ПоставкиИнвойса.НомерСтроки КАК ИндСтроки
	                     |	ИЗ
	                     |		Документ.ОтправкаAWB.Инвойсы КАК ОтправкаИнвойсы
	                     |			ЛЕВОЕ СОЕДИНЕНИЕ Документ._Инвойс.Поставки КАК ПоставкиИнвойса
	                     |			ПО ОтправкаИнвойсы.Инвойс = ПоставкиИнвойса.Ссылка
	                     |				И ОтправкаИнвойсы.Поставка = ПоставкиИнвойса.Поставка
	                     |	ГДЕ
	                     |		ОтправкаИнвойсы.Ссылка = &Ссылка
	                     |		И ПоставкиИнвойса.Ссылка.КоличествоПоставок > 0
	                     |	
	                     |	ОБЪЕДИНИТЬ
	                     |	
	                     |	ВЫБРАТЬ
	                     |		ОтправкаИнвойсы.Инвойс,
	                     |		ОтправкаИнвойсы.Поставка,
	                     |		ОтправкаИнвойсы.Инвойс.Валюта.Символ,
	                     |		ОтправкаИнвойсы.Инвойс.ВКД_НомерИнвойсаПоставщика,
	                     |		ОтправкаИнвойсы.Инвойс.Контрагент,
	                     |		ОтправкаИнвойсы.Инвойс.Контрагент.Псевдоним,
	                     |		ОтправкаИнвойсы.Инвойс.ВКД_ДатаИнвойсаПоставщика,
	                     |		ИнвойсОднойПоставкой.Номенклатура,
	                     |		ИнвойсОднойПоставкой.Количество,
	                     |		ИнвойсОднойПоставкой.СуммаЗакупки,
	                     |		ИнвойсОднойПоставкой.НомерСтроки
	                     |	ИЗ
	                     |		Документ.ОтправкаAWB.Инвойсы КАК ОтправкаИнвойсы
	                     |			ЛЕВОЕ СОЕДИНЕНИЕ Документ._Инвойс.ВКД_Товары КАК ИнвойсОднойПоставкой
	                     |			ПО ОтправкаИнвойсы.Инвойс = ИнвойсОднойПоставкой.Ссылка
	                     |	ГДЕ
	                     |		ОтправкаИнвойсы.Ссылка = &Ссылка
	                     |		И ИнвойсОднойПоставкой.Ссылка.КоличествоПоставок = 0) КАК Свод";
	ТекстЗапросаТовары = ТекстЗапросаТовары + "; ";
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	Запрос.УстановитьПараметр("СкрытьЦены", СкрытьЦены);
	
	Если ВариантПечатнойФормы = "Отправка" Тогда

		Запрос.Текст = ТекстЗапросаТовары + "ВЫБРАТЬ
		               |	ТЗ.Номенклатура КАК Номенклатура,  
					   |	ТЗ.Номенклатура.Вес КАК Вес,
		               |	СУММА(ТЗ.Количество) КАК Количество,
		               |	СУММА(ТЗ.Сумма) КАК Сумма,
		               |	среднее(ТЗ.Сумма / ТЗ.Количество) КАК Цена,
 						|	СУММА(ТЗ.Количество) * ТЗ.Номенклатура.Вес / 1000 КАК ИтВес
 						|ИЗ ТЗ      
					   |
					   |  сгруппировать по ТЗ.Номенклатура,
					   |  ТЗ.Номенклатура.Вес
					   |
		               |УПОРЯДОЧИТЬ ПО
		               |	ТЗ.Номенклатура.Наименование
		               |ИТОГИ
		               |	СУММА(Количество),
		               |	СУММА(Сумма), 
					   |	Среднее(Цена),
					   |	Среднее(Вес), Сумма(ИтВес)
		               |ПО Общие,
		               |	Номенклатура ИЕРАРХИЯ"; 
		
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка);

		Итоги = Запрос.Выполнить().Выбрать();
		Итоги.Следующий();

		ОбластьДно = Макет.ПолучитьОбласть("Дно");
		ОбластьДно.Параметры.Заполнить(Шапка);  
		ОбластьДно.Параметры.Сумма 		= Итоги.Сумма;
		ОбластьДно.Параметры.Количество = Итоги.Количество;
		ОбластьДно.Параметры.ИтВес 		= Итоги.ИтВес;

		Итоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией, "Номенклатура");
		ТабДокумент.НачатьАвтогруппировкуСтрок();
		ВыбратьЭлементыВИерархии(Итоги, Макет, ТабДокумент); 
		ТабДокумент.ЗакончитьАвтогруппировкуСтрок();

		ТабДокумент.Вывести(ОбластьДно);
		
	ИначеЕсли ВариантПечатнойФормы = "ПоИнвойсам" Тогда
		
		ЗапрТовары = Новый Запрос;  
		ЗапрТовары.УстановитьПараметр("Ссылка", ДокСсылка);
		ЗапрТовары.Текст = "ВЫБРАТЬ
		                   |	ИнвойсВКДТовары.Номенклатура КАК Номенклатура,
		                   |	ИнвойсВКДТовары.Количество КАК Количество,
		                   |	ИнвойсВКДТовары.Ссылка КАК Инвойс
		                   |ИЗ
		                   |	Документ._Инвойс.ВКД_Товары КАК ИнвойсВКДТовары
		                   |ГДЕ
		                   |	ИнвойсВКДТовары.Ссылка В
		                   |			(ВЫБРАТЬ
		                   |				ОтправкаAWBИнвойсы.Инвойс КАК Инвойс
		                   |			ИЗ
		                   |				Документ.ОтправкаAWB.Инвойсы КАК ОтправкаAWBИнвойсы
		                   |			ГДЕ
		                   |				ОтправкаAWBИнвойсы.Ссылка = &Ссылка)
		                   |
		                   |УПОРЯДОЧИТЬ ПО
		                   |	ИнвойсВКДТовары.Номенклатура.Наименование
		                   |ИТОГИ
		                   |	СУММА(Количество)
		                   |ПО
		                   |	Инвойс,
		                   |	Номенклатура"; 
		
		глВывестиСекцию(ТабДокумент, Макет, "Шапка", Шапка);
		ВыборкаИнв = ЗапрТовары.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		ИтКоличество = ВыборкаИнв.Количество();
		Пока ВыборкаИнв.Следующий() Цикл
			глВывестиСекцию(ТабДокумент, Макет, "Инвойс", ВыборкаИнв);
			ВыборкаСтрока = ВыборкаИнв.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаСтрока.Следующий() Цикл
				глВывестиСекцию(ТабДокумент, Макет, "Строка", ВыборкаСтрока);
			КонецЦикла;
		КонецЦикла;
		
		глВывестиСекцию(ТабДокумент, Макет, "Дно", Шапка);
		
	//ИначеЕсли ВариантПечатнойФормы = "Прибытие" Тогда	

