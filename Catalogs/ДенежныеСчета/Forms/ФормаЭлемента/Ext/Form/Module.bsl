&НаКлиенте
Процедура ПриОткрытии(Отказ) 
	
	Если НЕ гоЕстьРоль("Разработка") Тогда
		Элементы.ГруппаУчет.ТолькоПросмотр = ЕстьДокументы();
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Функция ЕстьДокументы()
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат Ложь;
	КонецЕсли;       
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ первые 1
	             |	ДвижениеДенег.Ссылка КАК Ссылка
	             |ИЗ
	             |	Документ.ДвижениеДенег КАК ДвижениеДенег
	             |ГДЕ
	             |	(ДвижениеДенег.ДСчет = &Счет
	             |	Или ДвижениеДенег.СубДСчет = &Счет )
	             |	И ДвижениеДенег.Проведен";
	Запр.УстановитьПараметр("Счет", Объект.Ссылка);
	РезультатЗапроса = Запр.Выполнить();
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции 

