#Область ДействияФормы 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запр.УстановитьПараметр("Владелец", Объект.Владелец);
    Запр.Текст = "ВЫБРАТЬ
                 |	ТоварныеГруппыПеревозчиковТовары.Номенклатура КАК Номенклатура
                 |ИЗ
                 |	Справочник.ТоварныеГруппыПеревозчиков.Товары КАК ТоварныеГруппыПеревозчиковТовары
                 |ГДЕ
                 |	ТоварныеГруппыПеревозчиковТовары.Ссылка <> &Ссылка
                 //|	И НЕ ТоварныеГруппыПеревозчиковТовары.Ссылка.ПометкаУдаления
                 |	И ТоварныеГруппыПеревозчиковТовары.Ссылка.Владелец = &Владелец";
	Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоменклатураПеревозчика.Добавить(Выборка.Номенклатура);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти


&НаКлиенте
Процедура Подбор(Команда)
	
	Номенклатура = Новый СписокЗначений;
	Для каждого СтрокаТЧ Из Объект.Товары Цикл
		Номенклатура.Добавить(СтрокаТЧ.Номенклатура);	
	КонецЦикла;

	///Создаем структуру с отбором и добавляем значения
	ПараметрыОтбора = Новый Структура;
	//ПараметрыОтбора.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийРеализацияТоваров.Товары"));
	//ПараметрыОтбора.Вставить("Дата", ТекущаяДата());   ///Дополнительный отбор
 
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", ПараметрыОтбора); ///Добавляем отбор в параметры формы

	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыФормы.Вставить("НеактуальнаяНоменклатура", Номенклатура);

	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма, "Подбор");

	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбораГруппы", 
					ПараметрыФормы, 
					ЭтаФорма, , , , 
					ОбработкаВыбора); 

КонецПроцедуры

