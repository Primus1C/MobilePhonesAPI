&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Для каждого Эл Из ВыбранноеЗначение Цикл   
		НайдСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Эл));
		Если НайдСтроки.ВГраница() = -1 Тогда
			НовСтрока = Объект.Товары.Добавить();
			НовСтрока.Номенклатура = Эл; 
			Модифицированность = Истина;
		Иначе	
			клНамекнуть("Добавление группы", "Группа " + Эл + " уже выбрана", БиблиотекаКартинок.ДиалогВосклицание);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры


