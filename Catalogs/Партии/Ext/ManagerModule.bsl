	лСерия = Данные.Ссылка.Серия;
	Если ЗначениеЗаполнено(лСерия) Тогда
	    СтандартнаяОбработка = Ложь;
		Представление = Данные.Наименование + " (" + лСерия + ")" ;
	КонецЕсли;

