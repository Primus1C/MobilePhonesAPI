	ПользовательИБСтарыйПароль 		= Результат.СтарыйПароль;
	//ПользовательИБПарольУстановлен	= ЗначениеЗаполнено(Результат.НовыйПароль);
	Объект.ПарольУстановлен			= ЗначениеЗаполнено(Результат.НовыйПароль);
	
	//Если Результат.СтарыйПароль <> Неопределено Тогда
	//	ПарольПользователяСервиса = Результат.СтарыйПароль;
	//КонецЕсли;
	//УстановитьНеобходимостьСинхронизацииССервисом(ЭтотОбъект);
	//
	//УстановитьНаличиеПароля(ЭтотОбъект, ЗначениеЗаполнено(ПользовательИБПароль),
	//	ПользователиКлиент.АвторизованныйПользователь());
	//
	//УстановитьДоступностьСвойств(ЭтотОбъект);
	
    ОтобразитьРеквизитыПароля();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьПользователяИБНаСервере(Отказ) 
	
	Если ЗначениеЗаполнено(Объект.ИдентификаторПользователяИБ) Тогда
		Если ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Объект.ИдентификаторПользователяИБ) = Неопределено Тогда
			НовПользователь = ПользователиИнформационнойБазы.СоздатьПользователя();
			НовПользователь.УникальныйИдентификатор = Объект.ИдентификаторПользователяИБ;
			НовПользователь.Имя = Объект.Код;
			НовПользователь.ПолноеИмя = Объект.Наименование;
			Попытка
				НовПользователь.Записать();
				Объект.ПользовательИБ = Истина;
				Сообщить("Создан новый пользователь ИБ");
			Исключение
				Отказ = Истина;
				Сообщить(ОписаниеОшибки()); 
			КонецПопытки;
		Иначе	
			Сообщить("Пользователь ИБ уже существует!");
		КонецЕсли;
	Иначе
		НовПользователь = ПользователиИнформационнойБазы.СоздатьПользователя();
		НовПользователь.Имя = Объект.Код;
		НовПользователь.ПолноеИмя = Объект.Наименование;
		Попытка
			НовПользователь.Записать();
			Объект.ПользовательИБ = Истина;
			Объект.ИдентификаторПользователяИБ = НовПользователь.УникальныйИдентификатор;
			Сообщить("Создан новый пользователь ИБ");
		Исключение
			Отказ = Истина;
			Сообщить(ОписаниеОшибки()); 
		КонецПопытки;
	КонецЕсли;      
	
	// заполним реквизиты пользователя ИБ ?

КонецПроцедуры

&НаКлиенте
Процедура СоздатьПользователяИБ(Команда)    
	
	Если НЕ ЗначениеЗаполнено(Объект.Код) Тогда
		клВнимание(	"Заполните имя пользователя"
					"(закладка 'Основное', поле 'Вход 1С')", , "Аутентификация пользователя");
		Возврат;
	КонецЕсли;
	Отказ = Ложь;
	СоздатьПользователяИБНаСервере(Отказ);
	Если НЕ Отказ Тогда   
		ОтобразитьРеквизитыПользователяИБ();
		Модифицированность = Истина;
	КонецЕсли;   
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьРеквизитыПользователяИБ()
	
	Элементы.ВходВПрограммуРазрешен.Видимость		= Объект.ПользовательИБ;		
	Элементы.СоздатьПользователяИБ.Видимость 		= НЕ Объект.ПользовательИБ;
	Элементы.ДекорацияНеПользовательИБ.Видимость 	= НЕ Объект.ПользовательИБ; 
	Элементы.ИдентификаторПользователяИБ.Видимость 	= Объект.ПользовательИБ;
	
	Элементы.ГрСвойстваАутентификации.Видимость     = Объект.ПользовательИБ;
	Элементы.РолиПользователя.Видимость				= Объект.ПользовательИБ; 
	
	Если Объект.ПользовательИБ Тогда  
		
		ОписаниеПользователяИБ = ОписаниеПользователяИБ();
		
		Если ОписаниеПользователяИБ.Язык <> Неопределено Тогда
			ПользовательИБЯзык 					= ОписаниеПользователяИБ.Язык;
		КонецЕсли;
		ПользовательИБЗапрещеноИзменятьПароль	= ОписаниеПользователяИБ.ЗапрещеноИзменятьПароль;
		ПользовательИБПоказыватьВСпискеВыбора	= ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора;
		Для каждого Роль Из Метаданные.Роли Цикл
			пометка = ОписаниеПользователяИБ.Роли.НайтиПоЗначению(Роль.Имя) <> Неопределено;
			РолиПользователя.Добавить(Роль.Имя, Роль.Представление(), пометка);
		КонецЦикла; 
		
	Иначе
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьРеквизитыПароля()
	
	//Если ПользовательИБПарольУстановлен Тогда
	Если Объект.ПарольУстановлен Тогда
		Элементы.НадписьНаличиеПароля.Заголовок 			= НСтр("ru='Пароль установлен';uk='Password set'");
		Элементы.ПотребоватьСменуПароляПриВходе.Заголовок 	= НСтр("ru='Потребовать смену пароля при входе';en='Require password change upon login'"); 
		Элементы.СменитьПароль.Заголовок 					= НСтр("ru='Сменить пароль...';en='Change password...'");
	Иначе
		Элементы.НадписьНаличиеПароля.Заголовок 			= НСтр("ru='Пустой пароль';en='Empty password'");
		Элементы.ПотребоватьСменуПароляПриВходе.Заголовок 	= НСтр("ru='Потребовать установку пароля при входе';en='Require password set upon login'"); 
		Элементы.СменитьПароль.Заголовок 					= НСтр("ru='Установить пароль...';en='Set password...'");
	КонецЕсли; 
	Элементы.ДекорацияПарольЕсть.Видимость = Объект.ПарольУстановлен;
	Элементы.ДекорацияПароляНет.Видимость  = НЕ Объект.ПарольУстановлен;
	
КонецПроцедуры

&НаСервере
Функция КэшТэгов() 
	
	Запр = Новый Запрос;
	Запр.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	             |	Пользователи.Тэг КАК Тэг
	             |ИЗ
	             |	Справочник.Пользователи КАК Пользователи
	             |ГДЕ
	             |	Пользователи.Тэг <> """"
	             |
	             |УПОРЯДОЧИТЬ ПО
	             |	Тэг";
    Возврат Запр.Выполнить().Выгрузить().ВыгрузитьКолонку(0);
	
КонецФункции

