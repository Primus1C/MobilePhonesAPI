#Область ДействияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если НЕ глПриСозданииНаСервереЭлемент(ЭтаФорма, Объект) Тогда Отказ = Истина; Возврат; КонецЕсли;  
	
	// © Primus1C  26.08.2023  НАЧАЛО ►
	
	ОписаниеПользователяИБ = ОписаниеПользователяИБ();	// ЭтоПользовательИБ,Язык,ЗапрещеноИзменятьПароль,ПоказыватьВСпискеВыбора,ПарольУстановлен,Роли
	Если ОписаниеПользователяИБ.ЭтоПользовательИБ Тогда
		ПользовательИБЗапрещеноИзменятьПароль	= ОписаниеПользователяИБ.ЗапрещеноИзменятьПароль;
		//ПользовательИБПарольУстановлен        = ОписаниеПользователяИБ.ПарольУстановлен; 
	    ПользовательИБПоказыватьВСпискеВыбора   = ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора;
		ПользовательИБЯзык                      = ОписаниеПользователяИБ.Язык; 
		Если НЕ РольДоступна("Администратор") Тогда
			Элементы.Код.ТолькоПросмотр = Истина;
		КонецЕсли;
	КонецЕсли;
	Если Объект.ПарольУстановлен <> ОписаниеПользователяИБ.ПарольУстановлен Тогда
	  	Объект.ПарольУстановлен = ОписаниеПользователяИБ.ПарольУстановлен;
	КонецЕсли;
	
	ОтобразитьРеквизитыПользователяИБ();
	ОтобразитьРеквизитыПароля();
	
	// Заполнение списка выбора языка
	Для каждого МетаданныеЯзыка Из Метаданные.Языки Цикл
		Элементы.ПользовательИБЯзык.СписокВыбора.Добавить(МетаданныеЯзыка.Имя, МетаданныеЯзыка.Синоним);
	КонецЦикла;
	
	Элементы.Тэг.СписокВыбора.ЗагрузитьЗначения(КэшТэгов());
	
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если Объект.ПользовательИБ Тогда
		
		ОписаниеПользователяИБ = ОписаниеПользователяИБ();
		ТребуетсяЗапись = Ложь;
		Если ПользовательИБЯзык <> ОписаниеПользователяИБ.Язык Тогда
			ТребуетсяЗапись = Истина;
		КонецЕсли;
		Если ПользовательИБЗапрещеноИзменятьПароль <> ОписаниеПользователяИБ.ЗапрещеноИзменятьПароль Тогда
			ТребуетсяЗапись = Истина;
		КонецЕсли;
		Если ПользовательИБПоказыватьВСпискеВыбора <> ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора Тогда
			ТребуетсяЗапись = Истина;
		КонецЕсли;
		
		Для каждого Р Из РолиПользователя Цикл 
			Если Р.Пометка Тогда
				Если ОписаниеПользователяИБ.Роли.НайтиПоЗначению(Р.Значение) = Неопределено Тогда
					ТребуетсяЗапись = Истина;
				КонецЕсли;	
			Иначе
				Если ОписаниеПользователяИБ.Роли.НайтиПоЗначению(Р.Значение) <> Неопределено Тогда
					ТребуетсяЗапись = Истина;
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
		Если ПарольИзменен Тогда
			ТребуетсяЗапись = Истина;
		КонецЕсли;
		
		Если ТребуетсяЗапись Тогда
			ЗаписатьПользователяИБ();
		КонецЕсли;
		
	КонецЕсли;                 
	
КонецПроцедуры

#КонецОбласти   

&НаСервере
Процедура ЗаписатьПользователяИБ()
	
	лПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Объект.ИдентификаторПользователяИБ);
	лПользовательИБ.Язык					=  ?(ПользовательИБЯзык="", Неопределено, Метаданные.Языки[ПользовательИБЯзык]);
	лПользовательИБ.ЗапрещеноИзменятьПароль	= ПользовательИБЗапрещеноИзменятьПароль;
	лПользовательИБ.ПоказыватьВСпискеВыбора	= ПользовательИБПоказыватьВСпискеВыбора; 
	Если ПарольИзменен Тогда
		лПользовательИБ.Пароль              = ПользовательИБПароль;  
	КонецЕсли;
    лПользовательИБ.Роли.Очистить();
	Для каждого Р Из РолиПользователя Цикл
		Если Р.Пометка Тогда
		    лПользовательИБ.Роли.Добавить(Метаданные.Роли[Р.Значение]);
		КонецЕсли;
	КонецЦикла;
	лПользовательИБ.Записать();
	
КонецПроцедуры

&НаСервере
Функция ОписаниеПользователяИБ() 
	
	УстановитьПривилегированныйРежим(Истина);
	лПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Объект.ИдентификаторПользователяИБ);
	Если лПользовательИБ = Неопределено Тогда
		ОписаниеПользователяИБ = Новый Структура("ЭтоПользовательИБ,Язык,ЗапрещеноИзменятьПароль,ПоказыватьВСпискеВыбора,ПарольУстановлен,Роли",
												Ложь, "", Ложь, Ложь, Ложь, Новый СписокЗначений); 
	Иначе	
		лРоли = Новый СписокЗначений;
		Для каждого Р Из лПользовательИБ.Роли Цикл
			лРоли.Добавить(Р.Имя);
		КонецЦикла;
		ОписаниеПользователяИБ = Новый Структура("ЭтоПользовательИБ,Язык,ЗапрещеноИзменятьПароль,ПоказыватьВСпискеВыбора,ПарольУстановлен,Роли",
												Истина,
											 	?(лПользовательИБ.Язык=Неопределено, "", Строка(лПользовательИБ.Язык.Имя)),   
												лПользовательИБ.ЗапрещеноИзменятьПароль, 
												лПользовательИБ.ПоказыватьВСпискеВыбора,
												лПользовательИБ.ПарольУстановлен,
												лРоли);
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ОписаниеПользователяИБ;
	
КонецФункции


&НаКлиенте
Процедура КодПриИзменении(Элемент)
	
	Код = СокрЛП(Код);
    // © Primus1C  03.03.2024  НАЧАЛО ►
	Если НЕ ЗначениеЗаполнено(Объект.Наименование) Тогда
		Объект.Наименование = Код;	
	КонецЕсли;	
	// © Primus1C  ОКОНЧАНИЕ ◄

КонецПроцедуры


