&НаСервере
Процедура СкопироватьТЧПользователяНаСервере(Польз, ИмяТЧ, ИмяРеквизита)
	
	ПользИсточник = Польз.ПолучитьОбъект();
	Для каждого СтрокаТЧ Из ПользИсточник[ИмяТЧ] Цикл 
		НайдСтроки = Объект[ИмяТЧ].НайтиСтроки(Новый Структура(ИмяРеквизита, СтрокаТЧ[ИмяРеквизита]));
		Если НайдСтроки.Количество() = 0 Тогда
			НовСтрока = Объект[ИмяТЧ].Добавить();
			//НовСтрока[ИмяРеквизита] = СтрокаТЧ[ИмяРеквизита];
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;
	
