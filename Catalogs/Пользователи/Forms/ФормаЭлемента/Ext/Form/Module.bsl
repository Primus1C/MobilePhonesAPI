#Область НастройкиСканераШК

&НаКлиенте
Процедура Версия(Команда)
	Сканер = РаботаСоСканеромШК.ПолучитьОбъектДрайвераСканераШтрихКодов();
	
	ВходныеПараметры = Неопределено;
	ПараметрыПодключения = Неопределено;
	ВыходныеПараметры = Новый Массив;
	
	ПодключаемоеОборудование1ССканерыШтрихкодаКлиент.ПолучитьВерсиюДрайвера(Сканер, ВходныеПараметры, ПараметрыПодключения, ВыходныеПараметры);
	
	Драйвер = ВыходныеПараметры[0];
	Версия = ВыходныеПараметры[1];
	
	клВнимание("Драйвер = " + Драйвер + гоРС() + "Версия = " + Версия);
КонецПроцедуры

&НаКлиенте
Процедура Тест(Команда)
	Сканер = РаботаСоСканеромШК.ПолучитьОбъектДрайвераСканераШтрихКодов();
	
	времПараметрыУстройства = Новый Структура();
	времПараметрыУстройства.Вставить("Порт", Объект.Порт);
	времПараметрыУстройства.Вставить("Скорость", Объект.Скорость);
	времПараметрыУстройства.Вставить("БитДанных", Объект.БитДанных);
	времПараметрыУстройства.Вставить("СтопБит", 0);
	времПараметрыУстройства.Вставить("Префикс", "");
	времПараметрыУстройства.Вставить("Суффикс", "");
	времПараметрыУстройства.Вставить("Таймаут", 75);
	времПараметрыУстройства.Вставить("Модель", "");
	
	ПараметрыПодключения = Неопределено;
	ВыходныеПараметры = Новый Массив;
	
	ПодключаемоеОборудование1ССканерыШтрихкодаКлиент.ТестУстройства(Сканер, времПараметрыУстройства, ПараметрыПодключения, ВыходныеПараметры);
КонецПроцедуры

