			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Спр.Ссылка КАК Ссылка,
	Спр.ПометкаУдаления КАК ПометкаУдаления,
	Спр.Родитель КАК Родитель,
	Спр.ЭтоГруппа КАК ЭтоГруппа,
	Спр.Код КАК Код,
	ВЫБОР
		КОГДА &amp;ИспользоватьПсевдоним
				И Спр.Псевдоним &lt;&gt; ""
			ТОГДА Спр.Псевдоним
		ИНАЧЕ Спр.Наименование
	КОНЕЦ КАК Название,
	Спр.Псевдоним КАК Псевдоним,
	ВЫБОР
		КОГДА &amp;ИспользоватьПсевдоним
				И Спр.Псевдоним &lt;&gt; ""
			ТОГДА Спр.Псевдоним
		ИНАЧЕ Спр.ПолнНаименование
	КОНЕЦ КАК ПолнНаименование,
	ВЫБОР
		КОГДА Спр.Псевдоним = ""
				ИЛИ Спр.ЭтоГруппа
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК Зашифрован,
	Спр.Город КАК Город,
