		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Спр.Ссылка,
	Спр.ПометкаУдаления,
	Спр.Родитель,
	Спр.ЭтоГруппа,
	Спр.Код,
		ВЫБОР
		КОГДА &amp;ИспользоватьПсевдоним
				И Спр.Псевдоним &lt;&gt; ""
			ТОГДА Спр.Псевдоним
		ИНАЧЕ Спр.Наименование
	КОНЕЦ КАК Наименование,
	ВЫБОР
		КОГДА &amp;ИспользоватьПсевдоним
				И Спр.Псевдоним &lt;&gt; ""
			ТОГДА Спр.Псевдоним
		ИНАЧЕ Спр.ПолнНаименование
	КОНЕЦ КАК ПолнНаименование,
	Спр.Город,
	Спр.Менеджер,
	Спр.Адрес,
	Спр.Телефоны,
	Спр.Примечание,
	Спр.КемСоздан,
	Спр.Создан,
	Спр.КемСохранен,
	Спр.Сохранен,
	Спр.Предопределенный,
	ВЫБОР КОГДА (ЕСТЬNULL(Рег.ДолгПоставщикуОстаток, 0) &lt;&gt; 0) ИЛИ (ЕСТЬNULL(Рег.ПредоплатаПоставщикуОстаток, 0) &lt;&gt; 0) ТОГДА ИСТИНА ИНАЧЕ ЛОЖЬ КОНЕЦ КАК ЕстьДолгПоставщику,
	ВЫБОР КОГДА (ЕСТЬNULL(Рег.ДолгПокупателяОстаток, 0) &lt;&gt; 0) ИЛИ (ЕСТЬNULL(Рег.ПредоплатаПокупателяОстаток, 0) &lt;&gt; 0) ТОГДА ИСТИНА ИНАЧЕ ЛОЖЬ КОНЕЦ КАК ЕстьДолгПокупателя,
	Спр.ИмяПредопределенныхДанных
ИЗ
	Справочник.Контрагенты КАК Спр
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Долги.Остатки(, {Фирма = &amp;Фирма}) КАК Рег
		ПО Спр.Ссылка = Рег.Контрагент
</QueryText>
