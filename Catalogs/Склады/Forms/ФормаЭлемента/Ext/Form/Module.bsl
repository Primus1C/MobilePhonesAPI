&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	
	Если НЕ глПриСозданииНаСервереЭлемент(ЭтаФорма, Объект) Тогда Отказ = Истина; Возврат; КонецЕсли;

	ЗаполнитьСотрудниковСклада();

КонецПроцедуры

// Заполняет список сотрудников, привязанных к складу через таб.часть Сотрудники.Склады.
//
Процедура ЗаполнитьСотрудниковСклада()
	
	Сотрудники.Очистить();
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Элементы.ГруппаОператоры.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.ГруппаОператоры.Видимость = Истина;
	
	Зап = Новый Запрос;
	Зап.Текст =
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	Сотрудники.Должность КАК Должность
		|ИЗ
		|	Справочник.Сотрудники.Склады КАК СотрудникиСклады
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		|		ПО СотрудникиСклады.Ссылка = Сотрудники.Ссылка
		|ГДЕ
		|	СотрудникиСклады.Склад = &Склад
		|	И НЕ Сотрудники.ЭтоГруппа
		|	И НЕ Сотрудники.ПометкаУдаления
		|	И (Сотрудники.ДатаУвольнения = &ПустаяДата
		|		ИЛИ Сотрудники.ДатаУвольнения >= &ТекущаяДата)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудники.Наименование";
	Зап.УстановитьПараметр("Склад", Объект.Ссылка);
	Зап.УстановитьПараметр("ПустаяДата", Дата(1, 1, 1));
	Зап.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	
	Сотрудники.Загрузить(Зап.Выполнить().Выгрузить());
	
КонецПроцедуры
