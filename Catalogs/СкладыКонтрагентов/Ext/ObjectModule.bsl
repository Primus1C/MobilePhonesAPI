Процедура ПередЗаписью(Отказ)        
	
	Если ЗначениеЗаполнено(Статья) и Статья.ВидСтатьи <> Перечисления.ДоходРасход.Доход Тогда
		Сообщить("Разрешены только доходные статьи!");
		Отказ = Истина;
		Возврат;
	КонецЕсли;   
	
	Если НЕ ЗначениеЗаполнено(КемСоздан) Тогда КемСоздан = гоПользователь() КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Создан) Тогда Создан = ТекущаяДата() КонецЕсли; 
	КемСохранен = гоПользователь();
	Сохранен = ТекущаяДата();   
	
КонецПроцедуры
