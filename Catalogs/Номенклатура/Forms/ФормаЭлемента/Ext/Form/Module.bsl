&НаКлиенте
Процедура КонструкторНаименований(Команда)

	//Если НЕ РольДоступна("Разработка") Тогда
	//	клЗаглушкаВРазработке("Конструктор наименования");
	//	Возврат;
	//КонецЕсли;
	
	ПараметрыВвода = Новый Структура("Родители, ВидНоменклатуры, Номенклатура", РодителиНоменклатурыСтрокой(Объект.Родитель), Объект.ВидНоменклатуры, Объект.Ссылка);    
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораКонструктора", ЭтотОбъект, , "ПриОшибкеКонструктора", ЭтотОбъект);
	ОткрытьФорму("Справочник.Номенклатура.Форма.КонструкторНаименования", ПараметрыВвода,,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображение()
	
	Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар") Тогда
		Элементы.Статья.Видимость = Ложь;
		Элементы.ГруппаТовар.Видимость = Истина;
	Иначе
		Элементы.Статья.Видимость = Истина;
		Элементы.ГруппаТовар.Видимость = Ложь;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТипНоменклатурыПриИзменении(Элемент)

	ОбновитьОтображение();

КонецПроцедуры

&НаСервере
Процедура ОтобразитьСпецификацию()
	
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("Объект", Объект.Ссылка);
	Запр.УстановитьПараметр("ИмяСвойства", "Спецификация");
	Запр.Текст = "ВЫБРАТЬ
	             |	ЗначенияСвойствОбъектов.ЗначениеСвойства КАК ЗначениеСвойства
	             |ИЗ
	             |	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	             |ГДЕ
	             |	ЗначенияСвойствОбъектов.Объект = &Объект
	             |	И ЗначенияСвойствОбъектов.Свойство.Наименование = &ИмяСвойства";
    Выборка = Запр.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ИндексКартинки = ОбщегоНазначения.ИндексКартинкиСпецификации(Выборка.ЗначениеСвойства);
	Иначе
		ИндексКартинки = -1; 
	КонецЕсли;
    
КонецПроцедуры

