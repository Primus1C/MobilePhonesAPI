&НаКлиенте
Процедура ПослеВыбораКонструктора(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
        Возврат;
	КонецЕсли;  

	Элементы.Наименование.ВыделенныйТекст = Результат.Наименование; 
	
	//КэшСвойств = Новый Структура;
	Для каждого текРезультат Из Результат Цикл
		Если текРезультат.Ключ = "Наименование" Тогда
			Продолжить;
		КонецЕсли; 
		Если КэшСвойств.Свойство(текРезультат.Ключ) Тогда
			КэшСвойств.Вставить(текРезультат.Ключ, текРезультат.Значение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

