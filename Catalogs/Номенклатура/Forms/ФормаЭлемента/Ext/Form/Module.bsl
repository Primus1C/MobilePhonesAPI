&НаСервереБезКонтекста
Процедура ПослеЗаписиНаСервере(Номенклатура, КэшСвойств)
	
	// заполним спецификацию  
	
	Свойство = ПланыВидовХарактеристик.ДополнительныеСвойства.Спецификация;
	Имя = Номенклатура.Наименование;
	СтрСпецификация = "";	
	Если Сред(Имя, СтрДлина(Имя)-2, 1) = " " Тогда
		СтрСпецификация	= Прав(Имя, 2); 
	Иначе
		Поз = СтрНайти(Имя, " (Asis"); 
		Если Поз = 0 Тогда
			Поз = СтрНайти(Имя, " (RFB"); 
		КонецЕсли;
		//Если Поз = 0 Тогда
		//	Поз = СтрНайти(Имя, " (..."); 
		//КонецЕсли;
		Если Поз > 0 Тогда
			СтрСпецификация = Сред(Имя, Поз-2, 2); 
		КонецЕсли;
	КонецЕсли;   
	
	Если СтрСпецификация = "" Тогда	
		СписСпецификаций = ОбщегоНазначенияПовтИсп.СписокСпецификаций();
		Для каждого Эл Из СписСпецификаций Цикл 
			Если СтрДлина(Эл.Значение) <> 2 Тогда
				Поз = СтрНайти(Имя, " ", НаправлениеПоиска.СКонца);
				Если Поз > 0 Тогда
					СтрСпецификация = Сред(Имя, Поз+1);
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;		
	
	Если СтрСпецификация <> "" Тогда	
		Спецификация = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(СтрСпецификация, Истина, , Свойство);
		Если Спецификация <> Неопределено Тогда
			Запись = РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьМенеджерЗаписи();
			Запись.Объект	= Номенклатура;
			Запись.Свойство	= Свойство;
			Запись.ЗначениеСвойства = Спецификация;      
			Запись.Записать();  
			КэшСвойств.Вставить(Свойство, Спецификация);
		КонецЕсли;
	КонецЕсли;	
	
	// удалим свойства с незаполненными значениями
	Для каждого Свойство Из КэшСвойств Цикл
		НоваяЗапись = РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьМенеджерЗаписи();
		Если ЗначениеЗаполнено(Свойство.Значение) Тогда
			НоваяЗапись.Объект 				= Номенклатура;
			НоваяЗапись.Свойство 			= ПланыВидовХарактеристик.ДополнительныеСвойства.НайтиПоНаименованию(Свойство.Ключ);
			НоваяЗапись.ЗначениеСвойства	= Свойство.Значение;
			НоваяЗапись.Записать();
		Иначе
			НоваяЗапись.Объект 				= Номенклатура;
			НоваяЗапись.Свойство 			= ПланыВидовХарактеристик.ДополнительныеСвойства.НайтиПоНаименованию(Свойство.Ключ);
			НоваяЗапись.Прочитать();
			НоваяЗапись.Удалить();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшСвойств()

	КэшСвойств = Новый Структура;
	Запр = Новый Запрос;
	Запр.УстановитьПараметр("ВидНоменклатуры", ОбщегоНазначенияСервер.ВидНоменклатуры(Объект.Ссылка));
	Запр.Текст = "ВЫБРАТЬ
	             |	ВидыНоменклатурыСвойстваНоменклатуры.Свойство КАК Свойство,
	             |	ВидыНоменклатурыСвойстваНоменклатуры.Свойство.Наименование КАК Наименование,
	             |	ВидыНоменклатурыСвойстваНоменклатуры.Свойство.ИмяПредопределенныхДанных КАК ИмяСвойства
	             |ИЗ
	             |	Справочник.ВидыНоменклатуры.СвойстваНоменклатуры КАК ВидыНоменклатурыСвойстваНоменклатуры
	             |ГДЕ
	             |	ВидыНоменклатурыСвойстваНоменклатуры.Ссылка = &ВидНоменклатуры";
    Выборка = Запр.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если ЗначениеЗаполнено(Выборка.ИмяСвойства) Тогда
	    	КэшСвойств.Вставить(Выборка.ИмяСвойства);  	
		Иначе
	    	КэшСвойств.Вставить(СтрЗаменить(Выборка.Наименование," ", "_"));  	
		КонецЕсли;
	КонецЦикла;	

КонецПроцедуры

