&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	Если Этаформа.Параметры.РежимВыбора Тогда
		ОбработкаВыбораНаСервере(Элемент.ТекущиеДанные.Ссылка); 
		Элемент.Обновить();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораНаСервере(Ссылка)

	ВыбраннаяНоменклатура.Добавить(Ссылка);
	
	Для каждого ЭлементУО Из Список.УсловноеОформление.Элементы Цикл
		Если ЭлементУО.Представление = "Ссылка" Тогда
			Список.УсловноеОформление.Элементы.Удалить(ЭлементУО);
			Прервать;			
		КонецЕсли;
	КонецЦикла;
	
	ЭлементУО = Список.УсловноеОформление.Элементы.Добавить();   
	
	Отб = ЭлементУО.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отб.Использование = Истина;
	Отб.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка");
	Отб.ВидСравнения  = ВидСравненияКомпоновкиДанных.ВСписке;
	Отб.ПравоеЗначение = ВыбраннаяНоменклатура;
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветФона", Метаданные.ЭлементыСтиля.ЦветФонаСтрокиИсключаемойИзВыбора.Значение); 
	
КонецПроцедуры

