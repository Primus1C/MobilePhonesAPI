		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ссылка</Field>
				<Field>Список.Услуги</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Спр.Ссылка КАК Ссылка,
	Спр.ПометкаУдаления КАК ПометкаУдаления,
	Спр.Родитель КАК Родитель,
	Спр.ЭтоГруппа КАК ЭтоГруппа,
	Спр.Код КАК Код,
	Спр.Наименование КАК Наименование,
	Спр.Производитель КАК Производитель,
	Спр.УчетПоСериям КАК УчетПоСериям,
	Спр.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга) КАК Услуги,
	Спр.ЗапретОтгрузки КАК ЗапретОтгрузки,
	Спр.Описание КАК Описание,
	ЕСТЬNULL(Рег.ОстатокОстаток, 0) КАК Остаток,
	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	Спецификации.ЗначениеСвойства.Наименование КАК Флаг,
	Спр.SKU КАК SKU
ИЗ
	Справочник.Номенклатура КАК Спр
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(, {(Фирма = &amp;Фирма), (Склад В (&amp;ФильтрСклады))}) КАК Рег
		ПО (Рег.Номенклатура = Спр.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТовара.Остатки(, {(Фирма = &amp;Фирма), (Склад В (&amp;ФильтрСклады))}) КАК Резервы
		ПО Спр.Ссылка = Резервы.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ЗначенияСвойствОбъектов.Объект КАК Объект,
			ЗначенияСвойствОбъектов.ЗначениеСвойства КАК ЗначениеСвойства
		ИЗ
			РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		ГДЕ
			ЗначенияСвойствОбъектов.Свойство.Наименование = "Спецификация") КАК Спецификации
		ПО Спр.Ссылка = Спецификации.Объект</QueryText>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Номенклатура</dcssch:dataPath>
					<dcssch:field>Номенклатура</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Остаток</dcssch:dataPath>
					<dcssch:field>Остаток</dcssch:field>
					<dcssch:title xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Остаток</v8:content>
						</v8:item>
					</dcssch:title>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Ссылка</dcssch:dataPath>
					<dcssch:field>Ссылка</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Код</dcssch:dataPath>
					<dcssch:field>Код</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>ПометкаУдаления</dcssch:dataPath>
					<dcssch:field>ПометкаУдаления</dcssch:field>
				</Field>
				<Field xsi:type="dcssch:DataSetFieldField">
					<dcssch:dataPath>Родитель</dcssch:dataPath>
					<dcssch:field>Родитель</dcssch:field>
				</Field>
