			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Спр.Ссылка КАК Ссылка,
	Спр.ПометкаУдаления КАК ПометкаУдаления,
	Спр.Родитель КАК Родитель,
	Спр.ЭтоГруппа КАК ЭтоГруппа,
	Спр.Код КАК Код,
	Спр.Наименование КАК Наименование,
	Спр.Производитель КАК Производитель,
	Спр.УчетПоСериям КАК УчетПоСериям,
	Спр.Услуги КАК Услуги,
	Спр.ЗапретОтгрузки КАК ЗапретОтгрузки,
	Спр.Описание КАК Описание,
	ЕСТЬNULL(Остатки.ОстатокОстаток, 0) КАК Остаток,
	ЕСТЬNULL(Резервы.КоличествоОстаток, 0) КАК Резерв,
	Спр.Вес КАК Вес,
	Спр.Вес + Спр.Вес * &amp;ПроцентВес / 100 КАК Брутто,
	НЕ Спр.Блок
		И НЕ Спр.ЭтоГруппа КАК Блок,
	Спецификации.ЗначениеСвойства.Наименование КАК Флаг,
	Спр.ВыводитьИзАссортимента КАК ВыводитьИзАссортимента,
	Спр.SKU КАК SKU
ИЗ
	Справочник.Номенклатура КАК Спр
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТовара.Остатки(, {(Фирма = &amp;Фирма), (Склад В (&amp;ФильтрСклады))}) КАК Остатки
		ПО (Остатки.Номенклатура = Спр.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ЗначенияСвойствОбъектов.Объект КАК Объект,
			ЗначенияСвойствОбъектов.ЗначениеСвойства КАК ЗначениеСвойства
		ИЗ
			РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		ГДЕ
			ЗначенияСвойствОбъектов.Свойство.Наименование = "Спецификация") КАК Спецификации
		ПО Спр.Ссылка = Спецификации.Объект
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТовара.Остатки(, {(Фирма = &amp;Фирма), (Склад В (&amp;ФильтрСклады))}) КАК Резервы
		ПО Спр.Ссылка = Резервы.Номенклатура</QueryText>
