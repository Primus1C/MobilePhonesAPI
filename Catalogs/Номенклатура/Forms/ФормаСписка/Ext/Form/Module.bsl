&НаСервереБезКонтекста
Процедура ЗаписатьВесНоменклатуры(Номенклатура, Вес, Ошибка)

	НомОбъект = Номенклатура.ПолучитьОбъект();
	НомОбъект.Вес = Вес;
	Попытка
	    НомОбъект.Записать();
	Исключение
		Ошибка = СтрШаблон("%1 %2: %3",
							НСтр("ru = 'Не удалось записать номенклатуру'; en = 'Failed to record nomenclature'"),
							Номенклатура,
							ОписаниеОшибки());	
	КонецПопытки;

КонецПроцедуры

