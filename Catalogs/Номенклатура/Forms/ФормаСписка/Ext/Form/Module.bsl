&НаСервере
Процедура УстановитьОформлениеДереваНаСервере()
	
	// 1. Создаем новый элемент условного оформления формы
	ЭлементОформления = ЭтаФорма.Дерево.УсловноеОформление.Элементы.Добавить();
	
	// 2. Устанавливаем цвет фона
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.АкварельноСиний);
	
	// 3. Добавляем ПЕРВОЕ условие: строка должна быть Группой справочника
	УсловиеГруппа = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	УсловиеГруппа.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ЭтоГруппа");
	УсловиеГруппа.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	УсловиеГруппа.ПравоеЗначение = Истина;
	
	// 4. Добавляем ВТОРОЕ условие: реквизит "ВыводитьИзАссортимента" равен Истина
	// Несколько условий в одном элементе оформления по умолчанию соединяются по "И"
	УсловиеРеквизит = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	УсловиеРеквизит.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ВыводитьИзАссортимента");
	УсловиеРеквизит.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	УсловиеРеквизит.ПравоеЗначение = Истина;
	
	// 5. Оформляемые поля (колонки)
	// Если коллекцию "Поля" оставить пустой, цвет применится ко всей строке целиком.
	// Если нужно подсветить только конкретную колонку, раскомментируйте код ниже:
	
	 ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	 ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Наименование");
	 ПолеОформления.Использование = Истина;
	
КонецПроцедуры  

