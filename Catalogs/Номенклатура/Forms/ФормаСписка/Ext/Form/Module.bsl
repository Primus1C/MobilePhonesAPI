&НаКлиенте
Процедура СписокВыборПослеВводаВеса(Вес, ВыбраннаяСтрока) Экспорт
	Если Вес = Неопределено Тогда Возврат КонецЕсли;
	Ошибка = "";
	ЗаписатьВесНоменклатуры(ВыбраннаяСтрока, Вес, Ошибка); 
	Если Ошибка = "" Тогда
		ОповеститьОбИзменении(ВыбраннаяСтрока);
	  	ПоказатьОповещениеПользователя( ВыбраннаяСтрока, ,
										НСтр("ru = 'Записан вес номенклатуры: '; en = 'Recorded weight of good: '") + Вес,
										БиблиотекаКартинок.Инфо);
	Иначе 
		Сообщить(Ошибка);
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура УстановитьВсеПараметры()
	//гоСтандартныйОтбор(Список, 0, ТолькоОстатки);
	//2016.05.29
	//добавили условие, чтобы были видны и услуги, на которых нет остатков
	//стандартный отбор больше не годится, потому что нужно сразу три элемента включать/выключать
	Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[0].Использование = ТолькоОстатки;
	Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[0].Элементы[0].Использование = ТолькоОстатки;
	//Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[0].Элементы[1].Использование = ТолькоОстатки;
	//2016.06.21
	//не хотят услуги
	Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[0].Элементы[1].Использование = Ложь;
	
	Список.Параметры.УстановитьЗначениеПараметра("Фирма", гоФирма());
	
	Если ФильтрСклады.Количество() = 0 Тогда
		Список.Параметры.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("ФильтрСклады")).Использование = Ложь;
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("ФильтрСклады", ФильтрСклады.ВыгрузитьЗначения());
	КонецЕсли; 
	
	ЭтаФорма.Модифицированность = Ложь;
КонецПроцедуры

