&НаСервереБезКонтекста
Процедура СлужбаНаСервере(Имя, Р)
	Т = Новый ТекстовыйДокумент;
	Т.Прочитать(Имя);
	
	Кол = Т.КоличествоСтрок();
	Для Н = 1 По Кол Цикл
		Стр = Т.ПолучитьСтроку(Н);
		Если СокрЛП(Стр) = "" Тогда Продолжить КонецЕсли;
		
		НомИмя = гоСледПолеТаб(Стр, "Строка");
		НомФла = 1;
		
		НовНом = Справочники.Номенклатура.НайтиПоНаименованию(НомИмя);
		Если НЕ НовНом.Пустая() Тогда гоРезСоо(Р, "Уже есть номенклатура: " + НомИмя); Продолжить; КонецЕсли; 
		
		НовНом = Справочники.Номенклатура.СоздатьЭлемент();
		НовНом.Наименование = НомИмя;
		НовНом.УчетПоСериям = (НомФла = 1);
		Попытка
			НовНом.Записать();
		Исключение
		    гоРезСоо(Р, ОписаниеОшибки());
		КонецПопытки; 
	КонецЦикла; 
КонецПроцедуры

&НаКлиенте
Процедура Служба(Команда)
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл с накладной:";
	Диалог.Фильтр = "Текстовые файлы (*.txt)|*.txt";
	Если НЕ Диалог.Выбрать() Тогда Возврат КонецЕсли;
	
	Имя = Диалог.ПолноеИмяФайла;
	Фай = Новый Файл(Имя);
	Если НЕ Фай.Существует() Тогда клОшибка("Не найден файл " + гоИмя(Имя) + "!"); Возврат; КонецЕсли;
	
	Р = "";
	СлужбаНаСервере(Имя, Р);
	клЕстьОшибка(Р);
КонецПроцедуры

