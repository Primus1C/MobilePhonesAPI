
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ПараметрыПечати = Новый Структура("Таб, Имя, НеДляПечати", ТабличныйДокумент(), "Что нового", Ложь);
	ОткрытьФорму("ОбщаяФорма.ПечатьБезЗащиты", ПараметрыПечати, , Истина); 

КонецПроцедуры

&НаСервере
Функция ТабличныйДокумент()

	ТабДок = Новый ТабличныйДокумент;   
	Макет = ПолучитьОбщийМакет("ЧтоНового");
	ТабДок.Вывести(Макет);
 Возврат ТабДок;
 
КонецФункции // ()
 